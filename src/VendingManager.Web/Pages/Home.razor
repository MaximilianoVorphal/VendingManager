@page "/"
@using VendingManager.Shared.DTOs
@using VendingManager.Web.Pages.Dashboard
@inject HttpClient Http
@inject NavigationManager NavManager
@inject IJSRuntime JS

<PageTitle>CENTRO DE COMANDO</PageTitle>

<div class="industrial-wrapper container-fluid px-4 mt-4">

    @* ─── Header + Machine Selector ─── *@
    <div class="row align-items-center mb-4 border-bottom border-3 border-dark pb-3">
        <div class="col-md-8">
            <h2 class="m-0 fw-bold text-uppercase" style="letter-spacing: -1px;">Status Operacional</h2>
            <small class="text-muted fw-bold">TIEMPO REAL: @DateTime.Now.ToString("dd/MM/yyyy HH:mm:ss")</small>
        </div>
        <div class="col-md-4">
            <label class="fw-bold mb-1 small text-uppercase">:: SELECCIÓN DE UNIDAD ::</label>
            <select class="form-select border-2 border-dark rounded-0 fw-bold bg-light text-uppercase py-2"
                    @onchange="CambiarMaquina">
                <option value="0">:: TODAS LAS UNIDADES ::</option>
                @if (ListaMaquinas != null)
                {
                    @foreach (var m in ListaMaquinas)
                    {
                        <option value="@m.Id">@m.Nombre.ToUpper()</option>
                    }
                }
            </select>
        </div>
    </div>

    @* ─── Loading State ─── *@
    @if (Dashboard == null)
    {
        <div class="text-center py-5 border border-dark border-2 bg-light mb-4">
            <div class="spinner-grow text-dark" role="status"></div>
            <p class="mt-2 fw-bold text-uppercase" style="letter-spacing: 2px;">Calculando Métricas...</p>
        </div>
    }
    else
    {
        @* ─── 1. Financial Pipeline (critical data, renders first) ─── *@
        <FinancialPipeline Pipeline="Dashboard.Pipeline"
                          MaquinaId="MaquinaActualId"
                          IsLoaded="true" />

        @* ─── 2. Alerts (visibility) ─── *@
        <UnifiedAlerts Alertas="Dashboard.Alertas"
                      IsLoaded="true" />

        @* ─── 3. Data Upload (preserved XLS functionality) ─── *@
        <DataUpload OnUploadComplete="CargarDashboard" />

        @* ─── 4. Recent Activity (timeline) ─── *@
        <RecentActivity Actividades="Dashboard.Actividad"
                      MaquinaId="MaquinaActualId"
                      IsLoaded="true" />
    }
</div>

@code {
    private DashboardUnificadoDto? Dashboard;
    private List<MaquinaSimpleDto>? ListaMaquinas;
    private int MaquinaActualId = 0;

    // ─── Lifecycle ─────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        await CargarMaquinas();
        await CargarDashboard();
    }

    // ─── Data Loading ───────────────────────────────────────────────────────

    private async Task CargarMaquinas()
    {
        try
        {
            ListaMaquinas = await Http.GetFromJsonAsync<List<MaquinaSimpleDto>>("api/Ventas/lista-maquinas");
        }
        catch { }
    }

    private async Task CargarDashboard()
    {
        try
        {
            Dashboard = await Http.GetFromJsonAsync<DashboardUnificadoDto>(
                $"api/dashboard/unificado?maquinaId={MaquinaActualId}");
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Dashboard load error: {ex.Message}");
        }
    }

    private async Task CambiarMaquina(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id))
        {
            MaquinaActualId = id;
            Dashboard = null;
            await CargarDashboard();
        }
    }

    // ─── DTOs ───────────────────────────────────────────────────────────────

    public class MaquinaSimpleDto
    {
        public int Id { get; set; }
        public string Nombre { get; set; } = "";
    }
}