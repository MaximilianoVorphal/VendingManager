@page "/rendiciones"
@using VendingManager.Shared.DTOs
@using VendingManager.Shared.Enums
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>RENDICIONES</PageTitle>

<div class="industrial-wrapper container-fluid px-4 mt-4">

    @* ====== LIST VIEW ====== *@
    @if (VistaActual == "lista")
    {
        <div class="row align-items-center mb-4 border-bottom border-3 border-dark pb-3">
            <div class="col-12 d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div>
                    <h2 class="m-0 fw-bold text-uppercase" style="letter-spacing: -1px;">RENDICIONES DE CAJA</h2>
                    <small class="text-muted fw-bold">CONCILIACIÓN DE FONDOS POR TRABAJADOR</small>
                </div>
                <button class="btn btn-dark rounded-0 fw-bold shadow" @onclick="AbrirModalNuevaRendicion">
                    <i class="bi bi-plus-lg me-2"></i>NUEVA RENDICIÓN
                </button>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Error))
        {
            <div class="alert alert-danger border-dark rounded-0 fw-bold mb-4 shadow-sm">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> @Error
            </div>
        }

        @if (!string.IsNullOrEmpty(MensajeExito))
        {
            <div class="alert alert-success border-dark rounded-0 fw-bold mb-4 shadow-sm">
                <i class="bi bi-check-circle-fill me-2"></i> @MensajeExito
            </div>
        }

        <div class="card border-2 border-dark rounded-0 shadow my-4">
            <div class="card-header bg-dark text-white rounded-0 fw-bold d-flex justify-content-between align-items-center flex-wrap">
                <span>RENDICIONES REGISTRADAS</span>
            </div>
            <div class="table-responsive">
                <table class="table table-hover table-bordered border-dark m-0 align-middle">
                    <thead class="bg-secondary text-white text-uppercase small font-monospace fw-bold">
                        <tr>
                            <th>TRABAJADOR <i class="bi bi-person"></i></th>
                            <th>FECHA INICIO <i class="bi bi-calendar"></i></th>
                            <th>FECHA FIN <i class="bi bi-calendar-check"></i></th>
                            <th class="text-center">ESTADO <i class="bi bi-info-circle"></i></th>
                            <th class="text-end">DIFERENCIA <i class="bi bi-graph-up-arrow"></i></th>
                            <th class="text-center" style="min-width: 100px;">ACCIONES</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white fw-bold" style="font-size: 0.9rem;">
                        @if (CargandoLista)
                        {
                            <tr>
                                <td colspan="6" class="text-center p-4">
                                    <div class="spinner-border text-dark spinner-border-sm me-2" role="status"></div>
                                    Cargando datos...
                                </td>
                            </tr>
                        }
                        else if (!ListaRendiciones.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center p-4 text-muted">No hay rendiciones registradas.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var r in ListaRendiciones)
                            {
                                <tr style="cursor: pointer;" @onclick="() => SeleccionarRendicion(r)">
                                    <td class="fw-bold text-uppercase">@r.Trabajador</td>
                                    <td>@r.FechaInicio.ToString("dd/MM/yyyy")</td>
                                    <td>@(r.FechaFin?.ToString("dd/MM/yyyy") ?? "—")</td>
                                    <td class="text-center">
                                        @if (r.Estado == RendicionEstado.Abierta)
                                        {
                                            <span class="badge bg-warning border border-dark rounded-0 text-dark fw-bold">
                                                <i class="bi bi-folder2-open me-1"></i>ABIERTA
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary border border-dark rounded-0 text-white fw-bold">
                                                <i class="bi bi-folder-check me-1"></i>CERRADA
                                            </span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        @{
                                            var dif = (r.Transferencias.Sum(t => t.Monto) - r.Transferencias.Sum(t => t.Compras.Sum(c => c.MontoTotal)) - r.Gastos.Sum(g => Math.Abs(g.Monto)));
                                            var difColor = dif >= 0 ? "text-success" : "text-danger";
                                        }
                                        <span class="font-monospace @difColor fw-bold">$@dif.ToString("N0")</span>
                                    </td>
                                    <td class="text-center" @onclick:stopPropagation="true">
                                        <button class="btn btn-sm btn-outline-dark rounded-0 fw-bold border-dark" 
                                                title="Ver Detalle" @onclick="() => SeleccionarRendicion(r)">
                                            <i class="bi bi-eye-fill"></i> VER
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @* ====== DETAIL VIEW ====== *@
    @if (VistaActual == "detalle" && RendicionActual != null)
    {
        <div class="row align-items-center mb-4 border-bottom border-3 border-dark pb-3">
            <div class="col-12 d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div class="d-flex align-items-center gap-3">
                    <button class="btn btn-outline-dark rounded-0 fw-bold shadow-sm" @onclick="VolverALista">
                        <i class="bi bi-arrow-left me-2"></i>VOLVER
                    </button>
                    <div>
                        <h2 class="m-0 fw-bold text-uppercase" style="letter-spacing: -1px;">
                            RENDICIÓN: @RendicionActual.Trabajador.ToUpper()
                        </h2>
                        <small class="text-muted fw-bold">
                            @(RendicionActual.FechaFin.HasValue 
                                ? $"{RendicionActual.FechaInicio:dd/MM/yyyy} — {RendicionActual.FechaFin:dd/MM/yyyy}" 
                                : $"Desde {RendicionActual.FechaInicio:dd/MM/yyyy}")
                        </small>
                    </div>
                </div>
                @if (RendicionActual.Estado == RendicionEstado.Abierta)
                {
                    <div class="d-flex gap-2 flex-wrap">
                        <button class="btn btn-warning rounded-0 fw-bold border-dark shadow" @onclick="AbrirModalCerrarRendicion">
                            <i class="bi bi-lock-fill me-2"></i>CERRAR RENDICIÓN
                        </button>
                        <button class="btn btn-outline-dark rounded-0 fw-bold border-dark" @onclick="EditarRendicion">
                            <i class="bi bi-pencil me-2"></i>EDITAR
                        </button>
                    </div>
                }
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Error))
        {
            <div class="alert alert-danger border-dark rounded-0 fw-bold mb-4 shadow-sm">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> @Error
            </div>
        }

        @if (!string.IsNullOrEmpty(MensajeExito))
        {
            <div class="alert alert-success border-dark rounded-0 fw-bold mb-4 shadow-sm">
                <i class="bi bi-check-circle-fill me-2"></i> @MensajeExito
            </div>
        }

        @* RESUMEN CARD *@
        @if (ResumenActual != null)
        {
            <div class="card border-2 border-dark rounded-0 shadow mb-4 bg-light">
                <div class="card-body p-3">
                    <div class="row g-3 text-center">
                        <div class="col-md-3">
                            <div class="bg-white border border-dark p-3 rounded-0 h-100">
                                <small class="text-muted fw-bold text-uppercase d-block mb-1" style="font-size: 0.7rem;">TRANSFERIDO</small>
                                <span class="fs-5 fw-bold text-success font-monospace">$@ResumenActual.Transferido.ToString("N0")</span>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="bg-white border border-dark p-3 rounded-0 h-100">
                                <small class="text-muted fw-bold text-uppercase d-block mb-1" style="font-size: 0.7rem;">COMPRAS</small>
                                <span class="fs-5 fw-bold text-danger font-monospace">-$@ResumenActual.TotalCompras.ToString("N0")</span>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="bg-white border border-dark p-3 rounded-0 h-100">
                                <small class="text-muted fw-bold text-uppercase d-block mb-1" style="font-size: 0.7rem;">GASTOS</small>
                                <span class="fs-5 fw-bold text-danger font-monospace">-$@ResumenActual.TotalGastos.ToString("N0")</span>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="@(ResumenActual.Diferencia >= 0 ? "bg-success text-white" : "bg-danger text-white") border border-dark p-3 rounded-0 h-100">
                                <small class="fw-bold text-uppercase d-block mb-1" style="font-size: 0.7rem;">DIFERENCIA</small>
                                <span class="fs-5 fw-bold font-monospace">$@ResumenActual.Diferencia.ToString("N0")</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        @* THREE COLLAPSIBLE SECTIONS *@
        <div class="row g-3 mb-4">

            @* SECTION 1: TRANSFERENCIAS *@
            <div class="col-12">
                <div class="card border-2 border-dark rounded-0 shadow">
                    <div class="card-header bg-dark text-white rounded-0 fw-bold d-flex justify-content-between align-items-center p-2 cursor-pointer" 
                         @onclick="() => ToggleSeccion(1)">
                        <span><i class="bi bi-bank me-2"></i>💰 TRANSFERENCIAS</span>
                        <div class="d-flex align-items-center gap-3">
                            <span class="badge bg-light text-dark rounded-0">@RendicionActual.Transferencias.Count linkeadas</span>
                            <span class="badge bg-success rounded-0">Total: $@RendicionActual.Transferencias.Sum(t => t.Monto).ToString("N0")</span>
                            <i class="bi @(seccion1Expanded ? "bi-chevron-up" : "bi-chevron-down")"></i>
                        </div>
                    </div>
                    @if (seccion1Expanded)
                    {
                        <div class="card-body bg-light p-0">
                            <div class="p-3 border-bottom border-dark bg-white">
                                @if (RendicionActual.Estado == RendicionEstado.Abierta)
                                {
                                    <button class="btn btn-outline-dark rounded-0 fw-bold btn-sm" @onclick="AbrirModalVincularTransferencia">
                                        <i class="bi bi-link me-1"></i>VINCULAR TRANSFERENCIA
                                    </button>
                                }
                            </div>
                            @if (RendicionActual.Transferencias.Any())
                            {
                                <table class="table table-hover table-bordered border-dark m-0 align-middle">
                                    <thead class="bg-secondary text-white text-uppercase small fw-bold">
                                        <tr>
                                            <th>FECHA</th>
                                            <th>DESCRIPCIÓN</th>
                                            <th class="text-end">MONTO</th>
                                            <th class="text-center">ESTADO</th>
                                        </tr>
                                    </thead>
                                    <tbody class="bg-white fw-bold" style="font-size: 0.85rem;">
                                        @foreach (var t in RendicionActual.Transferencias)
                                        {
                                            <tr>
                                                <td>@t.Fecha.ToString("dd/MM/yyyy")</td>
                                                <td>@(string.IsNullOrEmpty(t.Descripcion) ? "—" : t.Descripcion)</td>
                                                <td class="text-end text-success font-monospace">$@t.Monto.ToString("N0")</td>
                                                <td class="text-center">
                                                    @if (t.Estado == TransferenciaEstado.Conciliado)
                                                    {
                                                        <span class="badge bg-success rounded-0">CONCILIADO</span>
                                                    }
                                                    else if (t.Estado == TransferenciaEstado.EnUso)
                                                    {
                                                        <span class="badge bg-primary rounded-0">EN USO</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-warning rounded-0 text-dark">PENDIENTE</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                            else
                            {
                                <div class="text-center text-muted p-4">No hay transferencias vinculadas a esta rendición.</div>
                            }
                        </div>
                    }
                </div>
            </div>

            @* SECTION 2: COMPRAS *@
            <div class="col-12">
                <div class="card border-2 border-dark rounded-0 shadow">
                    <div class="card-header bg-dark text-white rounded-0 fw-bold d-flex justify-content-between align-items-center p-2 cursor-pointer" 
                         @onclick="() => ToggleSeccion(2)">
                        <span><i class="bi bi-cart4 me-2"></i>📦 COMPRAS</span>
                        <div class="d-flex align-items-center gap-3">
                            <span class="badge bg-light text-dark rounded-0">@RendicionActual.Transferencias.Sum(t => t.Compras.Count) linkeadas</span>
                            <span class="badge bg-danger rounded-0">Total: -$@RendicionActual.Transferencias.Sum(t => t.Compras.Sum(c => c.MontoTotal)).ToString("N0")</span>
                            <i class="bi @(seccion2Expanded ? "bi-chevron-up" : "bi-chevron-down")"></i>
                        </div>
                    </div>
                    @if (seccion2Expanded)
                    {
                        <div class="card-body bg-light p-0">
                            <div class="p-3 border-bottom border-dark bg-white">
                                @if (RendicionActual.Estado == RendicionEstado.Abierta)
                                {
                                    <button class="btn btn-outline-dark rounded-0 fw-bold btn-sm" @onclick="AbrirModalVincularCompra">
                                        <i class="bi bi-link me-1"></i>VINCULAR COMPRA
                                    </button>
                                }
                            </div>
                            @{
                                var todasLasCompras = RendicionActual.Transferencias.SelectMany(t => t.Compras).ToList();
                            }
                            @if (todasLasCompras.Any())
                            {
                                <table class="table table-hover table-bordered border-dark m-0 align-middle">
                                    <thead class="bg-secondary text-white text-uppercase small fw-bold">
                                        <tr>
                                            <th>FECHA</th>
                                            <th>Nº FACTURA</th>
                                            <th>PROVEEDOR</th>
                                            <th class="text-end">MONTO</th>
                                            <th class="text-center">ACCIÓN</th>
                                        </tr>
                                    </thead>
                                    <tbody class="bg-white fw-bold" style="font-size: 0.85rem;">
                                        @foreach (var c in todasLasCompras)
                                        {
                                            <tr>
                                                <td>@c.FechaCompra.ToString("dd/MM/yyyy")</td>
                                                <td><span class="font-monospace">@(string.IsNullOrEmpty(c.NumeroDocumento) ? "S/N" : c.NumeroDocumento)</span></td>
                                                <td>@c.Proveedor</td>
                                                <td class="text-end text-danger font-monospace">$@c.MontoTotal.ToString("N0")</td>
                                                <td class="text-center">
                                                    @if (RendicionActual.Estado == RendicionEstado.Abierta)
                                                    {
                                                        <button class="btn btn-sm btn-outline-danger rounded-0 fw-bold border-dark" 
                                                                title="Desvincular" @onclick="() => DesvincularCompra(c)">
                                                            <i class="bi bi-unlink"></i> DESVINCULAR
                                                        </button>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                            else
                            {
                                <div class="text-center text-muted p-4">No hay compras vinculadas a esta rendición.</div>
                            }
                        </div>
                    }
                </div>
            </div>

            @* SECTION 3: GASTOS *@
            <div class="col-12">
                <div class="card border-2 border-dark rounded-0 shadow">
                    <div class="card-header bg-dark text-white rounded-0 fw-bold d-flex justify-content-between align-items-center p-2 cursor-pointer" 
                         @onclick="() => ToggleSeccion(3)">
                        <span><i class="bi bi-fuel-pump me-2"></i>⛽ GASTOS</span>
                        <div class="d-flex align-items-center gap-3">
                            <span class="badge bg-light text-dark rounded-0">@RendicionActual.Gastos.Count linkeados</span>
                            <span class="badge bg-danger rounded-0">Total: -$@RendicionActual.Gastos.Sum(g => Math.Abs(g.Monto)).ToString("N0")</span>
                            <i class="bi @(seccion3Expanded ? "bi-chevron-up" : "bi-chevron-down")"></i>
                        </div>
                    </div>
                    @if (seccion3Expanded)
                    {
                        <div class="card-body bg-light p-0">
                            <div class="p-3 border-bottom border-dark bg-white">
                                @if (RendicionActual.Estado == RendicionEstado.Abierta)
                                {
                                    <button class="btn btn-outline-dark rounded-0 fw-bold btn-sm" @onclick="AbrirModalVincularGasto">
                                        <i class="bi bi-link me-1"></i>VINCULAR GASTO
                                    </button>
                                }
                            </div>
                            @if (RendicionActual.Gastos.Any())
                            {
                                <table class="table table-hover table-bordered border-dark m-0 align-middle">
                                    <thead class="bg-secondary text-white text-uppercase small fw-bold">
                                        <tr>
                                            <th>FECHA</th>
                                            <th>DESCRIPCIÓN</th>
                                            <th>CATEGORÍA</th>
                                            <th class="text-end">MONTO</th>
                                            <th class="text-center">ACCIÓN</th>
                                        </tr>
                                    </thead>
                                    <tbody class="bg-white fw-bold" style="font-size: 0.85rem;">
                                        @foreach (var g in RendicionActual.Gastos)
                                        {
                                            <tr>
                                                <td>@g.Fecha.ToString("dd/MM/yyyy")</td>
                                                <td>@g.Descripcion</td>
                                                <td><span class="badge bg-secondary rounded-0">@g.Categoria</span></td>
                                                <td class="text-end text-danger font-monospace">$@Math.Abs(g.Monto).ToString("N0")</td>
                                                <td class="text-center">
                                                    @if (RendicionActual.Estado == RendicionEstado.Abierta)
                                                    {
                                                        <button class="btn btn-sm btn-outline-danger rounded-0 fw-bold border-dark" 
                                                                title="Desvincular" @onclick="() => DesvincularGasto(g)">
                                                            <i class="bi bi-unlink"></i> DESVINCULAR
                                                        </button>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                            else
                            {
                                <div class="text-center text-muted p-4">No hay gastos vinculados a esta rendición.</div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    }

</div>

@* ====== MODAL: NUEVA RENDICIÓN ====== *@
@if (mostrarModalNuevaRendicion)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5); z-index: 2000;">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-0 border-2 border-dark shadow-lg">
                <div class="modal-header bg-dark text-white rounded-0">
                    <h5 class="modal-title fw-bold text-uppercase"><i class="bi bi-folder-plus me-2"></i>NUEVA RENDICIÓN</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarModalNuevaRendicion"></button>
                </div>
                <div class="modal-body p-4 bg-light">
                    <div class="mb-3">
                        <label class="fw-bold small text-uppercase mb-1">TRABAJADOR *</label>
                        <input type="text" class="form-control border-dark rounded-0" @bind="nuevaRendicion.Trabajador" placeholder="Nombre del trabajador..." />
                    </div>
                    <div class="mb-3">
                        <label class="fw-bold small text-uppercase mb-1">FECHA INICIO *</label>
                        <input type="date" class="form-control border-dark rounded-0" @bind="nuevaRendicion.FechaInicio" />
                    </div>
                    <div class="mb-3">
                        <label class="fw-bold small text-uppercase mb-1">OBSERVACIONES</label>
                        <textarea class="form-control border-dark rounded-0" rows="3" @bind="nuevaRendicion.Observaciones" placeholder="Notas adicionales..."></textarea>
                    </div>
                </div>
                <div class="modal-footer bg-white border-top border-dark rounded-0">
                    <button class="btn btn-outline-dark rounded-0" @onclick="CerrarModalNuevaRendicion">CANCELAR</button>
                    <button class="btn btn-dark rounded-0 fw-bold" @onclick="CrearRendicion" disabled="@creandoRendicion">
                        @if (creandoRendicion)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                        }
                        else
                        {
                            <i class="bi bi-check-lg me-1"></i>
                        }
                        CREAR RENDICIÓN
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* ====== MODAL: VINCULAR TRANSFERENCIA ====== *@
@if (mostrarModalVincularTransferencia)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5); z-index: 2000;">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content rounded-0 border-2 border-dark shadow-lg">
                <div class="modal-header bg-dark text-white rounded-0">
                    <h5 class="modal-title fw-bold text-uppercase"><i class="bi bi-link me-2"></i>VINCULAR TRANSFERENCIA</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarModalVincularTransferencia"></button>
                </div>
                <div class="modal-body p-4 bg-light">
                    <div class="row mb-3 bg-white border border-dark p-3 mx-0">
                        <div class="col-md-4 mb-2">
                            <label class="fw-bold small text-uppercase mb-1">FECHA DESDE</label>
                            <input type="date" class="form-control border-dark rounded-0" @bind="filtroTransf.FechaDesde" />
                        </div>
                        <div class="col-md-4 mb-2">
                            <label class="fw-bold small text-uppercase mb-1">FECHA HASTA</label>
                            <input type="date" class="form-control border-dark rounded-0" @bind="filtroTransf.FechaHasta" />
                        </div>
                        <div class="col-md-4 mb-2 d-flex align-items-end">
                            <button class="btn btn-outline-dark rounded-0 fw-bold w-100" @onclick="BuscarTransferenciasNoVinculadas">
                                <i class="bi bi-search me-1"></i>BUSCAR
                            </button>
                        </div>
                    </div>
                    @if (transferenciasNoVinculadas != null)
                    {
                        @if (!transferenciasNoVinculadas.Any())
                        {
                            <div class="text-center text-muted p-4 border border-dark bg-white">
                                No se encontraron transferencias sin vincular.
                            </div>
                        }
                        else
                        {
                            <table class="table table-bordered border-dark table-hover align-middle mb-0">
                                <thead class="bg-secondary text-white text-uppercase small fw-bold">
                                    <tr>
                                        <th>FECHA</th>
                                        <th>TRABAJADOR</th>
                                        <th>DESCRIPCIÓN</th>
                                        <th class="text-end">MONTO</th>
                                        <th class="text-center">ACCIÓN</th>
                                    </tr>
                                </thead>
                                <tbody class="bg-white fw-bold" style="font-size: 0.85rem;">
                                    @foreach (var t in transferenciasNoVinculadas)
                                    {
                                        <tr>
                                            <td>@t.Fecha.ToString("dd/MM/yyyy")</td>
                                            <td>@t.Trabajador</td>
                                            <td>@(string.IsNullOrEmpty(t.Descripcion) ? "—" : t.Descripcion)</td>
                                            <td class="text-end text-success font-monospace">$@t.Monto.ToString("N0")</td>
                                            <td class="text-center">
                                                <button class="btn btn-sm btn-success rounded-0 fw-bold border-dark" 
                                                        @onclick="() => VincularTransferencia(t.Id)">
                                                    <i class="bi bi-link"></i> VINCULAR
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    }
                </div>
                <div class="modal-footer bg-white border-top border-dark rounded-0">
                    <button class="btn btn-outline-dark rounded-0" @onclick="CerrarModalVincularTransferencia">CERRAR</button>
                </div>
            </div>
        </div>
    </div>
}

@* ====== MODAL: VINCULAR COMPRA ====== *@
@if (mostrarModalVincularCompra)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5); z-index: 2000;">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content rounded-0 border-2 border-dark shadow-lg">
                <div class="modal-header bg-dark text-white rounded-0">
                    <h5 class="modal-title fw-bold text-uppercase"><i class="bi bi-link me-2"></i>VINCULAR COMPRA</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarModalVincularCompra"></button>
                </div>
                <div class="modal-body p-4 bg-light">
                    <div class="row mb-3 bg-white border border-dark p-3 mx-0">
                        <div class="col-md-4 mb-2">
                            <label class="fw-bold small text-uppercase mb-1">PROVEEDOR</label>
                            <input type="text" class="form-control border-dark rounded-0" @bind="filtroCompra.Proveedor" placeholder="Buscar proveedor..." />
                        </div>
                        <div class="col-md-4 mb-2">
                            <label class="fw-bold small text-uppercase mb-1">Nº FACTURA</label>
                            <input type="text" class="form-control border-dark rounded-0" @bind="filtroCompra.NumeroDocumento" placeholder="N° documento..." />
                        </div>
                        <div class="col-md-4 mb-2 d-flex align-items-end">
                            <button class="btn btn-outline-dark rounded-0 fw-bold w-100" @onclick="BuscarComprasNoVinculadas">
                                <i class="bi bi-search me-1"></i>BUSCAR
                            </button>
                        </div>
                    </div>
                    @if (comprasNoVinculadas != null)
                    {
                        @if (!comprasNoVinculadas.Any())
                        {
                            <div class="text-center text-muted p-4 border border-dark bg-white">
                                No se encontraron compras sin vincular.
                            </div>
                        }
                        else
                        {
                            <table class="table table-bordered border-dark table-hover align-middle mb-0">
                                <thead class="bg-secondary text-white text-uppercase small fw-bold">
                                    <tr>
                                        <th>FECHA</th>
                                        <th>Nº FACTURA</th>
                                        <th>PROVEEDOR</th>
                                        <th class="text-end">MONTO</th>
                                        <th class="text-center">TRANSFERENCIA</th>
                                        <th class="text-center">ACCIÓN</th>
                                    </tr>
                                </thead>
                                <tbody class="bg-white fw-bold" style="font-size: 0.85rem;">
                                    @foreach (var c in comprasNoVinculadas)
                                    {
                                        <tr>
                                            <td>@c.FechaCompra.ToString("dd/MM/yyyy")</td>
                                            <td><span class="font-monospace">@(string.IsNullOrEmpty(c.NumeroDocumento) ? "S/N" : c.NumeroDocumento)</span></td>
                                            <td>@c.Proveedor</td>
                                            <td class="text-end text-danger font-monospace">$@c.MontoTotal.ToString("N0")</td>
                                            <td class="text-center">
                                                <select class="form-select form-select-sm border-dark rounded-0" @bind="compraParaVincular.TransferenciaId">
                                                    <option value="0">-- SEL. TRANSF. --</option>
                                                    @foreach (var t in RendicionActual!.Transferencias)
                                                    {
                                                        <option value="@t.Id">@t.Fecha.ToString("dd/MM") - $@t.Monto.ToString("N0")</option>
                                                    }
                                                </select>
                                            </td>
                                            <td class="text-center">
                                                <button class="btn btn-sm btn-success rounded-0 fw-bold border-dark" 
                                                        @onclick="() => VincularCompra(c.Id)" disabled="@(compraParaVincular.TransferenciaId == 0)">
                                                    <i class="bi bi-link"></i> VINCULAR
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    }
                </div>
                <div class="modal-footer bg-white border-top border-dark rounded-0">
                    <button class="btn btn-outline-dark rounded-0" @onclick="CerrarModalVincularCompra">CERRAR</button>
                </div>
            </div>
        </div>
    </div>
}

@* ====== MODAL: VINCULAR GASTO ====== *@
@if (mostrarModalVincularGasto)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5); z-index: 2000;">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content rounded-0 border-2 border-dark shadow-lg">
                <div class="modal-header bg-dark text-white rounded-0">
                    <h5 class="modal-title fw-bold text-uppercase"><i class="bi bi-link me-2"></i>VINCULAR GASTO</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarModalVincularGasto"></button>
                </div>
                <div class="modal-body p-4 bg-light">
                    <div class="row mb-3 bg-white border border-dark p-3 mx-0">
                        <div class="col-md-6 mb-2">
                            <label class="fw-bold small text-uppercase mb-1">FECHA DESDE</label>
                            <input type="date" class="form-control border-dark rounded-0" @bind="filtroGasto.FechaDesde" />
                        </div>
                        <div class="col-md-6 mb-2">
                            <label class="fw-bold small text-uppercase mb-1">FECHA HASTA</label>
                            <input type="date" class="form-control border-dark rounded-0" @bind="filtroGasto.FechaHasta" />
                        </div>
                    </div>
                    <button class="btn btn-outline-dark rounded-0 fw-bold mb-3" @onclick="BuscarGastosNoVinculados">
                        <i class="bi bi-search me-1"></i>BUSCAR GASTOS DISPONIBLES
                    </button>
                    @if (gastosNoVinculados != null)
                    {
                        @if (!gastosNoVinculados.Any())
                        {
                            <div class="text-center text-muted p-4 border border-dark bg-white">
                                No se encontraron gastos sin vincular a ninguna rendición.
                            </div>
                        }
                        else
                        {
                            <table class="table table-bordered border-dark table-hover align-middle mb-0">
                                <thead class="bg-secondary text-white text-uppercase small fw-bold">
                                    <tr>
                                        <th>FECHA</th>
                                        <th>DESCRIPCIÓN</th>
                                        <th>CATEGORÍA</th>
                                        <th class="text-end">MONTO</th>
                                        <th class="text-center">ACCIÓN</th>
                                    </tr>
                                </thead>
                                <tbody class="bg-white fw-bold" style="font-size: 0.85rem;">
                                    @foreach (var g in gastosNoVinculados)
                                    {
                                        <tr>
                                            <td>@g.Fecha.ToString("dd/MM/yyyy")</td>
                                            <td>@g.Descripcion</td>
                                            <td><span class="badge bg-secondary rounded-0">@g.Categoria</span></td>
                                            <td class="text-end text-danger font-monospace">$@Math.Abs(g.Monto).ToString("N0")</td>
                                            <td class="text-center">
                                                <button class="btn btn-sm btn-success rounded-0 fw-bold border-dark" 
                                                        @onclick="() => VincularGasto(g.Id)">
                                                    <i class="bi bi-link"></i> VINCULAR
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    }
                </div>
                <div class="modal-footer bg-white border-top border-dark rounded-0">
                    <button class="btn btn-outline-dark rounded-0" @onclick="CerrarModalVincularGasto">CERRAR</button>
                </div>
            </div>
        </div>
    </div>
}

@* ====== MODAL: CERRAR RENDICIÓN ====== *@
@if (mostrarModalCerrar)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5); z-index: 2000;">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-0 border-2 border-dark shadow-lg">
                <div class="modal-header bg-dark text-white rounded-0">
                    <h5 class="modal-title fw-bold text-uppercase"><i class="bi bi-lock-fill me-2"></i>CERRAR RENDICIÓN</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarModalCerrar"></button>
                </div>
                <div class="modal-body p-4 bg-light text-center">
                    <i class="bi bi-exclamation-triangle-fill display-4 text-warning mb-3"></i>
                    <p class="fs-5 fw-bold">¿Estás seguro de que deseas cerrar esta rendición?</p>
                    <p class="text-muted">Una vez cerrada, no se podrán modificar las vinculaciones.</p>
                    @if (ResumenActual != null)
                    {
                        <div class="alert border-dark mt-3 @(ResumenActual.Diferencia >= 0 ? "alert-success" : "alert-danger")">
                            <strong>Diferencia final:</strong> $@ResumenActual.Diferencia.ToString("N0")
                        </div>
                    }
                </div>
                <div class="modal-footer bg-white border-top border-dark rounded-0">
                    <button class="btn btn-outline-dark rounded-0" @onclick="CerrarModalCerrar">CANCELAR</button>
                    <button class="btn btn-warning rounded-0 fw-bold border-dark" @onclick="CerrarRendicion" disabled="@cerrandoRendicion">
                        @if (cerrandoRendicion)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                        }
                        <i class="bi bi-lock-fill me-1"></i>CERRAR RENDICIÓN
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    // View state
    private string VistaActual = "lista"; // "lista" | "detalle"
    private bool CargandoLista = true;
    private string? Error;
    private string? MensajeExito;

    // List view data
    private List<RendicionDto> ListaRendiciones = new();

    // Detail view data
    private RendicionDto? RendicionActual;
    private RendicionResumenDto? ResumenActual;

    // Collapsible sections
    private bool seccion1Expanded = true;
    private bool seccion2Expanded = true;
    private bool seccion3Expanded = true;

    // Modal states
    private bool mostrarModalNuevaRendicion = false;
    private bool mostrarModalVincularTransferencia = false;
    private bool mostrarModalVincularCompra = false;
    private bool mostrarModalVincularGasto = false;
    private bool mostrarModalCerrar = false;

    // Nueva rendicion form
    private CreateRendicionRequest nuevaRendicion = new();
    private bool creandoRendicion = false;

    // Vincular transferencia filters
    private FiltroTransferencia filtroTransf = new();
    private List<TransferenciaDto>? transferenciasNoVinculadas;

    // Vincular compra filters
    private FiltroCompra filtroCompra = new();
    private List<CompraDto>? comprasNoVinculadas;
    private LinkCompraRequest compraParaVincular = new() { TransferenciaId = 0 };

    // Vincular gasto filters
    private FiltroGasto filtroGasto = new();
    private List<MovimientoCajaDto>? gastosNoVinculados;

    // Cerrar rendicion
    private bool cerrandoRendicion = false;

    protected override async Task OnInitializedAsync()
    {
        await CargarRendiciones();
    }

    private async Task CargarRendiciones()
    {
        try
        {
            CargandoLista = true;
            Error = null;
            MensajeExito = null;
            ListaRendiciones = await Http.GetFromJsonAsync<List<RendicionDto>>("api/rendicion") ?? new();
        }
        catch (Exception ex)
        {
            Error = $"Error al cargar rendiciones: {ex.Message}";
        }
        finally
        {
            CargandoLista = false;
        }
    }

    private async Task SeleccionarRendicion(RendicionDto r)
    {
        try
        {
            Error = null;
            MensajeExito = null;
            VistaActual = "detalle";
            RendicionActual = await Http.GetFromJsonAsync<RendicionDto>($"api/rendicion/{r.Id}");
            ResumenActual = await Http.GetFromJsonAsync<RendicionResumenDto>($"api/rendicion/{r.Id}/resumen");
        }
        catch (Exception ex)
        {
            Error = $"Error al cargar rendición: {ex.Message}";
            VistaActual = "lista";
        }
    }

    private void VolverALista()
    {
        VistaActual = "lista";
        RendicionActual = null;
        ResumenActual = null;
        Error = null;
        MensajeExito = null;
    }

    private void EditarRendicion()
    {
        // Could open an edit modal in the future
        Error = "La edición de rendiciones se implementará en una versión futura.";
    }

    private void ToggleSeccion(int num)
    {
        if (num == 1) seccion1Expanded = !seccion1Expanded;
        else if (num == 2) seccion2Expanded = !seccion2Expanded;
        else if (num == 3) seccion3Expanded = !seccion3Expanded;
    }

    // ====== NUEVA RENDICIÓN ======
    private void AbrirModalNuevaRendicion()
    {
        nuevaRendicion = new CreateRendicionRequest { FechaInicio = DateTime.Today };
        mostrarModalNuevaRendicion = true;
        Error = null;
        MensajeExito = null;
    }

    private async Task CerrarModalNuevaRendicion()
    {
        mostrarModalNuevaRendicion = false;
        await Task.CompletedTask;
    }

    private async Task CrearRendicion()
    {
        if (string.IsNullOrWhiteSpace(nuevaRendicion.Trabajador))
        {
            Error = "Debe ingresar el nombre del trabajador.";
            return;
        }

        try
        {
            creandoRendicion = true;
            Error = null;
            var response = await Http.PostAsJsonAsync("api/rendicion", nuevaRendicion);
            if (response.IsSuccessStatusCode)
            {
                MensajeExito = "Rendición creada exitosamente.";
                await CerrarModalNuevaRendicion();
                await CargarRendiciones();
            }
            else
            {
                Error = "Error al crear rendición: " + await response.Content.ReadAsStringAsync();
            }
        }
        catch (Exception ex)
        {
            Error = $"Error: {ex.Message}";
        }
        finally
        {
            creandoRendicion = false;
        }
    }

    // ====== VINCULAR TRANSFERENCIA ======
    private void AbrirModalVincularTransferencia()
    {
        filtroTransf = new FiltroTransferencia();
        transferenciasNoVinculadas = null;
        mostrarModalVincularTransferencia = true;
    }

    private void CerrarModalVincularTransferencia()
    {
        mostrarModalVincularTransferencia = false;
    }

    private async Task BuscarTransferenciasNoVinculadas()
    {
        try
        {
            var url = "api/transferencia/no-vinculadas";
            if (filtroTransf.FechaDesde.HasValue)
                url += $"?fechaDesde={filtroTransf.FechaDesde:yyyy-MM-dd}";
            if (filtroTransf.FechaHasta.HasValue)
                url += $"{(filtroTransf.FechaDesde.HasValue ? "&" : "?")}fechaHasta={filtroTransf.FechaHasta:yyyy-MM-dd}";
            
            transferenciasNoVinculadas = await Http.GetFromJsonAsync<List<TransferenciaDto>>(url) ?? new();
        }
        catch (Exception ex)
        {
            Error = $"Error al buscar transferencias: {ex.Message}";
        }
    }

    private async Task VincularTransferencia(int transferenciaId)
    {
        try
        {
            Error = null;
            // Link the transferencia to the rendicion
            var response = await Http.PostAsync($"api/rendicion/{RendicionActual!.Id}/link-transferencia/{transferenciaId}", null);
            if (response.IsSuccessStatusCode)
            {
                MensajeExito = "Transferencia vinculada exitosamente.";
                await RefreshDetalle();
            }
            else
            {
                Error = "Error al vincular transferencia: " + await response.Content.ReadAsStringAsync();
            }
        }
        catch (Exception ex)
        {
            Error = $"Error: {ex.Message}";
        }
    }

    // ====== VINCULAR COMPRA ======
    private void AbrirModalVincularCompra()
    {
        filtroCompra = new FiltroCompra();
        comprasNoVinculadas = null;
        compraParaVincular = new LinkCompraRequest();
        mostrarModalVincularCompra = true;
    }

    private async Task CerrarModalVincularCompra()
    {
        mostrarModalVincularCompra = false;
        await Task.CompletedTask;
    }

    private async Task BuscarComprasNoVinculadas()
    {
        try
        {
            var url = "api/compras/no-vinculadas";
            if (!string.IsNullOrWhiteSpace(filtroCompra.Proveedor))
                url += $"?proveedor={Uri.EscapeDataString(filtroCompra.Proveedor)}";
            if (!string.IsNullOrWhiteSpace(filtroCompra.NumeroDocumento))
                url += $"{(filtroCompra.Proveedor != null ? "&" : "?")}numeroDocumento={Uri.EscapeDataString(filtroCompra.NumeroDocumento)}";
            
            comprasNoVinculadas = await Http.GetFromJsonAsync<List<CompraDto>>(url) ?? new();
        }
        catch (Exception ex)
        {
            Error = $"Error al buscar compras: {ex.Message}";
        }
    }

    private async Task VincularCompra(int compraId)
    {
        if (compraParaVincular.TransferenciaId == 0)
        {
            Error = "Debe seleccionar una transferencia.";
            return;
        }

        try
        {
            Error = null;
            var request = new LinkCompraRequest { CompraId = compraId, TransferenciaId = compraParaVincular.TransferenciaId };
            var response = await Http.PostAsJsonAsync($"api/rendicion/{RendicionActual!.Id}/link-compra", request);
            if (response.IsSuccessStatusCode)
            {
                MensajeExito = "Compra vinculada exitosamente.";
                await RefreshDetalle();
                await CerrarModalVincularCompra();
            }
            else
            {
                Error = "Error al vincular compra: " + await response.Content.ReadAsStringAsync();
            }
        }
        catch (Exception ex)
        {
            Error = $"Error: {ex.Message}";
        }
    }

    private async Task DesvincularCompra(CompraDto compra)
    {
        try
        {
            Error = null;
            var response = await Http.PostAsync($"api/rendicion/{RendicionActual!.Id}/unlink-compra/{compra.Id}", null);
            if (response.IsSuccessStatusCode)
            {
                MensajeExito = "Compra desvinculada exitosamente.";
                await RefreshDetalle();
            }
            else
            {
                Error = "Error al desvincular compra: " + await response.Content.ReadAsStringAsync();
            }
        }
        catch (Exception ex)
        {
            Error = $"Error: {ex.Message}";
        }
    }

    // ====== VINCULAR GASTO ======
    private void AbrirModalVincularGasto()
    {
        filtroGasto = new FiltroGasto { FechaDesde = DateTime.Today.AddMonths(-1), FechaHasta = DateTime.Today };
        gastosNoVinculados = null;
        mostrarModalVincularGasto = true;
    }

    private void CerrarModalVincularGasto()
    {
        mostrarModalVincularGasto = false;
    }

    private async Task BuscarGastosNoVinculados()
    {
        try
        {
            var url = $"api/caja/gastos-no-vinculados?fechaDesde={filtroGasto.FechaDesde:yyyy-MM-dd}&fechaHasta={filtroGasto.FechaHasta:yyyy-MM-dd}";
            gastosNoVinculados = await Http.GetFromJsonAsync<List<MovimientoCajaDto>>(url) ?? new();
        }
        catch (Exception ex)
        {
            Error = $"Error al buscar gastos: {ex.Message}";
        }
    }

    private async Task VincularGasto(int gastoId)
    {
        try
        {
            Error = null;
            var request = new LinkGastoRequest { GastoId = gastoId, RendicionId = RendicionActual!.Id };
            var response = await Http.PostAsJsonAsync($"api/rendicion/{RendicionActual.Id}/link-gasto", request);
            if (response.IsSuccessStatusCode)
            {
                MensajeExito = "Gasto vinculado exitosamente.";
                await RefreshDetalle();
            }
            else
            {
                Error = "Error al vincular gasto: " + await response.Content.ReadAsStringAsync();
            }
        }
        catch (Exception ex)
        {
            Error = $"Error: {ex.Message}";
        }
    }

    private async Task DesvincularGasto(MovimientoCajaDto gasto)
    {
        try
        {
            Error = null;
            var response = await Http.PostAsync($"api/rendicion/{RendicionActual!.Id}/unlink-gasto/{gasto.Id}", null);
            if (response.IsSuccessStatusCode)
            {
                MensajeExito = "Gasto desvinculado exitosamente.";
                await RefreshDetalle();
            }
            else
            {
                Error = "Error al desvincular gasto: " + await response.Content.ReadAsStringAsync();
            }
        }
        catch (Exception ex)
        {
            Error = $"Error: {ex.Message}";
        }
    }

    // ====== CERRAR RENDICIÓN ======
    private void AbrirModalCerrarRendicion()
    {
        mostrarModalCerrar = true;
        Error = null;
    }

    private async Task CerrarModalCerrar()
    {
        mostrarModalCerrar = false;
        await Task.CompletedTask;
    }

    private async Task CerrarRendicion()
    {
        if (RendicionActual == null) return;

        try
        {
            cerrandoRendicion = true;
            Error = null;
            var response = await Http.PostAsync($"api/rendicion/{RendicionActual.Id}/cerrar", null);
            if (response.IsSuccessStatusCode)
            {
                MensajeExito = "Rendición cerrada exitosamente.";
                await CerrarModalCerrar();
                await RefreshDetalle();
            }
            else
            {
                Error = "Error al cerrar rendición: " + await response.Content.ReadAsStringAsync();
            }
        }
        catch (Exception ex)
        {
            Error = $"Error: {ex.Message}";
        }
        finally
        {
            cerrandoRendicion = false;
        }
    }

    private async Task RefreshDetalle()
    {
        if (RendicionActual != null)
        {
            var id = RendicionActual.Id;
            RendicionActual = await Http.GetFromJsonAsync<RendicionDto>($"api/rendicion/{id}");
            ResumenActual = await Http.GetFromJsonAsync<RendicionResumenDto>($"api/rendicion/{id}/resumen");
        }
    }

    // Filter helper classes
    private class FiltroTransferencia
    {
        public DateTime? FechaDesde { get; set; }
        public DateTime? FechaHasta { get; set; }
    }

    private class FiltroCompra
    {
        public string? Proveedor { get; set; }
        public string? NumeroDocumento { get; set; }
    }

    private class FiltroGasto
    {
        public DateTime? FechaDesde { get; set; }
        public DateTime? FechaHasta { get; set; }
    }
}