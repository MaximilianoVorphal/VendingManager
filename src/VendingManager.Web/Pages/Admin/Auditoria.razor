@page "/admin/auditoria"
@using Microsoft.AspNetCore.Authorization
@using VendingManager.Shared.DTOs
@using VendingManager.Shared.Constants
@attribute [Authorize(Roles = Roles.Admin)]
@inject HttpClient Http

<PageTitle>Auditoría</PageTitle>
<div class="industrial-wrapper">
    <div class="container-fluid px-4 mt-4">

    <div class="row align-items-center mb-4 border-bottom border-3 border-dark pb-3">
        <div class="col-12">
            <h1 class="m-0 fw-bold text-uppercase" style="letter-spacing: -1px;">Registro de Auditoría</h1>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-3">
            <label class="form-label fw-bold">Usuario:</label>
            <input type="text" class="form-control border-dark rounded-0" @bind="filtroUsuario" placeholder="Ej: admin" />
        </div>
        <div class="col-md-3">
            <label class="form-label fw-bold">Acción:</label>
            <input type="text" class="form-control border-dark rounded-0" @bind="filtroAccion" placeholder="Ej: Login" />
        </div>
        <div class="col-md-2 d-flex align-items-end">
            <button class="btn btn-dark w-100 fw-bold rounded-0" @onclick="CargarLogs">
                <i class="bi bi-search me-2"></i>Filtrar
            </button>
        </div>
    </div>

@if (logs == null)
{
    <p><em>Cargando...</em></p>
}
else if (!logs.Any())
{
    <div class="alert alert-info">No se encontraron registros.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover table-bordered border-dark">
            <thead class="bg-secondary text-white text-uppercase">
                <tr>
                    <th>Fecha</th>
                    <th>Usuario</th>
                    <th>Acción</th>
                    <th>Detalle</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in logs)
                {
                    <tr>
                        <td>@log.Fecha.ToString("g")</td>
                        <td>@log.Usuario</td>
                        <td>@log.Accion</td>
                        <td>@log.Detalle</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
</div>

@code {
    private List<AuditoriaDto>? logs;
    private string filtroUsuario = "";
    private string filtroAccion = "";

    protected override async Task OnInitializedAsync()
    {
        await CargarLogs();
    }

    private async Task CargarLogs()
    {
        try
        {
            var url = "api/auditoria";
            if (!string.IsNullOrWhiteSpace(filtroUsuario))
            {
                url += $"?usuario={filtroUsuario}";
            }
            if (!string.IsNullOrWhiteSpace(filtroAccion))
            {
                url += string.IsNullOrWhiteSpace(filtroUsuario) ? "?" : "&";
                url += $"accion={filtroAccion}";
            }
            logs = await Http.GetFromJsonAsync<List<AuditoriaDto>>(url);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando auditoría: {ex.Message}");
            logs = new List<AuditoriaDto>();
        }
    }
}
