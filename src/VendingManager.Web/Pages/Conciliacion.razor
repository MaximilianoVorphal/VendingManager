                        <InputFile OnChange="OnTransfFotoSelected" accept="image/*,application/pdf" style="width:100%;padding:8px;border:2px solid var(--ink-900);font-family:var(--font-mono);font-size:0.72rem;" />
                        @if (_transfFoto is not null)
