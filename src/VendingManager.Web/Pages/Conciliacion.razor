    private string _reasignarNuevoNombre = string.Empty;
    private string? _reasignarError;
    private List<ProveedorCatalogDto> _proveedores = new();

    // ── Gasto modal state ─────────────────────────────────────────────────────
    private decimal _gastoMonto;
    private string _gastoMontoText = string.Empty;
    private string _gastoTrabajador = string.Empty;
    private string _gastoDescripcion = string.Empty;
