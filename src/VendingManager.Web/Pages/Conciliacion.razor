                        <input id="transf-monto" type="text" inputmode="decimal" value="@_transfMontoText" @onchange="OnTransfMontoChanged" placeholder="ej: 340.000" style="width:100%;padding:8px;border:2px solid var(--ink-900);font-family:var(--font-mono);font-size:0.82rem;" />
                    </div>
                    <div>
                        <label style="font-family:var(--font-mono);font-weight:700;font-size:0.62rem;text-transform:uppercase;letter-spacing:1px;color:var(--text-muted);">Trabajador</label>
