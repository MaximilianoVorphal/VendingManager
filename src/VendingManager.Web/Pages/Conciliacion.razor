@page "/contabilidad"
@inject HttpClient Http
@inject IJSRuntime JS
@implements IDisposable
@using System.Globalization
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Forms
@using VendingManager.Shared.DTOs
@using VendingManager.Shared.Enums

@* =============================================================================
   Conciliación — port fiel de templates/conciliacion/Conciliacion.dc.html.
   Las tres pestañas (Cuadre / Comprobantes / Saldo) colapsan en una sola
   pantalla sin scroll: cuadre = libro único con scroll interno a la izquierda,
   comprobante del documento seleccionado a la derecha, totales en la franja de
   KPIs y saldo a devolver como barra de acción permanente abajo.
   Ruta "fullscreen" en MainLayout. Datos demo idénticos al template (el cableado
   real a HttpClient es el paso siguiente). Estilos inline con var(--token)
   copiados del template; el bloque <style> cubre keyframes, hover y responsive.
   ============================================================================= *@

<style>
    @@keyframes conBlink { 50% { opacity: 0; } }
    @@keyframes conFade { from { opacity: 0; transform: translateY(-8px); } to { opacity: 1; transform: translateY(0); } }
    .con-cursor { animation: conBlink 1s steps(1) infinite; }
    .con-modal { animation: conFade .15s ease-out; }
    .con-row:hover { background: var(--bg-surface-inset) !important; }
    @@media (prefers-reduced-motion: reduce) {
        .con-cursor, .con-modal { animation: none !important; }
    }
    @@media (max-width: 1080px) {
        .con-work { flex-direction: column !important; }
        .con-comprobante {
            flex: none !important; width: 100% !important; max-width: none !important;
            border-top: 2px solid var(--ink-900);
        }
    }
    /* El título y su cursor parpadeante no deben poder seleccionarse. */
    .con-page [data-cuadre-title] { user-select: none; }
    /* Foco solo visible con teclado (accesible), no la caja al click de mouse. */
    .con-page :is(button, select, input):focus:not(:focus-visible) { outline: none; }
    .con-page :is(button, select, input):focus-visible {
        outline: 2px solid var(--ink-900); outline-offset: 2px;
    }
</style>

<div class="con-page" style="flex:1;min-height:0;display:flex;flex-direction:column;overflow:hidden;padding:0.9rem 1.25rem 0.9rem;gap:0.7rem;">

    <!-- ===== HEADER: selector + acciones ===== -->
    <div style="display:flex;justify-content:space-between;align-items:center;gap:14px;flex-wrap:wrap;flex-shrink:0;">
        <div style="display:flex;align-items:center;gap:10px;">
            @if (_loading)
            {
                <span style="font-family:var(--font-mono);font-weight:700;font-size:0.86rem;text-transform:uppercase;color:var(--text-muted);">Cargando períodos…</span>
            }
            else if (_periodos.Count > 0)
            {
                <!-- Selector de rendición: botón negro (bi-bank · monto · caret) con <select> nativo superpuesto e invisible. -->
                <div style="position:relative;display:inline-flex;">
                    <div aria-hidden="true" style="display:flex;align-items:center;gap:10px;background:var(--ink-900);color:var(--paper-0);border:2px solid var(--ink-900);border-radius:0;font-family:var(--font-mono);font-weight:700;font-size:0.86rem;text-transform:uppercase;letter-spacing:0.5px;padding:0.5rem 0.9rem;white-space:nowrap;pointer-events:none;">
                        <i class="bi bi-bank"></i>
                        @if (_periodo is not null)
                        {
                            <span>@Fmt(_periodo.TotalTransferido) — @_periodo.Trabajador</span>
                        }
                        else
                        {
                            <span>Seleccionar rendición</span>
                        }
                        <span style="opacity:0.7;">▾</span>
                    </div>
                    <select value="@_selectedPeriodoId" @onchange="OnPeriodoChanged" aria-label="Seleccionar período de rendición" style="position:absolute;inset:0;width:100%;height:100%;margin:0;padding:0;border:0;opacity:0;cursor:pointer;">
                        @foreach (var p in _periodos)
                        {
                            <option value="@p.Id">@p.Label</option>
                        }
                    </select>
                </div>
                @if (_periodo is not null)
                {
                    <span style="font-family:var(--font-mono);font-weight:700;font-size:0.62rem;text-transform:uppercase;letter-spacing:1px;background:@(_periodo.Estado == AccountingPeriodEstado.Abierto ? "var(--signal-success)" : "var(--text-muted)");color:#fff;padding:4px 9px;">@(_periodo.Estado == AccountingPeriodEstado.Abierto ? "Abierta" : "Cerrada")</span>
                }
            }
        </div>
        <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
            <VmButton Variant="outline" Bar="true" Icon="bi-bank" OnClick="() => _showTransfModal = true">Crear Transferencia</VmButton>
            @if (_periodo is not null && _periodo.Transferencias.Count == 0)
            {
                <span style="font-family:var(--font-mono);font-size:0.62rem;color:var(--signal-warning);text-transform:uppercase;letter-spacing:0.5px;">Necesitás al menos una transferencia para registrar una compra/gasto</span>
            }
            else
            {
                <VmButton Variant="outline" Bar="true" Icon="bi-cart" OnClick="AbrirCompraModal">Compra</VmButton>
                <VmButton Variant="outline" Bar="true" Icon="bi-receipt" OnClick="() => _showGastoModal = true">Gasto</VmButton>
                <VmButton Variant="danger" Bar="true" Icon="bi-trash"
                          Disabled="@(_periodo?.Transferencias.Count > 0 && _periodo.Transferencias[0].Estado == VendingManager.Shared.Enums.TransferenciaEstado.Conciliado)"
                          Title="@(_periodo?.Transferencias.Count > 0 && _periodo.Transferencias[0].Estado == VendingManager.Shared.Enums.TransferenciaEstado.Conciliado ? "No se puede eliminar una transferencia ya conciliada." : "")"
                          OnClick="() => _eliminarModalOpen = true"
                          data-testid="eliminar-transf-btn">
                    Eliminar Transferencia
                </VmButton>
            }
            <VmButton Variant="dark" Bar="true" Icon="bi-box-arrow-up-right">Ir a caja</VmButton>
        </div>
    </div>

    @if (_error is not null)
    {
        <IndustrialAlert Message="@_error" Variant="IndustrialAlert.AlertVariant.Danger" />
    }
    @if (_successMessage is not null)
    {
        <IndustrialAlert Message="@_successMessage" Variant="IndustrialAlert.AlertVariant.Success" />
    }

    <!-- ===== FRANJA KPI (totales del cuadre, siempre visibles) ===== -->
    @if (_periodo is not null)
    {
        var diferencia = _periodo.Diferencia;
        var diffFmt = Fmt(diferencia);
        <div style="display:grid;grid-template-columns:1.1fr 1fr 1fr 1fr 1.25fr;gap:0;border:2px solid var(--ink-900);background:var(--paper-0);flex-shrink:0;">
            <!-- Identidad -->
            <div style="padding:0.7rem 0.9rem;border-right:1px solid var(--line-200);display:flex;flex-direction:column;gap:4px;">
                <span style="font-family:var(--font-mono);font-weight:700;font-size:0.92rem;text-transform:uppercase;letter-spacing:-0.3px;">@_periodo.Trabajador</span>
                <span style="font-family:var(--font-mono);font-size:0.68rem;color:var(--text-muted);">@_periodo.FechaInicio.ToString("dd/MM/yyyy") · @(_periodo.Estado == AccountingPeriodEstado.Abierto ? "Rendición abierta" : "Rendición cerrada")</span>
            </div>
            <!-- Transferido -->
            <div style="padding:0.7rem 0.9rem;border-right:1px solid var(--line-200);text-align:center;display:flex;flex-direction:column;gap:3px;justify-content:center;">
                <span style="font-family:var(--font-mono);font-weight:700;font-size:0.6rem;text-transform:uppercase;letter-spacing:1px;color:var(--text-muted);">Transferido</span>
                <span style="font-family:var(--font-sans);font-weight:700;font-size:1.25rem;letter-spacing:-1px;line-height:1;color:var(--signal-success);">+@Fmt(_periodo.TotalTransferido)</span>
            </div>
            <!-- Compras -->
            <div style="padding:0.7rem 0.9rem;border-right:1px solid var(--line-200);text-align:center;display:flex;flex-direction:column;gap:3px;justify-content:center;">
                <span style="font-family:var(--font-mono);font-weight:700;font-size:0.6rem;text-transform:uppercase;letter-spacing:1px;color:var(--text-muted);">Compras</span>
                <span style="font-family:var(--font-sans);font-weight:700;font-size:1.25rem;letter-spacing:-1px;line-height:1;color:var(--signal-danger);">-@Fmt(_periodo.TotalCompras)</span>
            </div>
            <!-- Gastos -->
            <div style="padding:0.7rem 0.9rem;border-right:1px solid var(--line-200);text-align:center;display:flex;flex-direction:column;gap:3px;justify-content:center;">
                <span style="font-family:var(--font-mono);font-weight:700;font-size:0.6rem;text-transform:uppercase;letter-spacing:1px;color:var(--text-muted);">Gastos</span>
                <span style="font-family:var(--font-sans);font-weight:700;font-size:1.25rem;letter-spacing:-1px;line-height:1;color:var(--signal-danger);">-@Fmt(_periodo.TotalGastos)</span>
            </div>
            <!-- Diferencia -->
            <div style="padding:0.7rem 0.95rem;background:@(diferencia != 0 ? "var(--signal-warning)" : "var(--signal-success)");display:flex;align-items:center;justify-content:space-between;gap:10px;">
                <div style="display:flex;flex-direction:column;gap:2px;">
                    <span style="font-family:var(--font-mono);font-weight:700;font-size:0.6rem;text-transform:uppercase;letter-spacing:1px;color:rgba(0,0,0,0.65);">Diferencia</span>
                    <span style="font-family:var(--font-sans);font-weight:700;font-size:1.45rem;letter-spacing:-1px;line-height:1;color:var(--ink-900);">@diffFmt</span>
                </div>
                <span style="font-family:var(--font-mono);font-weight:700;font-size:0.58rem;text-transform:uppercase;letter-spacing:0.5px;background:var(--ink-900);color:#fff;padding:4px 8px;">@(diferencia >= 0 ? "Positiva" : "Negativa")</span>
            </div>
        </div>
    }

<!-- ===== MODAL: nueva compra ===== -->
@if (_showCompraModal)
{
    <div style="position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:2000;display:flex;align-items:center;justify-content:center;padding:16px;" @onclick="() => _showCompraModal = false">
        <div class="con-modal" style="width:100%;max-width:420px;background:var(--paper-0);border:2px solid var(--ink-900);box-shadow:4px 4px 0 #000;" @onclick:stopPropagation="true">
            <div style="background:var(--ink-900);color:#fff;display:flex;justify-content:space-between;align-items:center;padding:0.6rem 0.9rem;font-family:var(--font-mono);font-weight:700;text-transform:uppercase;letter-spacing:1px;">
                <span>Compra</span>
                <span style="cursor:pointer;font-size:1.2rem;line-height:1;" @onclick="() => _showCompraModal = false">×</span>
            </div>
            <!-- pestañas -->
            <div style="display:flex;border-bottom:2px solid var(--ink-900);">
                <button @onclick='() => _compraTab = "vincular"' style="flex:1;font-family:var(--font-mono);font-weight:700;font-size:0.68rem;text-transform:uppercase;letter-spacing:0.5px;border:none;border-radius:0;cursor:pointer;padding:9px;background:@(_compraTab == "vincular" ? "var(--ink-900)" : "var(--paper-0)");color:@(_compraTab == "vincular" ? "#fff" : "var(--ink-900)");">Vincular existente</button>
                <button @onclick='() => _compraTab = "crear"' style="flex:1;font-family:var(--font-mono);font-weight:700;font-size:0.68rem;text-transform:uppercase;letter-spacing:0.5px;border:none;border-left:2px solid var(--ink-900);border-radius:0;cursor:pointer;padding:9px;background:@(_compraTab == "crear" ? "var(--ink-900)" : "var(--paper-0)");color:@(_compraTab == "crear" ? "#fff" : "var(--ink-900)");">Crear nueva</button>
            </div>
            <div style="padding:1.2rem;">
                @if (_compraTab == "vincular")
                {
                    <div style="display:flex;flex-direction:column;gap:10px;">
                        <input type="text" placeholder="Buscar proveedor o Nº documento…" @bind="_boletaBusqueda" @bind:event="oninput" @bind:after="OnBoletaFiltroChanged" style="width:100%;padding:8px;border:2px solid var(--ink-900);font-family:var(--font-mono);font-size:0.82rem;" />
                        <div style="display:flex;gap:8px;align-items:end;">
                            <div style="flex:1;display:flex;flex-direction:column;gap:3px;">
                                <label style="font-family:var(--font-mono);font-weight:700;font-size:0.58rem;text-transform:uppercase;letter-spacing:1px;color:var(--text-muted);">Desde</label>
                                <input type="date" @bind="_boletaDesde" @bind:event="onchange" @bind:after="OnBoletaFiltroChanged" max="@(_boletaHasta?.ToString("yyyy-MM-dd"))" style="width:100%;padding:7px;border:2px solid var(--ink-900);font-family:var(--font-mono);font-size:0.78rem;" />
                            </div>
                            <div style="flex:1;display:flex;flex-direction:column;gap:3px;">
                                <label style="font-family:var(--font-mono);font-weight:700;font-size:0.58rem;text-transform:uppercase;letter-spacing:1px;color:var(--text-muted);">Hasta</label>
                                <input type="date" @bind="_boletaHasta" @bind:event="onchange" @bind:after="OnBoletaFiltroChanged" min="@(_boletaDesde?.ToString("yyyy-MM-dd"))" style="width:100%;padding:7px;border:2px solid var(--ink-900);font-family:var(--font-mono);font-size:0.78rem;" />
                            </div>
                            @if (_boletaDesde.HasValue || _boletaHasta.HasValue)
                            {
                                <button @onclick="LimpiarFiltrosFecha" title="Limpiar fechas" style="padding:7px 10px;border:2px solid var(--ink-900);background:var(--paper-0);color:var(--ink-900);font-family:var(--font-mono);font-weight:700;font-size:0.7rem;text-transform:uppercase;letter-spacing:0.5px;cursor:pointer;border-radius:0;align-self:end;">×</button>
                            }
                        </div>
                        @if (_compraError is not null)
                        {
                            <IndustrialAlert Message="@_compraError" Variant="IndustrialAlert.AlertVariant.Danger" />
                        }
                        @if (_cargandoBoletas)
                        {
                            <p style="font-family:var(--font-mono);font-size:0.72rem;color:var(--text-muted);text-align:center;margin:0.6rem 0;">Cargando boletas…</p>
                        }
                        else if (!BoletasFiltradas.Any())
                        {
                            <p style="font-family:var(--font-mono);font-size:0.72rem;color:var(--text-muted);text-align:center;margin:0.6rem 0;">No hay boletas sin vincular.</p>
                        }
                        else
                        {
                            <div style="display:flex;flex-direction:column;max-height:320px;overflow-y:auto;border:1px solid var(--ink-900);">
                                @foreach (var b in BoletasFiltradas)
                                {
                                    <button @onclick="() => VincularBoleta(b.Id)" style="display:flex;align-items:center;justify-content:space-between;gap:10px;text-align:left;font-family:var(--font-mono);border:none;border-bottom:1px solid var(--line-200);border-radius:0;cursor:pointer;background:var(--paper-0);padding:9px 11px;">
                                        <span style="display:flex;flex-direction:column;gap:2px;overflow:hidden;">
                                            <span style="font-weight:700;font-size:0.76rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@b.Proveedor</span>
                                            <span style="font-size:0.64rem;color:var(--text-muted);">#@(b.NumeroDocumento ?? "—") · @b.FechaCompra.ToString("dd/MM/yyyy")</span>
                                        </span>
                                        <span style="font-weight:700;font-size:0.82rem;white-space:nowrap;">@Fmt(b.MontoTotal)</span>
                                    </button>
                                }
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div style="display:flex;flex-direction:column;gap:10px;">
                        <div>
                            <label style="font-family:var(--font-mono);font-weight:700;font-size:0.62rem;text-transform:uppercase;letter-spacing:1px;color:var(--text-muted);">Proveedor</label>
                            <input id="compra-proveedor" type="text" @bind="_compraProveedor" style="width:100%;padding:8px;border:2px solid var(--ink-900);font-family:var(--font-mono);font-size:0.82rem;" />
                        </div>
                        <div>
                            <label style="font-family:var(--font-mono);font-weight:700;font-size:0.62rem;text-transform:uppercase;letter-spacing:1px;color:var(--text-muted);">Monto</label>
                            <input id="compra-monto" type="text" inputmode="decimal" value="@_compraMontoText" @onchange="OnCompraMontoChanged" placeholder="ej: 12.500" style="width:100%;padding:8px;border:2px solid var(--ink-900);font-family:var(--font-mono);font-size:0.82rem;" />
                        </div>
                        @if (_compraError is not null)
                        {
                            <IndustrialAlert Message="@_compraError" Variant="IndustrialAlert.AlertVariant.Danger" />
                        }
                        <VmButton Variant="dark" Block="true" OnClick="CrearCompra">Crear compra</VmButton>
                    </div>
                }
            </div>
        </div>
    </div>
}

<!-- ===== MODAL: nuevo gasto ===== -->
@if (_showGastoModal)
{
    <div style="position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:2000;display:flex;align-items:center;justify-content:center;padding:16px;" @onclick="() => _showGastoModal = false">
        <div class="con-modal" style="width:100%;max-width:420px;background:var(--paper-0);border:2px solid var(--ink-900);box-shadow:4px 4px 0 #000;" @onclick:stopPropagation="true">
            <div style="background:var(--ink-900);color:#fff;display:flex;justify-content:space-between;align-items:center;padding:0.6rem 0.9rem;font-family:var(--font-mono);font-weight:700;text-transform:uppercase;letter-spacing:1px;">
                <span>Nuevo gasto</span>
                <span style="cursor:pointer;font-size:1.2rem;line-height:1;" @onclick="() => _showGastoModal = false">×</span>
            </div>
            <div style="padding:1.2rem;">
                <div style="display:flex;flex-direction:column;gap:10px;">
                    <div>
                        <label style="font-family:var(--font-mono);font-weight:700;font-size:0.62rem;text-transform:uppercase;letter-spacing:1px;color:var(--text-muted);">Monto</label>
                        <input id="gasto-monto" type="text" inputmode="decimal" value="@_gastoMontoText" @onchange="OnGastoMontoChanged" placeholder="ej: 12.500" style="width:100%;padding:8px;border:2px solid var(--ink-900);font-family:var(--font-mono);font-size:0.82rem;" />
                    </div>
                    <div>
                        <label style="font-family:var(--font-mono);font-weight:700;font-size:0.62rem;text-transform:uppercase;letter-spacing:1px;color:var(--text-muted);">Trabajador</label>
                        <input id="gasto-trabajador" type="text" @bind="_gastoTrabajador" style="width:100%;padding:8px;border:2px solid var(--ink-900);font-family:var(--font-mono);font-size:0.82rem;" />
                    </div>
                    <div>
                        <label style="font-family:var(--font-mono);font-weight:700;font-size:0.62rem;text-transform:uppercase;letter-spacing:1px;color:var(--text-muted);">Descripción</label>
                        <input id="gasto-descripcion" type="text" @bind="_gastoDescripcion" style="width:100%;padding:8px;border:2px solid var(--ink-900);font-family:var(--font-mono);font-size:0.82rem;" />
                    </div>
                    @if (_gastoError is not null)
                    {
                        <IndustrialAlert Message="@_gastoError" Variant="IndustrialAlert.AlertVariant.Danger" />
                    }
                    <VmButton Variant="dark" Block="true" OnClick="CrearGasto">Crear gasto</VmButton>
                </div>
            </div>
        </div>
    </div>
}

    <!-- ===== ÁREA DE TRABAJO: cuadre (izq) + comprobante (der) ===== -->
    <div class="con-work" style="flex:1;min-height:0;display:flex;gap:0.7rem;">

        <!-- ---------- IZQUIERDA: CUADRE (libro único con scroll interno) ---------- -->
        <div style="flex:1.45;min-width:0;display:flex;flex-direction:column;border:2px solid var(--ink-900);box-shadow:var(--shadow-card);background:var(--paper-0);">
            <!-- barra negra: título + progreso + filtro -->
            <div style="flex-shrink:0;background:var(--ink-900);color:var(--paper-0);display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap;padding:0.5rem 0.85rem;">
                <div style="display:flex;align-items:center;gap:12px;">
                    <span data-cuadre-title style="font-family:var(--font-mono);font-weight:700;text-transform:uppercase;letter-spacing:1px;font-size:0.92rem;"><i class="bi bi-table"></i> Cuadre<span class="con-cursor">_</span></span>
                    <span style="font-family:var(--font-mono);font-weight:700;font-size:0.62rem;text-transform:uppercase;letter-spacing:0.5px;background:var(--signal-success);color:#fff;padding:3px 7px;">Transf. @TransfDone/@TransfTotal</span>
                    @if (DocsDone == DocsTotal)
                    {
                        <span style="font-family:var(--font-mono);font-weight:700;font-size:0.62rem;text-transform:uppercase;letter-spacing:0.5px;background:var(--signal-success);color:#fff;padding:3px 7px;">Docs @DocsDone/@DocsTotal</span>
                    }
                    else
                    {
                        <span style="font-family:var(--font-mono);font-weight:700;font-size:0.62rem;text-transform:uppercase;letter-spacing:0.5px;background:var(--signal-warning);color:var(--ink-900);padding:3px 7px;">Docs @DocsDone/@DocsTotal</span>
                    }
                </div>
                <div style="display:flex;gap:0;border:2px solid var(--paper-0);">
                    @foreach (var f in Filtros)
                    {
                        var on = _filter == f.Key;
                        <button @onclick="() => _filter = f.Key" style="font-family:var(--font-mono);font-weight:700;font-size:0.64rem;text-transform:uppercase;letter-spacing:0.5px;padding:4px 9px;border:none;border-radius:0;cursor:pointer;background:@(on ? "var(--paper-0)" : "transparent");color:@(on ? "var(--ink-900)" : "var(--paper-0)");">@f.Label</button>
                    }
                </div>
            </div>

            <!-- lista scrolleable -->
            <div style="flex:1;min-height:0;overflow:auto;background:var(--bg-surface-inset);">
                @foreach (var sec in BuildSections())
                {
                    <!-- cabecera de sección (sub-tabla) -->
                    <div style="position:sticky;top:0;z-index:2;display:flex;justify-content:space-between;align-items:center;gap:10px;background:var(--ink-900);color:var(--paper-0);padding:6px 12px;border-bottom:1px solid var(--line-200);">
                        <span style="display:flex;align-items:center;gap:9px;font-family:var(--font-mono);font-weight:700;font-size:0.72rem;text-transform:uppercase;letter-spacing:1px;"><i class="bi @sec.Icon"></i>@sec.Title <span style="background:var(--paper-0);color:var(--ink-900);padding:1px 7px;">@sec.Count</span></span>
                        <span style="font-family:var(--font-mono);font-weight:700;font-size:0.78rem;color:@(sec.TotalPos ? "#7ee2a8" : "#ff9aa3");">Total @sec.TotalFmt</span>
                    </div>
                    <!-- filas -->
                    @foreach (var r in sec.Rows)
                    {
                        <div class="con-row" @onclick="() => SelectRow(r.Id)" style="position:relative;display:flex;align-items:center;gap:11px;padding:9px 12px 9px 14px;border-bottom:1px solid var(--line-200);background:var(--paper-0);cursor:pointer;">
                            @if (r.Selected)
                            {
                                <div style="position:absolute;left:0;top:0;bottom:0;width:5px;background:var(--ink-900);"></div>
                            }
                            <div style="flex-shrink:0;width:38px;height:46px;border:1px solid var(--ink-900);background-image:repeating-linear-gradient(45deg,#f0f0f0,#f0f0f0 5px,#e2e2e2 5px,#e2e2e2 10px);display:flex;align-items:center;justify-content:center;overflow:hidden;">
                                @if (r.ThumbUrl is not null)
                                {
                                    <img src="@r.ThumbUrl" alt="" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;"
                                         onerror="this.onerror=null;this.style.display='none';this.nextElementSibling.style.display='block';" />
                                    <i class="bi @r.ThumbIcon" style="display:none;font-size:0.95rem;color:var(--ink-700);"></i>
                                }
                                else
                                {
                                    <i class="bi @r.ThumbIcon" style="font-size:0.95rem;color:var(--ink-700);"></i>
                                }
                            </div>
                            <div style="flex:1;min-width:0;">
                                <div style="font-family:var(--font-sans);font-weight:600;font-size:0.82rem;text-transform:uppercase;letter-spacing:-0.2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@r.Titulo</div>
                                <div style="font-family:var(--font-mono);font-size:0.66rem;color:var(--text-muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@r.Sub</div>
                                @if (r.SinProveedor)
                                {
                                    <span style="display:inline-block;margin-top:3px;font-family:var(--font-mono);font-weight:700;font-size:0.54rem;text-transform:uppercase;letter-spacing:0.4px;background:var(--signal-warning);color:var(--ink-900);padding:1px 6px;">Sin proveedor</span>
                                }
                            </div>
                            <span style="flex-shrink:0;font-family:var(--font-mono);font-weight:700;font-size:0.56rem;text-transform:uppercase;letter-spacing:0.4px;border:1px solid var(--ink-900);padding:2px 6px;">@r.TipoTag</span>
                            <span style="flex-shrink:0;width:96px;text-align:right;font-family:var(--font-mono);font-weight:700;font-size:0.84rem;color:@(r.MontoPos ? "var(--signal-success)" : "var(--signal-danger)");">@r.MontoFmt</span>
                            <div style="flex-shrink:0;width:34px;display:flex;justify-content:center;">
                                @if (r.Verified)
                                {
                                    <i class="bi bi-check-circle-fill" style="font-size:1.05rem;color:var(--signal-success);"></i>
                                }
                                else
                                {
                                    <span style="width:16px;height:16px;border:2px solid var(--signal-warning);border-radius:50%;background:var(--tint-pending);"></span>
                                }
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- ---------- DERECHA: COMPROBANTE del documento seleccionado ---------- -->
        @{ var sel = BuildSel(); }
        <div class="con-comprobante" style="flex:1;min-width:330px;max-width:440px;display:flex;flex-direction:column;border:2px solid var(--ink-900);box-shadow:var(--shadow-card);background:var(--paper-0);">
            <div style="flex-shrink:0;background:var(--ink-900);color:var(--paper-0);display:flex;justify-content:space-between;align-items:center;padding:0.5rem 0.85rem;">
                <span style="font-family:var(--font-mono);font-weight:700;text-transform:uppercase;letter-spacing:1px;font-size:0.92rem;"><i class="bi bi-card-image"></i> Comprobante</span>
                <span style="font-family:var(--font-mono);font-weight:700;font-size:0.62rem;text-transform:uppercase;letter-spacing:0.5px;border:1px solid var(--paper-0);padding:3px 7px;">@sel.KindLabel</span>
            </div>

            <div style="flex:1;min-height:0;overflow:auto;display:flex;flex-direction:column;">
                <!-- foto / imagen del comprobante -->
                <div style="position:relative;flex:1 1 120px;min-height:120px;margin:0.85rem;border:2px solid var(--ink-900);background-image:repeating-linear-gradient(45deg,#fafafa,#fafafa 9px,#eee 9px,#eee 18px);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;overflow:hidden;">
                    @if (sel.ImgUrl is not null)
                    {
                        <img src="@sel.ImgUrl" alt="" aria-hidden="true" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;filter:blur(16px) brightness(0.92);transform:scale(1.18);opacity:0.55;"
                             onerror="this.style.display='none';" />
                        <a href="@sel.ImgUrl" target="_blank" rel="noopener" style="position:relative;display:flex;align-items:center;justify-content:center;width:100%;height:100%;text-decoration:none;">
                            <img src="@sel.ImgUrl" alt="@sel.ImgCaption" style="max-width:100%;max-height:100%;object-fit:contain;display:block;box-shadow:0 2px 14px rgba(0,0,0,0.28);"
                                 onerror="this.onerror=null;this.parentElement.style.display='none';this.parentElement.nextElementSibling.style.display='flex';" />
                        </a>
                        <a href="@sel.ImgUrl" target="_blank" rel="noopener" style="position:relative;display:none;flex-direction:column;align-items:center;gap:8px;text-decoration:none;">
                            <i class="bi bi-file-earmark-text" style="font-size:2rem;color:var(--text-muted);"></i>
                            <span style="font-family:var(--font-mono);font-weight:700;font-size:0.7rem;text-transform:uppercase;letter-spacing:1px;color:var(--text-muted);">Abrir documento</span>
                        </a>
                    }
                    else
                    {
                        <i class="bi @sel.BigIcon" style="font-size:2rem;color:var(--text-muted);"></i>
                        <span style="font-family:var(--font-mono);font-weight:700;font-size:0.7rem;text-transform:uppercase;letter-spacing:1px;color:var(--text-muted);">@sel.ImgCaption</span>
                    }
                </div>

                <!-- datos del documento -->
                <div style="padding:0 0.95rem 0.5rem;">
                    <div style="font-family:var(--font-sans);font-weight:700;font-size:1rem;text-transform:uppercase;letter-spacing:-0.3px;line-height:1.15;margin-bottom:8px;">@sel.Titulo</div>
                    @if (sel.KindLabel == "Compra" && !string.IsNullOrWhiteSpace(sel.RawProveedor) && !string.Equals(sel.RawProveedor, sel.Canonical, StringComparison.OrdinalIgnoreCase))
                    {
                        <div style="font-family:var(--font-mono);font-size:0.64rem;color:var(--text-muted);margin:-4px 0 8px;">OCR: @sel.RawProveedor</div>
                    }
                    <div style="display:grid;grid-template-columns:auto 1fr;gap:6px 14px;font-family:var(--font-mono);font-size:0.74rem;align-items:baseline;">
                        <span style="color:var(--text-muted);font-weight:700;text-transform:uppercase;font-size:0.62rem;">@sel.F1Label</span><span style="font-weight:700;text-align:right;">@sel.F1</span>
                        <span style="color:var(--text-muted);font-weight:700;text-transform:uppercase;font-size:0.62rem;">@sel.F2Label</span><span style="font-weight:700;text-align:right;">@sel.F2</span>
                        <span style="color:var(--text-muted);font-weight:700;text-transform:uppercase;font-size:0.62rem;">Tipo</span><span style="font-weight:700;text-align:right;text-transform:uppercase;">@sel.TipoTag</span>
                        <span style="color:var(--text-muted);font-weight:700;text-transform:uppercase;font-size:0.62rem;">Monto</span>
                        <span style="font-weight:700;text-align:right;font-size:0.95rem;color:@(sel.MontoPos ? "var(--signal-success)" : "var(--signal-danger)");">@sel.MontoFmt</span>
                    </div>
                </div>

                <!-- corregir proveedor (inline, solo compras) -->
                @if (sel.KindLabel == "Compra")
                {
                    <div style="margin:0 0.95rem 0.7rem;">
                        @if (!_reasignarOpen)
                        {
                            <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
                                @if (sel.CatalogId is null)
                                {
                                    <span style="font-family:var(--font-mono);font-weight:700;font-size:0.58rem;text-transform:uppercase;letter-spacing:0.5px;background:var(--signal-warning);color:var(--ink-900);padding:2px 7px;">Sin proveedor</span>
                                }
                                <button @onclick="AbrirReasignar" style="display:flex;align-items:center;gap:6px;font-family:var(--font-mono);font-weight:700;font-size:0.64rem;text-transform:uppercase;letter-spacing:0.5px;background:var(--paper-0);color:var(--ink-900);border:2px solid var(--ink-900);border-radius:0;cursor:pointer;padding:6px 11px;"><i class="bi bi-pencil"></i> Corregir proveedor</button>
                            </div>
                        }
                        else
                        {
                            <div style="display:flex;flex-direction:column;gap:8px;border:2px solid var(--ink-900);padding:10px;">
                                <label style="font-family:var(--font-mono);font-weight:700;font-size:0.62rem;text-transform:uppercase;letter-spacing:1px;color:var(--text-muted);">Proveedor</label>
                                <select @bind="_reasignarCatalogId" style="width:100%;padding:8px;border:2px solid var(--ink-900);border-radius:0;font-family:var(--font-mono);font-size:0.78rem;background:var(--paper-0);">
                                    <option value="0">— Elegí un proveedor —</option>
                                    @foreach (var p in _proveedores)
                                    {
                                        <option value="@p.Id">@p.NombreCanonical</option>
                                    }
                                    <option value="-1">+ Nuevo proveedor…</option>
                                </select>
                                @if (_reasignarCatalogId == -1)
                                {
                                    <input type="text" placeholder="Nombre del nuevo proveedor" @bind="_reasignarNuevoNombre" style="width:100%;padding:8px;border:2px solid var(--ink-900);font-family:var(--font-mono);font-size:0.78rem;" />
                                }
                                @if (_reasignarError is not null)
                                {
                                    <IndustrialAlert Message="@_reasignarError" Variant="IndustrialAlert.AlertVariant.Danger" />
                                }
                                <div style="display:flex;gap:8px;">
                                    <button @onclick="() => _reasignarOpen = false" style="flex:1;font-family:var(--font-mono);font-weight:700;font-size:0.66rem;text-transform:uppercase;letter-spacing:0.5px;background:var(--paper-0);color:var(--text-muted);border:2px solid var(--line-200);border-radius:0;cursor:pointer;padding:8px;">Cancelar</button>
                                    <button @onclick="ConfirmarReasignar" disabled="@_reasignando" style="flex:2;font-family:var(--font-mono);font-weight:700;font-size:0.66rem;text-transform:uppercase;letter-spacing:0.5px;background:var(--ink-900);color:#fff;border:2px solid var(--ink-900);border-radius:0;cursor:@(_reasignando ? "wait" : "pointer");padding:8px;">@(_reasignando ? "Guardando…" : "Confirmar")</button>
                                </div>
                            </div>
                        }
                    </div>
                }

                <!-- selector de archivo -->
                @if (sel.KindLabel == "Transferencia" || sel.KindLabel == "Compra")
                {
                    <label style="margin:0 0.95rem 0.7rem;display:flex;border:1px solid var(--ink-900);cursor:@(_uploadingComprobante ? "wait" : "pointer");">
                        <span style="background:var(--bg-surface-inset);border-right:1px solid var(--ink-900);font-family:var(--font-mono);font-weight:700;font-size:0.64rem;text-transform:uppercase;letter-spacing:0.5px;padding:7px 10px;white-space:nowrap;">@(_uploadingComprobante ? "Subiendo…" : "Elegir archivo")</span>
                        <span style="flex:1;font-family:var(--font-mono);font-size:0.68rem;color:var(--text-muted);padding:7px 10px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@sel.FileName</span>
                        <InputFile OnChange="OnComprobanteSelected" accept="image/*,application/pdf" disabled="@_uploadingComprobante" style="display:none;" />
                    </label>
                }
                else
                {
                    <div style="margin:0 0.95rem 0.7rem;display:flex;border:1px solid var(--ink-900);">
                        <span style="background:var(--bg-surface-inset);border-right:1px solid var(--ink-900);font-family:var(--font-mono);font-weight:700;font-size:0.64rem;text-transform:uppercase;letter-spacing:0.5px;padding:7px 10px;white-space:nowrap;">Elegir archivo</span>
                        <span style="flex:1;font-family:var(--font-mono);font-size:0.68rem;color:var(--text-muted);padding:7px 10px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@sel.FileName</span>
                    </div>
                }

                @if (sel.HasComprobante)
                {
                    <div style="margin:0 0.95rem 0.7rem;">
                        <button @onclick="DescargarComprobante" style="display:flex;align-items:center;gap:6px;font-family:var(--font-mono);font-weight:700;font-size:0.66rem;text-transform:uppercase;letter-spacing:0.5px;background:var(--paper-0);color:var(--ink-900);border:2px solid var(--ink-900);border-radius:0;cursor:pointer;padding:7px 12px;"><i class="bi bi-download"></i> Descargar comprobante</button>
                    </div>
                }
                @if (_comprobanteError is not null)
                {
                    <div style="margin:0 0.95rem 0.7rem;">
                        <IndustrialAlert Message="@_comprobanteError" Variant="IndustrialAlert.AlertVariant.Danger" />
                    </div>
                }
            </div>

            <!-- acciones de verificación (pie fijo del panel) -->
            <div style="flex-shrink:0;border-top:2px solid var(--ink-900);padding:0.7rem 0.85rem;">
                @if (sel.Verified)
                {
                    <div style="display:flex;align-items:center;gap:10px;">
                        <div style="flex:1;display:flex;align-items:center;justify-content:center;gap:8px;background:var(--signal-success);color:#fff;font-family:var(--font-mono);font-weight:700;font-size:0.8rem;text-transform:uppercase;letter-spacing:1px;padding:9px;"><i class="bi bi-check-circle-fill"></i> Verificada</div>
                        <button @onclick="Unverify" style="font-family:var(--font-mono);font-weight:700;font-size:0.66rem;text-transform:uppercase;letter-spacing:0.5px;background:transparent;color:var(--text-muted);border:1px solid var(--line-200);border-radius:0;cursor:pointer;padding:9px 11px;">Quitar</button>
                    </div>
                }
                else
                {
                    <div style="display:flex;gap:9px;">
                        @if (sel.KindLabel == "Compra")
                        {
                            <button @onclick="DesvincularBoleta" style="flex-shrink:0;display:flex;align-items:center;gap:6px;font-family:var(--font-mono);font-weight:700;font-size:0.72rem;text-transform:uppercase;letter-spacing:0.5px;background:var(--paper-0);color:var(--signal-danger);border:2px solid var(--signal-danger);border-radius:0;cursor:pointer;padding:9px 12px;"><i class="bi bi-trash"></i> Eliminar</button>
                        }
                        <button @onclick="VerifyAndNext" style="flex:1;display:flex;align-items:center;justify-content:center;gap:8px;font-family:var(--font-mono);font-weight:700;font-size:0.78rem;text-transform:uppercase;letter-spacing:0.5px;background:var(--ink-900);color:#fff;border:2px solid var(--ink-900);border-radius:0;cursor:pointer;padding:9px;"><i class="bi bi-check2-all"></i> Verificar y seguir</button>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- ===== BARRA SALDO A DEVOLVER (acción permanente) ===== -->
    @if (_periodo is not null)
    {
        var diferencia = _periodo.Diferencia;
        var comprasGastos = _periodo.TotalCompras + _periodo.TotalGastos;
        <div style="flex-shrink:0;display:flex;align-items:stretch;border:2px solid var(--ink-900);background:var(--signal-warning);">
            <div style="display:flex;align-items:center;gap:14px;padding:0.6rem 1rem;flex:1;flex-wrap:wrap;">
                <span style="font-family:var(--font-mono);font-weight:700;font-size:0.7rem;text-transform:uppercase;letter-spacing:1px;color:var(--ink-900);"><i class="bi bi-arrow-counterclockwise"></i> Saldo a devolver</span>
                <span style="font-family:var(--font-mono);font-size:0.72rem;color:rgba(0,0,0,0.7);">Transferido <b>+@Fmt(_periodo.TotalTransferido)</b>  −  Compras + Gastos <b>-@Fmt(comprasGastos)</b></span>
                @if (AllDone)
                {
                    <span style="font-family:var(--font-mono);font-weight:700;font-size:0.6rem;text-transform:uppercase;letter-spacing:0.5px;background:var(--signal-success);color:#fff;padding:3px 8px;">Conciliado</span>
                }
                else
                {
                    <span style="font-family:var(--font-mono);font-weight:700;font-size:0.6rem;text-transform:uppercase;letter-spacing:0.5px;background:var(--ink-900);color:#fff;padding:3px 8px;">Pendiente · @DocsRemaining doc(s)</span>
                }
            </div>
            <div style="display:flex;align-items:center;gap:14px;padding:0.5rem 1rem;border-left:2px solid var(--ink-900);">
                <span style="font-family:var(--font-sans);font-weight:700;font-size:1.7rem;letter-spacing:-1.5px;line-height:1;color:var(--ink-900);">@Fmt(diferencia)</span>
            </div>
            <button @onclick="() => _modalOpen = true" style="display:flex;align-items:center;gap:9px;font-family:var(--font-mono);font-weight:700;font-size:0.82rem;text-transform:uppercase;letter-spacing:0.5px;background:var(--ink-900);color:#fff;border:none;border-left:2px solid var(--ink-900);border-radius:0;cursor:pointer;padding:0 1.4rem;"><i class="bi bi-arrow-counterclockwise"></i> Registrar devolución</button>
        </div>
    }
</div>

<!-- ===== MODAL: confirmación de devolución ===== -->
@if (_modalOpen && _periodo is not null)
{
    <div style="position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:2000;display:flex;align-items:center;justify-content:center;padding:16px;" @onclick="() => _modalOpen = false">
        <div class="con-modal" style="width:100%;max-width:420px;background:var(--paper-0);border:2px solid var(--ink-900);box-shadow:4px 4px 0 #000;" @onclick:stopPropagation="true">
            <div style="background:var(--ink-900);color:#fff;display:flex;justify-content:space-between;align-items:center;padding:0.6rem 0.9rem;font-family:var(--font-mono);font-weight:700;text-transform:uppercase;letter-spacing:1px;">
                <span>Registrar devolución</span>
                <span style="cursor:pointer;font-size:1.2rem;line-height:1;" @onclick="() => _modalOpen = false">×</span>
            </div>
            <div style="padding:1.2rem;text-align:center;">
                <div style="font-family:var(--font-sans);font-weight:700;font-size:2.4rem;letter-spacing:-1.5px;color:var(--ink-900);">@Fmt(_periodo.Diferencia)</div>
                <p style="font-family:var(--font-mono);font-size:0.78rem;color:var(--text-secondary);margin:0.5rem 0 1.2rem;">Saldo a devolver por @_periodo.Trabajador. Esta acción cierra la rendición.</p>
                <div style="display:flex;gap:10px;">
                    <VmButton Variant="outline" Block="true" OnClick="() => _modalOpen = false">Cancelar</VmButton>
                    <VmButton Variant="dark" Block="true" OnClick="ConfirmarDevolucion">Confirmar</VmButton>
                </div>
            </div>
        </div>
    </div>
}

<!-- ===== MODAL: eliminar transferencia (confirmación fuerte) ===== -->
@if (_eliminarModalOpen && _periodo is not null && _periodo.Transferencias.Count > 0)
{
    var transf = _periodo.Transferencias[0];
    var comprasCount = transf.Compras.Count;
    var totalMonto = transf.Compras.Sum(c => c.MontoTotal);
    var fileName = transf.ComprobanteImagenPath is not null ? System.IO.Path.GetFileName(transf.ComprobanteImagenPath) : "Sin archivo";
    var nameMatches = _eliminarConfirmName.Trim() == _periodo.Trabajador;

    <div style="position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:2000;display:flex;align-items:center;justify-content:center;padding:16px;" @onclick="() => _eliminarModalOpen = false">
        <div class="con-modal" style="width:100%;max-width:420px;background:var(--paper-0);border:2px solid var(--ink-900);box-shadow:4px 4px 0 #000;" @onclick:stopPropagation="true">
            <div style="background:var(--signal-danger);color:#fff;display:flex;justify-content:space-between;align-items:center;padding:0.6rem 0.9rem;font-family:var(--font-mono);font-weight:700;text-transform:uppercase;letter-spacing:1px;">
                <span>Eliminar transferencia</span>
                <span style="cursor:pointer;font-size:1.2rem;line-height:1;" @onclick="() => _eliminarModalOpen = false">×</span>
            </div>
            <div style="padding:1.2rem;">
                <div style="display:grid;grid-template-columns:auto 1fr;gap:6px 14px;font-family:var(--font-mono);font-size:0.74rem;margin-bottom:1rem;">
                    <span style="color:var(--text-muted);font-weight:700;text-transform:uppercase;font-size:0.62rem;">Compras vinculadas</span>
                    <span style="font-weight:700;">@comprasCount</span>
                    <span style="color:var(--text-muted);font-weight:700;text-transform:uppercase;font-size:0.62rem;">Total monto</span>
                    <span style="font-weight:700;">@Fmt(totalMonto)</span>
                    <span style="color:var(--text-muted);font-weight:700;text-transform:uppercase;font-size:0.62rem;">Período</span>
                    <span style="font-weight:700;">@_periodo.Name</span>
                    <span style="color:var(--text-muted);font-weight:700;text-transform:uppercase;font-size:0.62rem;">Comprobante</span>
                    <span style="font-weight:700;">@fileName</span>
                </div>
                <p style="font-family:var(--font-mono);font-size:0.72rem;color:var(--text-secondary);margin:0 0 0.8rem;">Para confirmar, escribí el nombre del trabajador: <b>@_periodo.Trabajador</b></p>
                <input type="text" data-testid="eliminar-confirm-name" placeholder="@_periodo.Trabajador" @bind="_eliminarConfirmName" @bind:event="oninput" style="width:100%;padding:8px;border:2px solid var(--ink-900);font-family:var(--font-mono);font-size:0.82rem;margin-bottom:10px;" />
                @if (_eliminarError is not null)
                {
                    <IndustrialAlert Message="@_eliminarError" Variant="IndustrialAlert.AlertVariant.Danger" />
                }
                <div style="display:flex;gap:10px;">
                    <VmButton Variant="outline" Block="true" OnClick="CancelarEliminarTransferencia">Cancelar</VmButton>
