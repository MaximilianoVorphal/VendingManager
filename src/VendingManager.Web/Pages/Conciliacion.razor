    // ── API state ─────────────────────────────────────────────────────────────
    private bool _loading;
    private string? _error;
    private List<PeriodoOpcion> _periodos = new();
    private int _selectedPeriodoId;
    private AccountingPeriodFullDto? _periodo;
    private CancellationTokenSource? _loadCts;

    // ── View-models ───────────────────────────────────────────────────────────
    private record PeriodoOpcion(int Id, string Label);
    private record RowVm(int Id, string Titulo, string Sub, string TipoTag, string MontoFmt, bool MontoPos, string ThumbIcon, bool Verified, bool Selected, bool HasComprobante, string? ThumbUrl = null, bool SinProveedor = false);
    private record SectionVm(string Title, string Icon, int Count, string TotalFmt, bool TotalPos, IReadOnlyList<RowVm> Rows);
    private record SelVm(string KindLabel, string BigIcon, string ImgCaption, string Titulo, string F1Label, string F1, string F2Label, string F2, string TipoTag, string MontoFmt, bool MontoPos, string FileName, bool Verified, bool HasComprobante, string? ImgUrl = null, int CompraId = 0, string? Canonical = null, int? CatalogId = null, string? RawProveedor = null);
    private record FiltroVm(string Key, string Label);

    private static readonly FiltroVm[] Filtros =
    [
        new("TODOS", "Todos"),
        new("COMPRAS", "Compras"),
        new("GASTOS", "Gastos"),
        new("PENDIENTES", "Pend."),
    ];

    // ── Progreso ──────────────────────────────────────────────────────────────
    private bool IsV(string key) => _verified.TryGetValue(key, out var v) && v;
    private int DocsTotal => (_periodo?.Transferencias.Sum(t => 1 + t.Compras.Count) ?? 0)
                           + (_periodo?.Gastos.Count ?? 0);
    private int DocsDone => _verified.Count(kv => kv.Value);
    private int DocsRemaining => DocsTotal - DocsDone;
    private int TransfDone => _periodo?.Transferencias.Count(t => IsV($"t{t.Id}")) ?? 0;
    private int TransfTotal => _periodo?.Transferencias.Count ?? 0;
    private bool AllDone => DocsRemaining == 0 && TransfTotal > 0 && TransfDone == TransfTotal;

    // ── Formato de moneda (es-CL: punto como separador de miles) ──────────────
    private static readonly NumberFormatInfo Nfi = new() { NumberGroupSeparator = ".", NumberDecimalDigits = 0 };
    private static string Fmt(decimal n) => (n < 0 ? "-$" : "$") + Math.Abs(n).ToString("N0", Nfi);

    // ── Handlers de input de monto (acepta formato chileno: 340.000, 340000, 340,000) ──
    private void OnTransfMontoChanged(ChangeEventArgs e)
    {
        _transfMontoText = e.Value?.ToString() ?? string.Empty;
        _transfMonto = ChileanAmountParser.TryParse(_transfMontoText, out var v) ? v : 0m;
    }

    private void OnCompraMontoChanged(ChangeEventArgs e)
    {
        _compraMontoText = e.Value?.ToString() ?? string.Empty;
        _compraMonto = ChileanAmountParser.TryParse(_compraMontoText, out var v) ? v : 0m;
    }

    private void OnGastoMontoChanged(ChangeEventArgs e)
    {
        _gastoMontoText = e.Value?.ToString() ?? string.Empty;
        _gastoMonto = ChileanAmountParser.TryParse(_gastoMontoText, out var v) ? v : 0m;
    }

    // ── Construcción de secciones según el filtro ─────────────────────────────
    private List<SectionVm> BuildSections()
    {
        if (_periodo is null) return new();

        var filter = _filter;
        var showTransf = filter == "TODOS" || (filter == "PENDIENTES" && _periodo.Transferencias.Any(t => !IsV($"t{t.Id}")));
        var showCompras = filter == "TODOS" || filter == "COMPRAS" || filter == "PENDIENTES";
        var showGastos = filter == "TODOS" || filter == "GASTOS" || filter == "PENDIENTES";

        var sections = new List<SectionVm>();

        if (showTransf)
        {
            var rows = _periodo.Transferencias
                .Where(t => filter != "PENDIENTES" || !IsV($"t{t.Id}"))
                .Select(t => new RowVm(
                    t.Id,
                    t.Trabajador.ToUpperInvariant(),
                    $"Fecha {t.Fecha:dd/MM/yyyy}",
                    "Transferencia",
                    Fmt(t.Monto),
                    true,
                    "bi-bank",
                    IsV($"t{t.Id}"),
                    _selectedId == t.Id,
                    t.ComprobanteImagenPath is not null,
                    t.ComprobanteImagenPath is not null ? $"/api/contabilidad/transferencia/{t.Id}/comprobante" : null
                ))
                .ToList();
            if (rows.Count > 0)
            {
                var total = _periodo.Transferencias.Sum(t => t.Monto);
                sections.Add(new("Transferencias", "bi-bank", rows.Count, Fmt(total), true, rows));
            }
        }

        if (showCompras)
        {
            var allCompras = _periodo.Transferencias.SelectMany(t => t.Compras).ToList();
            var compras = filter == "PENDIENTES"
                ? allCompras.Where(c => !IsV($"c{c.Id}")).ToList()
                : allCompras;
            var rows = compras.Select(c => new RowVm(
                c.Id,
                c.Proveedor.ToUpperInvariant(),
                $"Nº {c.NumeroDocumento} · {c.FechaCompra:dd/MM/yyyy}",
                c.TipoFactura,
                Fmt(-c.MontoTotal),
                false,
                "bi-receipt",
                IsV($"c{c.Id}"),
                _selectedId == c.Id,
                c.FacturaImagenPath is not null,
                c.FacturaImagenPath is not null ? $"/api/compras/{c.Id}/factura" : null,
                c.ProveedorCatalogId is null
            )).ToList();
            if (rows.Count > 0)
            {
                var total = compras.Sum(c => c.MontoTotal);
                sections.Add(new("Compras", "bi-cart", rows.Count, Fmt(-total), false, rows));
            }
        }

        if (showGastos)
        {
            var gastos = filter == "PENDIENTES"
                ? _periodo.Gastos.Where(g => !IsV($"g{g.Id}")).ToList()
                : _periodo.Gastos;
            var rows = gastos.Select(g => new RowVm(
                g.Id,
                g.Descripcion.ToUpperInvariant(),
                $"Fecha {g.Fecha:dd/MM/yyyy}",
                g.Categoria,
                Fmt(-g.Monto),
                false,
                "bi-receipt",
                IsV($"g{g.Id}"),
                _selectedId == g.Id,
                g.ImagenPath is not null,
                null
            )).ToList();
            if (rows.Count > 0)
            {
                var total = gastos.Sum(g => g.Monto);
                sections.Add(new("Gastos", "bi-receipt", rows.Count, Fmt(-total), false, rows));
            }
        }

        return sections;
    }

    // ── Panel derecho: documento seleccionado ─────────────────────────────────
    private SelVm BuildSel()
    {
        if (_periodo is null)
            return new("—", "bi-image", "Sin datos", "—", "—", "—", "—", "—", "—", "$0", false, "—", false, false, null);

        // Check transferencias
        var t = _periodo.Transferencias.FirstOrDefault(x => x.Id == _selectedId);
        if (t is not null)
        {
            return new("Transferencia", "bi-bank", "Comprobante transferencia",
                t.Trabajador.ToUpperInvariant(), "Para", t.Trabajador, "Fecha", $"{t.Fecha:dd/MM/yyyy}",
                "Transferencia", Fmt(t.Monto), true,
                t.ComprobanteImagenPath ?? "No se eligió ningún archivo",
                IsV($"t{t.Id}"), t.ComprobanteImagenPath is not null,
                t.ComprobanteImagenPath is not null ? $"/api/contabilidad/transferencia/{t.Id}/comprobante" : null);
        }

        // Check compras (flattened)
        var c = _periodo.Transferencias.SelectMany(x => x.Compras).FirstOrDefault(x => x.Id == _selectedId);
        if (c is not null)
        {
            return new("Compra", "bi-receipt", "Foto boleta",
                (c.ProveedorCanonical ?? c.Proveedor).ToUpperInvariant(), "Nº documento", c.NumeroDocumento ?? "—", "Fecha", $"{c.FechaCompra:dd/MM/yyyy}",
                c.TipoFactura, Fmt(-c.MontoTotal), false,
                c.FacturaImagenPath ?? "No se eligió ningún archivo",
                IsV($"c{c.Id}"), c.FacturaImagenPath is not null,
                c.FacturaImagenPath is not null ? $"/api/compras/{c.Id}/factura" : null,
                c.Id, c.ProveedorCanonical, c.ProveedorCatalogId, c.Proveedor);
        }

        // Check gastos
        var g = _periodo.Gastos.FirstOrDefault(x => x.Id == _selectedId);
        if (g is not null)
        {
            return new("Gasto", "bi-receipt", "Foto boleta",
                g.Descripcion.ToUpperInvariant(), "Tipo", g.Categoria, "Fecha", $"{g.Fecha:dd/MM/yyyy}",
                g.Categoria, Fmt(-g.Monto), false,
                g.ImagenPath ?? "No se eligió ningún archivo",
                IsV($"g{g.Id}"), g.ImagenPath is not null, null);
        }

        return new("—", "bi-image", "Sin datos", "—", "—", "—", "—", "—", "—", "$0", false, "—", false, false, null);
    }

    // ── Lifecycle ─────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        _loadCts = new CancellationTokenSource();
        await CargarPeriodos(_loadCts.Token);
    }

    private async Task CargarPeriodos(CancellationToken ct, int? selectId = null)
    {
        _loading = true;
        _error = null;
        StateHasChanged();

        try
        {
            var data = await Http.GetFromJsonAsync<List<AccountingPeriodDto>>("api/contabilidad/periodos", ct);
            if (data is not null && data.Count > 0)
            {
                _periodos = data.Select(p => new PeriodoOpcion(
                    p.Id,
                    $"{p.Trabajador} · {p.FechaInicio:dd/MM} – {p.FechaFin:dd/MM}"
                )).ToList();
                _selectedPeriodoId = selectId is not null && data.Any(p => p.Id == selectId)
                    ? selectId.Value
                    : data[0].Id;
                await CargarPeriodoDetalle(_selectedPeriodoId, ct);
            }
        }
        catch (OperationCanceledException) { }
        catch (Exception)
        {
            _error = "Error al cargar períodos del servidor.";
        }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task CargarPeriodoDetalle(int id, CancellationToken ct)
    {
        try
        {
            _periodo = await Http.GetFromJsonAsync<AccountingPeriodFullDto>($"api/contabilidad/periodos/{id}", ct);
            if (_periodo is not null)
            {
                // Initialize verified state from DTO
                _verified.Clear();
                foreach (var t in _periodo.Transferencias)
                {
                    _verified[$"t{t.Id}"] = t.Verificada;
                    foreach (var c in t.Compras)
                        _verified[$"c{c.Id}"] = c.Verificada;
                }
                // Select first row
                var firstT = _periodo.Transferencias.FirstOrDefault();
                _selectedId = firstT?.Id ?? 0;
            }
        }
        catch (OperationCanceledException) { }
        catch (Exception)
        {
            _error = "Error al cargar el detalle del período.";
        }
    }

    private async Task OnPeriodoChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var id))
        {
            _selectedPeriodoId = id;
            _loadCts?.Cancel();
            _loadCts = new CancellationTokenSource();
            var ct = _loadCts.Token;
            try
            {
                await Task.Delay(300, ct);
                _loading = true;
                await InvokeAsync(StateHasChanged);
                await CargarPeriodoDetalle(id, ct);
            }
            catch (OperationCanceledException) { }
            finally
            {
                _loading = false;
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    // ── Acciones de verificación ───────────────────────────────────────────────
    private async Task VerifyAndNext()
    {
        if (_periodo is null) return;

        var (kind, id) = ResolveSelectedKind();
        if (kind is null) return;

        var key = $"{kind[0]}{id}";
        var before = _verified.GetValueOrDefault(key);
        _verified[key] = true;
        _error = null;
        StateHasChanged();

        try
        {
            var url = kind == "transferencia"
                ? $"api/contabilidad/transferencia/{id}/verificar"
                : $"api/contabilidad/compra/{id}/verificar";
            var resp = await Http.PostAsync(url, null);
            if (!resp.IsSuccessStatusCode)
            {
                _verified[key] = before;
                _error = resp.StatusCode == System.Net.HttpStatusCode.Conflict
                    ? "Otro usuario modificó esta transferencia. Recargá la página."
                    : $"Error al verificar ({(int)resp.StatusCode}).";
            }
            else
            {
                AutoAdvance();
            }
        }
        catch (Exception)
        {
            _verified[key] = before;
            _error = "Error de red al verificar.";
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task Unverify()
    {
        if (_periodo is null) return;

        var (kind, id) = ResolveSelectedKind();
        if (kind is null) return;

        var key = $"{kind[0]}{id}";
        var before = _verified.GetValueOrDefault(key);
        _verified[key] = false;
        _error = null;
        StateHasChanged();

        try
        {
            var url = kind == "transferencia"
                ? $"api/contabilidad/transferencia/{id}/desverificar"
                : $"api/contabilidad/compra/{id}/desverificar";
            var resp = await Http.PostAsync(url, null);
            if (!resp.IsSuccessStatusCode)
            {
                _verified[key] = before;
                _error = resp.StatusCode == System.Net.HttpStatusCode.Conflict
                    ? "Otro usuario modificó esta transferencia. Recargá la página."
                    : $"Error al quitar verificación ({(int)resp.StatusCode}).";
            }
        }
        catch (Exception)
        {
            _verified[key] = before;
            _error = "Error de red al quitar verificación.";
        }

        await InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Uploads the selected file as the comprobante/factura image of the currently
    /// selected document. Transferencia → contabilidad comprobante endpoint;
    /// Compra → compras factura endpoint. Gasto has no upload endpoint.
    /// </summary>
    private async Task OnComprobanteSelected(InputFileChangeEventArgs e)
    {
        if (e.FileCount == 0) return;

        var (kind, id) = ResolveSelectedKind();
        if (kind != "transferencia" && kind != "compra") return;

        var file = e.File;
        _comprobanteError = null;
        _uploadingComprobante = true;
        StateHasChanged();

        try
        {
            using var content = new MultipartFormDataContent();
            var stream = file.OpenReadStream(10 * 1024 * 1024);
            var fileContent = new StreamContent(stream);
            fileContent.Headers.ContentType =
                new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);
            content.Add(fileContent, "file", file.Name);

            var url = kind == "transferencia"
                ? $"api/contabilidad/transferencia/{id}/comprobante"
                : $"api/compras/{id}/factura";

            var resp = await Http.PostAsync(url, content);
            if (!resp.IsSuccessStatusCode)
                _comprobanteError = $"Error al subir el comprobante ({(int)resp.StatusCode}).";
            else
                await CargarPeriodos(CancellationToken.None, selectId: _periodo?.Id);
        }
        catch (Exception)
        {
            _comprobanteError = "Error de red al subir el comprobante.";
        }

        _uploadingComprobante = false;
        await InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Unlinks the selected Compra from its Transferencia (sets TransferenciaId = null)
    /// without deleting the Compra from the database. Only applies to compras.
    /// </summary>
    private async Task DesvincularBoleta()
    {
        var (kind, id) = ResolveSelectedKind();
        if (kind != "compra") return;

        _error = null;
        try
        {
            var resp = await Http.DeleteAsync($"api/compras/{id}/transferencia");
            if (!resp.IsSuccessStatusCode)
                _error = $"Error al desvincular la boleta ({(int)resp.StatusCode}).";
            else
                await CargarPeriodos(CancellationToken.None, selectId: _periodo?.Id);
        }
        catch (Exception)
        {
            _error = "Error de red al desvincular la boleta.";
        }

        await InvokeAsync(StateHasChanged);
    }

    private void SelectRow(int id)
    {
        _selectedId = id;
        _reasignarOpen = false; // cerrar el editor de proveedor al cambiar de documento
    }

    // ── Reasignar proveedor (inline) ──────────────────────────────────────────
    private async Task AbrirReasignar()
    {
        _reasignarError = null;
        _reasignarNuevoNombre = string.Empty;
        var compra = _periodo?.Transferencias.SelectMany(t => t.Compras).FirstOrDefault(x => x.Id == _selectedId);
        _reasignarCatalogId = compra?.ProveedorCatalogId ?? 0;
        _reasignarOpen = true;

        if (!_proveedores.Any())
        {
            try
            {
                _proveedores = await Http.GetFromJsonAsync<List<ProveedorCatalogDto>>("api/proveedores") ?? new();
            }
            catch (Exception)
            {
                _reasignarError = "Error al cargar proveedores.";
            }
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task ConfirmarReasignar()
    {
        var compra = _periodo?.Transferencias.SelectMany(t => t.Compras).FirstOrDefault(x => x.Id == _selectedId);
        if (compra is null) return;

        ReasignarProveedorRequestDto request;
        if (_reasignarCatalogId == -1)
        {
            if (string.IsNullOrWhiteSpace(_reasignarNuevoNombre))
            {
                _reasignarError = "Ingresá el nombre del nuevo proveedor.";
                return;
            }
            request = new ReasignarProveedorRequestDto { NuevoNombreCanonical = _reasignarNuevoNombre.Trim() };
        }
        else if (_reasignarCatalogId > 0)
        {
            request = new ReasignarProveedorRequestDto { ProveedorCatalogId = _reasignarCatalogId };
        }
        else
        {
            _reasignarError = "Elegí un proveedor o creá uno nuevo.";
            return;
        }

        _reasignando = true;
        _reasignarError = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            var resp = await Http.PostAsJsonAsync($"api/compras/{compra.Id}/proveedor", request);
            if (resp.IsSuccessStatusCode)
            {
                _reasignarOpen = false;
                _proveedores.Clear(); // recargar la próxima vez (puede haberse creado uno nuevo)
                _loadCts ??= new CancellationTokenSource();
                await CargarPeriodoDetalle(_selectedPeriodoId, _loadCts.Token);
            }
            else if ((int)resp.StatusCode == 404)
            {
                _reasignarError = "La compra ya no existe.";
            }
            else
            {
                _reasignarError = "No se pudo reasignar el proveedor.";
            }
        }
        catch (Exception)
        {
            _reasignarError = "Error de red al reasignar.";
        }
        finally
        {
            _reasignando = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private (string? kind, int id) ResolveSelectedKind()
    {
        if (_periodo is null) return (null, 0);

        if (_periodo.Transferencias.Any(t => t.Id == _selectedId))
            return ("transferencia", _selectedId);

        if (_periodo.Transferencias.SelectMany(t => t.Compras).Any(c => c.Id == _selectedId))
            return ("compra", _selectedId);

        if (_periodo.Gastos.Any(g => g.Id == _selectedId))
            return ("gasto", _selectedId);

        return (null, 0);
    }

    private void AutoAdvance()
    {
        if (_periodo is null) return;

        // Find next unverified transferencia
        var nextT = _periodo.Transferencias
            .Where(t => !IsV($"t{t.Id}"))
            .OrderBy(t => t.Id)
            .FirstOrDefault();
        if (nextT is not null)
        {
            _selectedId = nextT.Id;
            return;
        }

        // Then next unverified compra
        var nextC = _periodo.Transferencias
            .SelectMany(t => t.Compras)
            .Where(c => !IsV($"c{c.Id}"))
            .OrderBy(c => c.Id)
            .FirstOrDefault();
        if (nextC is not null)
        {
            _selectedId = nextC.Id;
            return;
        }

        // Then next unverified gasto
        var nextG = _periodo.Gastos
            .Where(g => !IsV($"g{g.Id}"))
            .OrderBy(g => g.Id)
            .FirstOrDefault();
        if (nextG is not null)
        {
            _selectedId = nextG.Id;
        }
    }

    // ── Devolución ────────────────────────────────────────────────────────────
    private async Task ConfirmarDevolucion()
    {
        if (_periodo is null) return;

        _error = null;
        try
        {
            var request = new RegistrarDevolucionRequest
            {
                PeriodoId = _periodo.Id,
                Trabajador = _periodo.Trabajador ?? string.Empty,
                Monto = _periodo.Diferencia,
                Fecha = DateTime.Today
            };
            var resp = await Http.PostAsJsonAsync("api/contabilidad/devolucion", request);
            if (resp.IsSuccessStatusCode)
            {
                _modalOpen = false;
                _successMessage = "Devolución registrada exitosamente.";
                await CargarPeriodoDetalle(_periodo.Id, CancellationToken.None);
            }
            else
            {
                var body = await resp.Content.ReadAsStringAsync();
                _error = $"Error al registrar devolución: {body}";
            }
        }
        catch (Exception)
        {
            _error = "Error de red al registrar devolución.";
        }

        await InvokeAsync(StateHasChanged);
    }

    // ── Eliminar transferencia ────────────────────────────────────────────────
    private void CancelarEliminarTransferencia()
    {
        _eliminarModalOpen = false;
        _eliminarConfirmName = string.Empty;
        _eliminarError = null;
    }

    private async Task ConfirmarEliminarTransferencia()
    {
        if (_periodo is null || _periodo.Transferencias.Count == 0) return;

        var transf = _periodo.Transferencias[0];
        _eliminarError = null;
        try
        {
            var resp = await Http.DeleteAsync($"api/contabilidad/transferencia/{transf.Id}");
            if (resp.IsSuccessStatusCode)
            {
                _eliminarModalOpen = false;
                _eliminarConfirmName = string.Empty;
                _successMessage = "Transferencia eliminada exitosamente.";
                _selectedId = 0;
                await CargarPeriodos(CancellationToken.None);
                if (_periodos.Count > 0)
                {
                    await CargarPeriodoDetalle(_periodos[0].Id, CancellationToken.None);
                }
                else
                {
                    _periodo = null;
                }
            }
            else
            {
                var body = await resp.Content.ReadAsStringAsync();
                _eliminarError = $"Error al eliminar transferencia: {body}";
            }
        }
        catch (Exception)
        {
            _eliminarError = "Error de red al eliminar transferencia.";
        }

        await InvokeAsync(StateHasChanged);
    }
    private void OnTransfFotoSelected(InputFileChangeEventArgs e)
    {
        _transfFoto = e.FileCount > 0 ? e.File : null;
    }

    /// <summary>
    /// Crea un cuadre nuevo (período + transferencia 1:1) y, si hay foto, sube el
    /// comprobante. Cada transferencia es su propia hoja seleccionable en el header.
    /// </summary>
    private async Task CrearCuadre()
    {
        if (_transfMonto <= 0)
        {
            _transfError = "El monto debe ser mayor a cero.";
            return;
        }

        _transfError = null;
        try
        {
            var request = new CrearCuadreRequest
            {
                Trabajador = _transfTrabajador,
                Monto = _transfMonto,
                Fecha = _transfFecha
            };
            var resp = await Http.PostAsJsonAsync("api/contabilidad/cuadre", request);
            if (!resp.IsSuccessStatusCode)
            {
                var body = await resp.Content.ReadAsStringAsync();
                _transfError = $"Error: {body}";
                await InvokeAsync(StateHasChanged);
                return;
            }

            var created = await resp.Content.ReadFromJsonAsync<CuadreCreadoDto>();
            if (created is not null && _transfFoto is not null)
            {
                using var content = new MultipartFormDataContent();
                var stream = _transfFoto.OpenReadStream(10 * 1024 * 1024);
                var fileContent = new StreamContent(stream);
                fileContent.Headers.ContentType =
                    new System.Net.Http.Headers.MediaTypeHeaderValue(_transfFoto.ContentType);
                content.Add(fileContent, "file", _transfFoto.Name);
                await Http.PostAsync(
                    $"api/contabilidad/transferencia/{created.TransferenciaId}/comprobante", content);
            }

            _showTransfModal = false;
            _transfMonto = 0;
            _transfMontoText = string.Empty;
            _transfTrabajador = string.Empty;
            _transfFecha = DateTime.Today;
            _transfFoto = null;
            await CargarPeriodos(CancellationToken.None, selectId: created?.PeriodoId);
        }
        catch (Exception)
        {
            _transfError = "Error de red al crear la transferencia.";
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task AbrirCompraModal()
    {
        _compraTab = "vincular";
        _compraError = null;
        _boletaBusqueda = string.Empty;
        _boletaDesde = null;
        _boletaHasta = null;
        _showCompraModal = true;
        await CargarBoletasSinVincular();
    }

    /// <summary>
    /// Triggered by any of the search inputs (text, desde, hasta) after a debounce.
    /// Cancels the in-flight request and schedules a fresh one 300ms later.
    /// </summary>
    private async Task OnBoletaFiltroChanged()
    {
        _boletaFiltroCts?.Cancel();
        _boletaFiltroCts = new CancellationTokenSource();
        var token = _boletaFiltroCts.Token;
        try
        {
            await Task.Delay(300, token);
        }
        catch (TaskCanceledException)
        {
            return;
        }
        await CargarBoletasSinVincular();
    }

    private void LimpiarFiltrosFecha()
    {
        _boletaDesde = null;
        _boletaHasta = null;
        _ = OnBoletaFiltroChanged();
    }

    private async Task CargarBoletasSinVincular()
    {
        _compraError = null;
        _cargandoBoletas = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            var qs = new List<string>();
            if (!string.IsNullOrWhiteSpace(_boletaBusqueda))
            {
                qs.Add($"proveedor={Uri.EscapeDataString(_boletaBusqueda)}");
                qs.Add($"numeroDocumento={Uri.EscapeDataString(_boletaBusqueda)}");
            }
            if (_boletaDesde.HasValue)
                qs.Add($"desde={_boletaDesde.Value:yyyy-MM-dd}");
            if (_boletaHasta.HasValue)
                qs.Add($"hasta={_boletaHasta.Value:yyyy-MM-dd}");

            var url = "api/rendicion/compras-no-vinculadas" + (qs.Count > 0 ? "?" + string.Join("&", qs) : "");
            var data = await Http.GetFromJsonAsync<List<CompraDto>>(url);
            _boletasSinVincular = data ?? new();
        }
        catch (Exception)
        {
            _boletasSinVincular = new();
            _compraError = "Error al cargar las boletas sin vincular.";
        }
        _cargandoBoletas = false;
        await InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Links an already-registered boleta to the current period's transferencia and
    /// refreshes both the pending list and the period detail. Keeps the modal open so
    /// the user can link several in a row.
    /// </summary>
    private async Task VincularBoleta(int compraId)
    {
        if (_periodo is null) return;

        _compraError = null;
        try
        {
            var transf = _periodo.Transferencias.First();
            var resp = await Http.PostAsync(
                $"api/contabilidad/transferencia/{transf.Id}/vincular-compra/{compraId}", null);
            if (resp.IsSuccessStatusCode)
            {
                await CargarPeriodoDetalle(_periodo.Id, CancellationToken.None);
                await CargarBoletasSinVincular();
            }
            else
            {
                var body = await resp.Content.ReadAsStringAsync();
                _compraError = $"Error: {body}";
            }
        }
        catch (Exception)
        {
            _compraError = "Error de red al vincular la boleta.";
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task CrearCompra()
    {
        if (_periodo is null || _compraMonto <= 0 || string.IsNullOrWhiteSpace(_compraProveedor))
        {
            _compraError = "Proveedor y monto son obligatorios.";
            return;
        }

        _compraError = null;
        try
        {
            var primeraTransf = _periodo.Transferencias.First();
            var request = new CompraVinculadaRequest
            {
                TransferenciaId = primeraTransf.Id,
                RendicionId = primeraTransf.RendicionId ?? 0,
                Trabajador = _periodo.Trabajador ?? string.Empty,
                Proveedor = _compraProveedor,
                Detalles =
                [
                    new()
                    {
                        Cantidad = 1,
                        CostoUnitario = _compraMonto
                    }
                ]
            };
            var resp = await Http.PostAsJsonAsync("api/contabilidad/compra-vinculada", request);
            if (resp.IsSuccessStatusCode)
            {
                _showCompraModal = false;
                _compraProveedor = string.Empty;
                _compraMonto = 0;
                _compraMontoText = string.Empty;
                await CargarPeriodoDetalle(_periodo.Id, CancellationToken.None);
            }
            else
            {
                var body = await resp.Content.ReadAsStringAsync();
                _compraError = $"Error: {body}";
            }
        }
        catch (Exception)
        {
            _compraError = "Error de red al crear compra.";
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task CrearGasto()
    {
        if (_periodo is null || _gastoMonto <= 0)
        {
            _gastoError = "El monto debe ser mayor a cero.";
            return;
        }

        _gastoError = null;
        try
        {
            var request = new GastoVinculadoRequest
            {
                RendicionId = _periodo.Transferencias.FirstOrDefault()?.RendicionId ?? 0,
                Trabajador = _gastoTrabajador,
                Descripcion = _gastoDescripcion,
                Monto = _gastoMonto,
                Categoria = _gastoCategoria
            };
            var resp = await Http.PostAsJsonAsync("api/contabilidad/gasto-vinculado", request);
            if (resp.IsSuccessStatusCode)
            {
                _showGastoModal = false;
                _gastoMonto = 0;
                _gastoMontoText = string.Empty;
                _gastoTrabajador = string.Empty;
                _gastoDescripcion = string.Empty;
                _gastoCategoria = "GENERAL";
                await CargarPeriodoDetalle(_periodo.Id, CancellationToken.None);
            }
            else
            {
                var body = await resp.Content.ReadAsStringAsync();
                _gastoError = $"Error: {body}";
            }
        }
        catch (Exception)
        {
            _gastoError = "Error de red al crear gasto.";
        }

        await InvokeAsync(StateHasChanged);
    }

    // ── Comprobante download ──────────────────────────────────────────────────
    private async Task DescargarComprobante()
    {
        if (_periodo is null) return;

        var (kind, id) = ResolveSelectedKind();
        var url = kind switch
        {
            "transferencia" => $"api/contabilidad/transferencia/{id}/comprobante",
            "compra" => $"api/compras/{id}/factura",
            _ => null
        };
        if (url is null) return;

        _comprobanteError = null;
        try
        {
            var resp = await Http.GetAsync(url);
            if (resp.IsSuccessStatusCode)
            {
                var bytes = await resp.Content.ReadAsByteArrayAsync();
                var contentType = resp.Content.Headers.ContentType?.MediaType ?? "application/octet-stream";
                var ext = contentType switch
                {
                    "application/pdf" => ".pdf",
                    "image/jpeg" => ".jpg",
                    "image/png" => ".png",
                    _ => ".bin"
                };
                var prefix = kind == "compra" ? "boleta" : "comprobante";
                await JS.InvokeVoidAsync("descargarArchivo", bytes, $"{prefix}_{id}{ext}", contentType);
            }
            else
            {
                _comprobanteError = "No se encontró el comprobante para este documento.";
            }
        }
        catch (Exception)
        {
            _comprobanteError = "Error al descargar el comprobante.";
        }

        await InvokeAsync(StateHasChanged);
    }

    // ── IDisposable ───────────────────────────────────────────────────────────
    public void Dispose()
    {
        _loadCts?.Cancel();
        _loadCts?.Dispose();
        _boletaFiltroCts?.Cancel();
        _boletaFiltroCts?.Dispose();
    }
