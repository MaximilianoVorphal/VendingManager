@page "/test-timeline"
@using Microsoft.AspNetCore.Authorization
@using VendingManager.Shared.Constants
@attribute [Authorize(Roles = Roles.Admin)]
@inject HttpClient Http

<PageTitle>Test Timeline Templates</PageTitle>

<div class="container-fluid px-4 mt-4" style="font-family: 'Segoe UI', Consolas, monospace;">
    
    <!-- HEADER -->
    <div class="row align-items-center mb-4 border-bottom border-3 border-dark pb-3">
        <div class="col-12">
            <h2 class="m-0 fw-bold text-uppercase" style="letter-spacing: -1px; color: #333;">
                <i class="bi bi-bar-chart-steps me-2"></i>TIMELINE DE COBERTURA DE TEMPLATES
            </h2>
            <small class="text-muted fw-bold">TEST DASHBOARD / IDENTIFICA GAPS DE RELOAD Y VENTAS HUÉRFANAS</small>
        </div>
    </div>

    @if (Cargando)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status"></div>
            <p class="mt-3 fw-bold text-uppercase" style="letter-spacing: 2px;">Analizando histórico de templates...</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(MensajeError))
    {
        <div class="alert alert-danger fw-bold border-2 border-danger rounded-0 shadow-sm">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @MensajeError
        </div>
    }
    else if (LineasTiempo.Any())
    {
        <div class="card shadow-sm border-dark border-2 rounded-0 mb-5 bg-white">
            <div class="card-header bg-dark text-white rounded-0 border-bottom border-dark d-flex justify-content-between align-items-center py-2">
                <span class="fw-bold fs-6 text-uppercase">
                    <i class="bi bi-clock-history me-2"></i> VISUALIZACIÓN CRONOLÓGICA (@GlobalStart.ToString("dd MMM yyyy") HASTA @GlobalEnd.ToString("dd MMM yyyy"))
                </span>
                <span class="badge bg-danger rounded-0 px-2 py-1 fw-bold text-uppercase border border-light">
                    <i class="bi bi-exclamation-triangle-fill me-1"></i> ZONAS ROJAS = VENTAS SIN TEMPLATE
                </span>
            </div>
            
            <div class="card-body p-4 position-relative overflow-hidden bg-light">
                <!-- RULER SUPERIOR (Meses aproximados) -->
                <div class="timeline-ruler mb-4 border-bottom border-dark position-relative pb-2" style="height: 30px;">
                    @foreach (var tick in TicksMeses)
                    {
                        <div class="ruler-tick text-center position-absolute text-dark fw-bold" 
                             style="left: @(tick.Percentage.ToString(System.Globalization.CultureInfo.InvariantCulture))%; transform: translateX(-50%); font-size: 0.8rem;">
                            <div class="tick-line bg-dark mb-1" style="height:8px; width:2px; margin: 0 auto;"></div>
                            @tick.Label
                        </div>
                    }
                </div>

                <!-- LINEAS POR MAQUINA -->
                <div class="timeline-container d-flex flex-column gap-3">
                    @foreach (var row in LineasTiempo)
                    {
                        <div class="machine-row w-100 d-flex align-items-center">
                            <!-- ETIQUETA MAQUINA -->
                            <div class="machine-label fw-bold text-truncate text-uppercase px-2 text-dark" style="width: 280px; font-size: 0.85rem;">
                                <i class="bi bi-geo-alt-fill me-1"></i> @row.MaquinaNombre
                            </div>
                            
                            <!-- TRACK BACKGROUND -->
                            <div class="machine-track flex-grow-1 position-relative" style="height: 45px; background-color: #e9ecef; border: 2px solid #333;">
                                @foreach (var segment in row.Segments)
                                {
                                    if (segment.IsGap)
                                    {
                                        <!-- HUECO ROJO -->
                                        <div class="timeline-segment gap-segment position-absolute h-100" 
                                             style="left: @(segment.LeftPercentage.ToString(System.Globalization.CultureInfo.InvariantCulture))%; 
                                                    width: @(segment.WidthPercentage.ToString(System.Globalization.CultureInfo.InvariantCulture))%; min-width: 10px; z-index: 5;"
                                             title="HUECO PELIGROSO: @segment.Start.ToString("dd MMM HH:mm") - @segment.End.ToString("dd MMM HH:mm")">
                                        </div>
                                    }
                                    else
                                    {
                                        <!-- TEMPLATE ESTABLE -->
                                        <div class="timeline-segment template-segment position-absolute h-100 d-flex align-items-center justify-content-center overflow-hidden px-1 border-end border-dark" 
                                             style="left: @(segment.LeftPercentage.ToString(System.Globalization.CultureInfo.InvariantCulture))%; 
                                                    width: @(segment.WidthPercentage.ToString(System.Globalization.CultureInfo.InvariantCulture))%; z-index: 2;"
                                             title="TEMPLATE: @segment.TemplateName | @segment.Start.ToString("dd MMM HH:mm") - @segment.End.ToString("dd MMM HH:mm")">
                                            <span class="text-dark fw-bold text-truncate" style="font-size: 0.75rem; background: rgba(255,255,255,0.7); padding: 0 4px;">
                                                @segment.TemplateName
                                            </span>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    }
                </div>
                
                <!-- LEYENDA -->
                <div class="mt-5 d-flex gap-4 justify-content-center pt-3 border-top border-dark">
                    <div class="d-flex align-items-center">
                        <div class="me-2" style="width:25px; height:15px; background: #198754; border: 2px solid #000;"></div>
                        <span class="text-dark fw-bold small text-uppercase">Período Cubierto por Template</span>
                    </div>
                    <div class="d-flex align-items-center">
                        <div class="gap-segment me-2 border border-dark" style="width:25px; height:15px;"></div>
                        <span class="text-dark fw-bold small text-uppercase">Brecha sin Template (Alerta)</span>
                    </div>
                </div>

            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info fw-bold border-2 border-dark rounded-0 shadow-sm text-uppercase text-center p-5 bg-white">
            <i class="bi bi-info-circle-fill display-4 d-block mb-3"></i>
            No se encontraron templates registrados o información para armar la línea de tiempo.
        </div>
    }
</div>

<style>
    .timeline-segment {
        transition: all 0.1s ease-in-out;
        cursor: crosshair;
        min-width: 4px;
    }
    
    .timeline-segment:hover {
        transform: scaleY(1.2);
        z-index: 20 !important;
        box-shadow: 0 4px 8px rgba(0,0,0,0.3) !important;
    }

    .template-segment {
        background: #198754; /* Bootstrap success solid */
        border-right: 2px solid #111;
        border-left: 2px solid #111;
        border-bottom: 2px solid #111;
        border-top: 2px solid #111;
    }

    /* Danger Red Diagonal Stripes for Gaps */
    .gap-segment {
        background: repeating-linear-gradient(
            45deg,
            #dc3545,
            #dc3545 10px,
            #b02a37 10px,
            #b02a37 20px
        );
        border: 2px solid #000;
    }
    
    .machine-row:hover .machine-label {
        color: #0d6efd !important;
    }
</style>

@code {
    private bool Cargando = true;
    private string MensajeError = "";

    // Boundaries Visuales
    private DateTime GlobalStart;
    private DateTime GlobalEnd;
    private double TotalSeconds;

    private List<MaquinaTimelineRow> LineasTiempo = new();
    private List<RulerTick> TicksMeses = new();

    protected override async Task OnInitializedAsync()
    {
        await ProcesarTimeline();
    }

    private async Task ProcesarTimeline()
    {
        try
        {
            var templates = await Http.GetFromJsonAsync<List<TemplateData>>("api/TemplateRecarga");
            if (templates == null || !templates.Any() || !templates.SelectMany(t => t.Periodos).Any())
            {
                Cargando = false;
                return;
            }

            // 1. Aplanar todos los periodos con el nombre de su template origen
            var allPeriodosPlana = templates.SelectMany(t => t.Periodos.Select(p => new
            {
                TemplateName = t.Nombre,
                p.MaquinaId,
                p.MaquinaNombre,
                p.FechaRecarga,
                p.FechaFin
            })).ToList();

            if (!allPeriodosPlana.Any()) { Cargando = false; return; }

            // 2. Definir boundaries globales. 
            // Buscamos el inicio más antiguo y le quitamos un par de días de pad.
            // El fin será HOY + 7 días. El sentinel condicional (SYSDATETIME) 
            // asegura que los templates activos no estiren la timeline hasta 2099.
            var minDate = allPeriodosPlana.Min(p => p.FechaRecarga).Date;
            
            GlobalStart = minDate.AddDays(-3);
            GlobalEnd = DateTime.Now.Date.AddDays(7);
            TotalSeconds = (GlobalEnd - GlobalStart).TotalSeconds;

            // 3. Generar Rulerticks (Para marcar los inicios de mes en el encabezado)
            TicksMeses = GenerarTicksRuler(GlobalStart, GlobalEnd);

            // 4. Agrupar por máquina
            var dictMaquinas = allPeriodosPlana.GroupBy(x => new { x.MaquinaId, x.MaquinaNombre }).ToList();

            LineasTiempo = new();

            foreach (var maquina in dictMaquinas.OrderBy(m => m.Key.MaquinaNombre))
            {
                var row = new MaquinaTimelineRow
                {
                    MaquinaId = maquina.Key.MaquinaId,
                    MaquinaNombre = maquina.Key.MaquinaNombre,
                    Segments = new()
                };

                // Ordenar periodos cronologicamente
                var periodosOrdenados = maquina.OrderBy(p => p.FechaRecarga).ToList();
                
                DateTime cursorTime = GlobalStart;

                foreach (var per in periodosOrdenados)
                {
                    // Evitar bugs si hay basurita atras en el tiempo global (aunque global start se basa en el min)
                    if (per.FechaFin < GlobalStart) continue; 
                    
                    // ¿Hay Hueco antes del Template?
                    if (per.FechaRecarga > cursorTime)
                    {
                        var gapLength = (per.FechaRecarga - cursorTime).TotalSeconds;
                        // Evitar huecos milimétricos (menores a 1 hora)
                        if (gapLength > 3600) 
                        {
                            row.Segments.Add(CrearSegmento(cursorTime, per.FechaRecarga, true, "GAP"));
                        }
                    }

                    // Cubrimos el Template (Sanitizando limites)
                    var cStart = per.FechaRecarga < GlobalStart ? GlobalStart : per.FechaRecarga;
                    var cEnd = per.FechaFin > GlobalEnd ? GlobalEnd : per.FechaFin;
                    
                    row.Segments.Add(CrearSegmento(cStart, cEnd, false, per.TemplateName));
                    
                    cursorTime = cEnd > cursorTime ? cEnd : cursorTime;
                }

                // Finalmente verificar si el último cursor es antes que HOY
                if (cursorTime < DateTime.Now)
                {
                     // Significa que hoy por hoy la maquina esta en hueco!
                     row.Segments.Add(CrearSegmento(cursorTime, DateTime.Now, true, "GAP HAS HOY"));
                }

                LineasTiempo.Add(row);
            }
        }
        catch (Exception ex)
        {
            MensajeError = "Error al armar línea de tiempo: " + ex.Message;
        }
        finally
        {
            Cargando = false;
        }
    }

    private TimelineSegment CrearSegmento(DateTime start, DateTime end, bool isGap, string name)
    {
        var percentStart = ((start - GlobalStart).TotalSeconds / TotalSeconds) * 100;
        var percentWidth = ((end - start).TotalSeconds / TotalSeconds) * 100;
        
        // Boundaries strict clamp 0-100
        if (percentStart < 0) { percentWidth += percentStart; percentStart = 0; }
        if (percentStart + percentWidth > 100) { percentWidth = 100 - percentStart; }

        return new TimelineSegment
        {
            Start = start,
            End = end,
            IsGap = isGap,
            TemplateName = name,
            LeftPercentage = percentStart,
            WidthPercentage = Math.Max(0.1, percentWidth) // Evitar que colapse a 0 width
        };
    }

    private List<RulerTick> GenerarTicksRuler(DateTime start, DateTime end)
    {
        var ticks = new List<RulerTick>();
        // Generar un tick el primer día de cada mes intermedio
        var current = new DateTime(start.Year, start.Month, 1);
        if (current < start) current = current.AddMonths(1);

        while (current <= end)
        {
            var pct = ((current - start).TotalSeconds / TotalSeconds) * 100;
            ticks.Add(new RulerTick { Percentage = pct, Label = current.ToString("MMM yy").ToUpper() });
            current = current.AddMonths(1);
        }
        return ticks;
    }

    // CLASES LOCALES (Espejos de los DTOs)
    public class TemplateData
    {
        public string Nombre { get; set; } = string.Empty;
        public List<PeriodoData> Periodos { get; set; } = new();
    }
    public class PeriodoData
    {
        public int MaquinaId { get; set; }
        public string MaquinaNombre { get; set; } = string.Empty;
        public DateTime FechaRecarga { get; set; }
        public DateTime FechaFin { get; set; }
    }

    public class MaquinaTimelineRow
    {
        public int MaquinaId { get; set; }
        public string MaquinaNombre { get; set; } = string.Empty;
        public List<TimelineSegment> Segments { get; set; } = new();
    }

    public class TimelineSegment
    {
        public DateTime Start { get; set; }
        public DateTime End { get; set; }
        public bool IsGap { get; set; }
        public string TemplateName { get; set; } = string.Empty;
        public double LeftPercentage { get; set; }
        public double WidthPercentage { get; set; }
    }

    public class RulerTick
    {
        public double Percentage { get; set; }
        public string Label { get; set; } = string.Empty;
    }
}
