    private string MontoString
    {
        get => Nuevo.Monto == 0 ? "" : Nuevo.Monto.ToString("#,##0");
        set
        {
            if (string.IsNullOrWhiteSpace(value))
            {
                Nuevo.Monto = 0;
            }
            else
            {
                string v = value.Replace(".", "");
                if (decimal.TryParse(v, out decimal m))
                {
                    Nuevo.Monto = m;
                }
            }
        }
    }
