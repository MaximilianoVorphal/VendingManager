    private void AbrirModalNuevoGasto()
    {
        GastoEditando = new GastoRecurrenteDto { Categoria = "INTERNET" };
        GastoEditandoMaquinaId = 0;
        MostrarModalGastoFijo = true;
    }

    private void EditarGasto(GastoRecurrenteDto gasto)
    {
        GastoEditando = new GastoRecurrenteDto
        {
            Id = gasto.Id,
            Descripcion = gasto.Descripcion,
            MontoEstimado = gasto.MontoEstimado,
            Categoria = gasto.Categoria,
            MaquinaId = gasto.MaquinaId,
            Activo = gasto.Activo
        };
        GastoEditandoMaquinaId = gasto.MaquinaId ?? 0;
        MostrarModalGastoFijo = true;
    }

    private async Task GuardarGastoFijo()
    {
        if (string.IsNullOrWhiteSpace(GastoEditando.Descripcion) || GastoEditando.MontoEstimado <= 0) return;
        
        GastoEditando.MaquinaId = GastoEditandoMaquinaId > 0 ? GastoEditandoMaquinaId : null;
        GastoEditando.Tipo = "GASTO";
        GastoEditando.Activo = true;

        try
        {
            if (GastoEditando.Id > 0)
            {
                await Http.PutAsJsonAsync($"api/GastoRecurrente/{GastoEditando.Id}", GastoEditando);
            }
            else
            {
                await Http.PostAsJsonAsync("api/GastoRecurrente", GastoEditando);
            }
            MostrarModalGastoFijo = false;
            await CargarGastosRecurrentes();
            await CargarGastosPendientes();
        }
        catch (Exception ex) { Console.WriteLine($"Error: {ex.Message}"); }
    }

    private async Task DesactivarGasto(int id)
    {
        try
        {
            await Http.DeleteAsync($"api/GastoRecurrente/{id}");
            await CargarGastosRecurrentes();
            await CargarGastosPendientes();
        }
        catch { }
    }

    private void MostrarModalAplicar()
    {
        MontosReales = new Dictionary<int, decimal>();
        if (GastosPendientes != null)
        {
            foreach (var p in GastosPendientes)
            {
                MontosReales[p.GastoRecurrenteId] = 0; // 0 = usar estimado
            }
        }
        MostrarModalAplicarGastos = true;
    }

    private async Task AplicarTodosGastos()
    {
        AplicandoGastos = true;
        try
        {
            var request = new AplicarTodosRequest
            {
                Month = SelectedDate.Month,
                Year = SelectedDate.Year,
                MontosPersonalizados = MontosReales
                    .Where(kv => kv.Value > 0)
                    .Select(kv => new MontoPersonalizadoDto { GastoRecurrenteId = kv.Key, MontoReal = kv.Value })
                    .ToList()
            };
            await Http.PostAsJsonAsync("api/GastoRecurrente/aplicar-todos", request);
            MostrarModalAplicarGastos = false;
            await CargarDatos();
        }
        catch (Exception ex) { Console.WriteLine($"Error: {ex.Message}"); }
        finally { AplicandoGastos = false; }
    }

