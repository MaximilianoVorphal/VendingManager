                                        </td>
                                        <td class="text-end fw-bold font-monospace">$@p.MontoEstimado.ToString("N0")</td>
                                        <td class="text-center">
                                            <input type="number" class="form-control form-control-sm border-dark rounded-0 text-center fw-bold"
