@page "/caja-legacy"
@using System.Net.Http.Headers
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using VendingManager.Shared.DTOs
@using VendingManager.Web.Components.Mobile
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>CAJA</PageTitle>

<MobileShell>

    <div class="industrial-wrapper container-fluid px-4 mt-4" style="overflow: hidden;">

    <div class="row align-items-center mb-4 border-bottom border-3 border-dark pb-3 industrial-page-header">
        <div class="col-12 d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <h2 class="m-0 fw-bold text-uppercase" style="letter-spacing: -1px;">CONTROL DE CAJA</h2>
                <small class="text-muted fw-bold">FLUJO DE CAJA Y RENTABILIDAD</small>
            </div>

            <!-- MONTH SELECTOR -->
            <div class="d-flex align-items-center gap-2 flex-wrap justify-content-end">
                <button class="industrial-btn industrial-btn--dark industrial-btn--sm" @onclick="() => ChangeMonth(-1)">◀</button>
                <div class="bg-dark text-white px-3 py-2 fw-bold text-uppercase text-center" style="min-width: 180px; font-family: var(--industrial-font-primary);">
                    @SelectedDate.ToString("MMMM yyyy")
                </div>
                <button class="industrial-btn industrial-btn--dark industrial-btn--sm" @onclick="() => ChangeMonth(1)">▶</button>
                <button class="industrial-btn industrial-btn--outline industrial-btn--sm" @onclick="GoToToday" title="Ir a Hoy">Hoy</button>
                <a href="api/caja/exportar?month=@SelectedDate.Month&year=@SelectedDate.Year" target="_blank" class="industrial-btn industrial-btn--sm" style="background-color: #198754; color: white;">
                    📊 EXPORTAR
                </a>
            </div>
        </div>
    </div>

    <!-- LOCK WARNING -->
    @if (Resumen?.IsLocked == true)
    {
        <div class="alert alert-warning border-dark rounded-0 fw-bold d-flex align-items-center gap-2 mb-4">
            🔒 ESTE MES ESTÁ CERRADO. NO SE PUEDEN AGREGAR NUEVOS MOVIMIENTOS.
        </div>
    }

    <!-- MENSAJE DE ERROR -->
    @if (!string.IsNullOrEmpty(ErrorCarga))
    {
        <div class="alert alert-danger border-dark rounded-0 fw-bold mb-4 shadow-sm">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @ErrorCarga
        </div>
    }

    <!-- RESUMEN DE KPI -->
    @if (Resumen != null)
    {
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <VmKpiCard Header="VENTAS DEL MES" Caption="Ingresos por operación" Value="@($"${Resumen.IngresosVentas:N0}")" ValueColor="var(--signal-success)" />
            </div>
            <div class="col-md-3">
                <VmKpiCard Header="GASTOS TOTALES" Caption="Bencina, Peajes, Mantención" Value="@($"-${Resumen.GastosOperativos:N0}")" ValueColor="var(--signal-danger)" />
            </div>
            <div class="col-md-3">
                <VmKpiCard Header="APORTES / INYECCIONES" Caption="Capital ingresado externo" Value="@($"${Resumen.AportesExtra:N0}")" ValueColor="#0d6efd" />
            </div>
            <div class="col-md-3">
                <VmKpiCard Header="DISPONIBLE EN CAJA" Caption="Total Real (Incluye Histórico)" Value="@($"${Resumen.SaldoFinal:N0}")" ValueColor="var(--ink-900)" />
            </div>
        </div>
    }
    else
    {
        <div class="row g-3 mb-4">
            @for (int i = 0; i < 4; i++)
            {
                <div class="col-md-3">
                    <div class="industrial-card p-3 h-100 d-flex flex-column align-items-center justify-content-center">
                        <div class="spinner-border text-dark mb-3" role="status"></div>
                        <div class="placeholder-glow w-100">
                            <span class="placeholder col-8 mb-2" style="height: 12px;"></span>
                            <span class="placeholder col-5 mb-2" style="height: 28px;"></span>
                            <span class="placeholder col-6" style="height: 10px;"></span>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    @* ====== FILA DE ACCIONES ====== *@
    <div class="d-flex gap-2 mb-4 flex-wrap align-items-center">
        <VmButton Variant="dark" Icon="bi-plus-lg" OnClick="AbrirModalRegistro" Disabled="@(Resumen?.IsLocked == true)">NUEVO MOVIMIENTO</VmButton>
        <VmButton Variant="outline" Icon="bi-gear-fill" OnClick="AbrirModalGastosFijos">GASTOS FIJOS</VmButton>
        @if (GastosPendientes != null && GastosPendientes.Any())
        {
            <VmButton Variant="warning" Icon="bi-lightning-fill" OnClick="MostrarModalAplicar">APLICAR PENDIENTES</VmButton>
        }
        <AuthorizeView Roles="Admin">
            <VmButton Variant="outline" Icon="bi-graph-up-arrow" OnClick="AbrirModalResultados">ESTADO DE RESULTADOS</VmButton>
        </AuthorizeView>
    </div>

    @* ====== BANNER GASTOS RECURRENTES PENDIENTES ====== *@
    @if (GastosPendientes != null && GastosPendientes.Any())
    {
        <div class="border border-2 border-warning bg-warning-subtle p-3 mb-4 shadow-sm">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div class="d-flex align-items-center gap-2">
                    <span class="bg-warning text-dark px-2 py-1 fw-bold small rounded-0">⚡ PENDIENTES</span>
                    <span class="fw-bold text-uppercase">@GastosPendientes.Count gasto(s) fijo(s) sin registrar este mes</span>
                </div>
                <div class="d-flex gap-2">
                    <button class="industrial-btn industrial-btn--outline industrial-btn--sm" @onclick="MostrarModalAplicar">
                        <i class="bi bi-check2-all me-1"></i>REVISAR Y APLICAR
                    </button>
                </div>
            </div>
            <div class="mt-2">
                @foreach (var p in GastosPendientes)
                {
                    <span class="badge bg-dark rounded-0 me-1 mb-1 py-1 px-2">
                        @p.Descripcion — $@p.MontoEstimado.ToString("N0")
                        @if (p.MaquinaNombre != null) { <small class="text-warning-subtle"> (@p.MaquinaNombre)</small> }
                    </span>
                }
            </div>
        </div>
    }

    <div class="row g-3">
        <!-- LISTA AGRUPADA -->
        <div class="col-12">
            <div class="card border-2 border-dark rounded-0 h-100">
                <div class="card-header bg-white text-dark rounded-0 fw-bold border-bottom border-dark d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <span>MOVIMIENTOS DE @SelectedDate.ToString("MMMM yyyy").ToUpper()</span>
                    <div class="form-check form-switch m-0">
                        <input class="form-check-input" type="checkbox" role="switch" id="toggleLotes" @bind="MostrarLotes">
                        <label class="form-check-label small" for="toggleLotes">Mostrar Inventario</label>
                    </div>
                </div>
                
                <div class="table-responsive bg-light caja-movements-scroll">
                    @if (Movimientos != null && Movimientos.Any())
                    {
                        @* 
                           GROUPING LOGIC:
                           1. Get Keys (OrdenCargaId or Date)
                           2. Sort by Date Descending
                         *@

                        @foreach (var grupo in GruposVisuales)
                        {
                            var isExpanded = IsGroupExpanded(grupo.Id);
                            var iconClass = isExpanded ? "bi-chevron-up" : "bi-chevron-down";
var bgHeader = grupo.EsOrdenCarga ? "bg-warning-subtle" : "bg-white";
        var borderHeader = grupo.EsOrdenCarga ? "border-warning" : "border-light";
        var textColor = grupo.EsOrdenCarga ? "text-dark" : "text-muted";

                            <div class="border-bottom border-dark bg-white mb-2 shadow-sm">
                                <!-- HEADER DEL GRUPO (CLICKABLE) -->
                                <div class="@bgHeader p-3 d-flex justify-content-between align-items-center cursor-pointer user-select-none" 
                                     role="button" @onclick="() => ToggleGroup(grupo.Id)">
                                    
                                    <div class="d-flex align-items-center gap-3">
                                        <!-- DATE BOX -->
                                        <div class="text-center bg-dark text-white p-2 rounded-0 shadow-sm" style="min-width: 60px;">
                                            <span class="d-block fw-bold small text-uppercase" style="font-size: 0.65rem;">@grupo.Fecha.ToString("MMM")</span>
                                            <span class="d-block fw-bold fs-4 lh-1">@grupo.Fecha.Day</span>
                                        </div>
                                        
                                        <div>
                                            <div class="d-flex align-items-center gap-2">
                                                <h6 class="m-0 fw-bold text-uppercase @textColor">@grupo.Titulo</h6>
                                                @if(grupo.EsOrdenCarga) { <span class="badge bg-dark rounded-0 small">⚡ ORDEN DE CARGA</span> }
                                            </div>
                                            <small class="text-muted"><i class="bi bi-list-ul me-1"></i>@grupo.Items.Count movimientos</small>
                                        </div>
                                    </div>
                                    
                                    <div class="text-end">
                                        <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 0.65rem;">TOTAL GRUPO</small>
                                        @{
                                            var totalGrupo = grupo.MontoTotal;
                                            var colorTotal = totalGrupo > 0 ? "text-success" : "text-danger";
                                        }
                                        <span class="fw-bold fs-5 @colorTotal">@totalGrupo.ToString("N0")</span>
                                        <i class="bi @iconClass ms-2 text-dark"></i>
                                    </div>
                                </div>
                                
                                <!-- CONTENIDO DEL GRUPO (COLLAPSIBLE) -->
                                @if (isExpanded)
                                {
                                    <div class="animate__animated animate__fadeIn border-top border-secondary-subtle">
                                        <table class="table table-hover table-sm m-0 border-0 vm-accordion-table">
                                            <tbody class="bg-white">
                                                @foreach (var mov in grupo.Items)
                                                {
                                                   <tr @onclick="() => AbrirModalDetalle(mov)" style="cursor: pointer;">
                                                        <td style="width: 15%;" class="ps-4 align-middle">
                                                            <small class="font-monospace text-muted">@mov.Fecha.ToString("HH:mm")</small>
                                                            @if(mov.Fecha.Date != grupo.Fecha.Date)
                                                            {
                                                                <br/><small class="text-danger fw-bold" style="font-size: 0.65rem;">(@mov.Fecha.ToString("dd/MM"))</small>
                                                            }
                                                        </td>
                                                        <td style="width: 20%;" class="align-middle">
                                                            <span class="badge rounded-0 border border-dark text-dark fw-normal
                                                            @(mov.Monto > 0 ? "bg-success-subtle" : "bg-danger-subtle")">
                                                                @mov.Categoria
                                                            </span>
                                                        </td>
                                                        <td class="align-middle">
                                                            <span class="text-uppercase small fw-bold">@mov.Descripcion</span>
                                                        </td>
                                                        <td class="text-center align-middle" style="width: 50px;">
                                                            @if (!string.IsNullOrEmpty(mov.ImagenPath))
                                                            {
                                                                bool isPdf = mov.ImagenPath.Contains(".pdf", StringComparison.OrdinalIgnoreCase);
                                                                if (isPdf)
                                                                {
                                                                    <a href="@mov.ImagenPath" target="_blank" class="text-decoration-none" title="Ver Documento PDF">📄</a>
                                                                }
                                                                else
                                                                {
                                                                    <a href="@mov.ImagenPath" target="_blank" class="text-decoration-none" title="Ver Comprobante">📷</a>
                                                                }
                                                            }
                                                        </td>
                                                        <td class="text-end fw-bold font-monospace align-middle pe-4 @(mov.Monto > 0 ? "text-success" : "text-danger")" style="width: 20%;">
                                                            $@mov.Monto.ToString("N0")
                                                        </td>
                                                   </tr> 
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                            </div>
                        }
                    }
                    else
                    {
                          <div class="alert alert-light m-3 text-center text-muted fst-italic border border-light-subtle">
                             No hay movimientos registrados en este mes.
                          </div>
                    }
                </div>
            </div>
        </div>
    </div>

    @* ====== MODAL: GASTOS FIJOS ====== *@
    @if (_gastosFijosModalOpen)
    {
        <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5); z-index: 2000;">
            <div class="modal-dialog modal-dialog-centered modal-lg">
                <div class="modal-content rounded-0 border-2 border-dark shadow-lg">
                    <div class="modal-header bg-dark text-white rounded-0">
                        <h5 class="modal-title fw-bold text-uppercase"><i class="bi bi-gear-fill me-2"></i>GASTOS FIJOS MENSUALES</h5>
                        <button type="button" class="btn-close btn-close-white" @onclick="CerrarModalGastosFijos"></button>
                    </div>
                    <div class="modal-body p-0 bg-light">
                        <VmCard Header="CONFIGURACIÓN DE GASTOS FIJOS MENSUALES" HeaderVariant="dark" BodyStyle="padding:0;">
                            @if (_showGastoFijoInlineForm)
                            {
                                <div class="p-3 border-bottom border-dark bg-light">
                                    <h6 class="fw-bold text-uppercase mb-3">NUEVO GASTO FIJO</h6>
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <VmInput Label="DESCRIPCIÓN" @bind-Value="GastoEditando.Descripcion" Placeholder="Ej: Chip Máquina M-0023" />
                                        </div>
                                        <div class="col-md-6">
                                            <VmInput Label="MONTO ESTIMADO MENSUAL ($)" Type="number" @bind-Value="GastoMontoString" />
                                        </div>
                                        <div class="col-md-6">
                                            <VmSelect Label="CATEGORÍA" @bind-Value="GastoEditando.Categoria" Options="@GastoCategoriaOptions" />
                                        </div>
                                        <div class="col-md-6">
                                            <VmSelect Label="MÁQUINA (OPCIONAL)" Value="@(GastoEditandoMaquinaId.ToString())" ValueChanged="@(v => GastoEditandoMaquinaId = int.TryParse(v, out var id) ? id : 0)" Options="@MaquinaOptions" />
                                        </div>
                                    </div>
                                    <div class="d-flex gap-2 mt-3">
                                        <VmButton Variant="outline" OnClick="CancelarInlineGasto">CANCELAR</VmButton>
                                        <VmButton Variant="dark" OnClick="GuardarNuevoGastoFijo">GUARDAR</VmButton>
                                    </div>
                                </div>
                            }
                            @if (TodosGastos != null && TodosGastos.Any())
                            {
                                <table class="table table-hover table-sm m-0 vm-accordion-table">
                                    <thead class="bg-light text-dark text-uppercase small font-monospace">
                                        <tr>
                                            <th class="ps-3">DESCRIPCIÓN</th>
                                            <th>CATEGORÍA</th>
                                            <th class="text-end">MONTO ESTIMADO</th>
                                            <th class="text-center">MÁQUINA</th>
                                            <th class="text-center">ESTADO</th>
                                            <th class="text-center pe-3">ACCIONES</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var g in TodosGastos)
                                        {
                                            <tr class="@(!g.Activo ? "text-muted bg-light" : "")">
                                                <td class="ps-3 fw-bold">@g.Descripcion</td>
                                                <td><VmBadge Variant="light">@g.Categoria</VmBadge></td>
                                                <td class="text-end fw-bold font-monospace text-danger">$@g.MontoEstimado.ToString("N0")</td>
                                                <td class="text-center small">@(g.MaquinaId.HasValue ? $"M-{g.MaquinaId}" : "—")</td>
                                                <td class="text-center">
                                                    @if (g.Activo)
                                                    {
                                                        <VmBadge Variant="success">ACTIVO</VmBadge>
                                                    }
                                                    else
                                                    {
                                                        <VmBadge Variant="light">INACTIVO</VmBadge>
                                                    }
                                                </td>
                                                <td class="text-center pe-3">
                                                    <button class="btn btn-outline-dark btn-sm rounded-0 me-1" @onclick="() => EditarGasto(g)" title="Editar">
                                                        <i class="bi bi-pencil"></i>
                                                    </button>
                                                    @if (g.Activo)
                                                    {
                                                        <button class="btn btn-outline-danger btn-sm rounded-0" @onclick="() => DesactivarGasto(g.Id)" title="Desactivar">
                                                            <i class="bi bi-x-lg"></i>
                                                        </button>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                            else
                            {
                                <div class="p-4 text-center text-muted">
                                    <p class="mb-0">No hay gastos fijos configurados. Agrega uno para recibir alertas mensuales.</p>
                                </div>
                            }
                        </VmCard>
                    </div>
                    <div class="modal-footer bg-white border-top border-dark rounded-0 d-flex justify-content-end gap-2">
                        <VmButton Variant="outline" OnClick="CerrarModalGastosFijos">CERRAR</VmButton>
                        <VmButton Variant="dark" Icon="bi-plus-lg" OnClick="MostrarFormularioNuevoGasto">AGREGAR GASTO FIJO</VmButton>
                    </div>
                </div>
            </div>
        </div>
    }

    @* ====== MODAL: ESTADO DE RESULTADOS ====== *@
    @if (_pnlModalOpen && Resumen != null)
    {
        <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5); z-index: 2000;">
            <div class="modal-dialog modal-dialog-centered modal-xl">
                <div class="modal-content rounded-0 border-2 border-dark shadow-lg">
                    <div class="modal-header bg-dark text-white rounded-0">
                        <h5 class="modal-title fw-bold text-uppercase"><i class="bi bi-graph-up-arrow me-2"></i>ESTADO DE RESULTADOS · @SelectedDate.ToString("MMMM yyyy").ToUpper()</h5>
                        <button type="button" class="btn-close btn-close-white" @onclick="CerrarModalResultados"></button>
                    </div>
                    <div class="modal-body p-4 bg-light">
                        @* KPIs *@
                        <div class="row g-3 mb-4">
                            <div class="col-md-4">
                                <VmKpiCard Header="INGRESOS" Caption="Ventas netas" Value="@($"${Resumen.IngresosVentas:N0}")" ValueColor="var(--signal-success)" />
                            </div>
                            <div class="col-md-4">
                                <VmKpiCard Header="GASTOS" Caption="Total salidas" Value="@($"-${(Resumen.GastosVariables + Resumen.GastosFijos):N0}")" ValueColor="var(--signal-danger)" />
                            </div>
                            <div class="col-md-4">
                                <VmKpiCard Header="UTILIDAD" Caption="Resultado operacional" Value="@($"${Resumen.UtilidadOperacional:N0}")" ValueColor="var(--ink-900)" />
                            </div>
                        </div>

                        @* INDICADORES DE CAPITAL *@
                        @if (Valorizacion != null)
                        {
                            <VmCard Header="INDICADORES DE CAPITAL (SNAPSHOT ACTUAL)" HeaderVariant="dark" Style="margin-bottom:1rem;">
                                <div class="row g-3">
                                    <div class="col-md-4">
                                        <div class="d-flex flex-column border-end border-dark pe-3">
                                            <small class="text-muted fw-bold text-uppercase" style="font-size: 0.7rem;">Stock en Máquinas</small>
                                            <span class="fs-5 fw-bold font-monospace text-dark">$@Valorizacion.ValorMaquinas.ToString("N0")</span>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="d-flex flex-column border-end border-dark pe-3">
                                            <small class="text-muted fw-bold text-uppercase" style="font-size: 0.7rem;">Stock en Bodega</small>
                                            <span class="fs-5 fw-bold font-monospace text-dark">$@Valorizacion.ValorBodega.ToString("N0")</span>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="d-flex flex-column bg-light p-2 border border-secondary rounded-0">
                                            <small class="text-success fw-bold text-uppercase" style="font-size: 0.7rem;">Capital Total Mercadería</small>
                                            <span class="fs-4 fw-bold font-monospace text-success">$@Valorizacion.ValorTotal.ToString("N0")</span>
                                        </div>
                                    </div>
                                </div>
                            </VmCard>
                        }

                        @* 01 — VENTAS NETAS *@
                        <VmCard Header="@($"01 — VENTAS NETAS — ${(Resumen.IngresosVentas - Resumen.Mermas):N0}")" HeaderVariant="dark" Style="margin-bottom:1rem;" OnClick="() => _isVentasExpanded = !_isVentasExpanded">
                            @if (_isVentasExpanded)
                            {
                                <div class="bg-light p-3">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <span class="text-muted fw-bold text-uppercase small">Ventas Brutas</span>
                                        <span class="fw-bold fs-6 text-dark font-monospace">$@Resumen.IngresosVentas.ToString("N0")</span>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="text-danger fw-bold text-uppercase small">(-) Mermas / Pérdidas</span>
                                        <span class="fw-bold fs-6 text-danger font-monospace">-$@Resumen.Mermas.ToString("N0")</span>
                                    </div>
                                </div>
                            }
                        </VmCard>

                        @* 02 — MARGEN BRUTO *@
                        <VmCard Header="@($"02 — MARGEN BRUTO — ${Resumen.UtilidadTotal:N0}")" HeaderVariant="secondary" Style="margin-bottom:1rem;" OnClick="() => _isCostoExpanded = !_isCostoExpanded">
                            @if (_isCostoExpanded)
                            {
                                <div class="bg-light p-3">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <div>
                                            <span class="text-muted fw-bold text-uppercase small d-block">(-) Costo de Venta</span>
                                            <small class="text-muted">Reposición de Mercadería</small>
                                        </div>
                                        <span class="fw-bold fs-5 text-danger font-monospace">-$@Resumen.TotalCostoVenta.ToString("N0")</span>
                                    </div>
                                    <div class="d-flex justify-content-end">
                                        <VmBadge Variant="dark">@GetMarginPercentage()%</VmBadge>
                                    </div>
                                </div>
                            }
                        </VmCard>

                        @* 03 — GASTOS DE OPERACIÓN *@
                        <VmCard Header="@($"03 — GASTOS OPERACIÓN — -${(Resumen.GastosVariables + Resumen.GastosFijos):N0}")" HeaderVariant="danger" Style="margin-bottom:1rem;" OnClick="() => _isGastosExpanded = !_isGastosExpanded">
                            @if (_isGastosExpanded)
                            {
                                <div class="p-3" style="background-color: rgba(220, 53, 69, 0.1);">
                                    <div class="row g-2 mb-3">
                                        <div class="col-6">
                                            <div class="bg-white border border-danger rounded-0 p-2 text-center h-100">
                                                <span class="fw-bold small text-dark text-uppercase d-block mb-1"><i class="bi bi-truck me-1"></i>Variables</span>
                                                <span class="fw-bold text-danger font-monospace fs-5">-$@Resumen.GastosVariables.ToString("N0")</span>
                                            </div>
                                        </div>
                                        <div class="col-6">
                                            <div class="bg-white border border-danger rounded-0 p-2 text-center h-100">
                                                <span class="fw-bold small text-dark text-uppercase d-block mb-1"><i class="bi bi-building me-1"></i>Fijos</span>
                                                <span class="fw-bold text-danger font-monospace fs-5">-$@Resumen.GastosFijos.ToString("N0")</span>
                                            </div>
                                        </div>
                                    </div>

                                    @if (MovimientosGastos != null && MovimientosGastos.Any())
                                    {
                                        <h6 class="fw-bold text-uppercase border-bottom border-danger pb-1 mb-2 text-danger small">Detalle de Gastos</h6>
                                        <div class="table-responsive" style="max-height: 250px;">
                                            <table class="table table-sm table-borderless small mb-0 vm-accordion-table">
                                                <tbody>
                                                    @foreach (var g in MovimientosGastos)
                                                    {
                                                        <tr class="border-bottom border-white">
                                                            <td class="text-muted">@g.Fecha.ToString("dd/MM")</td>
                                                            <td class="fw-bold text-dark">@g.Categoria</td>
                                                            <td class="text-truncate" style="max-width: 150px;" title="@g.Descripcion">@g.Descripcion</td>
                                                            <td class="text-end fw-bold text-danger font-monospace">-$@Math.Abs(g.Monto).ToString("N0")</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                                <tfoot>
                                                    @if (_descontarTransbank)
                                                    {
                                                        <tr class="bg-white border-top border-danger">
                                                            <td class="text-muted">-</td>
                                                            <td class="fw-bold text-dark">COMISIONES</td>
                                                            <td>Comisión Transbank (Estimada)</td>
                                                            <td class="text-end fw-bold text-danger font-monospace">-$@Resumen.CostoTransbank.ToString("N0")</td>
                                                        </tr>
                                                    }
                                                </tfoot>
                                            </table>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="text-center text-muted small py-2">
                                            Sin gastos operativos registrados este mes.
                                        </div>
                                    }
                                </div>
                            }
                        </VmCard>

                        @* 04 — RESULTADO FINAL *@
                        <VmCard Header="04 — RESULTADO FINAL" HeaderVariant="dark" Style="margin-bottom:1rem;" BodyStyle="padding:0;">
                            <div class="card border-0 rounded-0 bg-dark text-white">
                                <div class="card-body d-flex flex-column flex-md-row justify-content-between align-items-center p-3 p-md-4">
                                    <div class="text-center text-md-start mb-2 mb-md-0">
                                        <small class="text-white-50 fw-bold text-uppercase d-block mb-1" style="font-size: 0.7rem;">Resultado operacional</small>
                                        <h4 class="m-0 fw-bold text-uppercase">(=) UTILIDAD OPERACIONAL</h4>
                                    </div>
                                    <h2 class="m-0 fw-bold text-white font-monospace">$@Resumen.UtilidadOperacional.ToString("N0")</h2>
                                </div>
                            </div>
                        </VmCard>

                        @* TOGGLE TRANSBANK *@
                        <div class="d-flex justify-content-end align-items-center gap-2 mb-3">
                            <div class="form-check form-switch m-0">
                                <input class="form-check-input" type="checkbox" id="toggleTBModal" @bind="_descontarTransbank" style="cursor: pointer;">
                                <label class="form-check-label fw-bold user-select-none" for="toggleTBModal" style="cursor: pointer;">
                                    Descontar Comisión Transbank (@Resumen.CantidadVentasTransbank tx ≈ $@Resumen.CostoTransbank.ToString("N0"))
                                </label>
                            </div>
                        </div>

                        @* RESULTADO NETO FINAL *@
                        <VmCard Header="RESULTADO NETO FINAL" HeaderVariant="dark" BodyStyle="padding:1.5rem;text-align:center;background:var(--signal-success);color:var(--paper-0);">
                            <h1 class="display-3 fw-bold m-0 font-monospace">$@GetUtilidadNetaFinal().ToString("N0")</h1>
                            @if (_descontarTransbank)
                            {
                                <small class="text-white-50 mt-2">(Incluye descuento comisión TB)</small>
                            }
                        </VmCard>
                    </div>
                    <div class="modal-footer bg-white border-top border-dark rounded-0 d-flex justify-content-between gap-2">
                        <VmButton Variant="dark" Icon="bi-download" OnClick="ExportarResultados">EXPORTAR</VmButton>
                        <VmButton Variant="outline" OnClick="CerrarModalResultados">CERRAR</VmButton>
                    </div>
                </div>
            </div>
        </div>
    }

</div>

@* ====== MODAL: CREAR/EDITAR GASTO FIJO ====== *@
@if (MostrarModalGastoFijo)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5); z-index: 2000;">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-0 border-2 border-dark shadow-lg">
                <div class="modal-header bg-dark text-white rounded-0">
                    <h5 class="modal-title fw-bold text-uppercase"><i class="bi bi-gear me-2"></i>@(GastoEditando.Id > 0 ? "EDITAR" : "NUEVO") GASTO FIJO</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarModalGastoFijo"></button>
                </div>
                <div class="modal-body p-4 bg-light">
                    <div class="mb-3">
                        <label class="fw-bold small text-uppercase mb-1">DESCRIPCIÓN:</label>
                        <input @bind="GastoEditando.Descripcion" type="text" class="form-control border-dark rounded-0" placeholder="Ej: Chip Máquina M-0023" />
                    </div>
                    <div class="mb-3">
                        <label class="fw-bold small text-uppercase mb-1">MONTO ESTIMADO MENSUAL ($):</label>
                        <input @bind="GastoEditando.MontoEstimado" type="number" class="form-control border-dark rounded-0 fw-bold" />
                    </div>
                    <div class="mb-3">
                        <label class="fw-bold small text-uppercase mb-1">CATEGORÍA:</label>
                        <select @bind="GastoEditando.Categoria" class="form-select border-dark rounded-0">
                            <optgroup label="⛽ GASTOS VARIABLES">
                                <option value="LOGISTICA">Logística (Bencina/Fletes)</option>
                                <option value="PEAJES">Peajes / Estacionamiento</option>
                                <option value="INSUMOS">Insumos (Limpieza/Bolsas)</option>
                                <option value="MANTENCION">Mantención / Repuestos</option>
                            </optgroup>
                            <optgroup label="🏢 GASTOS FIJOS">
                                <option value="INFRA">Infraestructura (Luz/Agua/Arriendo)</option>
                                <option value="ARRIENDO_POS">Arriendo POS (Transbank)</option>
                                <option value="INTERNET">Internet (Planes/Chips)</option>
                                <option value="COMISIONES">Comisiones Bancarias</option>
                                <option value="SUELDOS">👥 Sueldos Personal</option>
                                <option value="GASTOS GENERALES">🏢 Gastos Generales</option>
                                <option value="OTROS">Otros Gastos Fijos</option>
                            </optgroup>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="fw-bold small text-uppercase mb-1">MÁQUINA (OPCIONAL):</label>
                        <select @bind="GastoEditandoMaquinaId" class="form-select border-dark rounded-0">
                            <option value="0">-- GENERAL (SIN MÁQUINA) --</option>
                            @if (ListaMaquinas != null)
                            {
                                @foreach (var m in ListaMaquinas)
                                {
                                    <option value="@m.Id">@m.Nombre</option>
                                }
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer bg-white border-top border-dark rounded-0">
                    <button class="btn btn-outline-dark rounded-0" @onclick="CerrarModalGastoFijo">CANCELAR</button>
                    <button class="btn btn-dark rounded-0 fw-bold" @onclick="GuardarGastoFijo">
                        <i class="bi bi-check-lg me-1"></i>GUARDAR
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* ====== MODAL: APLICAR GASTOS PENDIENTES ====== *@
@if (MostrarModalAplicarGastos)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5); z-index: 2000;">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content rounded-0 border-2 border-warning shadow-lg">
                <div class="modal-header bg-warning text-dark rounded-0">
                    <h5 class="modal-title fw-bold text-uppercase"><i class="bi bi-lightning-fill me-2"></i>APLICAR GASTOS FIJOS — @SelectedDate.ToString("MMMM yyyy").ToUpper()</h5>
                    <button type="button" class="btn-close" @onclick="CerrarModalAplicarGastos"></button>
                </div>
                <div class="modal-body p-0">
                    <div class="alert alert-info rounded-0 m-3 mb-0 small border-dark">
                        <i class="bi bi-info-circle me-1"></i> Puedes ajustar el monto real de cada gasto antes de registrarlo. Si dejas el monto en 0, se usará el estimado.
                    </div>
                    <table class="table table-hover m-0 align-middle vm-accordion-table">
                        <thead class="bg-light text-uppercase small fw-bold">
                            <tr>
                                <th class="ps-3">GASTO</th>
                                <th class="text-end">ESTIMADO</th>
                                <th class="text-center" style="width: 180px;">MONTO REAL ($)</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (GastosPendientes != null)
                            {
                                @foreach (var p in GastosPendientes)
                                {
                                    <tr>
                                        <td class="ps-3">
                                            <span class="fw-bold">@p.Descripcion</span>
                                            <br/><small class="text-muted">@p.Categoria @(p.MaquinaNombre != null ? $"• {p.MaquinaNombre}" : "")</small>
                                        </td>
                                        <td class="text-end fw-bold font-monospace">$@p.MontoEstimado.ToString("N0")</td>
                                        <td class="text-center">
                                            <input type="number" class="form-control form-control-sm border-dark rounded-0 text-center fw-bold"
                                                   placeholder="@p.MontoEstimado.ToString("N0")" 
                                                   @bind="MontosReales[p.GastoRecurrenteId]" />
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
                <div class="modal-footer bg-light border-top border-dark rounded-0 d-flex justify-content-between">
                    <small class="text-muted">Los montos en 0 usarán el valor estimado.</small>
                    <div class="d-flex gap-2">
                        <button class="btn btn-outline-dark rounded-0" @onclick="CerrarModalAplicarGastos">CANCELAR</button>
                        <button class="btn btn-warning rounded-0 fw-bold text-dark" @onclick="AplicarTodosGastos" disabled="@AplicandoGastos">
                            @if (AplicandoGastos)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span><span>PROCESANDO...</span>
                            }
                            else
                            {
                                <i class="bi bi-check2-all me-1"></i><span>REGISTRAR TODOS</span>
                            }
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@* ====== MODAL: REGISTRAR MOVIMIENTO ====== *@
@if (_registroModalOpen)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5); z-index: 2000;">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-0 border-2 border-dark shadow-lg">
                <div class="modal-header bg-dark text-white rounded-0">
                    <h5 class="modal-title fw-bold text-uppercase"><i class="bi bi-plus-lg me-2"></i>REGISTRAR MOVIMIENTO</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarModalRegistro"></button>
                </div>
                <div class="modal-body p-4 bg-light">
                    <div class="mb-3">
                        <VmSelect Label="TIPO DE OPERACIÓN"
                                  Value="Nuevo.Tipo"
                                  ValueChanged="SetTipo"
                                  Options="@(new[] { new VmSelect.VmSelectOption("GASTO", "🔴 GASTO"), new VmSelect.VmSelectOption("APORTE", "🔵 APORTE"), new VmSelect.VmSelectOption("RETIRO", "💸 RETIRO") })" />
                    </div>

                    <div class="mb-3">
                        <VmInput Label="FECHA DE REGISTRO" Type="date" @bind-Value="FechaRegistroString" />
                        <small class="text-muted" style="font-size: 0.7rem;">Puedes registrar gastos de días anteriores del mes actual.</small>
                    </div>

                    <div class="mb-3">
                        <VmSelect Label="CATEGORÍA" @bind-Value="Nuevo.Categoria" Options="@CategoriaOptions" />
                    </div>

                    <div class="mb-3">
                        <VmSelect Label="VINCULAR A ORDEN DE CARGA"
                                  Value="@(Nuevo.OrdenCargaId?.ToString() ?? "")"
                                  ValueChanged="@(v => Nuevo.OrdenCargaId = string.IsNullOrEmpty(v) ? null : int.Parse(v))"
                                  Options="@OrdenCargaOptions" />
                        <small class="text-muted" style="font-size: 0.7rem;">Si gastaste dinero PARA esta orden de carga (ej: Bencina), selecciónala.</small>
                    </div>

                    <div class="mb-3">
                        <VmInput Label="DESCRIPCIÓN" @bind-Value="Nuevo.Descripcion" Placeholder="Ej: COPEC, LIDER..." />
                    </div>

                    @if (Nuevo.Categoria == "MERMA")
                    {
                        <div class="mb-3 p-3 border border-dashed border-danger bg-danger-subtle">
                            <h6 class="fw-bold text-danger small"><i class="bi bi-box-seam me-1"></i> DETALLE DE MERMA (STOCK)</h6>

                            <VmSelect Label="PRODUCTO AFECTADO"
                                      Value="@(Nuevo.ProductoId?.ToString() ?? "0")"
                                      ValueChanged="@(v => Nuevo.ProductoId = string.IsNullOrEmpty(v) || v == "0" ? null : int.Parse(v))"
                                      Options="@ProductoOptions" />

                            <VmInput Label="CANTIDAD PERDIDA" Type="number" @bind-Value="CantidadString" />

                            <small class="text-danger d-block mt-1 user-select-none">* El monto se calculará automáticamente según el costo promedio del producto y se descontará del inventario.</small>
                        </div>
                    }

                    <div class="mb-3">
                        <VmInput Label="MONTO ($)" @bind-Value="MontoString" Placeholder="0" Disabled="@(Nuevo.Categoria == "MERMA")" />
                        @if(Nuevo.Categoria == "MERMA") { <small class="text-muted">Calculado Automáticamente</small> }
                    </div>

                    <div class="mb-3">
                        <label class="fw-bold small text-uppercase mb-1">ADJUNTAR COMPROBANTE (OPCIONAL):</label>
                        <InputFile OnChange="@LoadFiles" class="form-control border-dark rounded-0" accept=".jpg,.jpeg,.png,.pdf" />
                        @if (fileToUpload != null)
                        {
                            <small class="text-success fw-bold">Archivo seleccionado: @fileToUpload.Name</small>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(Mensaje))
                    {
                        <div class="mt-2 text-center small fw-bold text-success animate__animated animate__fadeIn">@Mensaje</div>
                    }
                </div>
                <div class="modal-footer bg-white border-top border-dark rounded-0 d-flex gap-2">
                    <VmButton Variant="outline" Block="true" OnClick="CerrarModalRegistro">CANCELAR</VmButton>
                    <VmButton Variant="dark" Block="true" OnClick="Registrar" Disabled="@(Resumen?.IsLocked == true || IsUploading)">
                        @if (IsUploading)
                        {
                            <span>SUBIENDO ARCHIVO...</span>
                        }
                        else
                        {
                            <span>REGISTRAR OPERACIÓN_</span>
                        }
                    </VmButton>
                </div>
            </div>
        </div>
    </div>
}

@* ====== MODAL: DETALLE DE MOVIMIENTO ====== *@
@if (_detalleModalOpen && _selectedMovement != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5); z-index: 2000;" @onclick="CerrarModalDetalle">
        <div class="modal-dialog modal-dialog-centered" @onclick:stopPropagation="true">
            <div class="modal-content rounded-0 border-2 border-dark shadow-lg">
                <div class="modal-header bg-dark text-white rounded-0">
                    <h5 class="modal-title fw-bold text-uppercase"><i class="bi bi-eye me-2"></i>DETALLE DE MOVIMIENTO</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarModalDetalle"></button>
                </div>
                <div class="modal-body p-4 bg-light">
                    <div class="text-center mb-4">
                        <span class="fw-bold font-monospace" style="font-size: 2.2rem; letter-spacing: -1px; color: @(_selectedMovement.Monto > 0 ? "var(--signal-success)" : "var(--signal-danger)")">
                            @(_selectedMovement.Monto > 0 ? $"+${_selectedMovement.Monto:N0}" : $"-${Math.Abs(_selectedMovement.Monto):N0}")
                        </span>
                    </div>

                    <VmCard Header="DATOS GENERALES" HeaderVariant="dark" Style="margin-bottom:1rem;">
                        <div class="font-monospace" style="font-size: 0.8rem;">
                            <div class="d-flex justify-content-between border-bottom border-secondary-subtle py-2">
                                <span class="text-muted fw-bold text-uppercase">Fecha</span>
                                <span>@_selectedMovement.Fecha.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                            <div class="d-flex justify-content-between border-bottom border-secondary-subtle py-2">
                                <span class="text-muted fw-bold text-uppercase">Tipo</span>
                                <span>@_selectedMovement.Tipo</span>
                            </div>
                            <div class="d-flex justify-content-between border-bottom border-secondary-subtle py-2">
                                <span class="text-muted fw-bold text-uppercase">Categoría</span>
                                <span>@_selectedMovement.Categoria</span>
                            </div>
                            <div class="d-flex justify-content-between py-2">
                                <span class="text-muted fw-bold text-uppercase">Descripción</span>
                                <span>@_selectedMovement.Descripcion</span>
                            </div>
                        </div>
                    </VmCard>

                    @if (_selectedMovement.OrdenCargaId.HasValue || _selectedMovement.CompraId.HasValue || _selectedMovement.GastoRecurrenteId.HasValue)
                    {
                        <VmCard Header="VÍNCULOS" HeaderVariant="secondary" Style="margin-bottom:1rem;">
                            <div class="font-monospace" style="font-size: 0.8rem;">
                                @if (_selectedMovement.OrdenCargaId.HasValue)
                                {
                                    <div class="d-flex justify-content-between py-2">
                                        <span class="text-muted fw-bold text-uppercase">Orden de Carga</span>
                                        <span>#@_selectedMovement.OrdenCargaId</span>
                                    </div>
                                }
                                @if (_selectedMovement.CompraId.HasValue)
                                {
                                    <div class="d-flex justify-content-between py-2">
                                        <span class="text-muted fw-bold text-uppercase">Compra</span>
                                        <span>#@_selectedMovement.CompraId</span>
                                    </div>
                                }
                                @if (_selectedMovement.GastoRecurrenteId.HasValue)
                                {
                                    <div class="d-flex justify-content-between py-2">
                                        <span class="text-muted fw-bold text-uppercase">Gasto Recurrente</span>
                                        <span>#@_selectedMovement.GastoRecurrenteId</span>
                                    </div>
                                }
                            </div>
                        </VmCard>
                    }

                    @if (!string.IsNullOrEmpty(_selectedMovement.ImagenPath))
                    {
                        <VmCard Header="COMPROBANTE" HeaderVariant="light" Style="margin-bottom:1rem;">
                            <div class="text-center">
                                @if (_selectedMovement.ImagenPath.Contains(".pdf", StringComparison.OrdinalIgnoreCase))
                                {
                                    <a href="@_selectedMovement.ImagenPath" target="_blank" class="btn btn-outline-dark rounded-0">
                                        <i class="bi bi-file-earmark-pdf me-2"></i>Ver documento PDF
                                    </a>
                                }
                                else
                                {
                                    <a href="@_selectedMovement.ImagenPath" target="_blank" class="btn btn-outline-dark rounded-0">
                                        <i class="bi bi-image me-2"></i>Ver comprobante
                                    </a>
                                }
                            </div>
                        </VmCard>
                    }
                </div>
                <div class="modal-footer bg-white border-top border-dark rounded-0 d-flex gap-2">
                    <VmButton Variant="outline" Block="true" OnClick="CerrarModalDetalle">CERRAR</VmButton>
                    <VmButton Variant="dark" Block="true" Disabled="true">EDITAR</VmButton>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private DateTime SelectedDate = DateTime.Now;
    private CajaResumenDto? Resumen;
    private List<MovimientoCaja> Movimientos = new();
    private List<OrdenCargaDto> OrdenesMensuales = new();
    
    // UI Logic
    private bool MostrarLotes = false;
    private bool _gastosFijosModalOpen = false;
    private bool _showGastoFijoInlineForm = false;
    private bool _pnlModalOpen = false;
    private HashSet<string> ExpandedGroups = new(); // Stores IDs of expanded groups
    private List<GrupoVisual> GruposVisuales = new();

    // Estado de Resultados (P&L tab)
    private bool _isVentasExpanded = false;
    private bool _isCostoExpanded = false;
    private bool _isGastosExpanded = false;
    private bool _descontarTransbank = false;
    private List<MovimientoCaja>? MovimientosGastos;
    private ValorizacionStockData? Valorizacion;
    private readonly string[] _targetCategories = new[] 
    { 
        "LOGISTICA", "PEAJES", "INSUMOS", "MANTENCION",
        "INFRA", "ARRIENDO_POS", "INTERNET", "COMISIONES", "SUELDOS", "OTROS",
        "GASTOS GENERALES"
    };

    // Gastos Recurrentes
    private List<GastoPendienteDto>? GastosPendientes;
    private List<GastoRecurrenteDto>? TodosGastos;
    private List<MaquinaSimpleDto>? ListaMaquinas;
    private bool MostrarModalGastoFijo = false;
    private bool MostrarModalAplicarGastos = false;
    private bool _registroModalOpen = false;
    private bool _detalleModalOpen = false;
    private MovimientoCaja? _selectedMovement;
    private bool AplicandoGastos = false;
    private GastoRecurrenteDto GastoEditando = new();
    private int GastoEditandoMaquinaId = 0;
    private Dictionary<int, decimal> MontosReales = new();

    // Form Logic
    private string ErrorCarga = "";
    private List<Producto> ListaProductos = new();
    private MovimientoCaja Nuevo = new() { Tipo = "GASTO", Categoria = "MERCADERIA" };
    private DateTime FechaRegistro = DateTime.Now;
    private IBrowserFile? fileToUpload;
    private string Mensaje = "";
    private bool IsUploading = false;

    // Helpers de binding para VmInput / VmSelect
    private string FechaRegistroString
    {
        get => FechaRegistro.ToString("yyyy-MM-dd");
        set { if (DateTime.TryParse(value, out var d)) FechaRegistro = d; }
    }

    private string CantidadString
    {
        get => Nuevo.Cantidad == 0 ? "" : Nuevo.Cantidad.ToString();
        set { if (int.TryParse(value, out var c)) Nuevo.Cantidad = c; }
    }

    private IEnumerable<VmSelect.VmSelectOption> CategoriaOptions => Nuevo.Tipo switch
    {
        "GASTO" => new[]
        {
            new VmSelect.VmSelectOption("MERCADERIA", "📦 Mercadería (Reposición)"),
            new VmSelect.VmSelectOption("MERMA", "📦 Merma / Pérdida"),
            new VmSelect.VmSelectOption("LOGISTICA", "⛽ Logística (Bencina/Fletes)"),
            new VmSelect.VmSelectOption("PEAJES", "⛽ Peajes / Estacionamiento"),
            new VmSelect.VmSelectOption("INSUMOS", "⛽ Insumos (Limpieza/Bolsas)"),
            new VmSelect.VmSelectOption("MANTENCION", "⛽ Mantención / Repuestos"),
            new VmSelect.VmSelectOption("INFRA", "🏢 Infraestructura (Luz/Agua/Arriendo)"),
            new VmSelect.VmSelectOption("ARRIENDO_POS", "🏢 Arriendo POS (Transbank)"),
            new VmSelect.VmSelectOption("INTERNET", "🏢 Internet (Planes/Chips)"),
            new VmSelect.VmSelectOption("COMISIONES", "🏢 Comisiones Bancarias"),
            new VmSelect.VmSelectOption("SUELDOS", "🏢 👥 Sueldos Personal"),
            new VmSelect.VmSelectOption("OTROS", "🏢 Otros Gastos Fijos")
        },
