                                <th class="ps-3">GASTO</th>
                                <th class="text-end">ESTIMADO</th>
                                <th class="text-center" style="width: 180px;">MONTO REAL ($)</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (GastosPendientes != null)
                            {
                                @foreach (var p in GastosPendientes)
                                {
                                    <tr>
