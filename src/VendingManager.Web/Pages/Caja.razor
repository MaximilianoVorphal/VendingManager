    private void PrepareGroups()
    {
        GruposVisuales.Clear();
        
        var listaBase = MostrarLotes ? Movimientos : Movimientos.Where(m => m.Categoria != "LOTES").ToList();

        // 1. Separate items linked to a Recharge vs General items
        var movimientosVinculados = listaBase.Where(m => m.OrdenCargaId.HasValue).ToList();
        var movimientosGenerales = listaBase.Where(m => !m.OrdenCargaId.HasValue).ToList();

        // 2. Process Linked Items (Grouped by Recharge ID)
        var gruposOrdenCarga = movimientosVinculados
            .GroupBy(m => m.OrdenCargaId!.Value)
            .Select(g => 
            {
                var orden = OrdenesMensuales.FirstOrDefault(o => o.Id == g.Key);
                // If order info is missing (maybe from another month?), use first item date
                var fechaBase = orden?.FechaCreacion ?? g.First().Fecha;
                var nombre = orden != null ? $"ORDEN DE CARGA: {orden.MaquinaNombre}" : $"ORDEN DE CARGA #{g.Key}";
                
                return new GrupoVisual
                {
                    Id = $"R-{g.Key}",
                    Titulo = nombre,
                    Fecha = fechaBase,
                    EsOrdenCarga = true,
                    Items = g.OrderByDescending(m => m.Fecha).ToList(),
                    MontoTotal = g.Sum(m => m.Monto)
                };
            });

        // 3. Process General Items (Grouped by Date)
        var gruposFecha = movimientosGenerales
            .GroupBy(m => m.Fecha.Date)
            .Select(g => new GrupoVisual
            {
                Id = $"D-{g.Key.Ticks}",
                Titulo = g.Key.ToString("dddd, dd MMMM").ToUpper(),
                Fecha = g.Key,
                EsOrdenCarga = false,
                Items = g.OrderByDescending(m => m.Fecha).ToList(),
                MontoTotal = g.Sum(m => m.Monto)
            });

        // 4. Merge and Sort
        GruposVisuales = gruposOrdenCarga.Concat(gruposFecha)
            .OrderByDescending(g => g.Fecha)
            .ToList();
            
        // Auto-expand all by default or just today? Let's expand all for visibility
        if (!ExpandedGroups.Any())
        {
             foreach(var g in GruposVisuales) ExpandedGroups.Add(g.Id);
        }
    }

