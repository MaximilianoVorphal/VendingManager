    private async Task GuardarGastoFijo()
    {
        if (string.IsNullOrWhiteSpace(GastoEditando.Descripcion) || GastoEditando.MontoEstimado <= 0) return;
        
        GastoEditando.MaquinaId = GastoEditandoMaquinaId > 0 ? GastoEditandoMaquinaId : null;
        GastoEditando.Tipo = "GASTO";
        GastoEditando.Activo = true;

        try
        {
            if (GastoEditando.Id > 0)
            {
                await Http.PutAsJsonAsync($"api/GastoRecurrente/{GastoEditando.Id}", GastoEditando);
            }
            else
            {
                await Http.PostAsJsonAsync("api/GastoRecurrente", GastoEditando);
