    private async Task AplicarTodosGastos()
    {
        AplicandoGastos = true;
        try
        {
            var request = new AplicarTodosRequest
            {
                Month = SelectedDate.Month,
                Year = SelectedDate.Year,
                MontosPersonalizados = MontosReales
                    .Where(kv => kv.Value > 0)
                    .Select(kv => new MontoPersonalizadoDto { GastoRecurrenteId = kv.Key, MontoReal = kv.Value })
                    .ToList()
            };
            await Http.PostAsJsonAsync("api/GastoRecurrente/aplicar-todos", request);
            await JS.InvokeVoidAsync("modalScrollLock.unlock");
            MostrarModalAplicarGastos = false;
            await CargarDatos();
