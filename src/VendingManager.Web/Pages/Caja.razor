@* ====== MODAL: APLICAR GASTOS PENDIENTES ====== *@
@if (MostrarModalAplicarGastos)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5); z-index: 2000;">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content rounded-0 border-2 border-warning shadow-lg">
                <div class="modal-header bg-warning text-dark rounded-0">
                    <h5 class="modal-title fw-bold text-uppercase"><i class="bi bi-lightning-fill me-2"></i>APLICAR GASTOS FIJOS — @SelectedDate.ToString("MMMM yyyy").ToUpper()</h5>
