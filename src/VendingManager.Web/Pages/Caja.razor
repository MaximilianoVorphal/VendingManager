    private bool IsGroupExpanded(string id) => ExpandedGroups.Contains(id);
    
    private void ToggleGroup(string id)
    {
        if (ExpandedGroups.Contains(id))
            ExpandedGroups.Remove(id);
        else
            ExpandedGroups.Add(id);
