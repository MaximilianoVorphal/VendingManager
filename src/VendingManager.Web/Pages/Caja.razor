                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
                <div class="modal-footer bg-light border-top border-dark rounded-0 d-flex justify-content-between">
                    <small class="text-muted">Los montos en 0 usarán el valor estimado.</small>
                    <div class="d-flex gap-2">
                        <button class="btn btn-outline-dark rounded-0" @onclick="() => MostrarModalAplicarGastos = false">CANCELAR</button>
                        <button class="btn btn-warning rounded-0 fw-bold text-dark" @onclick="AplicarTodosGastos" disabled="@AplicandoGastos">
