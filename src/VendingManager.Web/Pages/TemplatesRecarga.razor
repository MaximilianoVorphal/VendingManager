@page "/templates-recarga"
@using Microsoft.AspNetCore.Authorization
@using VendingManager.Shared.Constants
@using VendingManager.Shared.DTOs
@using VendingManager.Shared.Enums
@using Microsoft.AspNetCore.Components.Forms
@using VendingManager.Web.Layout
@using VendingManager.Web.Components.Shared
@attribute [Authorize(Roles = Roles.Admin)]
@inject HttpClient Http
@inject Microsoft.Extensions.Logging.ILogger<TemplatesRecarga> Logger
@inject NavigationManager NavManager
@inject IJSRuntime JS
@implements IDisposable

@if (PeriodoEnEdicionVisual == null)
{
<div class="rec-page">

    <!-- HEADER -->
    <div class="rec-header d-flex justify-content-between align-items-end flex-wrap gap-3 pb-3 mb-4">
        <div>
            <span class="rec-breadcrumb">Terreno · Recarga</span>
            <h1 class="rec-title">Templates de Recarga</h1>
            <small class="rec-subtitle">Defini periodos por maquina y carga el planograma</small>
        </div>
        <div class="d-flex gap-2 flex-wrap header-actions">
            <VmButton Variant="dark" Icon="bi-arrow-repeat" OnClick="AbrirModalSincronizarGlobal">
                Sincronizar todo
            </VmButton>
            <VmButton Variant="dark" Icon="bi-plus-lg" OnClick="AbrirModalCrear">
                Nuevo template
            </VmButton>
            <button class="rec-pbtn @(SoloPendientes ? "rec-pbtn--active" : "")" @onclick="() => SoloPendientes = !SoloPendientes">
                <i class="bi bi-exclamation-circle"></i>
                Pendientes · @(Templates?.Count(t => t.CantidadSlotsPendientes > 0) ?? 0)
            </button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(MensajeError))
    {
        <div class="alert alert-danger border-2 border-dark rounded-0 mb-4 shadow-sm fw-bold">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @MensajeError
        </div>
    }

    @if (!string.IsNullOrEmpty(MensajeExito))
    {
        <div class="alert alert-success border-2 border-dark rounded-0 mb-4 shadow-sm fw-bold">
            <i class="bi bi-check-circle-fill me-2"></i> @MensajeExito
        </div>
    }

    @if (Cargando)
    {
        <div class="text-center py-5 border border-dark border-2 bg-light">
            <div class="spinner-grow text-dark" role="status"></div>
            <p class="mt-2 fw-bold text-uppercase loading-letter-spacing">Cargando Templates...</p>
        </div>
    }
    else if (TemplatesFiltrados != null && TemplatesFiltrados.Any())
    {
        <div class="rec-table-wrap">
            <table class="rec-table">
                <thead>
                    <tr>
                        <th>Estado</th>
                        <th>Recarga / Ruta</th>
                        <th>Período</th>
                        <th>Máquinas</th>
                        <th>Carga</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var template in TemplatesFiltrados)
                    {
                        var pendiente = template.CantidadSlotsPendientes > 0;
                        var slots = template.Periodos.SelectMany(p => p.SnapshotSlots).ToList();
                        var totalSlots = slots.Count;
                        var filledSlots = slots.Count(s => s.Estado != EstadoSlot.Vacio);
                        var pct = totalSlots > 0 ? (filledSlots * 100 / totalSlots) : 0;
                        var firstPeriodo = template.Periodos.FirstOrDefault();
                        <tr class="rec-trow @(pendiente ? "rec-trow-pend" : "")">
                            <td>
                                <span class="rec-tag rec-tag--@(GetEstadoTagVariant(template))">@GetEstadoDisplay(template)</span>
                            </td>
                            <td>
                                @if (firstPeriodo != null)
                                {
                                    <button class="rec-name-btn" @onclick="() => AbrirEdicionVisual(template, firstPeriodo)">
                                        <span>@template.Nombre</span>
                                        <span>@template.Descripcion</span>
                                    </button>
                                }
                                else
                                {
                                    <span class="rec-cell-mono">@template.Nombre</span>
                                }
                            </td>
                            <td>
                                <span class="rec-cell-mono">@template.FechaRecargaMin?.ToString("dd/MM/yyyy") - @template.FechaFinMax?.ToString("dd/MM/yyyy")</span>
                            </td>
                            <td>
                                <div class="rec-chips">
                                    @foreach (var periodo in template.Periodos)
                                    {
                                        <span>@periodo.MaquinaId</span>
                                    }
                                </div>
                            </td>
                            <td>
                                <div class="rec-carga">
                                    <div class="rec-bar">
                                        <div class="rec-bar__fill rec-bar--@(pct >= 80 ? "good" : pct >= 30 ? "warning" : "danger")" style="width:@pct%"></div>
                                    </div>
                                    <span class="rec-cell-mono">@pct%</span>
                                </div>
                                <small class="rec-carga-label">@filledSlots / @totalSlots u.</small>
                            </td>
                            <td>
                                <div class="rec-actions">
                                    <VmButton Variant="outline" Size="sm" Icon="bi-pencil" OnClick="() => AbrirModalEditar(template)"></VmButton>
                                    <VmButton Variant="outline" Size="sm" Icon="bi-trash" OnClick="() => TemplateAEliminar = template"></VmButton>
                                    <VmButton Variant="danger" Size="sm" Icon="bi-graph-up" OnClick="() => AnalizarTemplate(template.Id)">Stockout</VmButton>
                                    @if (firstPeriodo != null)
                                    {
                                        <VmButton Variant="dark" Size="sm" Icon="bi-box-arrow-in-right" OnClick="() => AbrirEdicionVisual(template, firstPeriodo)">Abrir</VmButton>
                                    }
                                    @if (pendiente)
                                    {
                                        <VmButton Variant="outline" Size="sm" Icon="bi-exclamation-circle" OnClick="async () => { TemplateAEliminar = null; await MostrarPendientes(); }">Slots pendientes</VmButton>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="rec-no-rows">
            <p>Sin recargas que coincidan con el filtro</p>
            <button class="rec-pbtn" @onclick="AbrirModalCrear">Crear primer template</button>
        </div>
    }

</div>

<!-- MODAL CREAR/EDITAR -->
@if (MostrarModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5); z-index: 1110;">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content border-2 border-dark rounded-0">
                <div class="modal-header bg-dark text-white rounded-0 border-bottom border-dark">
                    <h5 class="modal-title fw-bold text-uppercase">
                        @(EsEdicion ? "EDITAR TEMPLATE" : "NUEVO TEMPLATE DE RECARGA")
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarModal"></button>
                </div>
                <div class="modal-body">
                    <!-- Nombre y Descripción -->
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <VmInput Label="NOMBRE DEL TEMPLATE" @bind-Value="TemplateActual.Nombre" Placeholder="Ej: Recarga Nuevo 3" />
                        </div>
                        <div class="col-md-6">
                            <VmInput Label="DESCRIPCIÓN (OPCIONAL)" @bind-Value="TemplateActual.Descripcion" Placeholder="Ej: Recarga semanal enero" />
                        </div>
                    </div>

                    <!-- Períodos por Máquina -->
                    <div class="border border-dark p-3 bg-light">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="fw-bold text-uppercase m-0">
                                <i class="bi bi-clock-history me-1"></i> PERÍODOS POR MÁQUINA
                            </h6>
                            <VmButton Variant="dark" Size="sm" Icon="bi-plus-lg" OnClick="AgregarPeriodo">
                                Agregar Máquina
                            </VmButton>
                        </div>

                        @if (!PeriodosActuales.Any())
                        {
                            <div class="text-center text-muted py-3">
                                <i class="bi bi-info-circle"></i> Agrega al menos una máquina con su período
                            </div>
                        }
                        else
                        {
                            @for (int i = 0; i < PeriodosActuales.Count; i++)
                            {
                                var periodo = PeriodosActuales[i];
                                var index = i;
                                <div class="card rounded-0 border-dark mb-2">
                                    <div class="card-body p-2">
                                        <div class="row g-2 align-items-end">
                                            <div class="col-md-4 col-12">
                                                <VmSelect Label="MÁQUINA"
                                                          Value="@periodo.MaquinaId.ToString()"
                                                          ValueChanged="@(v => OnMaquinaChanged(index, v))"
                                                          Options="@(ListaMaquinas?.Select(m => new VmSelect.VmSelectOption(m.Id.ToString(), m.Nombre)) ?? [])" />
                                            </div>
                                            <div class="col-md-4 col-12">
                                                <VmInput Label="FECHA RECARGA" Type="date"
                                                         Value="@periodo.FechaRecargaText"
                                                         ValueChanged="@(v => OnFechaRecargaDateChanged(index, v))" />
                                            </div>
                                            <div class="col-md-2 col-12">
                                                <VmInput Label="HORA" Type="text" Placeholder="HH:mm"
                                                         Value="@periodo.HoraRecargaText"
                                                         ValueChanged="@(v => OnHoraRecargaChanged(index, v))" />
                                            </div>
                                            <div class="col-md-2 col-12">
                                                <div class="d-flex gap-1">
                                                    <VmButton Variant="outline" Size="sm" Icon="bi-box-seam" OnClick="() => CargarSlotsParaPeriodo(index)" Disabled="@(periodo.MaquinaId == 0 || CargandoSlots)">
                                                        Slots
                                                    </VmButton>
                                                    <VmButton Variant="danger" Size="sm" Icon="bi-x-lg" OnClick="() => EliminarPeriodo(index)">
                                                    </VmButton>
                                                </div>
                                            </div>
                                        </div>

                                        @if (periodo.SnapshotSlots.Any())
                                        {
                                            <div class="mt-3 p-3 bg-white border border-2 border-dark text-center shadow-sm">
                                                <h6 class="fw-bold text-success mb-3 text-uppercase">
                                                    <i class="bi bi-check-circle-fill me-1"></i>
                                                    @periodo.SnapshotSlots.Count(s => s.ProductoId.HasValue && s.ProductoId > 0) productos configurados
                                                    <span class="text-muted ms-1">(de @periodo.SnapshotSlots.Count slots)</span>
                                                </h6>
                                                <div class="slot-grid mb-3">
                                                    @foreach (var slot in periodo.SnapshotSlots)
                                                    {
                                                        <SlotCard Slot="slot" IsReadOnly="true" />
                                                    }
                                                </div>
                                                <button class="btn btn-warning rounded-0 fw-bold border-2 border-dark mb-2 px-4 py-2 text-uppercase btn-lg edit-slots-btn"
                                                    onmousedown="this.style.transform='translate(2px, 2px)'; this.style.boxShadow='1px 1px 0px #000';"
                                                    onmouseup="this.style.transform='none'; this.style.boxShadow='';"
                                                    onmouseleave="this.style.transform='none'; this.style.boxShadow='';"
                                                    @onclick="() => AbrirEdicionVisual(periodo)">
                                                    <i class="bi bi-grid-3x3-gap-fill me-2"></i> EDITAR SLOTS (GRILLA)
                                                </button>
                                                <div class="mt-3 border-top border-dark pt-3">
                                                    <VmButton Variant="outline" Size="sm" Icon="bi-trash" OnClick="() => periodo.SnapshotSlots.Clear()">
                                                        VACIAR MÁQUINA
                                                    </VmButton>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        }
                    </div>
            </div>
            <div class="modal-footer border-top border-dark">
                <VmButton Variant="outline" OnClick="CerrarModal">
                    CANCELAR
                </VmButton>
                <VmButton Variant="success" OnClick="GuardarTemplate" Disabled="@Guardando">
                    @(Guardando ? "GUARDANDO..." : (EsEdicion ? "ACTUALIZAR" : "GUARDAR TEMPLATE"))
                </VmButton>
            </div>
        </div>
    </div>
</div>
}
}

<!-- EDICIÓN VISUAL DE SLOTS (Full-page inline, no modal) -->
@if (PeriodoEnEdicionVisual != null)
{
    var templateActual = Templates?.FirstOrDefault(t => t.Id == _currentTemplateId);
    var estado = templateActual != null ? GetEstadoDisplay(templateActual) : "PENDIENTE";
    var estadoVariant = templateActual != null ? GetEstadoTagVariant(templateActual) : "pend";
    var descripcion = templateActual?.Descripcion ?? "";
    var maquinaNombre = ListaMaquinas?.FirstOrDefault(m => m.Id == PeriodoEnEdicionVisual.MaquinaId)?.Nombre ?? $"Máquina {PeriodoEnEdicionVisual.MaquinaId}";

    <div class="rec-editor">
        <!-- Top bar -->
        <div class="rec-topbar d-flex justify-content-between align-items-center flex-wrap gap-3 pb-3 mb-4">
            <div class="d-flex align-items-center gap-3 flex-wrap">
                <VmButton Variant="dark" Icon="bi-arrow-left" OnClick="CerrarEdicionVisual">Volver</VmButton>
                <h2 class="rec-title m-0">@maquinaNombre</h2>
                <span class="rec-tag rec-tag--@estadoVariant">@estado</span>
                <small class="rec-subtitle">@descripcion</small>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <VmButton Variant="outline" Size="sm" Icon="bi-pencil" OnClick="AbrirModalEditarActual">Editar</VmButton>
                <VmButton Variant="danger" Size="sm" Icon="bi-graph-up" OnClick="AnalizarTemplateActual">Analizar stockout</VmButton>
                <VmButton Variant="outline" Size="sm" Icon="bi-arrow-repeat" OnClick="SincronizarTemplateActual">Sincronizar todo</VmButton>
                @if (templateActual?.Estado == EstadoTemplate.Terminado)
                {
                    <span class="rec-finalizado"><i class="bi bi-check-circle"></i>Finalizado</span>
                }
                else
                {
                    <VmButton Variant="dark" Size="sm" Icon="bi-check-circle" OnClick="TerminarTemplateActual">Finalizar</VmButton>
                }
            </div>
        </div>

        @if (ProcesandoOcr)
        {
            <div style="position: absolute; inset: 0; background: rgba(0,0,0,0.6); z-index: 50; display: flex; flex-direction: column; align-items: center; justify-content: center;">
                <div class="spinner-border text-light mb-3" style="width: 3rem; height: 3rem;" role="status"></div>
                <span class="text-white fw-bold text-uppercase" style="letter-spacing: 2px;">PROCESANDO OCR...</span>
            </div>
        }
        @if (!string.IsNullOrEmpty(MensajeErrorOcr))
        {
            <div class="alert alert-danger border-2 border-dark rounded-0 mb-3 small fw-bold">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> @MensajeErrorOcr
            </div>
        }
        @if (!string.IsNullOrEmpty(MensajeInfoOcr))
        {
            <div class="alert alert-info border-2 border-dark rounded-0 mb-3 small fw-bold">
                <i class="bi bi-info-circle-fill me-2"></i> @MensajeInfoOcr
            </div>
        }

        <div class="rec-split">
            <!-- Rail de maquinas -->
            <aside class="rec-rail">
                <div class="rec-rail-header px-3 py-2">
                    <span class="rec-cell-mono">MAQUINAS · @(PeriodosActuales.Count)</span>
                    <small class="rec-subtitle">Periodo por maquina · clic para ver grilla</small>
                </div>
                <div style="flex: 1; min-height: 0; overflow: auto; padding: 11px; display: flex; flex-direction: column; gap: 11px;">
                    @for (int i = 0; i < PeriodosActuales.Count; i++)
                    {
                        var idx = i;
                        var periodo = PeriodosActuales[i];
                        var stats = GetPeriodoStats(periodo);
                        var pct = stats.cap > 0 ? (stats.units * 100 / stats.cap) : 0;
                        <div class="rec-mcard @(i == ActiveMachineIndex ? "rec-mcard-active" : "")" @onclick="() => ActiveMachineIndex = idx">
                            <div class="d-flex align-items-center gap-2">
                                <select class="rec-mcard__select" value="@periodo.MaquinaId" @onchange="e => OnMaquinaChanged(idx, e.Value?.ToString())" @onclick:stopPropagation="true">
                                    @foreach (var m in ListaMaquinas ?? new List<MaquinaSimpleDto>())
                                    {
                                        <option value="@m.Id">@m.Nombre</option>
                                    }
                                </select>
                                <button class="rec-mcard-del" @onclick="() => EliminarPeriodo(idx)" @onclick:stopPropagation="true" aria-label="Quitar maquina"><i class="bi bi-trash"></i></button>
                            </div>
                            <div class="d-flex gap-2">
                                <input type="date" class="form-control form-control-sm border-2 border-dark rounded-0" style="flex:1;min-width:0;font-family:var(--font-mono);font-size:0.7rem;" value="@periodo.FechaRecargaText" @onchange="e => OnFechaRecargaDateChanged(idx, e.Value?.ToString())" @onclick:stopPropagation="true" />
                                <input type="text" class="form-control form-control-sm border-2 border-dark rounded-0" style="width:84px;font-family:var(--font-mono);font-size:0.7rem;" value="@periodo.HoraRecargaText" @onchange="e => OnHoraRecargaChanged(idx, e.Value?.ToString())" @onclick:stopPropagation="true" />
                            </div>
                            <div class="rec-carga">
                                <div class="rec-bar"><div class="rec-bar__fill rec-bar--@(pct >= 80 ? "good" : pct >= 30 ? "warning" : "danger")" style="width:@pct%"></div></div>
                                <span class="rec-cell-mono">@stats.units/@stats.cap</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center">
                                <small class="rec-mcard-config">@stats.configured/@stats.total configurados</small>
                                @if (stats.vacios > 0)
                                {
                                    <span class="rec-mcard-vacios">@stats.vacios vacios</span>
                                }
                            </div>
                        </div>
                    }
                </div>
                <div style="flex-shrink: 0; border-top: var(--border-2); padding: 11px;">
                    <VmButton Variant="outline" Icon="bi-plus-lg" Block="true" OnClick="AgregarPeriodo">Agregar maquina</VmButton>
                </div>
            </aside>

            <!-- Estanteria -->
            <section class="rec-estanteria">
                <div class="rec-est-header d-flex justify-content-between align-items-center flex-wrap gap-3 px-3 py-2">
                    <div class="d-flex align-items-center gap-3">
                        <div class="rec-icon-tile"><i class="bi bi-grid-3x3-gap-fill"></i></div>
                        <div>
                            <h3 class="m-0">Estanteria · Maquina @(PeriodoEnEdicionVisual.MaquinaId)</h3>
                            <small class="rec-subtitle">@(GetEstanteriaPct())% LLENO · @(PeriodoEnEdicionVisual.SnapshotSlots.Count) SLOTS</small>
                        </div>
                    </div>
                    <div class="d-flex gap-2 flex-wrap align-items-center">
                        <input class="rec-search" placeholder="Buscar slot o producto..." @bind="SlotSearch" @bind:event="oninput" />
                        <div class="rec-density">
                            <button class="rec-density__btn @(DensidadCompacta ? "" : "active")" @onclick="() => DensidadCompacta = false">Comoda</button>
                            <button class="rec-density__btn @(DensidadCompacta ? "active" : "")" @onclick="() => DensidadCompacta = true">Compacta</button>
                        </div>
                        <VmButton Variant="outline" Size="sm" Icon="bi-camera" OnClick="TriggerOcrUpload">Foto recarga</VmButton>
                        <VmButton Variant="outline" Size="sm" Icon="bi-image" OnClick="TriggerFotoGuiaUpload">Foto guia</VmButton>
                    </div>
                </div>

                <div class="rec-floors" id="rec-floors-placeholder">
                    <!-- Populated in Commit 4 -->
                </div>

                <div class="rec-bottombar" id="rec-bottombar-placeholder">
                    <!-- Populated in Commit 4 -->
                </div>
            </section>
        </div>

        <!-- PRODUCT SELECTOR OVERLAY (for slot product change) -->
        @if (SlotConProductoSelector != null && ListaProductos != null)
        {
            <div class="product-selector-overlay" @onclick="CerrarProductoSelector" @onclick:stopPropagation="true">
                <div class="product-selector-dropdown" @onclick:stopPropagation="true">
                    <div class="product-selector-header">
                        <span class="fw-bold text-uppercase small">
                            <i class="bi bi-box-seam me-2"></i>CAMBIAR PRODUCTO — SLOT @SlotConProductoSelector.NumeroSlot
                        </span>
                        <button type="button" class="btn-close" @onclick="CerrarProductoSelector"></button>
                    </div>
                    <div class="product-selector-search">
                        <input type="text" class="form-control form-control-sm border-dark rounded-0"
                               placeholder="Buscar producto..."
                               @bind="ProductoSearch"
                               @bind:event="oninput" />
                    </div>
                    <div class="product-selector-list">
                        @foreach (var prod in ListaProductos.Where(p =>
                            string.IsNullOrEmpty(ProductoSearch) ||
                            p.Nombre.Contains(ProductoSearch, StringComparison.OrdinalIgnoreCase)))
                        {
                            <button class="product-selector-item @(SlotConProductoSelector.ProductoId == prod.Id ? "active" : "")"
                                    @onclick="() => SeleccionarProductoParaSlot(prod)">
                                <span class="fw-bold">@prod.Nombre</span>
                                @if (SlotConProductoSelector.ProductoId == prod.Id)
                                {
                                    <i class="bi bi-check-circle-fill text-success ms-2"></i>
                                }
                            </button>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Floating Action Panel (right side) -->
    <div class="slot-action-panel">
        <InputFile OnChange="HandleOcrPhotoUpload" accept="image/*" class="d-none" id="ocrRecargaFileInput" disabled="@ProcesandoOcr" />
        <button class="slot-action-btn slot-action-btn--primary" @onclick="TriggerOcrUpload" disabled="@ProcesandoOcr"
                title="Fotos legibles tardan ~5s. Formatos: JPG, PNG, HEIC. Máx 10MB.">
            @if (_fotoOcrLoading)
            {
                <span class="spinner-border spinner-border-sm"></span>
            }
            else
            {
                <i class="bi bi-camera-fill"></i>
            }
            <span class="slot-action-label">FOTO RECARGA</span>
        </button>

        @if (string.IsNullOrEmpty(FotoGuiaUrl))
        {
            <InputFile OnChange="HandleFotoGuiaUpload" accept="image/*" class="d-none" id="fotoGuiaFileInput" />
            <button class="slot-action-btn slot-action-btn--secondary" @onclick="TriggerFotoGuiaUpload"
                    title="Cargar foto de referencia (productos)">
                @if (_fotoGuiaLoading)
                {
                    <span class="spinner-border spinner-border-sm"></span>
                }
                else
                {
                    <i class="bi bi-image"></i>
                }
                <span class="slot-action-label">FOTO GUÍA</span>
            </button>
        }
        else
        {
            <button class="slot-action-btn slot-action-btn--info" @onclick="MostrarFotoGuiaModal"
                    title="Ver foto guía">
                <i class="bi bi-eye"></i>
                <span class="slot-action-label">VER GUÍA</span>
            </button>
        }

        <div class="slot-action-divider"></div>

        <button class="slot-action-btn slot-action-btn--save" @onclick="CerrarEdicionVisual"
                title="Guardar cambios y volver">
            <i class="bi bi-save"></i>
            <span class="slot-action-label">GUARDAR</span>
        </button>
    </div>
}

<!-- MODAL FOTO GUÍA (Photo 2 — reference only, never sent to backend) -->
@if (MostrarFotoGuia && !string.IsNullOrEmpty(FotoGuiaUrl))
{
    <div @ref="fotoGuiaModalRef" tabindex="-1"
         class="modal fade show d-block" style="background-color: rgba(0,0,0,0.9); z-index: 1130; outline: none;"
         @onkeydown="OnFotoGuiaKeydown">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content border-3 border-dark rounded-0 bg-dark">
                <div class="modal-header bg-dark text-white rounded-0 border-bottom border-dark">
                    <h5 class="modal-title fw-bold text-uppercase">
                        <i class="bi bi-image-fill me-2"></i> FOTO GUÍA — @((ListaMaquinas?.FirstOrDefault(m => m.Id == PeriodoEnEdicionVisual?.MaquinaId)?.Nombre ?? "MÁQUINA"))
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarFotoGuiaModal"></button>
                </div>
                <div class="modal-body p-0"
                     style="background-color: #111; overflow: hidden; position: relative; height: 80vh; cursor: @(_fotoGuiaDragging ? "grabbing" : "grab"); user-select: none;"
                     @onwheel:preventDefault="true"
                     @onwheel="OnFotoGuiaZoom"
                     @onmousedown="OnFotoGuiaPanStart"
                     @onmousemove="OnFotoGuiaPanMove"
                     @onmouseup="OnFotoGuiaPanEnd"
                     @onmouseleave="OnFotoGuiaPanLeave"
                     @ontouchstart="OnFotoGuiaTouchStart"
                     @ontouchmove:preventDefault="true"
                     @ontouchmove="OnFotoGuiaTouchMove"
                     @ontouchend="OnFotoGuiaTouchEnd">
                    <div style="display: flex; align-items: center; justify-content: center; width: 100%; height: 100%;">
                        <img src="@FotoGuiaUrl" alt="Foto Guía"
                             style="max-width: 100%; max-height: 100%; object-fit: contain; transform-origin: center; transform: @FotoGuiaTransform; pointer-events: none; display: block;" />
                    </div>
                </div>
                <div class="modal-footer bg-dark border-top border-dark rounded-0 d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center gap-3">
                        <button class="btn btn-sm btn-outline-danger rounded-0 fw-bold" @onclick="EliminarFotoGuia" title="Eliminar foto guía">
                            <i class="bi bi-trash me-1"></i>ELIMINAR FOTO
                        </button>
                        <small class="text-muted">
                            <i class="bi bi-info-circle-fill me-1"></i>
                            Esta foto es solo referencia.
                        </small>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        @if (_fotoGuiaZoom > 1.0 || _fotoGuiaPanX != 0 || _fotoGuiaPanY != 0)
                        {
                            <button class="btn btn-sm btn-outline-light rounded-0 fw-bold" @onclick="ResetFotoGuiaView" title="Restablecer zoom">
                                <i class="bi bi-arrow-counterclockwise me-1"></i>RESTABLECER
                            </button>
                        }
                        <span class="text-muted small fw-bold font-monospace">@(FotoGuiaZoomDisplay)x</span>
                        <button type="button" class="btn btn-light rounded-0 fw-bold ms-2" @onclick="CerrarFotoGuiaModal">
                            CERRAR
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

