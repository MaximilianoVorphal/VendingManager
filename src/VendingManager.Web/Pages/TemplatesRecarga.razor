@page "/templates-recarga"
@using Microsoft.AspNetCore.Authorization
@using VendingManager.Shared.Constants
@using VendingManager.Shared.DTOs
@using VendingManager.Shared.Enums
@using Microsoft.AspNetCore.Components.Forms
@using VendingManager.Web.Layout
@attribute [Authorize(Roles = Roles.Admin)]
@inject HttpClient Http
@inject Microsoft.Extensions.Logging.ILogger<TemplatesRecarga> Logger
@inject NavigationManager NavManager
@inject IJSRuntime JS

<div class="industrial-wrapper container-fluid px-4 mt-4">

    <!-- HEADER -->
    <div class="row align-items-center mb-4 border-bottom border-3 border-dark pb-3">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <div>
                <h2 class="m-0 fw-bold text-uppercase" style="letter-spacing: -1px;">
                    <i class="bi bi-calendar-range me-2"></i>TEMPLATES DE RECARGA
                </h2>
                <small class="text-muted fw-bold">DEFINE PERÍODOS ESPECÍFICOS POR MÁQUINA PARA ANÁLISIS</small>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-warning rounded-0 fw-bold border-dark" @onclick="MostrarPendientes" title="Slots pendientes de configurar">
                    <i class="bi bi-exclamation-circle me-1"></i> PENDIENTES
                </button>
                <button class="btn btn-success rounded-0 fw-bold border-dark" @onclick="AbrirModalCrear">
                    <i class="bi bi-plus-lg me-1"></i> NUEVO TEMPLATE
                </button>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(MensajeError))
    {
        <div class="alert alert-danger border-2 border-dark rounded-0 mb-4 shadow-sm fw-bold">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @MensajeError
        </div>
    }

    @if (!string.IsNullOrEmpty(MensajeExito))
    {
        <div class="alert alert-success border-2 border-dark rounded-0 mb-4 shadow-sm fw-bold">
            <i class="bi bi-check-circle-fill me-2"></i> @MensajeExito
        </div>
    }

    @if (Cargando)
    {
        <div class="text-center py-5 border border-dark border-2 bg-light">
            <div class="spinner-grow text-dark" role="status"></div>
            <p class="mt-2 fw-bold text-uppercase" style="letter-spacing: 2px;">Cargando Templates...</p>
        </div>
    }
    else if (Templates != null && Templates.Any())
    {
        <div class="row g-4">
            @foreach (var template in Templates)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    @{
                        var cardClass = "card border-2 border-dark rounded-0 shadow-sm h-100";
                        if (template.CantidadSlotsPendientes > 0) cardClass += " template-card-warning";
                    }
                    <div class="@cardClass">
                        <div class="card-header bg-dark text-white rounded-0 d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center gap-2">
                                <span class="fw-bold text-uppercase">@template.Nombre</span>
                                @if (template.TieneFotoGuia || template.TieneFotoOcr)
                                {
                                    <span class="badge bg-secondary rounded-0" title="Tiene fotos asociadas">
                                        <i class="bi bi-camera-fill"></i>
                                    </span>
                                }
                                @if (template.CantidadSlotsPendientes > 0)
                                {
                                    <span class="badge bg-warning text-dark rounded-0">⚠ @template.CantidadSlotsPendientes pendiente(s)</span>
                                }
                            </div>
                            <div>
                                <button class="btn btn-sm btn-outline-light rounded-0 me-1"
                            @onclick="() => AbrirModalEditar(template)" title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger rounded-0"
                            @onclick="() => EliminarTemplate(template.Id)" title="Eliminar">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                        <div class="card-body">
                            @if (!string.IsNullOrEmpty(template.Descripcion))
                            {
                                <p class="text-muted small mb-2">@template.Descripcion</p>
                            }
                            <div class="mb-3">
                                <small class="text-muted">
                                    <i class="bi bi-calendar me-1"></i>
                                    @template.FechaInicioMin?.ToString("dd/MM/yyyy") -
                                    @template.FechaFinMax?.ToString("dd/MM/yyyy")
                                </small>
                            </div>

                            <h6 class="fw-bold text-uppercase small mb-2">
                                <i class="bi bi-geo-alt me-1"></i> @template.CantidadMaquinas Máquinas
                            </h6>

                            <div style="max-height: 150px; overflow-y: auto;">
                                @foreach (var periodo in template.Periodos)
                                {
                                    <div class="d-flex justify-content-between align-items-center border-bottom py-1 small">
                                        <span class="fw-bold">@periodo.MaquinaNombre</span>
                                        <span class="font-monospace text-muted">
                                            @periodo.FechaInicio.ToString("dd/MM HH:mm") → @periodo.FechaFin.ToString("dd/MM HH:mm")
                                        </span>
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="card-footer bg-light border-top border-dark">
                            <button class="btn btn-danger w-100 rounded-0 fw-bold mb-2"
                        @onclick="() => AnalizarTemplate(template.Id)">
                                <i class="bi bi-graph-up me-1"></i> ANALIZAR STOCKOUT
                            </button>
<button class="btn btn-warning w-100 rounded-0 fw-bold"
                                @onclick="() => AbrirModalSincronizar(template.Id)"
                                disabled="@_syncCtors.Any()">
                                <i class="bi bi-arrow-repeat me-1"></i> APLICAR A VENTAS
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5 border border-dark border-2 bg-light">
            <i class="bi bi-calendar-x fs-1 text-muted"></i>
            <p class="mt-2 fw-bold text-uppercase">No hay templates creados</p>
            <button class="btn btn-dark rounded-0 fw-bold" @onclick="AbrirModalCrear">
                <i class="bi bi-plus-lg me-1"></i> CREAR PRIMER TEMPLATE
            </button>
        </div>
    }

</div>

<!-- MODAL CREAR/EDITAR -->
@if (MostrarModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5); z-index: 1110;">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content border-2 border-dark rounded-0">
                <div class="modal-header bg-dark text-white rounded-0 border-bottom border-dark">
                    <h5 class="modal-title fw-bold text-uppercase">
                        @(EsEdicion ? "EDITAR TEMPLATE" : "NUEVO TEMPLATE DE RECARGA")
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarModal"></button>
                </div>
                <div class="modal-body">
                    <!-- Nombre y Descripción -->
                <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="fw-bold small text-uppercase mb-1">NOMBRE DEL TEMPLATE:</label>
                            <input type="text" @bind="TemplateActual.Nombre"
                            class="form-control border-dark rounded-0 fw-bold" placeholder="Ej: Recarga Nuevo 3" />
                        </div>
                        <div class="col-md-6">
                            <label class="fw-bold small text-uppercase mb-1">DESCRIPCIÓN (OPCIONAL):</label>
                            <input type="text" @bind="TemplateActual.Descripcion" class="form-control border-dark rounded-0"
                            placeholder="Ej: Recarga semanal enero" />
                        </div>
                    </div>

                    <!-- Períodos por Máquina -->
                <div class="border border-dark p-3 bg-light">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="fw-bold text-uppercase m-0">
                                <i class="bi bi-clock-history me-1"></i> PERÍODOS POR MÁQUINA
                            </h6>
                            <button class="btn btn-sm btn-dark rounded-0" @onclick="AgregarPeriodo">
                                <i class="bi bi-plus-lg me-1"></i> Agregar Máquina
                            </button>
                        </div>

                        @if (!PeriodosActuales.Any())
                        {
                            <div class="text-center text-muted py-3">
                                <i class="bi bi-info-circle"></i> Agrega al menos una máquina con su período
                            </div>
                        }
                        else
                        {
                            @for (int i = 0; i < PeriodosActuales.Count; i++)
                            {
                                var periodo = PeriodosActuales[i];
                                var index = i;
                                <div class="card rounded-0 border-dark mb-2">
                                    <div class="card-body p-2">
                                        <div class="row g-2 align-items-end">
                                             <div class="col-md-4 col-12">
                                                 <label class="small fw-bold">MÁQUINA:</label>
                                                 <select class="form-select border-dark rounded-0 text-truncate"
                                         @bind="periodo.MaquinaId">
                                                     <option value="0">-- Seleccionar --</option>
                                                     @if (ListaMaquinas != null)
                                                     {
                                                         @foreach (var m in ListaMaquinas)
                                                         {
                                                             <option value="@m.Id">@m.Nombre</option>
                                                         }
                                                     }
                                                 </select>
                                             </div>
                                          <div class="col-md-3 col-12">
                                              <label class="small fw-bold">DESDE:</label>
                                              <div class="input-group input-group-sm">
                                                    <input type="date"
                                                           class="form-control border-dark rounded-0 date-input"
                                                           value="@periodo.FechaInicio.ToString("yyyy-MM-dd")"
                                                           @onchange="(ChangeEventArgs e) => OnFechaDateChanged(index, true, e)" />
                                                    <input type="text"
                                                           class="form-control border-dark rounded-0 time-input font-monospace"
                                                           value="@periodo.HoraInicioText"
                                                           placeholder="HH:mm"
                                                           maxlength="5"
                                                           @oninput="(ChangeEventArgs e) => OnHoraInput(index, true, e)"
                                                           @onchange="(ChangeEventArgs e) => OnHoraBlur(index, true, e)" />
                                              </div>
                                          </div>
                                          <div class="col-md-3 col-12">
                                              <label class="small fw-bold">HASTA:</label>
                                              <div class="input-group input-group-sm">
                                                    <input type="date"
                                                           class="form-control border-dark rounded-0 date-input"
                                                           value="@periodo.FechaFin.ToString("yyyy-MM-dd")"
                                                           @onchange="(ChangeEventArgs e) => OnFechaDateChanged(index, false, e)" />
                                                    <input type="text"
                                                           class="form-control border-dark rounded-0 time-input font-monospace"
                                                           value="@periodo.HoraFinText"
                                                           placeholder="HH:mm"
                                                           maxlength="5"
                                                           @oninput="(ChangeEventArgs e) => OnHoraInput(index, false, e)"
                                                           @onchange="(ChangeEventArgs e) => OnHoraBlur(index, false, e)" />
                                              </div>
                                          </div>
                                         <div class="col-md-2 col-12">
                                             <div class="d-flex gap-1">
                                                 <button class="btn btn-sm btn-outline-primary rounded-0 flex-fill"
                                         @onclick="() => CargarSlotsParaPeriodo(index)"
                                         disabled="@(periodo.MaquinaId == 0 || CargandoSlots)">
                                                     <i class="bi bi-box-seam me-1"></i> Slots
                                                 </button>
                                                 <button class="btn btn-sm btn-outline-danger rounded-0"
                                         @onclick="() => EliminarPeriodo(index)">
                                                     <i class="bi bi-x-lg"></i>
                                                 </button>
                                             </div>
                                         </div>
                                     </div>

                                    @if (periodo.SnapshotSlots.Any())
                                    {
                                        <div class="mt-3 p-3 bg-white border border-2 border-dark text-center shadow-sm">
                                            <h6 class="fw-bold text-success mb-3 text-uppercase">
                                                <i class="bi bi-check-circle-fill me-1"></i>
                                                @periodo.SnapshotSlots.Count(s => s.ProductoId.HasValue && s.ProductoId > 0) productos configurados
                                                <span class="text-muted ms-1">(de @periodo.SnapshotSlots.Count slots)</span>
                                            </h6>
                                            <button class="btn btn-warning rounded-0 fw-bold border-2 border-dark mb-2 px-4 py-2 text-uppercase btn-lg" style="box-shadow: 3px 3px 0px #000; transition: transform 0.1s;"
                                                onmousedown="this.style.transform='translate(2px, 2px)'; this.style.boxShadow='1px 1px 0px #000';"
                                                onmouseup="this.style.transform='none'; this.style.boxShadow='3px 3px 0px #000';"
                                                onmouseleave="this.style.transform='none'; this.style.boxShadow='3px 3px 0px #000';"
                                                @onclick="() => AbrirEdicionVisual(periodo)">
                                                <i class="bi bi-grid-3x3-gap-fill me-2"></i> EDITAR SLOTS (GRILLA)
                                            </button>
                                            <div class="mt-3 border-top border-dark pt-3">
                                                <button class="btn btn-sm btn-outline-danger rounded-0 fw-bold"
                                                    @onclick="() => periodo.SnapshotSlots.Clear()">
                                                    <i class="bi bi-trash"></i> VACIAR MÁQUINA
                                                </button>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
            <div class="modal-footer border-top border-dark">
                <button type="button" class="btn btn-secondary rounded-0" @onclick="CerrarModal">
                    CANCELAR
                </button>
                <button type="button" class="btn btn-success rounded-0 fw-bold" @onclick="GuardarTemplate"
                disabled="@Guardando">
                    @(Guardando ? "GUARDANDO..." : (EsEdicion ? "ACTUALIZAR" : "GUARDAR TEMPLATE"))
                </button>
            </div>
        </div>
    </div>
</div>
}

<!-- MODAL EDICION VISUAL DE SLOTS -->
@if (PeriodoEnEdicionVisual != null)
{
    var maq = ListaMaquinas?.FirstOrDefault(m => m.Id == PeriodoEnEdicionVisual.MaquinaId)?.Nombre ?? "MÁQUINA";
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.85); z-index: 1120;">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content border-3 border-dark rounded-0">
                <div class="modal-header bg-dark text-white rounded-0 border-bottom border-dark">
                    <h5 class="modal-title fw-bold text-uppercase m-0">
                        <i class="bi bi-grid-3x3-gap-fill me-2"></i> ESTANTERÍA - @maq
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarEdicionVisual"></button>
                </div>
                <div class="modal-body bg-light p-4" style="position: relative;">
                    @if (ProcesandoOcr)
                    {
                        <div style="position: absolute; inset: 0; background: rgba(0,0,0,0.6); z-index: 50; display: flex; flex-direction: column; align-items: center; justify-content: center;">
                            <div class="spinner-border text-light mb-3" style="width: 3rem; height: 3rem;" role="status"></div>
                            <span class="text-white fw-bold text-uppercase" style="letter-spacing: 2px;">PROCESANDO OCR...</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(MensajeErrorOcr))
                    {
                        <div class="alert alert-danger border-2 border-dark rounded-0 mb-3 small fw-bold">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i> @MensajeErrorOcr
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(MensajeInfoOcr))
                    {
                        <div class="alert alert-info border-2 border-dark rounded-0 mb-3 small fw-bold">
                            <i class="bi bi-info-circle-fill me-2"></i> @MensajeInfoOcr
                        </div>
                    }
                    @{
                        var validSlots = PeriodoEnEdicionVisual.SnapshotSlots.ToList();
                        var shelves = validSlots.GroupBy(s => (int.TryParse(s.NumeroSlot, out var n) ? n - 1 : 0) / 10).OrderBy(g => g.Key);
                    }
                    
                    @if (!validSlots.Any())
                    {
                        <div class="text-center py-5">
                            <h5 class="text-muted fw-bold">NO HAY SLOTS CONFIGURADOS</h5>
                            <p class="text-muted small">Esta máquina no tiene slots cargados. Volvé al paso anterior y usá el botón <strong>Slots</strong> para cargarlos desde la configuración de la máquina.</p>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex flex-column gap-4 machine-chassis">
                            @foreach (var shelf in shelves)
                            {
                                int bgIndex = shelf.Key % 2;

                                <div class="shelf-container p-3 border border-3 border-dark bg-white shadow-sm" style="@(bgIndex == 1 ? "background-color: #fafafa !important;" : "")">
                                    <div class="badge bg-dark text-white rounded-0 px-3 py-2 mb-3 fs-6">PISO @(shelf.Key + 1)</div>
                                    <div class="inventory-grid">
                                        @foreach (var slot in shelf.OrderBy(s => int.TryParse(s.NumeroSlot, out var n) ? n : 999))
                                        {
                                            var estaResaltado = SlotsResaltados.Contains(slot.NumeroSlot);
                                            string productColorClass = slot.ProductoId.HasValue ? "bg-white" : "bg-warning bg-opacity-25";

                                            <div class="slot-unit p-2 border border-2 border-dark d-flex flex-column shadow-sm @productColorClass @(estaResaltado ? "slot-ocr-highlight" : "")" style="min-height: 140px; transition: all 0.2s;">
                                                <div class="d-flex justify-content-between align-items-center mb-2 pb-2 border-bottom border-secondary">
                                                    <div class="d-flex align-items-center">
                                                        <span class="text-muted fw-bold me-1" style="font-size:0.7rem;">SLOT</span>
                                                        <span class="font-monospace fw-bold" style="font-size: 0.9rem;">@slot.NumeroSlot</span>
                                                    </div>
                                                    <button class="btn btn-sm text-danger p-0 m-0 lh-1" @onclick="() => PeriodoEnEdicionVisual.SnapshotSlots.Remove(slot)" title="Eliminar Slot">
                                                        <i class="bi bi-x-circle-fill fs-5"></i>
                                                    </button>
                                                </div>
                                                
                                                <div class="mb-2 flex-grow-1 d-flex align-items-center position-relative">
                                                    <select class="form-select form-select-sm border-dark shadow-none fw-bold text-start product-select"
                                                        style="height: 100%; white-space: normal; cursor: pointer; padding: 2px;"
                                                        @bind="slot.ProductoId">
                                                        <option value="">-- SELECCIONAR --</option>
                                                        @if (ListaProductos != null)
                                                        {
                                                            @foreach (var prod in ListaProductos)
                                                            {
                                                                <option value="@prod.Id">@prod.Nombre</option>
                                                            }
                                                        }
                                                    </select>
                                                    @if (slot.Sincronizando)
                                                    {
                                                        <div class="position-absolute top-0 end-0 p-1">
                                                            <div class="spinner-border spinner-border-sm text-dark" role="status"></div>
                                                        </div>
                                                    }
                                                </div>
                                                
                                                <div class="mt-auto d-flex align-items-center justify-content-between border-top border-secondary pt-2">
                                                    <div class="d-flex flex-column w-50 pe-1 border-end border-secondary">
                                                        <span class="text-muted" style="font-size:0.6rem; font-weight: 800;">CANT.</span>
                                                        <input type="number" class="form-control form-control-sm text-center border-dark p-0 fw-bold"
                                                            style="height: 22px; font-size:0.85rem;" min="0" max="100" @bind="slot.CantidadInicial" title="Cantidad Inicial" />
                                                    </div>
                                                    <div class="d-flex flex-column w-50 ps-1">
                                                        <span class="text-muted" style="font-size:0.6rem; font-weight: 800;">CAPAC.</span>
                                                        <span class="fw-bold text-dark text-center d-block border bg-light" style="height: 22px; font-size: 0.9rem; line-height: 22px;">5</span>
                                                    </div>
                                                </div>
                                                <div class="mt-2">
                                                    <select class="form-select form-select-sm border-dark shadow-none fw-bold text-center @GetEstadoSlotCssClass(slot.Estado)"
                                                        style="height: 2rem; font-size: 0.7rem;"
                                                        @bind="slot.Estado" @bind:after="() => OnSlotEstadoChanged(slot)">
                                                        <option value="@EstadoSlot.Vacio">Vacío</option>
                                                        <option value="@EstadoSlot.Pendiente">Pendiente</option>
                                                        <option value="@EstadoSlot.Lleno">Lleno</option>
                                                    </select>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>

                        @if (UltimosSlotsNoCoincidentes.Any())
                        {
                            <div class="mt-4 p-3 border border-2 border-warning bg-warning bg-opacity-10 rounded-0">
                                <h6 class="fw-bold text-uppercase mb-2">
                                    <i class="bi bi-exclamation-triangle-fill text-warning me-2"></i>
                                    Slots sin coincidencia (@UltimosSlotsNoCoincidentes.Count)
                                </h6>
                                <small class="text-muted mb-2 d-block">Estos slots fueron detectados en la foto pero no existen en la máquina. Revisalos manualmente.</small>
                                <div class="table-responsive">
                                    <table class="table table-sm table-borderless m-0 small">
                                        <thead>
                                            <tr class="text-uppercase text-muted">
                                                <th>Slot (OCR)</th>
                                                <th>Cantidad</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var unmatched in UltimosSlotsNoCoincidentes)
                                            {
                                                <tr>
                                                    <td class="font-monospace fw-bold">@unmatched.SlotNumber</td>
                                                    <td class="fw-bold">@unmatched.Quantity</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        }
                    }
                </div>
                <div class="modal-footer bg-light border-top border-dark rounded-0 px-4 py-3 d-flex justify-content-between flex-wrap gap-2">
                    <div class="d-flex gap-2 align-items-center">
                        
                        <InputFile OnChange="HandleOcrPhotoUpload" accept="image/*" class="d-none" id="ocrRecargaFileInput" disabled="@ProcesandoOcr" />
                        <button class="btn btn-success rounded-0 fw-bold border-dark shadow-sm px-3" @onclick="TriggerOcrUpload" disabled="@ProcesandoOcr" title="Fotos legibles tardan ~5s. Asegurate de que los números de slot y cantidades sean claramente visibles. Formatos: JPG, PNG, HEIC. Máx 10MB.">
                            @if (_fotoOcrLoading)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                            }
                            else
                            {
                                <i class="bi bi-camera-fill me-2"></i>
                            }SUBIR FOTO RECARGA
                        </button>
                        <InputFile OnChange="HandleFotoGuiaUpload" accept="image/*" class="d-none" id="fotoGuiaFileInput" />
                        <button class="btn btn-outline-secondary rounded-0 fw-bold px-3" @onclick="TriggerFotoGuiaUpload" title="Cargar foto de referencia (productos)">
                            @if (_fotoGuiaLoading)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                            }
                            else
                            {
                                <i class="bi bi-image me-1"></i>
                            }FOTO GUÍA
                        </button>
                        @if (!string.IsNullOrEmpty(FotoGuiaUrl))
                        {
                            <button class="btn btn-outline-info rounded-0 fw-bold px-3" @onclick="MostrarFotoGuiaModal" title="Ver foto guía">
                                <i class="bi bi-eye me-1"></i>VER FOTO GUÍA
                            </button>
                        }
                    </div>
                    <button type="button" class="btn btn-success px-5 py-2 fw-bold rounded-0 shadow-sm border-2 border-dark text-uppercase" style="font-size: 1.1rem" @onclick="CerrarEdicionVisual">
                        <i class="bi bi-save me-2"></i> GUARDAR CAMBIOS Y VOLVER
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- MODAL FOTO GUÍA (Photo 2 — reference only, never sent to backend) -->
@if (MostrarFotoGuia && !string.IsNullOrEmpty(FotoGuiaUrl))
{
    <div @ref="fotoGuiaModalRef" tabindex="-1"
         class="modal fade show d-block" style="background-color: rgba(0,0,0,0.9); z-index: 1130; outline: none;"
         @onkeydown="OnFotoGuiaKeydown">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content border-3 border-dark rounded-0 bg-dark">
                <div class="modal-header bg-dark text-white rounded-0 border-bottom border-dark">
                    <h5 class="modal-title fw-bold text-uppercase">
                        <i class="bi bi-image-fill me-2"></i> FOTO GUÍA — @((ListaMaquinas?.FirstOrDefault(m => m.Id == PeriodoEnEdicionVisual?.MaquinaId)?.Nombre ?? "MÁQUINA"))
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarFotoGuiaModal"></button>
                </div>
                <div class="modal-body p-0"
                     style="background-color: #111; overflow: hidden; position: relative; height: 80vh; cursor: @(_fotoGuiaDragging ? "grabbing" : "grab"); user-select: none;"
                     @onwheel:preventDefault="true"
                     @onwheel="OnFotoGuiaZoom"
                     @onmousedown="OnFotoGuiaPanStart"
                     @onmousemove="OnFotoGuiaPanMove"
                     @onmouseup="OnFotoGuiaPanEnd"
                     @onmouseleave="OnFotoGuiaPanLeave">
                    <div style="display: flex; align-items: center; justify-content: center; width: 100%; height: 100%;">
                        <img src="@FotoGuiaUrl" alt="Foto Guía"
                             style="max-width: 100%; max-height: 100%; object-fit: contain; transform-origin: center; transform: @FotoGuiaTransform; pointer-events: none; display: block;" />
                    </div>
                </div>
                <div class="modal-footer bg-dark border-top border-dark rounded-0 d-flex justify-content-between align-items-center">
                    <div>
                        <small class="text-muted">
                            <i class="bi bi-info-circle-fill me-1"></i>
                            Esta foto es solo referencia. No se envía a ningún servidor.
                        </small>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        @if (_fotoGuiaZoom > 1.0 || _fotoGuiaPanX != 0 || _fotoGuiaPanY != 0)
                        {
                            <button class="btn btn-sm btn-outline-light rounded-0 fw-bold" @onclick="ResetFotoGuiaView" title="Restablecer zoom">
                                <i class="bi bi-arrow-counterclockwise me-1"></i>RESTABLECER
                            </button>
                        }
                        <span class="text-muted small fw-bold font-monospace">@(FotoGuiaZoomDisplay)x</span>
                        <button type="button" class="btn btn-light rounded-0 fw-bold ms-2" @onclick="CerrarFotoGuiaModal">
                            CERRAR
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- MODAL SLOTS PENDIENTES -->
@if (MostrarModalPendientes)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content border-2 border-dark rounded-0">
                <div class="modal-header bg-warning text-dark rounded-0 border-bottom border-dark">
                    <h5 class="modal-title fw-bold text-uppercase">
                        <i class="bi bi-exclamation-circle-fill me-2"></i> SLOTS PENDIENTES DE CONFIGURAR
                    </h5>
                    <button type="button" class="btn-close" @onclick="CerrarModalPendientes"></button>
                </div>
                <div class="modal-body">
                    @if (SlotsPendientes == null || !SlotsPendientes.Any())
                    {
                        <div class="text-center py-4">
                            <i class="bi bi-check-circle-fill fs-1 text-success"></i>
                            <p class="fw-bold mt-2">No hay slots pendientes</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-borderless m-0">
                                <thead class="text-uppercase small text-muted border-bottom border-dark">
                                    <tr>
                                        <th class="fw-bold">Template</th>
                                        <th class="fw-bold">Máquina</th>
                                        <th class="fw-bold text-center">Slot</th>
                                        <th class="fw-bold text-center">Estado</th>
                                        <th class="fw-bold text-center">Acción</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var pend in SlotsPendientes)
                                    {
                                        <tr class="border-bottom border-light">
                                            <td class="fw-bold">@pend.TemplateNombre</td>
                                            <td>@pend.MaquinaNombre</td>
                                            <td class="text-center font-monospace fw-bold">@pend.NumeroSlot</td>
                                            <td class="text-center">
                                                <span class="badge bg-warning text-dark rounded-0">Pendiente</span>
                                            </td>
                                            <td class="text-center">
                                                <button class="btn btn-sm btn-dark rounded-0 fw-bold"
                                                    @onclick="() => IrAPendiente(pend)">
                                                    <i class="bi bi-pencil me-1"></i> CONFIGURAR
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
                <div class="modal-footer border-top border-dark">
                    <button type="button" class="btn btn-secondary rounded-0" @onclick="CerrarModalPendientes">
                        CERRAR
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- MODAL SINCRONIZAR VENTAS -->
@if (MostrarModalSincronizar)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-2 border-dark rounded-0">
                <div class="modal-header bg-warning text-dark rounded-0 border-bottom border-dark">
                    <h5 class="modal-title fw-bold text-uppercase">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i> CONFIRMAR SINCRONIZACIÓN
                    </h5>
                    <button type="button" class="btn-close" @onclick="CerrarModalSincronizar"></button>
                </div>
                <div class="modal-body">
                    <p class="fw-bold">Estás a punto de reescribir datos históricos en Ventas.</p>
                    <p class="small text-muted mb-4">
                        Esto reemplazará el producto asignado a las ventas del período para que coincida con el snapshot actual.
                    </p>
                    <div class="form-check">
                        <input class="form-check-input border-dark" type="checkbox" id="checkCostos" @bind="ActualizarCostosSincronizacion">
                        <label class="form-check-label fw-bold small" for="checkCostos">
                            ¿Actualizar también Costo de Venta con el valor actual del producto?
                        </label>
                    </div>
                </div>
                <div class="modal-footer border-top border-dark">
                    <button type="button" class="btn btn-secondary rounded-0" @onclick="CerrarModalSincronizar" disabled="@Sincronizando">
                        CANCELAR
                    </button>
                    <button type="button" class="btn btn-warning rounded-0 fw-bold border-dark" @onclick="SincronizarVentas" disabled="@Sincronizando">
                        @(Sincronizando ? "SINCRONIZANDO..." : "SÍ, SINCRONIZAR")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [CascadingParameter] public MainLayout? Layout { get; set; }

    private PeriodoFormModel? PeriodoEnEdicionVisual;

    // OCR-related state
    private bool ProcesandoOcr = false;
    private string MensajeErrorOcr = "";
    private string MensajeInfoOcr = "";
    private byte[]? FotoGuiaData; // Photo 2 — never sent to server
    private string? FotoGuiaUrl; // Blob URL for display
    private bool MostrarFotoGuia = false;
    private HashSet<string> SlotsResaltados = new(); // Slots recently pre-filled via OCR
    private List<OcrRecargaSlotDto> UltimosSlotsNoCoincidentes = new(); // Unmatched OCR slots with quantity

    // Foto Guía zoom/pan state (persists across photo modal close/reopen, resets when opening a different period)
    private double _fotoGuiaZoom = 1.0;
    private double _fotoGuiaPanX = 0;
    private double _fotoGuiaPanY = 0;
    private bool _fotoGuiaDragging = false;
    private double _fotoGuiaLastMouseX = 0;
    private double _fotoGuiaLastMouseY = 0;
    private Dictionary<string, CancellationTokenSource> _syncCtors = new();

    // OCR photo state (persisted to backend on successful OCR)
    private byte[]? _fotoOcrData;
    private string? _fotoOcrUrl;

    // Loading state for photos
    private bool _fotoGuiaLoading = false;
    private bool _fotoOcrLoading = false;

    // Tracks the template being edited for photo upload targets
    private int _currentTemplateId = 0;

    // CSS transform string — must use InvariantCulture or comma-decimal cultures break CSS syntax
    private string FotoGuiaTransform =>
        $"scale({_fotoGuiaZoom.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture)}) translate({_fotoGuiaPanX.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture)}px, {_fotoGuiaPanY.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture)}px)";

    // Zoom display for footer — also InvariantCulture to avoid comma decimals in es-AR etc.
    private string FotoGuiaZoomDisplay =>
        _fotoGuiaZoom.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture);

    private void AbrirEdicionVisual(PeriodoFormModel periodo)
    {
        PeriodoEnEdicionVisual = periodo;
        // Reset OCR state when opening
        ProcesandoOcr = false;
        MensajeErrorOcr = "";
        MensajeInfoOcr = "";
        // Reset zoom/pan for new period (different machine = different photo)
        _fotoGuiaZoom = 1.0;
        _fotoGuiaPanX = 0;
        _fotoGuiaPanY = 0;
        // Note: FotoGuiaData/FotoGuiaUrl intentionally preserved across opens for convenience
        // Colapsar navbar para ganar espacio vertical en pantallas chicas
        Layout?.CollapseNavbar();
    }

    private void CerrarEdicionVisual()
    {
        if (MostrarFotoGuia)
        {
            MostrarFotoGuia = false;
        }
        PeriodoEnEdicionVisual = null;
        RevokeFotoGuiaUrl();
        // Revoke OCR photo blob URL if present
        if (!string.IsNullOrEmpty(_fotoOcrUrl))
        {
            _fotoOcrUrl = null;
        }
        _currentTemplateId = 0;
        // Restaurar navbar al salir del editor
        Layout?.ExpandNavbar();
    }

    /// <summary>
    /// Loads both foto-guia and foto-ocr for a template in parallel.
    /// Non-critical: failures show inline messages but do not block the UI.
    /// </summary>
    private async Task LoadFotosForTemplate(int id)
    {
        _fotoGuiaLoading = true;
        _fotoOcrLoading = true;
        StateHasChanged();

        try
        {
            // Parallel GET requests to both photo endpoints
            var fotoGuiaTask = Http.GetAsync($"api/TemplateRecarga/{id}/foto-guia");
            var fotoOcrTask = Http.GetAsync($"api/TemplateRecarga/{id}/foto-ocr");

            await Task.WhenAll(fotoGuiaTask, fotoOcrTask);

            var guiaResp = await fotoGuiaTask;
            if (guiaResp.IsSuccessStatusCode)
            {
                var bytes = await guiaResp.Content.ReadAsByteArrayAsync();
                FotoGuiaData = bytes;
                FotoGuiaUrl = $"data:image/jpeg;base64,{Convert.ToBase64String(bytes)}";
            }
            // On failure for foto-guia, show inline message but continue
            else if (guiaResp.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                // No photo stored — not an error, just leave current state
            }
            else
            {
                MensajeErrorOcr = "No se pudo cargar la foto guía.";
            }

            var ocrResp = await fotoOcrTask;
            if (ocrResp.IsSuccessStatusCode)
            {
                var bytes = await ocrResp.Content.ReadAsByteArrayAsync();
                _fotoOcrData = bytes;
                _fotoOcrUrl = $"data:image/jpeg;base64,{Convert.ToBase64String(bytes)}";
            }
            else if (ocrResp.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                // No OCR photo stored — not an error
            }
            else
            {
                MensajeErrorOcr = "No se pudo cargar la foto OCR.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Error loading photos for template {Id}", id);
            MensajeErrorOcr = "Error al cargar fotos del template.";
        }
        finally
        {
            _fotoGuiaLoading = false;
            _fotoOcrLoading = false;
            StateHasChanged();
        }
    }

    private async Task TriggerOcrUpload()
    {
        await JS.InvokeVoidAsync("eval", "document.getElementById('ocrRecargaFileInput').click()");
    }

    private async Task TriggerFotoGuiaUpload()
    {
        await JS.InvokeVoidAsync("eval", "document.getElementById('fotoGuiaFileInput').click()");
    }

    private async Task HandleOcrPhotoUpload(InputFileChangeEventArgs e)
    {
        if (PeriodoEnEdicionVisual == null) return;

        var file = e.File;
        MensajeErrorOcr = "";
        MensajeInfoOcr = "";

        // Client-side validation
        if (file == null || file.Size == 0)
        {
            MensajeErrorOcr = "No se seleccionó ningún archivo.";
            return;
        }

        const long maxSize = 10 * 1024 * 1024; // 10MB
        if (file.Size > maxSize)
        {
            MensajeErrorOcr = "La foto supera los 10MB. Usá una foto más pequeña.";
            return;
        }

        var allowedTypes = new[] { "image/jpeg", "image/png", "image/jpg", "image/heic", "image/webp" };
        if (!allowedTypes.Contains(file.ContentType.ToLowerInvariant()))
        {
            MensajeErrorOcr = "Formato no soportado. Usá JPG, PNG o HEIC.";
            return;
        }

        ProcesandoOcr = true;
        MensajeErrorOcr = "";
        StateHasChanged();

        try
        {
            using var stream = file.OpenReadStream(maxSize);
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);
            memoryStream.Position = 0;

            var content = new MultipartFormDataContent();
            var byteContent = new ByteArrayContent(memoryStream.ToArray());
            byteContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);
            content.Add(byteContent, "file", file.Name);

            var response = await Http.PostAsync(
                $"api/ordencarga/from-photo?maquinaId={PeriodoEnEdicionVisual.MaquinaId}",
                content);

            if (!response.IsSuccessStatusCode)
            {
                var error = await response.Content.ReadAsStringAsync();
                MensajeErrorOcr = "Error OCR: " + error;
                return;
            }

            var result = await response.Content.ReadFromJsonAsync<OcrRecargaResultDto>();
            if (result == null)
            {
                MensajeErrorOcr = "No se recibió respuesta del servicio OCR.";
                return;
            }

            // Empty result
            if (result.ExtractedSlots.Count == 0 && result.UnmatchedOcrSlots.Count == 0)
            {
                MensajeInfoOcr = "No se detectaron slots en la foto. Verificá que la foto sea legible.";
                return;
            }

            // Pre-fill matched slots
            SlotsResaltados.Clear();
            foreach (var matched in result.ExtractedSlots)
            {
                var slot = PeriodoEnEdicionVisual.SnapshotSlots
                    .FirstOrDefault(s => s.NumeroSlot == matched.MatchedSlot);

                if (slot != null)
                {
                    slot.CantidadInicial = matched.Quantity;
                    SlotsResaltados.Add(slot.NumeroSlot);

                    // Si la cantidad es 0, el slot no se recargó → Vacío automático
                    if (matched.Quantity == 0)
                    {
                        slot.ProductoId = null;
                        slot.Estado = EstadoSlot.Vacio;
                    }
                }
            }

            // Build unmatched list with quantities (subtract matched from raw OCR slots)
            var matchedSlotNumbers = result.ExtractedSlots
                .Where(e => e.MatchedSlot != null)
                .Select(e => e.MatchedSlot!)
                .ToHashSet(StringComparer.OrdinalIgnoreCase);

            UltimosSlotsNoCoincidentes = result.Slots
                .Where(s => !matchedSlotNumbers.Contains(s.SlotNumber))
                .ToList();

            // Persist OCR photo to backend (non-critical: failure does not block slot population)
            if (_currentTemplateId > 0)
            {
                try
                {
                    memoryStream.Position = 0;
                    var persistContent = new MultipartFormDataContent();
                    var persistBytes = new ByteArrayContent(memoryStream.ToArray());
                    persistBytes.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);
                    persistContent.Add(persistBytes, "file", file.Name);

                    var persistResp = await Http.PutAsync(
                        $"api/TemplateRecarga/{_currentTemplateId}/foto-ocr",
                        persistContent);

                    if (!persistResp.IsSuccessStatusCode)
                    {
                        Logger.LogWarning("OCR photo persist failed with {Status} for template {Id}",
                            persistResp.StatusCode, _currentTemplateId);
                        // Non-critical — do not interrupt the user experience
                    }
                }
                catch (Exception ex)
                {
                    Logger.LogWarning(ex, "Error persisting OCR photo for template {Id}", _currentTemplateId);
                    // Non-critical failure — slot population continues
                }
            }

            // Brief green flash for matched slots — clean up after 1.5s
            _ = Task.Run(async () =>
            {
                await Task.Delay(1500);
                await InvokeAsync(() =>
                {
                    SlotsResaltados.Clear();
                    StateHasChanged();
                });
            });
        }
        catch (Exception ex)
        {
            MensajeErrorOcr = "Error de red: " + ex.Message;
        }
        finally
        {
            ProcesandoOcr = false;
            StateHasChanged();
        }
    }

    private async Task HandleFotoGuiaUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null || file.Size == 0) return;

        RevokeFotoGuiaUrl();

        using var stream = file.OpenReadStream();
        using var memoryStream = new MemoryStream();
        await stream.CopyToAsync(memoryStream);
        FotoGuiaData = memoryStream.ToArray();

        // Create blob URL — this is reference-only, never sent to any backend
        var url = $"data:{file.ContentType};base64,{Convert.ToBase64String(FotoGuiaData)}";
        FotoGuiaUrl = url;
        StateHasChanged();

        // Immediate persist to backend if we have a template ID
        if (_currentTemplateId > 0)
        {
            try
            {
                var content = new MultipartFormDataContent();
                var byteContent = new ByteArrayContent(FotoGuiaData);
                byteContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);
                content.Add(byteContent, "file", file.Name);

                var resp = await Http.PutAsync(
                    $"api/TemplateRecarga/{_currentTemplateId}/foto-guia",
                    content);

                if (!resp.IsSuccessStatusCode)
                {
                    MensajeErrorOcr = "No se pudo guardar la foto guía en el servidor. La foto está en memoria pero se perderá al cerrar.";
                }
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Error persisting foto guia for template {Id}", _currentTemplateId);
                MensajeErrorOcr = "No se pudo guardar la foto guía en el servidor.";
            }
        }
    }

    private void MostrarFotoGuiaModal()
    {
        if (!string.IsNullOrEmpty(FotoGuiaUrl))
        {
            MostrarFotoGuia = true;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (MostrarFotoGuia)
        {
            // Focus the modal wrapper so @onkeydown captures ESC immediately
            // without the user having to click anything first.
            try { await fotoGuiaModalRef.FocusAsync(); } catch { /* best effort */ }
        }
    }

    // ElementReference for the foto guía modal wrapper — needed for FocusAsync
    private ElementReference fotoGuiaModalRef;

    private void CerrarFotoGuiaModal()
    {
        MostrarFotoGuia = false;
        StateHasChanged();
    }

    private void OnFotoGuiaKeydown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape" && MostrarFotoGuia)
            CerrarFotoGuiaModal();
    }

    private void RevokeFotoGuiaUrl()
    {
        if (!string.IsNullOrEmpty(FotoGuiaUrl))
        {
            FotoGuiaUrl = null;
        }
        // FotoGuiaData is kept in memory for convenience across opens
    }

    // === Foto Guía Zoom/Pan handlers ===
    private void OnFotoGuiaZoom(WheelEventArgs e)
    {
        // Proportional zoom based on actual scroll distance.
        // Mouse scrolls send DeltaY ~ ±120 per notch → ~ ±0.3 zoom per notch
        // Touchpad smooth scrolling sends DeltaY ~ ±(1–15) per frame → fine-grained, proportional
        var zoomDelta = -e.DeltaY / 400.0;
        _fotoGuiaZoom = Math.Clamp(_fotoGuiaZoom + zoomDelta, 1.0, 5.0);
    }

    private void OnFotoGuiaPanStart(MouseEventArgs e)
    {
        _fotoGuiaDragging = true;
        _fotoGuiaLastMouseX = e.ClientX;
        _fotoGuiaLastMouseY = e.ClientY;
    }

    private void OnFotoGuiaPanMove(MouseEventArgs e)
    {
        if (!_fotoGuiaDragging) return;
        var dx = e.ClientX - _fotoGuiaLastMouseX;
        var dy = e.ClientY - _fotoGuiaLastMouseY;
        _fotoGuiaPanX += dx / _fotoGuiaZoom;
        _fotoGuiaPanY += dy / _fotoGuiaZoom;
        _fotoGuiaLastMouseX = e.ClientX;
        _fotoGuiaLastMouseY = e.ClientY;
    }

    private void OnFotoGuiaPanEnd(MouseEventArgs e)
    {
        _fotoGuiaDragging = false;
    }

    private void OnFotoGuiaPanLeave()
    {
        _fotoGuiaDragging = false;
    }

    private void ResetFotoGuiaView()
    {
        _fotoGuiaZoom = 1.0;
        _fotoGuiaPanX = 0;
        _fotoGuiaPanY = 0;
    }

    private bool Cargando = false;
    private bool Guardando = false;
    private bool CargandoSlots = false;
    private string MensajeError = "";
    private string MensajeExito = "";

    // Pendientes
    private bool MostrarModalPendientes = false;
    private List<PendingSlotInfo> SlotsPendientes = new();

    // Sincronización
    private bool MostrarModalSincronizar = false;
    private int TemplateIdSincronizar = 0;
    private bool ActualizarCostosSincronizacion = false;
    private bool Sincronizando = false;

    private List<TemplateRecargaDto>? Templates;
    private List<MaquinaSimpleDto>? ListaMaquinas;

    // Modal
    private bool MostrarModal = false;
    private bool EsEdicion = false;
    private int TemplateIdEdicion = 0;
    private TemplateFormModel TemplateActual = new();
    private List<PeriodoFormModel> PeriodosActuales = new();
    private List<ProductoSimpleDto>? ListaProductos;

    protected override async Task OnInitializedAsync()
    {
        await CargarMaquinas();
        await CargarProductos();
        await CargarTemplates();
    }

    private async Task CargarMaquinas()
    {
        try
        {
            ListaMaquinas = await Http.GetFromJsonAsync<List<MaquinaSimpleDto>>("api/Ventas/lista-maquinas");
        }
        catch { }
    }

    private async Task CargarProductos()
    {
        try
        {
            ListaProductos = await Http.GetFromJsonAsync<List<ProductoSimpleDto>>("api/Ventas/lista-productos");
        }
        catch { }
    }

    private async Task CargarTemplates()
    {
        Cargando = true;
        MensajeError = "";
        StateHasChanged();

        try
        {
            Templates = await Http.GetFromJsonAsync<List<TemplateRecargaDto>>("api/TemplateRecarga");
        }
        catch (Exception ex)
        {
            MensajeError = "Error al cargar templates: " + ex.Message;
            Logger.LogError(ex, "Error cargando templates");
        }
        finally
        {
            Cargando = false;
        }
    }

    private void AbrirModalCrear()
    {
        EsEdicion = false;
        TemplateIdEdicion = 0;
        _currentTemplateId = 0;
        TemplateActual = new TemplateFormModel();
        PeriodosActuales = new List<PeriodoFormModel>();
        MostrarModal = true;
    }

    private void AbrirModalEditar(TemplateRecargaDto template)
    {
        EsEdicion = true;
        TemplateIdEdicion = template.Id;
        _currentTemplateId = template.Id;
        TemplateActual = new TemplateFormModel
        {
            Nombre = template.Nombre,
            Descripcion = template.Descripcion
        };
        PeriodosActuales = template.Periodos.Select(p => new PeriodoFormModel
        {
            Id = p.Id,
            MaquinaId = p.MaquinaId,
            FechaInicio = p.FechaInicio,
            FechaFin = p.FechaFin,
            SnapshotSlots = p.SnapshotSlots.Select(s => new SnapshotSlotFormModel
            {
                NumeroSlot = s.NumeroSlot,
                ProductoId = s.ProductoId,
                ProductoNombre = s.ProductoNombre,
                CantidadInicial = s.CantidadInicial,
                CapacidadSlot = 5,
                Estado = s.Estado
            }).ToList()
        }).ToList();

        foreach (var periodo in PeriodosActuales)
            periodo.SyncDisplayFromDateTime();
        MostrarModal = true;

        // Load persisted photos for this template (non-blocking)
        if (template.Id > 0)
        {
            _ = LoadFotosForTemplate(template.Id);
        }
    }

