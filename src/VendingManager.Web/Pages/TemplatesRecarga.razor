    private void OnFechaDateChanged(int index, bool esInicio, ChangeEventArgs e)
    {
        var dateVal = e.Value?.ToString();
        if (string.IsNullOrEmpty(dateVal) || index < 0 || index >= PeriodosActuales.Count) return;
        var p = PeriodosActuales[index];

        // Intentar leer la hora del display text (puede estar editándose)
        var displayText = esInicio ? p.HoraInicioText : p.HoraFinText;
        int hora = 0, minuto = 0;
        bool horaFromDisplay = !string.IsNullOrWhiteSpace(displayText)
                               && int.TryParse(displayText.Replace(":", "").PadRight(4, '0')[..2], out int h)
                               && h is >= 0 and <= 23
                               && int.TryParse(displayText.Replace(":", "").PadRight(4, '0')[2..4], out int m)
                               && m is >= 0 and <= 59;

        if (!horaFromDisplay)
        {
            // Fallback: usar la hora del DateTime actual
            var current = esInicio ? p.FechaInicio : p.FechaFin;
            hora = current.Hour;
            minuto = current.Minute;
        }

        if (DateOnly.TryParse(dateVal, System.Globalization.CultureInfo.InvariantCulture,
                System.Globalization.DateTimeStyles.None, out var dateOnly))
        {
            var d = new DateTime(dateOnly.Year, dateOnly.Month, dateOnly.Day,
                                  hora, minuto, 0, DateTimeKind.Unspecified);
            if (esInicio) p.FechaInicio = d;
            else p.FechaFin = d;
            p.SyncDisplayFromDateTime();
        }
        else
        {
            Logger.LogWarning("OnFechaDateChanged: no se pudo parsear fecha '{DateVal}'", dateVal);
        }
    }

    private void OnHoraInput(int index, bool esInicio, ChangeEventArgs e)
    {
        if (index < 0 || index >= PeriodosActuales.Count) return;
        var raw = e.Value?.ToString() ?? "";
        var formatted = FormatearHoraMask(raw);
        var p = PeriodosActuales[index];
        if (esInicio) p.HoraInicioText = formatted;
        else p.HoraFinText = formatted;
    }

    private void OnHoraBlur(int index, bool esInicio, ChangeEventArgs e)
    {
        if (index < 0 || index >= PeriodosActuales.Count) return;
        var p = PeriodosActuales[index];
        // Al perder foco, consolidar el display text al DateTime
        if (esInicio)
        {
            p.HoraInicioText = FormatearHoraMask(p.HoraInicioText);
            p.SyncDateTimeFromDisplay(true);
        }
        else
        {
            p.HoraFinText = FormatearHoraMask(p.HoraFinText);
            p.SyncDateTimeFromDisplay(false);
        }
        StateHasChanged();
    }

    /// <summary>
    /// Aplica máscara HH:mm en vivo: filtra no-dígitos, inserta ":" después del 2do dígito.
    ///   "1" → "1"       "13" → "13:"     "133" → "13:3"    "1330" → "13:30"
    /// </summary>
    private static string FormatearHoraMask(string input)
    {
        if (string.IsNullOrEmpty(input)) return "";
        var digits = new string(input.Where(char.IsDigit).ToArray());
        if (digits.Length == 0) return "";

        return digits.Length switch
        {
            1 => digits,
            2 => digits + ":",
            >= 3 => digits[..2] + ":" + digits[2..],
            _ => digits
        };
    }

    private void ActualizarNombreProducto(SnapshotSlotFormModel slot)
    {
        if (slot.ProductoId.HasValue && ListaProductos != null)
        {
            var prod = ListaProductos.FirstOrDefault(p => p.Id == slot.ProductoId.Value);
            slot.ProductoNombre = prod?.Nombre ?? "";
