@code {
    [CascadingParameter] public MainLayout? Layout { get; set; }

    private PeriodoFormModel? PeriodoEnEdicionVisual;

    // Design v3 list/editor state
    private bool SoloPendientes = false;
    private bool DensidadCompacta = false;
    private int ActiveMachineIndex = 0;

    // VmSegmented bridge: maps the bool DensidadCompacta to a string key
    // expected by VmSegmented (e.g. "comoda" / "compacta").
    private string DensidadKey
    {
        get => DensidadCompacta ? "compacta" : "comoda";
        set => DensidadCompacta = (value == "compacta");
    }
    private IEnumerable<TemplateRecargaDto>? TemplatesFiltrados => SoloPendientes ? Templates?.Where(t => t.CantidadSlotsPendientes > 0) : Templates;

    // OCR-related state
    private bool _recargaVisible = false; // FotoRecargaModal visibility (PR3)
    private bool _ocrPreviewVisible = false; // Foto OCR full-size preview overlay
    private string MensajeErrorOcr = "";
    private string MensajeInfoOcr = "";
    private byte[]? FotoGuiaData; // Foto guía bytes; persisted via PUT .../foto-guia on upload
    private string? FotoGuiaUrl; // Blob URL for display
    private bool _guiaVisible = false; // Panel visibility (replaces old modal MostrarFotoGuia)
    // PR3: SlotsResaltados and UltimosSlotsNoCoincidentes removed — no longer used
    // (the old direct-apply OCR path was replaced by FotoRecargaModal in PR3)

    // Pan/zoom state is handled by foto-guia.js — no C# fields needed
    private Dictionary<string, CancellationTokenSource> _syncCtors = new();

    // OCR photo state (persisted to backend on successful OCR)
    private byte[]? _fotoOcrData;
    private string? _fotoOcrUrl;

    // Loading state for photos
    private bool _fotoGuiaLoading = false;
    private bool _fotoOcrLoading = false;

    // Tracks the template being edited for photo upload targets
    private int _currentTemplateId = 0;

    // === Defensive scroll lock helpers (guard against missing JS) ===
    private async Task LockScroll() {
        try { await JS.InvokeVoidAsync("modalScrollLock.lock"); } catch { }
    }
    private async Task UnlockScroll() {
        try { await JS.InvokeVoidAsync("modalScrollLock.unlock"); } catch { }
    }

    private async Task AbrirEdicionVisual(PeriodoFormModel periodo)
    {
        PeriodoEnEdicionVisual = periodo;
        ActiveMachineIndex = PeriodosActuales.FindIndex(p => p.Id == periodo.Id);
        if (ActiveMachineIndex < 0) ActiveMachineIndex = 0;
        await OpenEditorCommon();
    }

    private async Task AbrirEdicionVisual(TemplateRecargaDto template, PeriodoRecargaDto periodo)
    {
        _currentTemplateId = template.Id;
        // Capture template-level fields so a visual-editor save (PUT) doesn't overwrite
        // Nombre/Descripcion with empty values — the PUT endpoint does not re-validate them.
        EsEdicion = true;
        TemplateIdEdicion = template.Id;
        TemplateActual = new TemplateFormModel
        {
            Nombre = template.Nombre,
            Descripcion = template.Descripcion
        };
        PeriodosActuales = template.Periodos.Select(p => new PeriodoFormModel
        {
            Id = p.Id,
            MaquinaId = p.MaquinaId,
            FechaRecarga = p.FechaRecarga,
            SnapshotSlots = p.SnapshotSlots.Select(s => new SnapshotSlotFormModel
            {
                NumeroSlot = s.NumeroSlot,
                ProductoId = s.ProductoId,
                ProductoNombre = s.ProductoNombre,
                CantidadInicial = s.CantidadInicial,
                CapacidadSlot = s.CapacidadSlot,
                Estado = s.Estado
            }).ToList()
        }).ToList();
        foreach (var p in PeriodosActuales) p.SyncDisplayFromDateTime();
        ActiveMachineIndex = PeriodosActuales.FindIndex(p => p.Id == periodo.Id);
        if (ActiveMachineIndex < 0) ActiveMachineIndex = 0;
        PeriodoEnEdicionVisual = PeriodosActuales[ActiveMachineIndex];
        await OpenEditorCommon();
    }

    private async Task OpenEditorCommon()
    {
        var periodo = PeriodoEnEdicionVisual;
        if (periodo == null) return;
        // Reset OCR state when opening
        MensajeErrorOcr = "";
        MensajeInfoOcr = "";
        // Clear photo state before loading new periodo — prevents stale photo leakage
        RevokeFotoGuiaUrl();
        FotoGuiaData = null;
        _fotoOcrUrl = null;
        _fotoOcrData = null;
        // Load photos for this specific periodo
        await LoadFotosForPeriodo(periodo.Id);
        // Note: FotoGuiaData/FotoGuiaUrl intentionally preserved across opens for convenience
        // Colapsar navbar para ganar espacio vertical en pantallas chicas
        Layout?.CollapseNavbar();
        StateHasChanged();
        // Reset scroll position — DOM structure changes dramatically (main content hidden)
        // Force body scroll unlock (defensive against stale modal locks)
        try { await JS.InvokeVoidAsync("eval", "document.body.style.overflow='';window.scrollTo(0,0);"); } catch { }
        await Task.CompletedTask;
    }

    private async Task CerrarEdicionVisual()
    {
        _guiaVisible = false;
        PeriodoEnEdicionVisual = null;
        // Photos kept in memory for convenience across reopens — no revoke here
        // Restaurar navbar al salir del editor
        Layout?.ExpandNavbar();
        // Defensive: ensure scroll is never left locked
        try { await JS.InvokeVoidAsync("eval", "document.body.style.overflow='';"); } catch { }
        StateHasChanged();
        await Task.CompletedTask;
    }

    /// <summary>
    /// Loads both foto-guia and foto-ocr for a specific periodo.
    /// Non-critical: failures show inline messages but do not block the UI.
    /// </summary>
    private async Task LoadFotosForPeriodo(int periodoId)
    {
        if (periodoId <= 0 || _currentTemplateId <= 0) return;

        // Check periodo-level flags to avoid unnecessary 404 requests (browser console noise)
        var template = Templates?.FirstOrDefault(t => t.Id == _currentTemplateId);
        var periodo = template?.Periodos.FirstOrDefault(p => p.Id == periodoId);
        var hasFotoGuia = periodo?.TieneFotoGuia ?? true;
        var hasFotoOcr = periodo?.TieneFotoOcr ?? true;

        if (!hasFotoGuia && !hasFotoOcr) return;

        _fotoGuiaLoading = hasFotoGuia;
        _fotoOcrLoading = hasFotoOcr;
        StateHasChanged();

        try
        {
            Task<HttpResponseMessage>? fotoGuiaTask = hasFotoGuia
                ? Http.GetAsync($"api/TemplateRecarga/{_currentTemplateId}/periodo/{periodoId}/foto-guia")
                : null;
            Task<HttpResponseMessage>? fotoOcrTask = hasFotoOcr
                ? Http.GetAsync($"api/TemplateRecarga/{_currentTemplateId}/periodo/{periodoId}/foto-ocr")
                : null;

            if (fotoGuiaTask != null && fotoOcrTask != null)
                await Task.WhenAll(fotoGuiaTask, fotoOcrTask);
            else if (fotoGuiaTask != null)
                await fotoGuiaTask;
            else if (fotoOcrTask != null)
                await fotoOcrTask;

            if (fotoGuiaTask != null)
            {
                var guiaResp = fotoGuiaTask.Result;
                if (guiaResp.IsSuccessStatusCode)
                {
                    var bytes = await guiaResp.Content.ReadAsByteArrayAsync();
                    FotoGuiaData = bytes;
                    FotoGuiaUrl = $"data:image/jpeg;base64,{Convert.ToBase64String(bytes)}";
                }
                else if (guiaResp.StatusCode == System.Net.HttpStatusCode.NotFound)
                {
                    RevokeFotoGuiaUrl();
                    FotoGuiaData = null;
                }
                else
                {
                    MensajeErrorOcr = "No se pudo cargar la foto guía.";
                }
            }

            if (fotoOcrTask != null)
            {
                var ocrResp = fotoOcrTask.Result;
                if (ocrResp.IsSuccessStatusCode)
                {
                    var bytes = await ocrResp.Content.ReadAsByteArrayAsync();
                    _fotoOcrData = bytes;
                    _fotoOcrUrl = $"data:image/jpeg;base64,{Convert.ToBase64String(bytes)}";
                }
                else if (ocrResp.StatusCode == System.Net.HttpStatusCode.NotFound)
                {
                    _fotoOcrData = null;
                    _fotoOcrUrl = null;
                }
                else
                {
                    MensajeErrorOcr = "No se pudo cargar la foto OCR.";
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Error loading photos for periodo {PeriodoId}", periodoId);
            MensajeErrorOcr = "Error al cargar fotos del período.";
        }
        finally
        {
            _fotoGuiaLoading = false;
            _fotoOcrLoading = false;
            StateHasChanged();
        }
    }

    // PR3 Migration: TriggerOcrUpload and HandleOcrPhotoUpload were moved into
    // FotoRecargaModal.Capturar step. The "Foto recarga" button now opens the modal.
    // The modal handles HTTP POST + OcrRecargaMapper mapping + review.
    // The page keeps only AplicarRecarga which writes confirmed quantities to the grid.

    private void AplicarRecarga(Dictionary<int, int> map)
    {
        if (PeriodoEnEdicionVisual == null) return;

        int confirmed = 0;
        foreach (var kvp in map)
        {
            var slotIdx = kvp.Key;
            var qty = kvp.Value;
            if (slotIdx >= 0 && slotIdx < PeriodoEnEdicionVisual.SnapshotSlots.Count)
            {
                PeriodoEnEdicionVisual.SnapshotSlots[slotIdx].CantidadInicial = qty;
                confirmed++;
            }
        }

        MensajeInfoOcr = $"Se aplicaron {confirmed} slots desde OCR.";
        _recargaVisible = false;
        StateHasChanged();
    }

    private List<SlotActual> ProjectedSlotsActual()
    {
        if (PeriodoEnEdicionVisual == null) return new();

        return PeriodoEnEdicionVisual.SnapshotSlots
            .Select((s, i) => new SlotActual
            {
                Index = i,
                Slot = s.NumeroSlot,
                Producto = s.ProductoNombre,
                Capacidad = s.CapacidadSlot
            })
            .ToList();
    }

    // PR3 Migration: HandleOcrPhotoUpload removed.
    // OCR upload + HTTP call + mapping + review are now handled by FotoRecargaModal.
    // The page's AplicarRecarga method writes confirmed quantities to the grid.
    // The old direct-apply path (L992-L1009) no longer exists.
    // Foto OCR is persisted inside FotoRecargaModal.AplicarRecarga (PUT .../foto-ocr)
    // and reloaded by LoadFotosForPeriodo; the top-bar thumbnail renders it as proof.

    private void RevokeFotoGuiaUrl()
    {
        if (!string.IsNullOrEmpty(FotoGuiaUrl))
        {
            FotoGuiaUrl = null;
        }
        // FotoGuiaData is kept in memory for convenience across opens
    }

    // === Foto Guía Panel management (replaces old fullscreen modal + C# pan/zoom) ===
    private void ToggleGuiaPanel()
    {
        _guiaVisible = !_guiaVisible;
    }

    private void CerrarGuiaPanel()
    {
        _guiaVisible = false;
    }

    private async Task HandlePanelFotoUpload(byte[] bytes)
    {
        if (bytes == null || bytes.Length == 0) return;

        // Show the photo immediately for a responsive feel, then persist.
        RevokeFotoGuiaUrl();
        FotoGuiaData = bytes;
        FotoGuiaUrl = $"data:image/jpeg;base64,{Convert.ToBase64String(bytes)}";
        _guiaVisible = true;
        StateHasChanged();

        await PersistFotoGuia(bytes);
    }

    /// <summary>
    /// Uploads the foto guía bytes to the server so they survive a reload.
    /// Requires a persisted template and periodo; the visual editor is always
    /// opened from an existing template, so both ids are valid there.
    /// </summary>
    private async Task PersistFotoGuia(byte[] bytes)
    {
        var periodoId = PeriodoEnEdicionVisual?.Id ?? 0;
        if (_currentTemplateId <= 0 || periodoId <= 0)
        {
            ShowToast("Guardá el template antes de subir la foto guía.", "bi-exclamation-triangle-fill");
            return;
        }

        try
        {
            using var content = new MultipartFormDataContent();
            var byteContent = new ByteArrayContent(bytes);
            byteContent.Headers.ContentType =
                new System.Net.Http.Headers.MediaTypeHeaderValue("image/jpeg");
            content.Add(byteContent, "file", "foto-guia.jpg");

            var response = await Http.PutAsync(
                $"api/TemplateRecarga/{_currentTemplateId}/periodo/{periodoId}/foto-guia",
                content);

            if (response.IsSuccessStatusCode)
            {
                // Keep periodo flag in sync so a later reopen fetches the photo.
                var template = Templates?.FirstOrDefault(t => t.Id == _currentTemplateId);
                var periodo = template?.Periodos.FirstOrDefault(p => p.Id == periodoId);
                if (periodo != null) periodo.TieneFotoGuia = true;

                ShowToast("Foto guía guardada", "bi-check-circle-fill");
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                ShowToast($"Error al guardar la foto guía (HTTP {(int)response.StatusCode}): {body}",
                    "bi-exclamation-triangle-fill");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[HandlePanelFotoUpload] Error al persistir la foto guía");
            ShowToast("Error de red al guardar la foto guía: " + ex.Message, "bi-exclamation-triangle-fill");
        }
    }

    private bool Cargando = false;
    private bool Guardando = false;
    private bool CargandoSlots = false;
    private string? ToastMessage { get; set; }
    private string ToastIcon { get; set; } = "bi-check-circle-fill";
    private System.Timers.Timer? _toastTimer;

    private void ShowToast(string message, string icon = "bi-check-circle-fill")
    {
        ToastMessage = message;
        ToastIcon = icon;
        _toastTimer?.Stop();
        _toastTimer?.Dispose();
        _toastTimer = new System.Timers.Timer(2400);
        _toastTimer.Elapsed += (s, e) =>
        {
            ToastMessage = null;
            InvokeAsync(StateHasChanged);
        };
        _toastTimer.AutoReset = false;
        _toastTimer.Start();
    }

    // State transition methods
    private async Task TerminarTemplate(int templateId)
    {
        try
        {
            var response = await Http.PostAsync($"api/TemplateRecarga/{templateId}/terminar", null);
            if (response.IsSuccessStatusCode)
            {
                ShowToast("Template terminado correctamente.", "bi-check-circle-fill");
                await CargarTemplates();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                ShowToast("Error al terminar template: " + error, "bi-exclamation-triangle-fill");
            }
        }
        catch (Exception ex)
        {
            ShowToast("Error de red: " + ex.Message, "bi-exclamation-triangle-fill");
        }
    }

    private async Task ReabrirTemplate(int templateId)
    {
        try
        {
            var response = await Http.PostAsync($"api/TemplateRecarga/{templateId}/reabrir", null);
            if (response.IsSuccessStatusCode)
            {
                ShowToast("Template reabierto correctamente.", "bi-check-circle-fill");
                await CargarTemplates();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                ShowToast("Error al reabrir template: " + error, "bi-exclamation-triangle-fill");
            }
        }
        catch (Exception ex)
        {
            ShowToast("Error de red: " + ex.Message, "bi-exclamation-triangle-fill");
        }
    }

    private string GetEstadoBadgeClass(TemplateRecargaDto template) => template.Estado switch
    {
        EstadoTemplate.Pendiente => "bg-warning text-dark",
        EstadoTemplate.Terminado when template.EsActivo => "bg-success",
        EstadoTemplate.Terminado => "bg-dark",
        _ => "bg-secondary"
    };

    private string GetEstadoBadgeVariant(TemplateRecargaDto template) => template.Estado switch
    {
        EstadoTemplate.Pendiente => "warning",
        EstadoTemplate.Terminado when template.EsActivo => "success",
        EstadoTemplate.Terminado => "dark",
        _ => "dark"
    };

    private string GetEstadoDisplay(TemplateRecargaDto template)
    {
        if (template.Estado == EstadoTemplate.Terminado && template.EsActivo)
            return "ACTIVO";
        return Enum.IsDefined(template.Estado)
            ? template.Estado.ToString().ToUpper()
            : "DESCONOCIDO";
    }

    private string GetEstadoTagVariant(TemplateRecargaDto template) => template.Estado switch
    {
        EstadoTemplate.Terminado => "ok",
        _ => "pending"
    };

    private (int units, int cap, int configured, int total, int vacios) GetPeriodoStats(PeriodoFormModel periodo)
    {
        var slots = periodo.SnapshotSlots;
        var cap = slots.Sum(s => s.CapacidadSlot);
        var units = slots.Sum(s => s.CantidadInicial);
        var configured = slots.Count(s => s.Estado != EstadoSlot.Vacio);
        var vacios = slots.Count(s => s.Estado == EstadoSlot.Vacio);
        return (units, cap, configured, slots.Count, vacios);
    }

    private int GetEstanteriaPct()
    {
        var slots = PeriodoEnEdicionVisual?.SnapshotSlots ?? new List<SnapshotSlotFormModel>();
        var cap = slots.Sum(s => s.CapacidadSlot);
        var units = slots.Sum(s => s.CantidadInicial);
        return cap > 0 ? (units * 100 / cap) : 0;
    }

