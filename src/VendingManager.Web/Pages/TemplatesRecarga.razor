    private async Task EliminarFotoGuia()
    {
        // Close the modal first
        MostrarFotoGuia = false;
        try { await JS.InvokeVoidAsync("eval", "document.body.style.overflow='';"); } catch { }

        // Clear local state
        RevokeFotoGuiaUrl();
        FotoGuiaData = null;

        // Delete from backend if we have a periodo
        if (PeriodoEnEdicionVisual?.Id > 0)
        {
            try
            {
                var response = await Http.DeleteAsync($"api/TemplateRecarga/{_currentTemplateId}/periodo/{PeriodoEnEdicionVisual.Id}/foto-guia");
                if (!response.IsSuccessStatusCode && response.StatusCode != System.Net.HttpStatusCode.NotFound)
                {
