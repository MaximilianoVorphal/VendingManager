        public List<SnapshotSlotFormModel> SnapshotSlots { get; set; } = new();

        // Display strings para masking en vivo del input de hora
        public string HoraInicioText { get; set; } = "";
        public string HoraFinText { get; set; } = "";

        public void SyncDisplayFromDateTime()
        {
            HoraInicioText = FechaInicio.ToString("HH:mm");
            HoraFinText = FechaFin.ToString("HH:mm");
        }

        public void SyncDateTimeFromDisplay(bool esInicio)
        {
            if (TryParseHora24Internal(esInicio ? HoraInicioText : HoraFinText, out int h, out int m))
            {
                var dt = new DateTime(
                    (esInicio ? FechaInicio : FechaFin).Year,
                    (esInicio ? FechaInicio : FechaFin).Month,
                    (esInicio ? FechaInicio : FechaFin).Day,
                    h, m, 0, DateTimeKind.Unspecified);
                if (esInicio) FechaInicio = dt; else FechaFin = dt;
            }
        }

        private static bool TryParseHora24Internal(string input, out int hora, out int minuto)
        {
            hora = 0; minuto = 0;
            if (string.IsNullOrWhiteSpace(input)) return false;
            var cleaned = input.Replace(":", "").Trim();
            if (cleaned.Length is 1 or 2 && int.TryParse(cleaned, out int v) && v is >= 0 and <= 23)
            { hora = v; return true; }
            if (cleaned.Length is 3 or 4 && int.TryParse(cleaned, out int v2))
            {
                int h = cleaned.Length == 3 ? v2 / 10 : v2 / 100;
                int m = cleaned.Length == 3 ? (v2 % 10) * 10 : v2 % 100;
                if (h is >= 0 and <= 23 && m is >= 0 and <= 59) { hora = h; minuto = m; return true; }
            }
            return false;
        }
    }

