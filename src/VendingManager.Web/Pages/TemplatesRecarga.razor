    private async Task CargarSlotsParaPeriodo(int periodoIndex)
    {
        if (periodoIndex < 0 || periodoIndex >= PeriodosActuales.Count) return;

        var periodo = PeriodosActuales[periodoIndex];
        if (periodo.MaquinaId == 0) return;

        CargandoSlots = true;
        StateHasChanged();

        try
        {
            var slots = await Http.GetFromJsonAsync<List<SnapshotSlotFormModel>>(
            $"api/TemplateRecarga/maquina/{periodo.MaquinaId}/slots");

            if (slots != null)
            {
                periodo.SnapshotSlots = slots;
                foreach (var slot in periodo.SnapshotSlots)
                {
                    slot.CapacidadSlot = 5;
                }
                ShowToast($"Se cargaron {slots.Count} slots para la máquina", "bi-check-circle-fill");
            }
        }
        catch (Exception ex)
        {
            ShowToast("Error al cargar slots: " + ex.Message, "bi-exclamation-triangle-fill");
        }
        finally
        {
            CargandoSlots = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Builds the persistence DTO from the in-memory form state.
    /// Shared by the modal save (GuardarTemplate) and the visual editor save (GuardarCarga)
    /// so both flows hit the same backend contract.
    /// Normalizes empty/pending slots (clears product + quantity) as a side effect.
    /// </summary>
    private CreateTemplateDto BuildTemplateDto()
    {
        return new CreateTemplateDto
        {
            Nombre = TemplateActual.Nombre,
            Descripcion = TemplateActual.Descripcion,
            Periodos = PeriodosActuales
                .Where(p => p.MaquinaId > 0)
                .Select(p => new CreatePeriodoDto
                {
                    MaquinaId = p.MaquinaId,
                    FechaRecarga = p.FechaRecarga,
                    SnapshotSlots = p.SnapshotSlots
                        .Select(s =>
                        {
                            // Solo limpiar Pendiente si no tiene producto seleccionado (sigue pendiente)
                            // Vacío → siempre limpiar
                            if (s.Estado == EstadoSlot.Vacio)
                            {
                                s.ProductoId = null;
                                s.CantidadInicial = 0;
                            }
                            else if (s.Estado == EstadoSlot.Pendiente && (!s.ProductoId.HasValue || s.ProductoId <= 0))
                            {
                                s.ProductoId = null;
                                s.CantidadInicial = 0;
                            }
                            return new CreateSnapshotSlotDto
                            {
                                NumeroSlot = s.NumeroSlot,
                                ProductoId = s.ProductoId,
                                CantidadInicial = s.CantidadInicial,
                                CapacidadSlot = 5,
                                Estado = s.Estado
                            };
                        }).ToList()
                }).ToList()
        };
    }

    private async Task GuardarTemplate()
    {
        if (string.IsNullOrWhiteSpace(TemplateActual.Nombre))
        {
            ShowToast("El nombre del template es requerido", "bi-exclamation-triangle-fill");
            return;
        }

        if (!PeriodosActuales.Any() || PeriodosActuales.All(p => p.MaquinaId == 0))
        {
            ShowToast("Debe agregar al menos un período con una máquina seleccionada", "bi-exclamation-triangle-fill");
            return;
        }

        Guardando = true;
        StateHasChanged();

        try
        {
            var dto = BuildTemplateDto();

            // [DEBUG] Log the exact payload being sent so we can confirm shape + counts.
            var debugJson = System.Text.Json.JsonSerializer.Serialize(dto);
            Logger.LogInformation("[GuardarTemplate] EsEdicion={EsEdicion} Id={Id} Periodos={Periodos} Slots={Slots}",
                EsEdicion, TemplateIdEdicion, dto.Periodos.Count, dto.Periodos.Sum(p => p.SnapshotSlots.Count));
            Logger.LogInformation("[GuardarTemplate] Payload: {Payload}", debugJson);
            try { await JS.InvokeVoidAsync("console.log", "[GuardarTemplate] Payload:", debugJson); } catch { }

            HttpResponseMessage response;
            if (EsEdicion)
            {
                response = await Http.PutAsJsonAsync($"api/TemplateRecarga/{TemplateIdEdicion}", dto);
            }
            else
            {
                response = await Http.PostAsJsonAsync("api/TemplateRecarga", dto);
            }

            // [DEBUG] Always read the body and log the status so we know exactly what came back.
            var body = await response.Content.ReadAsStringAsync();
            Logger.LogInformation("[GuardarTemplate] Response {Status} ({Code}) — body: {Body}",
                (int)response.StatusCode, response.StatusCode, body);
            try { await JS.InvokeVoidAsync("console.log", $"[GuardarTemplate] Response {(int)response.StatusCode} {response.StatusCode}", body); } catch { }

            if (response.IsSuccessStatusCode)
            {
                ShowToast($"Template guardado (HTTP {(int)response.StatusCode})", "bi-check-circle-fill");
                await UnlockScroll();
                MostrarModal = false;
                await CargarTemplates();
                // [DEBUG] Confirm the just-saved template is actually in the reloaded list.
                Logger.LogInformation("[GuardarTemplate] Post-reload: {Count} templates en lista", Templates?.Count ?? -1);
                try { await JS.InvokeVoidAsync("console.log", $"[GuardarTemplate] Post-reload: {Templates?.Count ?? -1} templates en lista"); } catch { }
            }
            else
            {
                ShowToast($"Error HTTP {(int)response.StatusCode}: {body}", "bi-exclamation-triangle-fill");
            }
        }
        catch (Exception ex)
        {
            // [DEBUG] Surface the full exception — a throw here means the modal stays open.
            Logger.LogError(ex, "[GuardarTemplate] Excepción al guardar");
            try { await JS.InvokeVoidAsync("console.error", "[GuardarTemplate] Excepción:", ex.ToString()); } catch { }
            ShowToast("Error al guardar: " + ex.Message, "bi-exclamation-triangle-fill");
        }
        finally
        {
            Guardando = false;
        }
    }

