    private void VaciarMaquina()
    {
        if (PeriodoEnEdicionVisual == null) return;
        foreach (var slot in PeriodoEnEdicionVisual.SnapshotSlots)
        {
            slot.ProductoId = null;
            slot.ProductoNombre = "";
            slot.CantidadInicial = 0;
            slot.Estado = EstadoSlot.Vacio;
        }
        StateHasChanged();
    }

    private void ResetSlots()
    {
        if (PeriodoEnEdicionVisual == null) return;
        foreach (var slot in PeriodoEnEdicionVisual.SnapshotSlots)
        {
            slot.CantidadInicial = 0;
            if (slot.Estado == EstadoSlot.Lleno && slot.ProductoId.HasValue && slot.ProductoId > 0)
                slot.Estado = EstadoSlot.Pendiente;
        }
        StateHasChanged();
    }

    private async Task GuardarCarga()
    {
        // A brand-new, not-yet-persisted template (no id) has nothing to PUT.
        // It must be created first via the modal save — just close the editor.
        if (_currentTemplateId <= 0)
        {
            await CerrarEdicionVisual();
            return;
        }

        Guardando = true;
        StateHasChanged();

        try
        {
            var dto = BuildTemplateDto();
            var response = await Http.PutAsJsonAsync($"api/TemplateRecarga/{_currentTemplateId}", dto);
            var body = await response.Content.ReadAsStringAsync();

            if (response.IsSuccessStatusCode)
            {
                ShowToast("Carga guardada", "bi-check-circle-fill");
                await CargarTemplates();
                await CerrarEdicionVisual();
            }
            else
            {
                ShowToast($"Error HTTP {(int)response.StatusCode}: {body}", "bi-exclamation-triangle-fill");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[GuardarCarga] Excepción al guardar la carga");
            ShowToast("Error al guardar: " + ex.Message, "bi-exclamation-triangle-fill");
        }
        finally
        {
            Guardando = false;
        }
    }

