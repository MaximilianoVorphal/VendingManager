    private async Task OnSlotProductoChanged(SnapshotSlotFormModel slot, int periodoId)
    {
        if (!slot.ProductoId.HasValue || slot.ProductoId <= 0)
            return;

        // Cancel any in-flight request for this slot
        if (_syncCtors.TryGetValue(slot.NumeroSlot, out var existing))
        {
            existing.Cancel();
            _syncCtors.Remove(slot.NumeroSlot);
        }

        var cts = new CancellationTokenSource();
        _syncCtors[slot.NumeroSlot] = cts;

        slot.Sincronizando = true;
        slot.SyncError = false;
        StateHasChanged();

        try
        {
            await Task.Delay(500, cts.Token); // debounce
            if (cts.Token.IsCancellationRequested) return;

            var response = await Http.PatchAsJsonAsync(
                $"api/TemplateRecarga/{TemplateIdEdicion}/periodo/{periodoId}/slot/{slot.NumeroSlot}/sincronizar-producto",
                new { productoId = slot.ProductoId });

            if (!response.IsSuccessStatusCode)
                slot.SyncError = true;
            else
                slot.SyncError = false;
        }
        catch (OperationCanceledException)
        {
            // Debounce cancelled — expected
        }
        finally
        {
            slot.Sincronizando = false;
            _syncCtors.Remove(slot.NumeroSlot);
            StateHasChanged();
        }
    }

