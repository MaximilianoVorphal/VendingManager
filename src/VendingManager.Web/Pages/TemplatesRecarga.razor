        finally
        {
            Sincronizando = false;
            MostrarModalSincronizar = false;
            await UnlockScroll();
            StateHasChanged();
        }
    }

    // === Sincronización global (todos los templates) ===

    private async Task AbrirModalSincronizarGlobal()
    {
        await LockScroll();
        ActualizarCostosSincronizacionGlobal = false;
        ResultadoSincronizacionGlobal = null;
        MostrarModalSincronizarGlobal = true;
    }

    private async Task CerrarModalSincronizarGlobal()
    {
        await UnlockScroll();
        MostrarModalSincronizarGlobal = false;
    }

    private async Task SincronizarTodasVentas()
    {
        SincronizandoGlobal = true;
        MensajeError = "";
        MensajeExito = "";
        ResultadoSincronizacionGlobal = null;
        StateHasChanged();

        try
        {
            var response = await Http.PostAsync(
                $"api/TemplateRecarga/sincronizar-todas-ventas?actualizarCostos={ActualizarCostosSincronizacionGlobal}",
                null);

            if (response.IsSuccessStatusCode)
            {
                ResultadoSincronizacionGlobal = await response.Content.ReadFromJsonAsync<SyncAllResultDto>();
                MensajeExito = $"Sincronización completada: {ResultadoSincronizacionGlobal?.TotalVentasActualizadas ?? 0} ventas actualizadas en {ResultadoSincronizacionGlobal?.TemplatesProcesados ?? 0} templates.";
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                MensajeError = "Error al sincronizar: " + error;
            }
        }
        catch (Exception ex)
        {
            MensajeError = "Error de red: " + ex.Message;
        }
        finally
        {
            SincronizandoGlobal = false;
            StateHasChanged();
        }
    }

