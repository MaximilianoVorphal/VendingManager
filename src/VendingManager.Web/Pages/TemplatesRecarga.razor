    private async Task OnMaquinaChanged(int index, string? value)
    {
        if (index < 0 || index >= PeriodosActuales.Count || !int.TryParse(value, out var id))
            return;

        var periodo = PeriodosActuales[index];

        // Si ya había slots configurados para OTRA máquina, los limpiamos.
        // No tiene sentido mezclar slots de dos máquinas distintas — cada período
        // corresponde a UNA sola máquina y sus slots reales.
        if (periodo.MaquinaId != id && periodo.SnapshotSlots.Count > 0)
        {
            periodo.SnapshotSlots.Clear();
        }

        periodo.MaquinaId = id;

        // Cargar slots SIEMPRE que cambie la máquina y sea válida.
        // Antes solo cargaba si el período estaba vacío, lo que provocaba
        // que al cambiar de máquina se mantuvieran los slots de la anterior.
        if (id > 0)
        {
            await CargarSlotsParaPeriodo(index);
        }
    }

    private void OnHoraRecargaChanged(int index, string? value)
    {
        if (index < 0 || index >= PeriodosActuales.Count) return;
        var p = PeriodosActuales[index];
        p.HoraRecargaText = FormatearHoraMask(value ?? "");
        p.SyncDateTimeFromRecarga();
    }

    private void OnFechaRecargaDateChanged(int index, string? dateVal)
    {
        if (string.IsNullOrEmpty(dateVal) || index < 0 || index >= PeriodosActuales.Count) return;
        var p = PeriodosActuales[index];

        // Intentar leer la hora del display text (puede estar editándose)
        int hora = p.FechaRecarga.Hour;
        int minuto = p.FechaRecarga.Minute;

        if (!string.IsNullOrWhiteSpace(p.HoraRecargaText))
        {
            var cleaned = p.HoraRecargaText.Replace(":", "").PadRight(4, '0');
            if (cleaned.Length >= 4 &&
                int.TryParse(cleaned[..2], out int h) && h is >= 0 and <= 23 &&
                int.TryParse(cleaned[2..4], out int m) && m is >= 0 and <= 59)
            {
                hora = h;
                minuto = m;
            }
        }

        if (DateOnly.TryParse(dateVal, System.Globalization.CultureInfo.InvariantCulture,
                System.Globalization.DateTimeStyles.None, out var dateOnly))
        {
            p.FechaRecarga = new DateTime(dateOnly.Year, dateOnly.Month, dateOnly.Day,
                                  hora, minuto, 0, DateTimeKind.Unspecified);
            p.SyncDisplayFromDateTime();
        }
        else
        {
            Logger.LogWarning("OnFechaRecargaDateChanged: no se pudo parsear fecha '{DateVal}'", dateVal);
        }
    }

    private void OnFechaRecargaTimeInput(int index, ChangeEventArgs e)
    {
        if (index < 0 || index >= PeriodosActuales.Count) return;
        var raw = e.Value?.ToString() ?? "";
        var formatted = FormatearHoraMask(raw);
        PeriodosActuales[index].HoraRecargaText = formatted;
