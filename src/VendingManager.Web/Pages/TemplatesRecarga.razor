    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (MostrarFotoGuia)
        {
            // Focus the modal wrapper so @onkeydown captures ESC immediately
            // without the user having to click anything first.
            try { await fotoGuiaModalRef.FocusAsync(); } catch { /* best effort */ }
        }
        else if (PeriodoEnEdicionVisual != null)
        {
            // Defensive: ensure scroll is never locked while in slot editor
            // This catches edge cases where modal close didn't properly reset overflow
            try { await JS.InvokeVoidAsync("eval", "if(document.body.style.overflow==='hidden')document.body.style.overflow='';"); } catch { }
        }
    }

