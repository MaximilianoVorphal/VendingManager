        var periodo = PeriodosActuales[periodoIndex];
        if (periodo.MaquinaId == 0) return;

        CargandoSlots = true;
        StateHasChanged();

        try
        {
            var slots = await Http.GetFromJsonAsync<List<SnapshotSlotFormModel>>(
            $"api/TemplateRecarga/maquina/{periodo.MaquinaId}/slots");

            if (slots != null)
            {
                periodo.SnapshotSlots = slots;
                foreach (var slot in periodo.SnapshotSlots)
                {
                    slot.CapacidadSlot = 5;
                }
                MensajeExito = $"Se cargaron {slots.Count} slots para la máquina";
            }
        }
        catch (Exception ex)
        {
            MensajeError = "Error al cargar slots: " + ex.Message;
        }
        finally
        {
            CargandoSlots = false;
            StateHasChanged();
        }
    }

    private async Task GuardarTemplate()
    {
        MensajeError = "";
        MensajeExito = "";

        if (string.IsNullOrWhiteSpace(TemplateActual.Nombre))
        {
            MensajeError = "El nombre del template es requerido";
            return;
        }

        if (!PeriodosActuales.Any() || PeriodosActuales.All(p => p.MaquinaId == 0))
        {
            MensajeError = "Debe agregar al menos un período con una máquina seleccionada";
            return;
        }

        Guardando = true;
        StateHasChanged();

        try
        {
            var dto = new CreateTemplateDto
            {
                Nombre = TemplateActual.Nombre,
                Descripcion = TemplateActual.Descripcion,
                Periodos = PeriodosActuales
            .Where(p => p.MaquinaId > 0)
            .Select(p => new CreatePeriodoDto
            {
                MaquinaId = p.MaquinaId,
                FechaRecarga = p.FechaRecarga,
                SnapshotSlots = p.SnapshotSlots
            .Select(s =>
            {
                // Solo limpiar Pendiente si no tiene producto seleccionado (sigue pendiente)
                // Vacío → siempre limpiar
                if (s.Estado == EstadoSlot.Vacio)
                {
                    s.ProductoId = null;
                    s.CantidadInicial = 0;
                }
                else if (s.Estado == EstadoSlot.Pendiente && (!s.ProductoId.HasValue || s.ProductoId <= 0))
                {
                    s.ProductoId = null;
                    s.CantidadInicial = 0;
                }
                return new CreateSnapshotSlotDto
                {
                    NumeroSlot = s.NumeroSlot,
                    ProductoId = s.ProductoId,
                    CantidadInicial = s.CantidadInicial,
                    CapacidadSlot = 5,
                    Estado = s.Estado
                };
            }).ToList()
            }).ToList()
            };

            HttpResponseMessage response;
            if (EsEdicion)
            {
                response = await Http.PutAsJsonAsync($"api/TemplateRecarga/{TemplateIdEdicion}", dto);
            }
            else
            {
                response = await Http.PostAsJsonAsync("api/TemplateRecarga", dto);
            }

            if (response.IsSuccessStatusCode)
            {
                MensajeExito = EsEdicion ? "Template actualizado correctamente" : "Template creado correctamente";
                await UnlockScroll();
                MostrarModal = false;
                await CargarTemplates();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                MensajeError = "Error: " + error;
            }
        }
        catch (Exception ex)
        {
            MensajeError = "Error al guardar: " + ex.Message;
        }
        finally
        {
            Guardando = false;
        }
    }

    private void CancelarEliminacion()
    {
        TemplateAEliminar = null;
        Eliminando = false;
    }

    private async Task EliminarTemplateConfirmado()
    {
        if (TemplateAEliminar == null) return;
        var id = TemplateAEliminar.Id;
        MensajeError = "";
        MensajeExito = "";
        Eliminando = true;

        try
        {
            var response = await Http.DeleteAsync($"api/TemplateRecarga/{id}");
            if (response.IsSuccessStatusCode)
            {
                MensajeExito = "Template eliminado";
                TemplateAEliminar = null;
                await CargarTemplates();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                MensajeError = "Error al eliminar: " + error;
            }
        }
        catch (Exception ex)
        {
            MensajeError = "Error al eliminar: " + ex.Message;
        }
        finally
        {
            Eliminando = false;
            TemplateAEliminar = null;
        }
    }

    private async Task MostrarPendientes()
    {
        SlotsPendientes = new List<PendingSlotInfo>();
        if (Templates == null) return;

        foreach (var t in Templates)
        {
            foreach (var p in t.Periodos)
            {
                foreach (var s in p.SnapshotSlots.Where(s => s.Estado == EstadoSlot.Pendiente))
                {
                    SlotsPendientes.Add(new PendingSlotInfo
                    {
                        TemplateId = t.Id,
                        TemplateNombre = t.Nombre,
                        PeriodoId = p.Id,
                        MaquinaId = p.MaquinaId,
                        MaquinaNombre = p.MaquinaNombre,
                        NumeroSlot = s.NumeroSlot
                    });
                }
            }
        }

        await LockScroll();
        MostrarModalPendientes = true;
    }

    private async Task CerrarModalPendientes()
    {
        await UnlockScroll();
        MostrarModalPendientes = false;
    }

    private async Task IrAPendiente(PendingSlotInfo info)
    {
        await CerrarModalPendientes();

        var template = Templates?.FirstOrDefault(t => t.Id == info.TemplateId);
        if (template == null) return;

        // Abrir edición del template
        await AbrirModalEditar(template);
        StateHasChanged();

        // Buscar el índice del período que tiene el slot pendiente
        var periodoIndex = PeriodosActuales.FindIndex(p => p.Id == info.PeriodoId);
        if (periodoIndex < 0) return;

        // Cargar slots del período
        await CargarSlotsParaPeriodo(periodoIndex);

        // Abrir el editor visual
        if (periodoIndex < PeriodosActuales.Count)
        {
            await AbrirEdicionVisual(PeriodosActuales[periodoIndex]);
        }
        StateHasChanged();
    }

