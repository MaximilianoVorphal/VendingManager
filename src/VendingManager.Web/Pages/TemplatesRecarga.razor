                            </button>
                        }
                        <span class="text-muted small fw-bold font-monospace">@(FotoGuiaZoomDisplay)x</span>
                        <button type="button" class="btn btn-light rounded-0 fw-bold ms-2" @onclick="CerrarFotoGuiaModal">
                            CERRAR
                        </button>
                    </div>
                </div>
            </div>
        </div>
