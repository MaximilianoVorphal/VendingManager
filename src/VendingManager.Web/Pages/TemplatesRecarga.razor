    private void OnFechaRecargaDateChanged(int index, string? dateVal)
    {
        if (string.IsNullOrEmpty(dateVal) || index < 0 || index >= PeriodosActuales.Count) return;
        var p = PeriodosActuales[index];

        // Intentar leer la hora del display text (puede estar editándose)
        int hora = p.FechaRecarga.Hour;
        int minuto = p.FechaRecarga.Minute;

        if (!string.IsNullOrWhiteSpace(p.HoraRecargaText))
        {
            var cleaned = p.HoraRecargaText.Replace(":", "").PadRight(4, '0');
            if (cleaned.Length >= 4 &&
                int.TryParse(cleaned[..2], out int h) && h is >= 0 and <= 23 &&
                int.TryParse(cleaned[2..4], out int m) && m is >= 0 and <= 59)
            {
                hora = h;
                minuto = m;
            }
        }

        if (DateOnly.TryParse(dateVal, System.Globalization.CultureInfo.InvariantCulture,
                System.Globalization.DateTimeStyles.None, out var dateOnly))
        {
            p.FechaRecarga = new DateTime(dateOnly.Year, dateOnly.Month, dateOnly.Day,
                                  hora, minuto, 0, DateTimeKind.Unspecified);
            p.SyncDisplayFromDateTime();
        }
        else
        {
            Logger.LogWarning("OnFechaRecargaDateChanged: no se pudo parsear fecha '{DateVal}'", dateVal);
        }
    }

