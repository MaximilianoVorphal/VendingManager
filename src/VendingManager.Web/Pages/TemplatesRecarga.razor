@code {
    [CascadingParameter] public MainLayout? Layout { get; set; }

    private PeriodoFormModel? PeriodoEnEdicionVisual;

    // OCR-related state
    private bool ProcesandoOcr = false;
    private string MensajeErrorOcr = "";
    private string MensajeInfoOcr = "";
    private byte[]? FotoGuiaData; // Photo 2 — never sent to server
    private string? FotoGuiaUrl; // Blob URL for display
    private bool MostrarFotoGuia = false;
    private HashSet<string> SlotsResaltados = new(); // Slots recently pre-filled via OCR
    private List<OcrRecargaSlotDto> UltimosSlotsNoCoincidentes = new(); // Unmatched OCR slots with quantity

    // Foto Guía zoom/pan state (persists across photo modal close/reopen, resets when opening a different period)
    private double _fotoGuiaZoom = 1.0;
    private double _fotoGuiaPanX = 0;
    private double _fotoGuiaPanY = 0;
    private bool _fotoGuiaDragging = false;
    private double _fotoGuiaLastMouseX = 0;
    private double _fotoGuiaLastMouseY = 0;
    private Dictionary<string, CancellationTokenSource> _syncCtors = new();

    // OCR photo state (persisted to backend on successful OCR)
    private byte[]? _fotoOcrData;
    private string? _fotoOcrUrl;

    // Loading state for photos
    private bool _fotoGuiaLoading = false;
    private bool _fotoOcrLoading = false;

    // Tracks the template being edited for photo upload targets
    private int _currentTemplateId = 0;

    // === Defensive scroll lock helpers (guard against missing JS) ===
    private async Task LockScroll() {
        try { await JS.InvokeVoidAsync("modalScrollLock.lock"); } catch { }
    }
    private async Task UnlockScroll() {
        try { await JS.InvokeVoidAsync("modalScrollLock.unlock"); } catch { }
    }

    // CSS transform string — must use InvariantCulture or comma-decimal cultures break CSS syntax
    private string FotoGuiaTransform =>
        $"scale({_fotoGuiaZoom.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture)}) translate({_fotoGuiaPanX.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture)}px, {_fotoGuiaPanY.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture)}px)";

    // Zoom display for footer — also InvariantCulture to avoid comma decimals in es-AR etc.
    private string FotoGuiaZoomDisplay =>
        _fotoGuiaZoom.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture);

private async Task AbrirEdicionVisual(PeriodoFormModel periodo)
    {
        PeriodoEnEdicionVisual = periodo;
        // Reset OCR state when opening
        ProcesandoOcr = false;
        MensajeErrorOcr = "";
        MensajeInfoOcr = "";
        // Reset zoom/pan for new period (different machine = different photo)
        _fotoGuiaZoom = 1.0;
        _fotoGuiaPanX = 0;
        _fotoGuiaPanY = 0;
        // Load photos for this specific periodo
        _ = LoadFotosForPeriodo(periodo.Id);
        // Note: FotoGuiaData/FotoGuiaUrl intentionally preserved across opens for convenience
        // Colapsar navbar para ganar espacio vertical en pantallas chicas
        Layout?.CollapseNavbar();
        StateHasChanged();
        // Reset scroll position — DOM structure changes dramatically (main content hidden)
        // Force body scroll unlock (defensive against stale modal locks)
        try { await JS.InvokeVoidAsync("eval", "document.body.style.overflow='';window.scrollTo(0,0);"); } catch { }
        await Task.CompletedTask;
    }

    private async Task CerrarEdicionVisual()
    {
        if (MostrarFotoGuia)
        {
            MostrarFotoGuia = false;
        }
        PeriodoEnEdicionVisual = null;
        // Photos kept in memory for convenience across reopens — no revoke here
        // Restaurar navbar al salir del editor
        Layout?.ExpandNavbar();
        // Defensive: ensure scroll is never left locked
        try { await JS.InvokeVoidAsync("eval", "document.body.style.overflow='';"); } catch { }
        StateHasChanged();
        await Task.CompletedTask;
    }

    /// <summary>
    /// Loads both foto-guia and foto-ocr for a specific periodo.
    /// Non-critical: failures show inline messages but do not block the UI.
    /// </summary>
    private async Task LoadFotosForPeriodo(int periodoId)
    {
        if (periodoId <= 0 || _currentTemplateId <= 0) return;

        // Check template flags to avoid unnecessary 404 requests (browser console noise)
        var template = Templates?.FirstOrDefault(t => t.Id == _currentTemplateId);
        var hasFotoGuia = template?.TieneFotoGuia ?? true;
        var hasFotoOcr = template?.TieneFotoOcr ?? true;

        if (!hasFotoGuia && !hasFotoOcr) return;

        _fotoGuiaLoading = hasFotoGuia;
        _fotoOcrLoading = hasFotoOcr;
        StateHasChanged();

        try
        {
            Task<HttpResponseMessage>? fotoGuiaTask = hasFotoGuia
                ? Http.GetAsync($"api/TemplateRecarga/{_currentTemplateId}/periodo/{periodoId}/foto-guia")
                : null;
            Task<HttpResponseMessage>? fotoOcrTask = hasFotoOcr
                ? Http.GetAsync($"api/TemplateRecarga/{_currentTemplateId}/periodo/{periodoId}/foto-ocr")
                : null;

            if (fotoGuiaTask != null && fotoOcrTask != null)
                await Task.WhenAll(fotoGuiaTask, fotoOcrTask);
            else if (fotoGuiaTask != null)
                await fotoGuiaTask;
            else if (fotoOcrTask != null)
                await fotoOcrTask;

            if (fotoGuiaTask != null)
            {
                var guiaResp = fotoGuiaTask.Result;
                if (guiaResp.IsSuccessStatusCode)
                {
                    var bytes = await guiaResp.Content.ReadAsByteArrayAsync();
                    FotoGuiaData = bytes;
                    FotoGuiaUrl = $"data:image/jpeg;base64,{Convert.ToBase64String(bytes)}";
                }
                else if (guiaResp.StatusCode == System.Net.HttpStatusCode.NotFound)
                {
                    RevokeFotoGuiaUrl();
                    FotoGuiaData = null;
                }
                else
                {
                    MensajeErrorOcr = "No se pudo cargar la foto guía.";
                }
            }

            if (fotoOcrTask != null)
            {
                var ocrResp = fotoOcrTask.Result;
                if (ocrResp.IsSuccessStatusCode)
                {
                    var bytes = await ocrResp.Content.ReadAsByteArrayAsync();
                    _fotoOcrData = bytes;
                    _fotoOcrUrl = $"data:image/jpeg;base64,{Convert.ToBase64String(bytes)}";
                }
                else if (ocrResp.StatusCode == System.Net.HttpStatusCode.NotFound)
                {
                    _fotoOcrData = null;
                    _fotoOcrUrl = null;
                }
                else
                {
                    MensajeErrorOcr = "No se pudo cargar la foto OCR.";
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Error loading photos for periodo {PeriodoId}", periodoId);
            MensajeErrorOcr = "Error al cargar fotos del período.";
        }
        finally
        {
            _fotoGuiaLoading = false;
            _fotoOcrLoading = false;
            StateHasChanged();
        }
    }

    private async Task TriggerOcrUpload()
    {
        await JS.InvokeVoidAsync("eval", "document.getElementById('ocrRecargaFileInput').click()");
    }

    private async Task TriggerFotoGuiaUpload()
    {
        await JS.InvokeVoidAsync("eval", "document.getElementById('fotoGuiaFileInput').click()");
    }

    private async Task HandleOcrPhotoUpload(InputFileChangeEventArgs e)
    {
        if (PeriodoEnEdicionVisual == null) return;

        var file = e.File;
        MensajeErrorOcr = "";
        MensajeInfoOcr = "";

        // Client-side validation
        if (file == null || file.Size == 0)
        {
            MensajeErrorOcr = "No se seleccionó ningún archivo.";
            return;
        }

        const long maxSize = 10 * 1024 * 1024; // 10MB
        if (file.Size > maxSize)
        {
            MensajeErrorOcr = "La foto supera los 10MB. Usá una foto más pequeña.";
            return;
        }

        var allowedTypes = new[] { "image/jpeg", "image/png", "image/jpg", "image/heic", "image/webp" };
        if (!allowedTypes.Contains(file.ContentType.ToLowerInvariant()))
        {
            MensajeErrorOcr = "Formato no soportado. Usá JPG, PNG o HEIC.";
            return;
        }

        ProcesandoOcr = true;
        MensajeErrorOcr = "";
        StateHasChanged();

        try
        {
            using var stream = file.OpenReadStream(maxSize);
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);
            memoryStream.Position = 0;

            var content = new MultipartFormDataContent();
            var byteContent = new ByteArrayContent(memoryStream.ToArray());
            byteContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);
            content.Add(byteContent, "file", file.Name);

            var response = await Http.PostAsync(
                $"api/ordencarga/from-photo?maquinaId={PeriodoEnEdicionVisual.MaquinaId}",
                content);

            if (!response.IsSuccessStatusCode)
            {
                var error = await response.Content.ReadAsStringAsync();
                MensajeErrorOcr = "Error OCR: " + error;
                return;
            }

            var result = await response.Content.ReadFromJsonAsync<OcrRecargaResultDto>();
            if (result == null)
            {
                MensajeErrorOcr = "No se recibió respuesta del servicio OCR.";
                return;
            }

            // Empty result
            if (result.ExtractedSlots.Count == 0 && result.UnmatchedOcrSlots.Count == 0)
            {
                MensajeInfoOcr = "No se detectaron slots en la foto. Verificá que la foto sea legible.";
                return;
            }

            // Pre-fill matched slots
            SlotsResaltados.Clear();
            foreach (var matched in result.ExtractedSlots)
            {
                var slot = PeriodoEnEdicionVisual.SnapshotSlots
                    .FirstOrDefault(s => s.NumeroSlot == matched.MatchedSlot);

                if (slot != null)
                {
                    slot.CantidadInicial = matched.Quantity;
                    SlotsResaltados.Add(slot.NumeroSlot);

                    // Si la cantidad es 0, el slot no se recargó → Vacío automático
                    if (matched.Quantity == 0)
                    {
                        slot.ProductoId = null;
                        slot.Estado = EstadoSlot.Vacio;
                    }
                }
            }

            // Build unmatched list with quantities (subtract matched from raw OCR slots)
            var matchedSlotNumbers = result.ExtractedSlots
                .Where(e => e.MatchedSlot != null)
                .Select(e => e.MatchedSlot!)
                .ToHashSet(StringComparer.OrdinalIgnoreCase);

            UltimosSlotsNoCoincidentes = result.Slots
                .Where(s => !matchedSlotNumbers.Contains(s.SlotNumber))
                .ToList();

            // Persist OCR photo to backend (non-critical: failure does not block slot population)
            if (PeriodoEnEdicionVisual?.Id > 0)
            {
                try
                {
                    memoryStream.Position = 0;
                    var persistContent = new MultipartFormDataContent();
                    var persistBytes = new ByteArrayContent(memoryStream.ToArray());
                    persistBytes.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);
                    persistContent.Add(persistBytes, "file", file.Name);

                    var persistResp = await Http.PutAsync(
                        $"api/TemplateRecarga/{_currentTemplateId}/periodo/{PeriodoEnEdicionVisual.Id}/foto-ocr",
                        persistContent);

                    if (!persistResp.IsSuccessStatusCode)
                    {
                        Logger.LogWarning("OCR photo persist failed with {Status} for periodo {PeriodoId}",
                            persistResp.StatusCode, PeriodoEnEdicionVisual.Id);
                        // Non-critical — do not interrupt the user experience
                    }
                }
                catch (Exception ex)
                {
                    Logger.LogWarning(ex, "Error persisting OCR photo for periodo {PeriodoId}", PeriodoEnEdicionVisual.Id);
                    // Non-critical failure — slot population continues
                }
            }

            // Brief green flash for matched slots — clean up after 1.5s
            _ = Task.Run(async () =>
            {
                await Task.Delay(1500);
                await InvokeAsync(() =>
                {
                    SlotsResaltados.Clear();
                    StateHasChanged();
                });
            });
        }
        catch (Exception ex)
        {
            MensajeErrorOcr = "Error de red: " + ex.Message;
        }
        finally
        {
            ProcesandoOcr = false;
            StateHasChanged();
        }
    }

    private async Task HandleFotoGuiaUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null || file.Size == 0) return;

        RevokeFotoGuiaUrl();

        using var stream = file.OpenReadStream();
        using var memoryStream = new MemoryStream();
        await stream.CopyToAsync(memoryStream);
        FotoGuiaData = memoryStream.ToArray();

        // Create blob URL — this is reference-only, never sent to any backend
        var url = $"data:{file.ContentType};base64,{Convert.ToBase64String(FotoGuiaData)}";
        FotoGuiaUrl = url;
        StateHasChanged();

        // Immediate persist to backend if we have a periodo ID
        if (PeriodoEnEdicionVisual?.Id > 0)
        {
            try
            {
                var content = new MultipartFormDataContent();
                var byteContent = new ByteArrayContent(FotoGuiaData);
                byteContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);
                content.Add(byteContent, "file", file.Name);

                var resp = await Http.PutAsync(
                    $"api/TemplateRecarga/{_currentTemplateId}/periodo/{PeriodoEnEdicionVisual.Id}/foto-guia",
                    content);

                if (!resp.IsSuccessStatusCode)
                {
                    MensajeErrorOcr = "No se pudo guardar la foto guía en el servidor. La foto está en memoria pero se perderá al cerrar.";
                }
            }
            catch (Exception ex)
