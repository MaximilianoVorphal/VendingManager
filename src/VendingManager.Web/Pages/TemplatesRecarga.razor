@page "/templates-recarga"
@using Microsoft.AspNetCore.Authorization
@using VendingManager.Shared.Constants
@using VendingManager.Shared.DTOs
@using VendingManager.Shared.Enums
@using Microsoft.AspNetCore.Components.Forms
@using VendingManager.Web.Layout
@using VendingManager.Web.Components.Shared
@attribute [Authorize(Roles = Roles.Admin)]
@inject HttpClient Http
@inject Microsoft.Extensions.Logging.ILogger<TemplatesRecarga> Logger
@inject NavigationManager NavManager
@inject IJSRuntime JS

@if (PeriodoEnEdicionVisual == null)
{
<div class="industrial-wrapper container-fluid px-4 mt-4">

    <!-- HEADER -->
    <div class="row align-items-center mb-4 border-bottom border-3 border-dark pb-3">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <div>
                <h2 class="m-0 fw-bold text-uppercase templates-title">
                    <i class="bi bi-calendar-range me-2"></i>TEMPLATES DE RECARGA
                </h2>
                <small class="text-muted fw-bold">DEFINE PERÍODOS ESPECÍFICOS POR MÁQUINA PARA ANÁLISIS</small>
            </div>
            <div class="d-flex gap-2 flex-wrap header-actions">
                <button class="btn btn-dark rounded-0 fw-bold border-dark" @onclick="AbrirModalSincronizarGlobal" title="Sincronizar ventas históricas de TODOS los templates">
                    <i class="bi bi-arrow-repeat me-1"></i> SINCRONIZAR TODO
                </button>
                <button class="btn btn-warning rounded-0 fw-bold border-dark" @onclick="MostrarPendientes" title="Slots pendientes de configurar">
                    <i class="bi bi-exclamation-circle me-1"></i> PENDIENTES
                </button>
                <button class="btn btn-success rounded-0 fw-bold border-dark d-none d-md-block" @onclick="AbrirModalCrear">
                    <i class="bi bi-plus-lg me-1"></i> NUEVO TEMPLATE
                </button>
            </div>
        </div>
    </div>

    <!-- FAB: NUEVO TEMPLATE on mobile (<768px) -->
    <div class="fab-container">
        <button class="fab-btn btn border-dark shadow-lg" @onclick="AbrirModalCrear" title="Nuevo Template">
            <i class="bi bi-plus-lg"></i>
        </button>
    </div>

    @if (!string.IsNullOrEmpty(MensajeError))
    {
        <div class="alert alert-danger border-2 border-dark rounded-0 mb-4 shadow-sm fw-bold">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @MensajeError
        </div>
    }

    @if (!string.IsNullOrEmpty(MensajeExito))
    {
        <div class="alert alert-success border-2 border-dark rounded-0 mb-4 shadow-sm fw-bold">
            <i class="bi bi-check-circle-fill me-2"></i> @MensajeExito
        </div>
    }

    @if (Cargando)
    {
        <div class="text-center py-5 border border-dark border-2 bg-light">
            <div class="spinner-grow text-dark" role="status"></div>
            <p class="mt-2 fw-bold text-uppercase loading-letter-spacing">Cargando Templates...</p>
        </div>
    }
    else if (Templates != null && Templates.Any())
    {
        <div class="row g-4">
            @foreach (var template in Templates)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    @{
                        var cardClass = "card border-2 border-dark rounded-0 shadow-sm h-100";
                        if (template.CantidadSlotsPendientes > 0) cardClass += " template-card-warning";
                    }
                    <div class="@cardClass">
                        <div class="card-header bg-dark text-white rounded-0 d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center gap-2">
                                <span class="fw-bold text-uppercase text-truncate d-block template-name">@template.Nombre</span>
                                @if (template.CantidadSlotsPendientes > 0)
                                {
                                    <span class="badge bg-warning text-dark rounded-0 pending-badge">
                                        <span class="pending-count">@template.CantidadSlotsPendientes</span>
                                        <span class="pending-label"> pendiente</span>
                                    </span>
                                }
                            </div>
                            <div class="d-flex gap-1 flex-nowrap">
                                <button class="btn btn-sm btn-outline-light rounded-0"
                            @onclick="() => AbrirModalEditar(template)" title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger rounded-0"
                            @onclick="() => TemplateAEliminar = template" title="Eliminar">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                        <div class="card-body">
                            @if (!string.IsNullOrEmpty(template.Descripcion))
                            {
                                <p class="text-muted small mb-2">@template.Descripcion</p>
                            }
                            <div class="mb-3">
                                <small class="text-muted">
                                    <i class="bi bi-calendar me-1"></i>
                                    @template.FechaRecargaMin?.ToString("dd/MM/yyyy") -
                                    @template.FechaFinMax?.ToString("dd/MM/yyyy")
                                </small>
                            </div>

                            <h6 class="fw-bold text-uppercase small mb-2">
                                <i class="bi bi-geo-alt me-1"></i> @template.CantidadMaquinas Máquinas
                            </h6>

                            <div class="period-list">
                                @foreach (var periodo in template.Periodos)
                                {
                                    <div class="d-flex justify-content-between align-items-center border-bottom py-1 small">
                                        <span class="fw-bold">@periodo.MaquinaNombre</span>
                                        <span class="font-monospace text-muted">
                                            @periodo.FechaRecarga.ToString("dd/MM HH:mm")
                                        </span>
                                    </div>
                                }
                            </div>
                        </div>
<div class="card-footer bg-light border-top border-dark d-flex flex-column gap-2">
                            <!-- State badge + transition controls -->
                            <div class="d-flex align-items-center justify-content-between mb-1">
                                <span class="badge @GetEstadoBadgeClass(template) rounded-0 fw-bold">
                                    @GetEstadoDisplay(template)
                                </span>
                                @if (template.Estado == EstadoTemplate.Pendiente)
                                {
                                    <button class="btn btn-sm btn-success rounded-0 fw-bold"
                                        @onclick="() => TerminarTemplate(template.Id)">
                                        <i class="bi bi-check-circle me-1"></i> FINALIZAR
                                    </button>
                                }
                                else if (template.Estado == EstadoTemplate.Terminado && !template.EsActivo)
                                {
                                    <button class="btn btn-sm btn-outline-dark rounded-0 fw-bold"
                                        @onclick="() => ReabrirTemplate(template.Id)">
                                        <i class="bi bi-arrow-counterclockwise me-1"></i> REABRIR
                                    </button>
                                }
                            </div>

                            <button class="btn btn-danger w-100 rounded-0 fw-bold"
                                        @onclick="() => AnalizarTemplate(template.Id)">
                                <i class="bi bi-graph-up me-1"></i> ANALIZAR STOCKOUT
                            </button>
                            <button class="btn btn-warning w-100 rounded-0 fw-bold"
                                @onclick="() => AbrirModalSincronizar(template.Id)"
                                disabled="@_syncCtors.Any()">
                                <i class="bi bi-arrow-repeat me-1"></i> SINCRONIZAR TODO
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5 border border-dark border-2 bg-light">
            <i class="bi bi-calendar-x fs-1 text-muted"></i>
            <p class="mt-2 fw-bold text-uppercase">No hay templates creados</p>
            <button class="btn btn-dark rounded-0 fw-bold" @onclick="AbrirModalCrear">
                <i class="bi bi-plus-lg me-1"></i> CREAR PRIMER TEMPLATE
            </button>
        </div>
    }

</div>

<!-- MODAL CREAR/EDITAR -->
@if (MostrarModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5); z-index: 1110;">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content border-2 border-dark rounded-0">
                <div class="modal-header bg-dark text-white rounded-0 border-bottom border-dark">
                    <h5 class="modal-title fw-bold text-uppercase">
                        @(EsEdicion ? "EDITAR TEMPLATE" : "NUEVO TEMPLATE DE RECARGA")
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarModal"></button>
                </div>
                <div class="modal-body">
                    <!-- Nombre y Descripción -->
                <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="fw-bold small text-uppercase mb-1">NOMBRE DEL TEMPLATE:</label>
                            <input type="text" @bind="TemplateActual.Nombre"
                            class="form-control border-dark rounded-0 fw-bold" placeholder="Ej: Recarga Nuevo 3" />
                        </div>
                        <div class="col-md-6">
                            <label class="fw-bold small text-uppercase mb-1">DESCRIPCIÓN (OPCIONAL):</label>
                            <input type="text" @bind="TemplateActual.Descripcion" class="form-control border-dark rounded-0"
                            placeholder="Ej: Recarga semanal enero" />
                        </div>
                    </div>

                    <!-- Períodos por Máquina -->
                <div class="border border-dark p-3 bg-light">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="fw-bold text-uppercase m-0">
                                <i class="bi bi-clock-history me-1"></i> PERÍODOS POR MÁQUINA
                            </h6>
                            <button class="btn btn-sm btn-dark rounded-0" @onclick="AgregarPeriodo">
                                <i class="bi bi-plus-lg me-1"></i> Agregar Máquina
                            </button>
                        </div>

                        @if (!PeriodosActuales.Any())
                        {
                            <div class="text-center text-muted py-3">
                                <i class="bi bi-info-circle"></i> Agrega al menos una máquina con su período
                            </div>
                        }
                        else
                        {
                            @for (int i = 0; i < PeriodosActuales.Count; i++)
                            {
                                var periodo = PeriodosActuales[i];
                                var index = i;
                                <div class="card rounded-0 border-dark mb-2">
                                    <div class="card-body p-2">
                                        <div class="row g-2 align-items-end">
                                             <div class="col-md-4 col-12">
                                                 <label class="small fw-bold">MÁQUINA:</label>
                                                 <select class="form-select border-dark rounded-0 text-truncate"
                                         @bind="periodo.MaquinaId">
                                                     <option value="0">-- Seleccionar --</option>
                                                     @if (ListaMaquinas != null)
                                                     {
                                                         @foreach (var m in ListaMaquinas)
                                                         {
                                                             <option value="@m.Id">@m.Nombre</option>
                                                         }
                                                     }
                                                 </select>
                                             </div>
<div class="col-md-4 col-12">
                                                 <label class="small fw-bold">FECHA RECARGA:</label>
                                                 <div class="input-group input-group-sm">
                                                       <input type="date"
                                                              class="form-control border-dark rounded-0 date-input"
                                                              value="@periodo.FechaRecargaText"
                                                              @onchange="(ChangeEventArgs e) => OnFechaRecargaDateChanged(index, e)" />
                                                       <input type="text"
                                                              class="form-control border-dark rounded-0 time-input font-monospace"
                                                              value="@periodo.HoraRecargaText"
                                                              placeholder="HH:mm"
                                                              maxlength="5"
                                                              @oninput="(ChangeEventArgs e) => OnFechaRecargaTimeInput(index, e)"
                                                              @onchange="(ChangeEventArgs e) => OnFechaRecargaTimeBlur(index, e)" />
                                                 </div>
                                             </div>
                                         <div class="col-md-2 col-12">
                                             <div class="d-flex gap-1">
                                                 <button class="btn btn-sm btn-outline-primary rounded-0 flex-fill"
                                         @onclick="() => CargarSlotsParaPeriodo(index)"
                                         disabled="@(periodo.MaquinaId == 0 || CargandoSlots)">
                                                     <i class="bi bi-box-seam me-1"></i> Slots
                                                 </button>
                                                 <button class="btn btn-sm btn-outline-danger rounded-0"
                                         @onclick="() => EliminarPeriodo(index)">
                                                     <i class="bi bi-x-lg"></i>
                                                 </button>
                                             </div>
                                         </div>
                                     </div>

                                    @if (periodo.SnapshotSlots.Any())
                                    {
                                        <div class="mt-3 p-3 bg-white border border-2 border-dark text-center shadow-sm">
                                            <h6 class="fw-bold text-success mb-3 text-uppercase">
                                                <i class="bi bi-check-circle-fill me-1"></i>
                                                @periodo.SnapshotSlots.Count(s => s.ProductoId.HasValue && s.ProductoId > 0) productos configurados
                                                <span class="text-muted ms-1">(de @periodo.SnapshotSlots.Count slots)</span>
                                            </h6>
                                             <button class="btn btn-warning rounded-0 fw-bold border-2 border-dark mb-2 px-4 py-2 text-uppercase btn-lg edit-slots-btn"
                                                 onmousedown="this.style.transform='translate(2px, 2px)'; this.style.boxShadow='1px 1px 0px #000';"
                                                 onmouseup="this.style.transform='none'; this.style.boxShadow='';"
                                                 onmouseleave="this.style.transform='none'; this.style.boxShadow='';"
                                                 @onclick="() => AbrirEdicionVisual(periodo)">
                                                 <i class="bi bi-grid-3x3-gap-fill me-2"></i> EDITAR SLOTS (GRILLA)
                                            </button>
                                            <div class="mt-3 border-top border-dark pt-3">
                                                <button class="btn btn-sm btn-outline-danger rounded-0 fw-bold"
                                                    @onclick="() => periodo.SnapshotSlots.Clear()">
                                                    <i class="bi bi-trash"></i> VACIAR MÁQUINA
                                                </button>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
            <div class="modal-footer border-top border-dark">
                <button type="button" class="btn btn-secondary rounded-0" @onclick="CerrarModal">
                    CANCELAR
                </button>
                <button type="button" class="btn btn-success rounded-0 fw-bold" @onclick="GuardarTemplate"
                disabled="@Guardando">
                    @(Guardando ? "GUARDANDO..." : (EsEdicion ? "ACTUALIZAR" : "GUARDAR TEMPLATE"))
                </button>
            </div>
        </div>
    </div>
</div>
}
}

<!-- EDICIÓN VISUAL DE SLOTS (Full-page inline, no modal) -->
@if (PeriodoEnEdicionVisual != null)
{
    var maq = ListaMaquinas?.FirstOrDefault(m => m.Id == PeriodoEnEdicionVisual.MaquinaId)?.Nombre ?? "MÁQUINA";
    <div class="slot-editor-wrapper bg-light p-3 p-md-4" style="position: relative;">
        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-3 border-dark pb-3">
            <h4 class="fw-bold text-uppercase m-0">
                <i class="bi bi-grid-3x3-gap-fill me-2"></i> ESTANTERÍA — @maq
            </h4>
            <button class="btn btn-dark rounded-0 fw-bold" @onclick="CerrarEdicionVisual">
                <i class="bi bi-arrow-left me-1"></i> VOLVER
            </button>
        </div>

        @if (ProcesandoOcr)
        {
            <div style="position: absolute; inset: 0; background: rgba(0,0,0,0.6); z-index: 50; display: flex; flex-direction: column; align-items: center; justify-content: center;">
                <div class="spinner-border text-light mb-3" style="width: 3rem; height: 3rem;" role="status"></div>
                <span class="text-white fw-bold text-uppercase" style="letter-spacing: 2px;">PROCESANDO OCR...</span>
            </div>
        }
        @if (!string.IsNullOrEmpty(MensajeErrorOcr))
        {
            <div class="alert alert-danger border-2 border-dark rounded-0 mb-3 small fw-bold">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> @MensajeErrorOcr
            </div>
        }
        @if (!string.IsNullOrEmpty(MensajeInfoOcr))
        {
            <div class="alert alert-info border-2 border-dark rounded-0 mb-3 small fw-bold">
                <i class="bi bi-info-circle-fill me-2"></i> @MensajeInfoOcr
            </div>
        }
        @{
            var validSlots = PeriodoEnEdicionVisual.SnapshotSlots.ToList();
            var shelves = validSlots.GroupBy(s => (int.TryParse(s.NumeroSlot, out var n) ? n - 1 : 0) / 10).OrderBy(g => g.Key);
        }

        @if (!validSlots.Any())
        {
            <div class="text-center py-5">
                <h5 class="text-muted fw-bold">NO HAY SLOTS CONFIGURADOS</h5>
                <p class="text-muted small">Esta máquina no tiene slots cargados. Volvé al paso anterior y usá el botón <strong>Slots</strong> para cargarlos desde la configuración de la máquina.</p>
            </div>
        }
        else
        {
            <div class="d-flex flex-column gap-4 machine-chassis">
                @foreach (var shelf in shelves)
                {
                    int bgIndex = shelf.Key % 2;

                    <div class="shelf-container p-3 border border-3 border-dark bg-white shadow-sm" style="@(bgIndex == 1 ? "background-color: #fafafa !important;" : "")">
                        <div class="badge bg-dark text-white rounded-0 px-3 py-2 mb-3 fs-6">PISO @(shelf.Key + 1)</div>
                        <div class="slot-grid">
                            @foreach (var slot in shelf.OrderBy(s => int.TryParse(s.NumeroSlot, out var n) ? n : 999))
                            {
                                var estaResaltado = SlotsResaltados.Contains(slot.NumeroSlot);
                                <SlotCard
                                    Slot="slot"
                                    IsOcrHighlighted="estaResaltado"
                                    IsReadOnly="false"
                                    OnQuantityChanged="(qty) => OnSlotQuantityChanged(slot, qty)"
                                    OnChangeProductRequested="() => OnChangeProductForSlot(slot)"
                                    OnEmptySlotRequested="() => OnEmptySlot(slot)" />
                            }
                        </div>
                    </div>
                }
            </div>

            @if (UltimosSlotsNoCoincidentes.Any())
            {
                <div class="mt-4 p-3 border border-2 border-warning bg-warning bg-opacity-10 rounded-0">
                    <h6 class="fw-bold text-uppercase mb-2">
                        <i class="bi bi-exclamation-triangle-fill text-warning me-2"></i>
                        Slots sin coincidencia (@UltimosSlotsNoCoincidentes.Count)
                    </h6>
                    <small class="text-muted mb-2 d-block">Estos slots fueron detectados en la foto pero no existen en la máquina. Revisalos manualmente.</small>
                    <div class="table-responsive">
                        <table class="table table-sm table-borderless m-0 small">
                            <thead>
                                <tr class="text-uppercase text-muted">
                                    <th>Slot (OCR)</th>
                                    <th>Cantidad</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var unmatched in UltimosSlotsNoCoincidentes)
                                {
                                    <tr>
                                        <td class="font-monospace fw-bold">@unmatched.SlotNumber</td>
                                        <td class="fw-bold">@unmatched.Quantity</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        }

        <!-- PRODUCT SELECTOR OVERLAY (for slot product change) -->
        @if (SlotConProductoSelector != null && ListaProductos != null)
        {
            <div class="product-selector-overlay" @onclick="CerrarProductoSelector" @onclick:stopPropagation="true">
                <div class="product-selector-dropdown" @onclick:stopPropagation="true">
                    <div class="product-selector-header">
                        <span class="fw-bold text-uppercase small">
                            <i class="bi bi-box-seam me-2"></i>CAMBIAR PRODUCTO — SLOT @SlotConProductoSelector.NumeroSlot
                        </span>
                        <button type="button" class="btn-close" @onclick="CerrarProductoSelector"></button>
                    </div>
                    <div class="product-selector-search">
                        <input type="text" class="form-control form-control-sm border-dark rounded-0"
                               placeholder="Buscar producto..."
                               @bind="ProductoSearch"
                               @bind:event="oninput" />
                    </div>
                    <div class="product-selector-list">
                        @foreach (var prod in ListaProductos.Where(p =>
                            string.IsNullOrEmpty(ProductoSearch) ||
                            p.Nombre.Contains(ProductoSearch, StringComparison.OrdinalIgnoreCase)))
                        {
                            <button class="product-selector-item @(SlotConProductoSelector.ProductoId == prod.Id ? "active" : "")"
                                    @onclick="() => SeleccionarProductoParaSlot(prod)">
                                <span class="fw-bold">@prod.Nombre</span>
                                @if (SlotConProductoSelector.ProductoId == prod.Id)
                                {
                                    <i class="bi bi-check-circle-fill text-success ms-2"></i>
                                }
                            </button>
                        }
                    </div>
                </div>
            </div>
        }

        }
    </div>

    <!-- Floating Action Panel (right side) -->
    <div class="slot-action-panel">
        <InputFile OnChange="HandleOcrPhotoUpload" accept="image/*" class="d-none" id="ocrRecargaFileInput" disabled="@ProcesandoOcr" />
        <button class="slot-action-btn slot-action-btn--primary" @onclick="TriggerOcrUpload" disabled="@ProcesandoOcr"
                title="Fotos legibles tardan ~5s. Formatos: JPG, PNG, HEIC. Máx 10MB.">
            @if (_fotoOcrLoading)
            {
                <span class="spinner-border spinner-border-sm"></span>
            }
            else
            {
                <i class="bi bi-camera-fill"></i>
            }
            <span class="slot-action-label">FOTO RECARGA</span>
        </button>

        @if (string.IsNullOrEmpty(FotoGuiaUrl))
        {
            <InputFile OnChange="HandleFotoGuiaUpload" accept="image/*" class="d-none" id="fotoGuiaFileInput" />
            <button class="slot-action-btn slot-action-btn--secondary" @onclick="TriggerFotoGuiaUpload"
                    title="Cargar foto de referencia (productos)">
                @if (_fotoGuiaLoading)
                {
                    <span class="spinner-border spinner-border-sm"></span>
                }
                else
                {
                    <i class="bi bi-image"></i>
                }
                <span class="slot-action-label">FOTO GUÍA</span>
            </button>
        }
        else
        {
            <button class="slot-action-btn slot-action-btn--info" @onclick="MostrarFotoGuiaModal"
                    title="Ver foto guía">
                <i class="bi bi-eye"></i>
                <span class="slot-action-label">VER GUÍA</span>
            </button>
        }

        <div class="slot-action-divider"></div>

        <button class="slot-action-btn slot-action-btn--save" @onclick="CerrarEdicionVisual"
                title="Guardar cambios y volver">
            <i class="bi bi-save"></i>
            <span class="slot-action-label">GUARDAR</span>
        </button>
    </div>
}

<!-- MODAL FOTO GUÍA (Photo 2 — reference only, never sent to backend) -->
@if (MostrarFotoGuia && !string.IsNullOrEmpty(FotoGuiaUrl))
{
    <div @ref="fotoGuiaModalRef" tabindex="-1"
         class="modal fade show d-block" style="background-color: rgba(0,0,0,0.9); z-index: 1130; outline: none;"
         @onkeydown="OnFotoGuiaKeydown">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content border-3 border-dark rounded-0 bg-dark">
                <div class="modal-header bg-dark text-white rounded-0 border-bottom border-dark">
                    <h5 class="modal-title fw-bold text-uppercase">
                        <i class="bi bi-image-fill me-2"></i> FOTO GUÍA — @((ListaMaquinas?.FirstOrDefault(m => m.Id == PeriodoEnEdicionVisual?.MaquinaId)?.Nombre ?? "MÁQUINA"))
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarFotoGuiaModal"></button>
                </div>
                <div class="modal-body p-0"
                     style="background-color: #111; overflow: hidden; position: relative; height: 80vh; cursor: @(_fotoGuiaDragging ? "grabbing" : "grab"); user-select: none;"
                     @onwheel:preventDefault="true"
                     @onwheel="OnFotoGuiaZoom"
                     @onmousedown="OnFotoGuiaPanStart"
                     @onmousemove="OnFotoGuiaPanMove"
                     @onmouseup="OnFotoGuiaPanEnd"
                     @onmouseleave="OnFotoGuiaPanLeave">
                    <div style="display: flex; align-items: center; justify-content: center; width: 100%; height: 100%;">
                        <img src="@FotoGuiaUrl" alt="Foto Guía"
