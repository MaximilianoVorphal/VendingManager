@page "/templates-recarga"
@using Microsoft.AspNetCore.Authorization
@using VendingManager.Shared.Constants
@using VendingManager.Shared.DTOs
@using VendingManager.Shared.Enums
@using VendingManager.Shared.Models
@using Microsoft.AspNetCore.Components.Forms
@using System.Globalization
@using VendingManager.Web.Layout
@using VendingManager.Web.Components
@using VendingManager.Web.Components.Shared
@attribute [Authorize(Roles = Roles.Admin)]
@inject HttpClient Http
@inject Microsoft.Extensions.Logging.ILogger<TemplatesRecarga> Logger
@inject NavigationManager NavManager
@inject IJSRuntime JS
@implements IDisposable

@if (PeriodoEnEdicionVisual == null)
{
<div class="rec-list">

    <!-- HEADER -->
    <div class="rec-list__head">
        <div>
            <span class="rec-eyebrow">Terreno · Recarga</span>
            <h1 class="rec-title">Templates de Recarga<span class="rec-title__cursor">_</span></h1>
            <small class="rec-subtitle">Definí períodos por máquina y cargá el planograma</small>
        </div>
        <div class="d-flex gap-2 flex-wrap header-actions">
            <button class="rec-pill @(SoloPendientes ? "is-on" : "")" @onclick="() => SoloPendientes = !SoloPendientes">
                <i class="bi bi-exclamation-circle"></i>
                Pendientes · @(Templates?.Count(t => t.CantidadSlotsPendientes > 0) ?? 0)
            </button>
            <VmButton Variant="dark" Icon="bi-arrow-repeat" OnClick="AbrirModalSincronizarGlobal">
                Sincronizar todo
            </VmButton>
            <VmButton Variant="dark" Icon="bi-plus-lg" OnClick="AbrirModalCrear">
                Nuevo template
            </VmButton>
        </div>
    </div>

    @if (Cargando)
    {
        <div class="text-center py-5 border border-dark border-2 bg-light">
            <div class="spinner-grow text-dark" role="status"></div>
            <p class="mt-2 fw-bold text-uppercase loading-letter-spacing">Cargando Templates...</p>
        </div>
    }
    else if (TemplatesFiltrados != null && TemplatesFiltrados.Any())
    {
        <div class="rec-tablewrap">
            <table class="rec-table">
                <thead>
                    <tr>
                        <th>Estado</th>
                        <th>Recarga / Ruta</th>
                        <th>Período</th>
                        <th>Máquinas</th>
                        <th>Carga</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var template in TemplatesFiltrados)
                    {
                        var pendiente = template.CantidadSlotsPendientes > 0;
                        var firstPeriodo = template.Periodos.FirstOrDefault();
                        <tr class="rec-trow @(pendiente ? "is-pending" : "")">
                            <td>
                                <span class="rec-badge rec-badge--@(GetEstadoTagVariant(template))">@GetEstadoDisplay(template)</span>
                            </td>
                            <td>
                                @if (firstPeriodo != null)
                                {
                                    <button class="rec-name-btn" @onclick="() => AbrirEdicionVisual(template, firstPeriodo)">
                                        <span>@template.Nombre</span>
                                        <span>@template.Descripcion</span>
                                    </button>
                                }
                                else
                                {
                                    <span class="rec-cell-mono">@template.Nombre</span>
                                }
                            </td>
                            <td>
                                @if (template.FechaRecargaMin?.Date == template.FechaFinMax?.Date)
                                {
                                    <span class="rec-cell-mono">@template.FechaRecargaMin?.ToString("dd/MM/yyyy")</span>
                                }
                                else
                                {
                                    <span class="rec-cell-mono">@template.FechaRecargaMin?.ToString("dd/MM/yyyy") - @template.FechaFinMax?.ToString("dd/MM/yyyy")</span>
                                }
                            </td>
                            <td>
                                <div class="rec-chips">
                                    @foreach (var periodo in template.Periodos)
                                    {
                                        var idStr = periodo.MaquinaId.ToString();
                                        <span>@idStr.Substring(Math.Max(0, idStr.Length - 4))</span>
                                    }
                                </div>
                            </td>
                            <td>
                                <div class="rec-carga-list">
                                    @foreach (var periodo in template.Periodos)
                                    {
                                        var cap = periodo.SnapshotSlots.Sum(s => s.CapacidadSlot);
                                        var units = periodo.SnapshotSlots.Sum(s => s.CantidadInicial);
                                        var mpct = cap > 0 ? (units * 100 / cap) : 0;
                                        var mIdStr = periodo.MaquinaId.ToString();
                                        <div class="rec-carga">
                                            <span class="rec-carga-mid">@mIdStr.Substring(Math.Max(0, mIdStr.Length - 4))</span>
                                            <div class="rec-progress">
                                                <span class="fill-@(mpct >= 80 ? "good" : mpct >= 30 ? "warning" : "danger")" style="width:@mpct%"></span>
                                            </div>
                                            <span class="rec-cell-mono">@units/@cap u.</span>
                                        </div>
                                    }
                                </div>
                            </td>
                            <td>
                                <div class="rec-actions">
                                    <VmButton Variant="outline" Size="sm" Icon="bi-pencil" OnClick="() => AbrirModalEditar(template)"></VmButton>
                                    <VmButton Variant="danger" Size="sm" Icon="bi-graph-up" OnClick="() => AnalizarTemplate(template.Id)">Stockout</VmButton>
                                    @if (firstPeriodo != null)
                                    {
                                        <VmButton Variant="dark" Size="sm" Icon="bi-box-arrow-in-right" OnClick="() => AbrirEdicionVisual(template, firstPeriodo)">Abrir</VmButton>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="rec-empty">
            <p>Sin recargas que coincidan con el filtro</p>
            <button class="rec-pill" @onclick="AbrirModalCrear">Crear primer template</button>
        </div>
    }

</div>

<!-- MODAL CREAR/EDITAR -->
@if (MostrarModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5); z-index: 1110;">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content border-2 border-dark rounded-0">
                <div class="modal-header bg-dark text-white rounded-0 border-bottom border-dark">
                    <h5 class="modal-title fw-bold text-uppercase">
                        @(EsEdicion ? "EDITAR TEMPLATE" : "NUEVO TEMPLATE DE RECARGA")
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarModal"></button>
                </div>
                <div class="modal-body">
                    <!-- Nombre y Descripción -->
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <VmInput Label="NOMBRE DEL TEMPLATE" @bind-Value="TemplateActual.Nombre" Placeholder="Ej: Recarga Nuevo 3" />
                        </div>
                        <div class="col-md-6">
                            <VmInput Label="DESCRIPCIÓN (OPCIONAL)" @bind-Value="TemplateActual.Descripcion" Placeholder="Ej: Recarga semanal enero" />
                        </div>
                    </div>

                    <!-- Períodos por Máquina -->
                    <div class="border border-dark p-3 bg-light">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="fw-bold text-uppercase m-0">
                                <i class="bi bi-clock-history me-1"></i> PERÍODOS POR MÁQUINA
                            </h6>
                            <VmButton Variant="dark" Size="sm" Icon="bi-plus-lg" OnClick="AgregarPeriodo">
                                Agregar Máquina
                            </VmButton>
                        </div>

                        @if (!PeriodosActuales.Any())
                        {
                            <div class="text-center text-muted py-3">
                                <i class="bi bi-info-circle"></i> Agrega al menos una máquina con su período
                            </div>
                        }
                        else
                        {
                            @for (int i = 0; i < PeriodosActuales.Count; i++)
                            {
                                var periodo = PeriodosActuales[i];
                                var index = i;
                                <div class="card rounded-0 border-dark mb-2">
                                    <div class="card-body p-2">
                                        <div class="row g-2 align-items-end">
                                            <div class="col-md-4 col-12">
                                                <VmSelect Label="MÁQUINA"
                                                          Value="@periodo.MaquinaId.ToString()"
                                                          ValueChanged="@(v => OnMaquinaChanged(index, v))"
                                                          Options="@(ListaMaquinas?.Select(m => new VmSelect.VmSelectOption(m.Id.ToString(), m.Nombre)) ?? [])" />
                                            </div>
                                            <div class="col-md-4 col-12">
                                                <VmInput Label="FECHA RECARGA" Type="date"
                                                         Value="@periodo.FechaRecargaText"
                                                         ValueChanged="@(v => OnFechaRecargaDateChanged(index, v))" />
                                            </div>
                                            <div class="col-md-2 col-12">
                                                <VmInput Label="HORA" Type="text" Placeholder="HH:mm"
                                                         Value="@periodo.HoraRecargaText"
                                                         ValueChanged="@(v => OnHoraRecargaChanged(index, v))" />
                                            </div>
                                            <div class="col-md-2 col-12">
                                                <div class="d-flex gap-1">
                                                    <VmButton Variant="outline" Size="sm" Icon="bi-box-seam" OnClick="() => CargarSlotsParaPeriodo(index)" Disabled="@(periodo.MaquinaId == 0 || CargandoSlots)">
                                                        Slots
                                                    </VmButton>
                                                    <VmButton Variant="danger" Size="sm" Icon="bi-x-lg" OnClick="() => EliminarPeriodo(index)">
                                                    </VmButton>
                                                </div>
                                            </div>
                                        </div>

                                        @if (periodo.SnapshotSlots.Any())
                                        {
                                            <div class="mt-3 p-3 bg-white border border-2 border-dark text-center shadow-sm">
                                                <h6 class="fw-bold text-success mb-3 text-uppercase">
                                                    <i class="bi bi-check-circle-fill me-1"></i>
                                                    @periodo.SnapshotSlots.Count(s => s.ProductoId.HasValue && s.ProductoId > 0) productos configurados
                                                    <span class="text-muted ms-1">(de @periodo.SnapshotSlots.Count slots)</span>
                                                </h6>
                                                <div class="slot-grid mb-3">
                                                    @foreach (var slot in periodo.SnapshotSlots)
                                                    {
                                                        <SlotCard Slot="slot" IsReadOnly="true" />
                                                    }
                                                </div>
                                                <div class="mb-2">
                                                    <VmButton Variant="dark" Size="sm" Icon="bi-grid-3x3-gap-fill" OnClick="() => AbrirEdicionVisual(periodo)">
                                                        EDITAR SLOTS (GRILLA)
                                                    </VmButton>
                                                </div>
                                                <div class="mt-3 border-top border-dark pt-3">
                                                    <VmButton Variant="outline" Size="sm" Icon="bi-trash" OnClick="() => periodo.SnapshotSlots.Clear()">
                                                        VACIAR MÁQUINA
                                                    </VmButton>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        }
                    </div>
            </div>
            <div class="modal-footer border-top border-dark">
                <VmButton Variant="outline" Size="sm" OnClick="CerrarModal">
                    CANCELAR
                </VmButton>
                <VmButton Variant="dark" Size="sm" OnClick="GuardarTemplate" Disabled="@Guardando">
                    @(Guardando ? "GUARDANDO..." : (EsEdicion ? "ACTUALIZAR" : "GUARDAR TEMPLATE"))
                </VmButton>
            </div>
        </div>
    </div>
</div>
}
}

<!-- EDICIÓN VISUAL DE SLOTS (Full-page inline, no modal) -->
@if (PeriodoEnEdicionVisual != null)
{
    var templateActual = Templates?.FirstOrDefault(t => t.Id == _currentTemplateId);
    var estado = templateActual != null ? GetEstadoDisplay(templateActual) : "PENDIENTE";
    var estadoVariant = templateActual != null ? GetEstadoTagVariant(templateActual) : "pend";
    var descripcion = templateActual?.Descripcion ?? "";
    var maquinaNombre = ListaMaquinas?.FirstOrDefault(m => m.Id == PeriodoEnEdicionVisual.MaquinaId)?.Nombre ?? $"Máquina {PeriodoEnEdicionVisual.MaquinaId}";

    <div class="rec-editor">
        <!-- Top bar -->
        <div class="rec-bar">
            <div class="rec-bar__left">
                <VmButton Variant="outline" Bar="true" Icon="bi-arrow-left" OnClick="CerrarEdicionVisual">Volver</VmButton>
                <div class="rec-bar__title-group">
                    <div class="d-flex align-items-center gap-2">
                        <h2 class="rec-bar__title">@maquinaNombre</h2>
                        <span class="rec-badge rec-badge--@estadoVariant">@estado</span>
                    </div>
                    @if (!string.IsNullOrEmpty(descripcion))
                    {
                        <small class="rec-bar__subtitle">@descripcion</small>
                    }
                </div>
            </div>
            <div class="rec-bar__actions">
                @if (_fotoOcrLoading)
                {
                    <span class="d-inline-flex align-items-center gap-1 small text-muted">
                        <span class="spinner-border spinner-border-sm"></span> Foto OCR
                    </span>
                }
                else if (!string.IsNullOrEmpty(_fotoOcrUrl))
                {
                    <button type="button"
                            class="btn btn-outline-dark btn-sm rounded-0 d-inline-flex align-items-center gap-2 p-1"
                            title="Ver foto OCR guardada"
                            @onclick="() => _ocrPreviewVisible = true">
                        <img src="@_fotoOcrUrl" alt="Foto OCR" style="height:32px;width:32px;object-fit:cover;" />
                        <span class="small fw-bold pe-1">Foto OCR</span>
                    </button>
                }
                <VmButton Variant="outline" Bar="true" Width="100px" Icon="bi-pencil" OnClick="AbrirModalEditarActual">Editar</VmButton>
                <VmButton Variant="danger" Bar="true" Width="160px" Icon="bi-graph-up" OnClick="AnalizarTemplateActual">Analizar stockout</VmButton>
                <VmButton Variant="outline" Bar="true" Width="150px" Icon="bi-arrow-repeat" OnClick="SincronizarTemplateActual">Sincronizar todo</VmButton>
                @if (templateActual?.Estado == EstadoTemplate.Terminado)
                {
                    <VmStatusChip Icon="bi-check2-circle">Finalizado</VmStatusChip>
                }
                else
                {
                    <VmButton Variant="dark" Bar="true" Width="130px" Icon="bi-check2-circle" OnClick="TerminarTemplateActual">Finalizar</VmButton>
                }
            </div>
        </div>

        @if (!string.IsNullOrEmpty(MensajeErrorOcr))
        {
            <div class="alert alert-danger border-2 border-dark rounded-0 mb-3 small fw-bold">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> @MensajeErrorOcr
            </div>
        }
        @if (!string.IsNullOrEmpty(MensajeInfoOcr))
        {
            <div class="alert alert-info border-2 border-dark rounded-0 mb-3 small fw-bold">
                <i class="bi bi-info-circle-fill me-2"></i> @MensajeInfoOcr
            </div>
        }

        <!-- PR3 Migration: OCR upload now goes through FotoRecargaModal Capturar step.
             The old Hidden InputFile id="ocrRecargaFileInput" + HandleOcrPhotoUpload + TriggerOcrUpload
             were removed in PR3. The "Foto recarga" button opens the modal instead. -->

        <div class="rec-split">
            <!-- Rail de maquinas -->
            <aside class="rec-rail">
                <div class="rec-rail__head">
                    <span class="rec-rail__title">MÁQUINAS · @(PeriodosActuales.Count)</span>
                    <small class="rec-rail__hint">Período por máquina · clic para ver grilla</small>
                </div>
                <div class="rec-rail__body">
                    @for (int i = 0; i < PeriodosActuales.Count; i++)
                    {
                        var idx = i;
                        var periodo = PeriodosActuales[i];
                        var stats = GetPeriodoStats(periodo);
                        var pct = stats.cap > 0 ? (stats.units * 100 / stats.cap) : 0;
                        <div class="rec-mcard @(i == ActiveMachineIndex ? "is-active" : "")" @onclick="() => SeleccionarMaquinaEnRail(idx)">
                            <div class="d-flex align-items-center gap-2">
                                <select class="rec-mcard__select" value="@periodo.MaquinaId" @onchange="e => OnMaquinaChanged(idx, e.Value?.ToString())" @onclick:stopPropagation="true">
                                    @foreach (var m in ListaMaquinas ?? new List<MaquinaSimpleDto>())
                                    {
                                        <option value="@m.Id">@m.Nombre</option>
                                    }
                                </select>
                                <VmIconButton Icon="bi-trash" Variant="danger" Label="Quitar máquina" OnClick="() => EliminarPeriodo(idx)" />
                            </div>
                            <div class="d-flex gap-2">
                                <input type="date" class="form-control form-control-sm border-2 border-dark rounded-0" style="flex:1;min-width:0;font-family:var(--font-mono);font-size:0.7rem;" value="@periodo.FechaRecargaText" @onchange="e => OnFechaRecargaDateChanged(idx, e.Value?.ToString())" @onclick:stopPropagation="true" />
                                <input type="time" class="form-control form-control-sm border-2 border-dark rounded-0" style="width:84px;font-family:var(--font-mono);font-size:0.7rem;" value="@periodo.HoraRecargaText" @onchange="e => OnHoraRecargaChanged(idx, e.Value?.ToString())" @onclick:stopPropagation="true" />
                            </div>
                            <div class="rec-carga">
                                <div class="rec-progress">
                                    <span class="fill-@(pct >= 80 ? "good" : pct >= 30 ? "warning" : "danger")" style="width:@pct%"></span>
                                </div>
                                <span class="rec-cell-mono">@stats.units/@stats.cap</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center">
                                <small class="rec-mcard-config">@stats.configured/@stats.total configurados</small>
                                @if (stats.vacios > 0)
                                {
                                    <span class="rec-tag-empty">@stats.vacios vacíos</span>
                                }
                            </div>
                        </div>
                    }
                </div>
                <div class="rec-rail__foot">
                    <VmButton Variant="outline" Block="true" Bar="true" Icon="bi-plus-lg" OnClick="AgregarPeriodo">Agregar máquina</VmButton>
                </div>
            </aside>

            <!-- Estanteria -->
            <section class="rec-shelf">
                <div class="rec-shelf__head">
                    <div class="d-flex align-items-center gap-3">
                        <div class="rec-iconbox"><i class="bi bi-grid-3x3-gap-fill"></i></div>
                        <div>
                            <div class="rec-shelf__title">Estantería · Máquina @(PeriodoEnEdicionVisual.MaquinaId)</div>
                            <small class="rec-subtitle">@(GetEstanteriaPct())% LLENO · @(PeriodoEnEdicionVisual.SnapshotSlots.Count) SLOTS</small>
                        </div>
                    </div>
                    <div class="d-flex gap-2 flex-wrap align-items-center">
                        <input class="rec-search" placeholder="Buscar slot o producto..." @bind="SlotSearch" @bind:event="oninput" />
                        <VmSegmented @bind-Value="DensidadKey"
                                     Options="@(new[] { ("comoda","Cómoda"), ("compacta","Compacta") })" />
                        <VmButton Variant="outline" Size="sm" Icon="bi-camera" OnClick="() => _recargaVisible = true">Foto recarga</VmButton>
                        @if (!_guiaVisible)
                        {
                            <VmButton Variant="outline" Size="sm" Icon="bi-image" OnClick="ToggleGuiaPanel">Foto guia</VmButton>
                        }
                    </div>
                </div>

                <div class="rec-shelf__body">
                    @{
                        var editorSlots = PeriodoEnEdicionVisual.SnapshotSlots.ToList();
                        var search = SlotSearch.Trim();
                        var filteredSlots = string.IsNullOrEmpty(search)
                            ? editorSlots
                            : editorSlots.Where(s =>
                                s.NumeroSlot.Contains(search, StringComparison.OrdinalIgnoreCase) ||
                                (!string.IsNullOrEmpty(s.ProductoNombre) && s.ProductoNombre.Contains(search, StringComparison.OrdinalIgnoreCase))).ToList();
                        var floors = filteredSlots.GroupBy(s => (int.TryParse(s.NumeroSlot, out var n) ? n - 1 : 0) / 10).OrderBy(g => g.Key);
                    }
                    @if (!filteredSlots.Any())
                    {
                        <div class="rec-empty">
                            <p>Ningún slot coincide con "@SlotSearch"</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var floor in floors)
                        {
                            <section class="rec-floor">
                                <div class="rec-floor__head">
                                    <span class="rec-floor__tag">PISO @(floor.Key + 1)</span>
                                    <span class="rec-floor__rule"></span>
                                    <small class="rec-floor__sum">@(floor.Count()) slots</small>
                                </div>
                                <div class="rec-grid @(DensidadCompacta ? "is-compact" : "")">
                                    @foreach (var slot in floor.OrderBy(s => int.TryParse(s.NumeroSlot, out var n) ? n : 999))
                                    {
                                        var empty = slot.Estado == EstadoSlot.Vacio;
                                        var pct = slot.CapacidadSlot > 0 ? Math.Min(100, slot.CantidadInicial * 100 / slot.CapacidadSlot) : 0;
                                        <div class="rec-slot @(empty ? "rec-slot-empty" : "")">
                                            <div class="d-flex justify-content-between align-items-center">
                                                <div class="d-flex align-items-center gap-2">
                                                    <span class="rec-slot-id">Slot @slot.NumeroSlot</span>
                                                    @if (empty)
                                                    {
                                                        <span class="rec-slot-vacio-tag">Vacío</span>
                                                    }
                                                </div>
                                                @if (MostrarPrecios)
                                                {
                                                    @if (slot.ProductoId.HasValue && _preciosByProductoId.TryGetValue(slot.ProductoId.Value, out var slotPrice) && slotPrice > 0)
                                                    {
                                                        <span class="rec-slot-price">@slotPrice.ToString("C0", new CultureInfo("es-CL"))</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="rec-slot-price rec-slot-price--dash">$—</span>
                                                    }
                                                }
                                            </div>
                                            <button class="rec-slot-pick" @onclick="() => OnChangeProductForSlot(slot)">
                                                <span>@(empty ? "— Elegir producto —" : slot.ProductoNombre)</span>
                                                <i class="bi bi-search"></i>
                                            </button>
                                            <div class="rec-carga">
                                                <div class="rec-progress">
                                                    <span class="fill-@(pct >= 80 ? "good" : pct >= 30 ? "warning" : "danger")" style="width:@pct%"></span>
                                                </div>
                                                <span class="rec-cell-mono">@slot.CantidadInicial/@slot.CapacidadSlot</span>
                                            </div>
                                            <div class="d-flex align-items-center gap-2">
                                                <VmStepper Quantity="@slot.CantidadInicial" Capacity="@slot.CapacidadSlot"
                                                           OnChange="q => OnSlotQuantityChanged(slot, q)" />
                                            </div>
                                        </div>
                                    }
                                </div>
                            </section>
                        }
                    }
                </div>

                <div class="rec-shelf__foot">
                    @{
                        var bottomSlots = PeriodoEnEdicionVisual.SnapshotSlots;
                        var bottomCap = bottomSlots.Sum(s => s.CapacidadSlot);
                        var bottomUnits = bottomSlots.Sum(s => s.CantidadInicial);
                        var bottomVacios = bottomSlots.Count(s => s.Estado == EstadoSlot.Vacio);
                    }
                    <div>
                        <small class="rec-bottombar-label">Carga máquina</small>
                        <div class="rec-bottombar-totals">@bottomUnits <span class="rec-bottombar-cap">/ @bottomCap u.</span></div>
                    </div>
                    @if (bottomVacios > 0)
                    {
                        <span class="rec-bottombar-vacios">@bottomVacios slots vacíos</span>
                    }
                    <div class="rec-shelf__foot-actions">
                        <VmButton Variant="danger" Bar="true" Width="140px" Icon="bi-trash" OnClick="VaciarMaquina">Vaciar máquina</VmButton>
                        <VmButton Variant="outline" Bar="true" Width="100px" Icon="bi-arrow-counterclockwise" OnClick="ResetSlots">Reset</VmButton>
                        <VmButton Variant="dark" Bar="true" Width="160px" Icon="bi-save" OnClick="GuardarCarga">Guardar carga</VmButton>
                    </div>
                </div>
            </section>

            <!-- Foto Guía Panel (3rd column, replaces old fullscreen modal) -->
            @if (_guiaVisible)
            {
                <FotoGuiaPanel MaquinaId="@(PeriodoEnEdicionVisual?.MaquinaId.ToString() ?? "")"
                               FotoGuiaUrl="@FotoGuiaUrl"
                               OnClose="CerrarGuiaPanel"
                               OnFotoUpload="HandlePanelFotoUpload" />
            }
        </div>

        <!-- Foto Recarga Modal (PR3 — replaces old direct-apply OCR path) -->
        @if (PeriodoEnEdicionVisual != null)
        {
            <FotoRecargaModal Visible="@_recargaVisible"
                              MaquinaId="@(PeriodoEnEdicionVisual.MaquinaId.ToString())"
                              SlotsActuales="@ProjectedSlotsActual()"
                              TemplateId="@_currentTemplateId"
                              PeriodoId="@PeriodoEnEdicionVisual.Id"
                              OnClose="() => _recargaVisible = false"
                              OnAplicar="AplicarRecarga" />
        }

        <!-- Foto OCR preview overlay (proof that the persisted photo loads back) -->
        @if (_ocrPreviewVisible && !string.IsNullOrEmpty(_fotoOcrUrl))
        {
            <div class="modal fade show d-block" tabindex="-1"
                 style="background-color: rgba(0,0,0,0.8); z-index: 1115;"
                 @onclick="() => _ocrPreviewVisible = false">
                <div class="modal-dialog modal-dialog-centered modal-lg" @onclick:stopPropagation="true">
                    <div class="modal-content border-0 bg-transparent shadow-none">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="text-white small fw-bold">Foto OCR guardada</span>
                            <button type="button" class="btn btn-light btn-sm rounded-circle"
                                    @onclick="() => _ocrPreviewVisible = false">×</button>
                        </div>
                        <img src="@_fotoOcrUrl" alt="Foto OCR guardada"
                             class="img-fluid" style="max-height:80vh;object-fit:contain;" />
                    </div>
                </div>
            </div>
        }

        <!-- PRODUCT SELECTOR MODAL (for slot product change) -->
        @if (SlotConProductoSelector != null && ListaProductos != null)
        {
            <div class="modal fade show d-block" tabindex="-1"
                 style="background-color: rgba(0,0,0,0.5); z-index: 1110;"
                 @onclick="CerrarProductoSelector">
                <div class="modal-dialog modal-dialog-centered" @onclick:stopPropagation="true">
                    <div class="modal-content border-0 bg-transparent shadow-none">
                        <VmCard Header="@($"CAMBIAR PRODUCTO — SLOT {SlotConProductoSelector.NumeroSlot}")" HeaderVariant="dark">
                            <input type="text" class="form-control form-control-sm border-dark rounded-0 mb-3"
                                   placeholder="Buscar producto..."
                                   @bind="ProductoSearch"
                                   @bind:event="oninput" />
                            <div style="max-height: 320px; overflow-y: auto; display: flex; flex-direction: column; gap: 0.25rem;">
                                @foreach (var prod in ListaProductos.Where(p =>
                                    string.IsNullOrEmpty(ProductoSearch) ||
                                    p.Nombre.Contains(ProductoSearch, StringComparison.OrdinalIgnoreCase)))
                                {
                                    var isActive = SlotConProductoSelector.ProductoId == prod.Id;
                                    <button class="btn btn-sm text-start rounded-0 border-dark d-flex justify-content-between align-items-center @(isActive ? "btn-dark" : "btn-outline-dark")"
                                            @onclick="() => SeleccionarProductoParaSlot(prod)">
                                        <span class="fw-bold">@prod.Nombre</span>
                                        @if (isActive)
                                        {
                                            <i class="bi bi-check-circle-fill ms-2"></i>
                                        }
                                    </button>
                                }
                            </div>
                        </VmCard>
                    </div>
                </div>
            </div>
        }
    </div>

}

