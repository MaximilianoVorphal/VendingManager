    private async Task SincronizarVentas()
    {
        Sincronizando = true;
        MensajeError = "";
        MensajeExito = "";
        StateHasChanged();

        try
        {
            var response = await Http.PostAsync($"api/TemplateRecarga/{TemplateIdSincronizar}/sincronizar-ventas?actualizarCostos={ActualizarCostosSincronizacion}", null);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<SyncResultDto>();
                MensajeExito = $"Se actualizaron {result?.Count ?? 0} registros de ventas de manera retroactiva.";
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                MensajeError = "Error al sincronizar: " + error;
            }
        }
        catch (Exception ex)
        {
            MensajeError = "Error de red: " + ex.Message;
        }
        finally
        {
            Sincronizando = false;
            MostrarModalSincronizar = false;
            await UnlockScroll();
            StateHasChanged();
        }
    }

