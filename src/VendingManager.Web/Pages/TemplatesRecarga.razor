    private async Task IrAPendiente(PendingSlotInfo info)
    {
        await CerrarModalPendientes();

        var template = Templates?.FirstOrDefault(t => t.Id == info.TemplateId);
        if (template == null) return;

        // Abrir edición del template
        await AbrirModalEditar(template);
        StateHasChanged();

        // Buscar el índice del período que tiene el slot pendiente
        var periodoIndex = PeriodosActuales.FindIndex(p => p.Id == info.PeriodoId);
        if (periodoIndex < 0) return;

        // Cargar slots del período
        await CargarSlotsParaPeriodo(periodoIndex);

        // Abrir el editor visual
        if (periodoIndex < PeriodosActuales.Count)
        {
            await AbrirEdicionVisual(PeriodosActuales[periodoIndex]);
        }
        StateHasChanged();
    }

