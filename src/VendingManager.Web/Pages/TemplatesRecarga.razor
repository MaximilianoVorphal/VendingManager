    // === Foto Guía Zoom/Pan handlers ===
    private void OnFotoGuiaZoom(WheelEventArgs e)
    {
        // Proportional zoom based on actual scroll distance.
        // Mouse scrolls send DeltaY ~ ±120 per notch → ~ ±0.3 zoom per notch
        // Touchpad smooth scrolling sends DeltaY ~ ±(1–15) per frame → fine-grained, proportional
        var zoomDelta = -e.DeltaY / 400.0;
        _fotoGuiaZoom = Math.Clamp(_fotoGuiaZoom + zoomDelta, 1.0, 5.0);
    }

    private void OnFotoGuiaPanStart(MouseEventArgs e)
    {
        _fotoGuiaDragging = true;
        _fotoGuiaLastMouseX = e.ClientX;
        _fotoGuiaLastMouseY = e.ClientY;
    }

    private void OnFotoGuiaPanMove(MouseEventArgs e)
    {
        if (!_fotoGuiaDragging) return;
        var dx = e.ClientX - _fotoGuiaLastMouseX;
        var dy = e.ClientY - _fotoGuiaLastMouseY;
        _fotoGuiaPanX += dx / _fotoGuiaZoom;
        _fotoGuiaPanY += dy / _fotoGuiaZoom;
        _fotoGuiaLastMouseX = e.ClientX;
        _fotoGuiaLastMouseY = e.ClientY;
    }

    private void OnFotoGuiaPanEnd(MouseEventArgs e)
    {
        _fotoGuiaDragging = false;
    }

    private void OnFotoGuiaPanLeave()
    {
        _fotoGuiaDragging = false;
    }

    // Touch handlers for mobile panning
    private void OnFotoGuiaTouchStart(TouchEventArgs e)
    {
        if (e.Touches.Length == 1)
        {
            _fotoGuiaDragging = true;
            _fotoGuiaLastMouseX = e.Touches[0].ClientX;
            _fotoGuiaLastMouseY = e.Touches[0].ClientY;
        }
    }

    private void OnFotoGuiaTouchMove(TouchEventArgs e)
    {
        if (!_fotoGuiaDragging || e.Touches.Length != 1) return;
        var dx = e.Touches[0].ClientX - _fotoGuiaLastMouseX;
        var dy = e.Touches[0].ClientY - _fotoGuiaLastMouseY;
        _fotoGuiaPanX += dx / _fotoGuiaZoom;
        _fotoGuiaPanY += dy / _fotoGuiaZoom;
        _fotoGuiaLastMouseX = e.Touches[0].ClientX;
        _fotoGuiaLastMouseY = e.Touches[0].ClientY;
    }

    private void OnFotoGuiaTouchEnd(TouchEventArgs e)
    {
        _fotoGuiaDragging = false;
    }

    private void ResetFotoGuiaView()
    {
        _fotoGuiaZoom = 1.0;
        _fotoGuiaPanX = 0;
        _fotoGuiaPanY = 0;
    }

