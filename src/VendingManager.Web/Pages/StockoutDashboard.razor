@page "/stockout-dashboard"
@attribute [Authorize]

@* =============================================================================
   Quiebres de Stock — port visual fiel de templates/quiebres-de-stock/
   QuiebresDeStock.dc.html (VendingManager Design System, lenguaje industrial v3).
   Data real: cableada al backend vía el partial StockoutDashboard.razor.cs
   (HttpClient + stockout-analysis / TemplateRecarga/{id}/analyze). Un adapter
   en el code-behind mapea Datos/DatosAgrupados a los view-models del markup.
   Layout sin scroll de página (ruta fullscreen en MainLayout); el scroll vive
   dentro de la tabla y el aside. Estilos inline con var(--token) copiados del
   template; el bloque <style> cubre keyframes, hover y responsive.
   ============================================================================= *@

<PageTitle>Quiebres de Stock</PageTitle>

<style>
    @@keyframes qsBlink { 50% { opacity: 0; } }
    .qs-cursor { animation: qsBlink 1s steps(1) infinite; }
    .qs-row { cursor: pointer; transition: background .12s; }
    .qs-row:hover td { background: var(--paper-50); }
    .qs-row-sel td { background: #eef0f2 !important; }
    .qs-row-sel td:first-child { box-shadow: inset 4px 0 0 var(--ink-900); }
    .qs-tl-item:hover { background: var(--paper-50); }
    .qs-slot { transition: transform .1s, box-shadow .1s; }
    .qs-slot:hover { transform: translateY(-1px); z-index: 1; }
    .qs-th { user-select: none; }
    .qs-page h1 { user-select: none; }
    @@media (prefers-reduced-motion: reduce) { .qs-cursor { animation: none !important; } }
    @@media (max-width: 1000px) {
        .qs-body { flex-direction: column !important; overflow: auto !important; }
        .qs-rail { width: 100% !important; flex-direction: row !important; flex-wrap: wrap !important; }
        .qs-rail > * { flex: 1 1 300px; }
        .qs-kpis { flex-direction: row !important; }
        .qs-split { flex-direction: column !important; }
        .qs-aside { flex: none !important; width: 100% !important; }
    }
</style>

<div class="qs-page" style="flex:1;min-height:0;display:flex;flex-direction:column;overflow:hidden;padding:0.7rem 1.3rem 1rem;gap:9px;">

    <!-- ===== Header (franja fina full-width) ===== -->
    <div style="flex-shrink:0;display:flex;justify-content:space-between;align-items:center;gap:14px;border-bottom:3px solid var(--ink-900);padding-bottom:7px;">
        <div style="display:flex;align-items:center;gap:12px;min-width:0;">
            <div style="flex-shrink:0;background:var(--ink-900);color:#fff;font-family:var(--font-mono);font-weight:700;font-size:0.54rem;letter-spacing:2px;padding:3px 9px;text-transform:uppercase;">Gestión · Stock</div>
            <h1 style="margin:0;font-family:var(--font-mono);font-weight:700;text-transform:uppercase;letter-spacing:-1px;font-size:1.25rem;line-height:1;display:flex;align-items:center;gap:8px;white-space:nowrap;"><i class="bi bi-exclamation-triangle-fill" style="color:var(--signal-danger);font-size:1.05rem;"></i>Quiebres de Stock<span class="qs-cursor">_</span></h1>
            <p style="margin:0;font-family:var(--font-mono);font-size:0.62rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.4px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">Detección de silencio y costo de oportunidad</p>
        </div>
        <div style="flex-shrink:0;display:flex;align-items:center;gap:7px;font-family:var(--font-mono);font-size:0.62rem;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">
            <i class="bi bi-clock-history"></i><span>Análisis: @AnalizadosN slots · @MachinesN máquinas</span>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(MensajeError))
    {
        <div style="flex-shrink:0;border:2px solid var(--signal-danger);background:#fff0f1;color:var(--signal-danger);font-family:var(--font-mono);font-weight:700;font-size:0.68rem;text-transform:uppercase;letter-spacing:0.4px;padding:0.5rem 0.8rem;display:flex;align-items:center;gap:8px;">
            <i class="bi bi-exclamation-octagon-fill"></i><span>@MensajeError</span>
        </div>
    }

    <!-- ===== Barra de comando (arriba, horizontal) ===== -->
    <div class="qs-cmd" style="flex-shrink:0;border:2px solid var(--ink-900);background:var(--paper-50);box-shadow:var(--shadow-card);padding:0.5rem 0.8rem;display:flex;gap:12px;align-items:flex-end;flex-wrap:wrap;">
        <div style="flex:1.3;min-width:220px;display:flex;flex-direction:column;gap:0.3rem;">
            <label style="font-family:var(--font-mono);font-size:0.61rem;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;"><i class="bi bi-card-list" style="margin-right:5px;"></i>Template de recarga</label>
            <div style="display:flex;gap:6px;">
                <div style="flex:1;min-width:0;">
                    <VmSelect Value="@_template" Options="TemplateOptions" ValueChanged="@((string v) => _template = v)" />
                </div>
                <button type="button" title="Configurar períodos" style="flex-shrink:0;width:40px;height:40px;border:2px solid var(--ink-900);border-radius:0;background:var(--paper-0);cursor:pointer;font-size:0.9rem;display:flex;align-items:center;justify-content:center;"><i class="bi bi-gear"></i></button>
            </div>
        </div>
        <div style="flex:1.2;min-width:180px;align-self:stretch;display:flex;flex-direction:column;gap:0.3rem;">
            <label style="font-family:var(--font-mono);font-size:0.61rem;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Períodos configurados</label>
            <div style="flex:1;border:2px solid var(--signal-info);background:#e8fbff;display:flex;align-items:center;gap:7px;padding:0 8px;overflow:hidden;">
                <i class="bi bi-calendar-check" style="color:#0a8aa0;flex-shrink:0;"></i>
                <span style="background:var(--ink-900);color:#fff;font-family:var(--font-mono);font-weight:700;font-size:0.54rem;letter-spacing:0.5px;padding:3px 6px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">MAQUINA 2410280023 SNACK</span>
                <span style="font-family:var(--font-mono);font-size:0.55rem;color:var(--text-muted);white-space:nowrap;flex-shrink:0;">+ 2 más</span>
            </div>
        </div>
        <div style="flex:1.5;min-width:210px;display:flex;flex-direction:column;gap:0.3rem;">
            <label style="font-family:var(--font-mono);font-size:0.61rem;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;">Filtrar máquina</label>
            <VmSelect Value="@_maquina" Options="MaquinaOptions" ValueChanged="@((string v) => _maquina = v)" />
        </div>
        <div style="width:88px;flex-shrink:0;display:flex;flex-direction:column;gap:0.3rem;">
            <label style="font-family:var(--font-mono);font-size:0.61rem;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;">Umbral h</label>
            <input type="number" value="@_umbral" @onchange="OnUmbralChanged" style="font-family:var(--font-mono);font-size:0.85rem;font-weight:700;border:2px solid var(--ink-900);border-radius:0;background:var(--paper-0);padding:0.42rem 0.55rem;outline:none;width:100%;" />
        </div>
        <div style="flex:1;min-width:170px;">
            <VmButton Variant="danger" Icon="bi-radar" Block="true" Width="100%" OnClick="CargarDatosPorTemplate">Analizar por template</VmButton>
        </div>
    </div>

    <!-- ===== Cuerpo: KPIs (riel izquierdo) + área de datos ===== -->
    <div class="qs-body" style="flex:1;min-height:0;display:flex;gap:11px;overflow:hidden;">

    <!-- ----- Riel izquierdo: KPIs (altura completa) ----- -->
    <aside class="qs-rail" style="width:236px;flex-shrink:0;display:flex;flex-direction:column;gap:9px;overflow:hidden;">
        <div class="qs-kpis" style="flex:1;min-height:0;display:flex;flex-direction:column;gap:9px;">
            <!-- Alertas críticas -->
            <div style="border:2px solid var(--ink-900);background:var(--signal-danger);color:#fff;box-shadow:var(--shadow-card);padding:0.6rem 0.8rem;flex:1;display:flex;align-items:center;justify-content:space-between;gap:8px;">
                <div style="min-width:0;">
                    <div style="font-family:var(--font-mono);font-weight:700;font-size:0.6rem;text-transform:uppercase;letter-spacing:0.8px;opacity:.92;">Alertas críticas</div>
                    <div style="font-family:var(--font-mono);font-size:0.53rem;text-transform:uppercase;letter-spacing:0.3px;opacity:.85;margin-top:2px;">Productos &gt;@(Umbral48)h sin stock</div>
                </div>
                <div style="font-family:var(--font-sans);font-weight:700;font-size:1.32rem;letter-spacing:-1px;line-height:1;flex-shrink:0;">@KCritico</div>
            </div>
            <!-- Productos en alerta -->
            <div style="border:2px solid var(--ink-900);background:var(--signal-warning);color:var(--ink-900);box-shadow:var(--shadow-card);padding:0.6rem 0.8rem;flex:1;display:flex;align-items:center;justify-content:space-between;gap:8px;">
                <div style="min-width:0;">
                    <div style="font-family:var(--font-mono);font-weight:700;font-size:0.6rem;text-transform:uppercase;letter-spacing:0.8px;">Productos en alerta</div>
                    <div style="font-family:var(--font-mono);font-size:0.53rem;text-transform:uppercase;letter-spacing:0.3px;opacity:.8;margin-top:2px;">de @AnalizadosN analizados</div>
                </div>
                <div style="font-family:var(--font-sans);font-weight:700;font-size:1.32rem;letter-spacing:-1px;line-height:1;flex-shrink:0;">@KAlerta</div>
            </div>
            <!-- Ventas perdidas est. -->
            <div style="border:2px solid var(--ink-900);background:var(--ink-900);color:#fff;box-shadow:var(--shadow-card);padding:0.6rem 0.8rem;flex:1;display:flex;align-items:center;justify-content:space-between;gap:8px;">
                <div style="min-width:0;">
                    <div style="font-family:var(--font-mono);font-weight:700;font-size:0.6rem;text-transform:uppercase;letter-spacing:0.8px;opacity:.85;">Ventas perdidas est.</div>
                    <div style="font-family:var(--font-mono);font-size:0.53rem;text-transform:uppercase;letter-spacing:0.3px;color:#5fd08a;margin-top:2px;">Ganancia: @KGanancia</div>
                </div>
                <div style="font-family:var(--font-sans);font-weight:700;font-size:1.32rem;letter-spacing:-1px;line-height:1;color:#ff5a67;flex-shrink:0;white-space:nowrap;">@KPerdido</div>
            </div>
            <!-- Más crítico -->
            <div style="border:2px solid var(--ink-900);background:var(--ink-500);color:#fff;box-shadow:var(--shadow-card);padding:0.6rem 0.8rem;flex:1;display:flex;flex-direction:column;justify-content:center;">
                <div style="font-family:var(--font-mono);font-weight:700;font-size:0.6rem;text-transform:uppercase;letter-spacing:0.8px;opacity:.9;">Más crítico</div>
                <div style="font-family:var(--font-sans);font-weight:700;font-size:0.95rem;letter-spacing:-0.4px;line-height:1.05;margin:4px 0 2px;text-transform:uppercase;">@KWorstName</div>
                <div style="font-family:var(--font-mono);font-size:0.57rem;text-transform:uppercase;letter-spacing:0.4px;opacity:.9;">@KWorstMeta</div>
            </div>
        </div>
    </aside>

    <!-- ===== Split principal (altura completa) ===== -->
    <div class="qs-split" style="flex:1;min-width:0;display:flex;gap:11px;overflow:hidden;">

        <!-- ----- Izquierda: Dashboard de Alertas ----- -->
        <section style="flex:2;min-width:0;display:flex;flex-direction:column;border:2px solid var(--ink-900);box-shadow:var(--shadow-card);background:var(--paper-0);overflow:hidden;">
            <div style="flex-shrink:0;background:var(--ink-900);color:#fff;display:flex;justify-content:space-between;align-items:center;gap:10px;flex-wrap:wrap;padding:0.45rem 0.8rem;">
                <div style="font-family:var(--font-mono);font-weight:700;text-transform:uppercase;letter-spacing:0.5px;font-size:0.8rem;display:flex;align-items:center;gap:8px;"><i class="bi bi-grid-3x3-gap-fill"></i>Dashboard de alertas<span style="font-family:var(--font-mono);font-weight:700;font-size:0.62rem;border:1px solid rgba(255,255,255,0.5);padding:2px 7px;">@Rows.Count</span></div>
                <div style="display:flex;gap:14px;align-items:center;">
                    <!-- Solo dead slots -->
                    <label style="display:inline-flex;align-items:center;gap:7px;cursor:pointer;">
                        @if (_soloDead)
                        {
                            <button type="button" @onclick="() => _soloDead = !_soloDead" role="checkbox" aria-checked="true" style="width:17px;height:17px;border:2px solid #fff;border-radius:0;background:#fff;color:var(--ink-900);display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:0.62rem;"><i class="bi bi-check-lg"></i></button>
                        }
                        else
                        {
                            <button type="button" @onclick="() => _soloDead = !_soloDead" role="checkbox" aria-checked="false" style="width:17px;height:17px;border:2px solid #fff;border-radius:0;background:transparent;cursor:pointer;"></button>
                        }
                        <span style="font-family:var(--font-mono);font-weight:700;font-size:0.6rem;text-transform:uppercase;letter-spacing:0.4px;">Solo dead slots</span>
                    </label>
                    <!-- Solo quiebres -->
                    <button type="button" @onclick="() => _soloQuiebres = !_soloQuiebres" style="display:inline-flex;align-items:center;gap:7px;background:none;border:none;cursor:pointer;padding:0;color:#fff;">
                        @if (_soloQuiebres)
                        {
                            <span style="width:30px;height:16px;border-radius:9px;background:#fff;position:relative;flex-shrink:0;"><span style="position:absolute;top:2px;right:2px;width:12px;height:12px;border-radius:50%;background:var(--ink-900);"></span></span>
                        }
                        else
                        {
                            <span style="width:30px;height:16px;border-radius:9px;background:#555;position:relative;flex-shrink:0;"><span style="position:absolute;top:2px;left:2px;width:12px;height:12px;border-radius:50%;background:#fff;"></span></span>
                        }
                        <span style="font-family:var(--font-mono);font-weight:700;font-size:0.6rem;text-transform:uppercase;letter-spacing:0.4px;">Solo quiebres</span>
                    </button>
                    <!-- Agrupar por producto -->
                    <button type="button" @onclick="() => _agrupar = !_agrupar" style="display:inline-flex;align-items:center;gap:7px;background:none;border:none;cursor:pointer;padding:0;color:#fff;">
                        @if (_agrupar)
                        {
                            <span style="width:30px;height:16px;border-radius:9px;background:#fff;position:relative;flex-shrink:0;"><span style="position:absolute;top:2px;right:2px;width:12px;height:12px;border-radius:50%;background:var(--ink-900);"></span></span>
                        }
                        else
                        {
                            <span style="width:30px;height:16px;border-radius:9px;background:#555;position:relative;flex-shrink:0;"><span style="position:absolute;top:2px;left:2px;width:12px;height:12px;border-radius:50%;background:#fff;"></span></span>
                        }
                        <span style="font-family:var(--font-mono);font-weight:700;font-size:0.6rem;text-transform:uppercase;letter-spacing:0.4px;">Agrupar por producto</span>
                    </button>
                </div>
            </div>

            <div style="flex:1;min-height:0;overflow:auto;">
                <table style="width:100%;border-collapse:collapse;">
                    <thead style="position:sticky;top:0;z-index:2;">
                        <tr style="background:var(--ink-700);color:#fff;font-family:var(--font-mono);text-transform:uppercase;font-size:0.58rem;letter-spacing:0.5px;">
                            <th class="qs-th" style="text-align:left;padding:7px 10px;font-weight:700;background:var(--ink-700);">Producto</th>
                            <th class="qs-th" style="text-align:left;padding:7px 8px;font-weight:700;background:var(--ink-700);">Máq · Slot</th>
                            <th class="qs-th" style="text-align:center;padding:7px 8px;font-weight:700;background:var(--ink-700);">Stock</th>
                            <th class="qs-th" style="text-align:left;padding:7px 8px;font-weight:700;background:var(--ink-700);">Últ. venta</th>
                            <th class="qs-th" style="text-align:right;padding:7px 8px;font-weight:700;background:var(--ink-700);">Días</th>
                            <th class="qs-th" style="text-align:right;padding:7px 8px;font-weight:700;background:var(--ink-700);">Vel/día</th>
                            <th class="qs-th" style="text-align:right;padding:7px 8px;font-weight:700;background:var(--ink-700);">$ Perd.</th>
                            <th class="qs-th" style="text-align:center;padding:7px 10px;font-weight:700;background:var(--ink-700);">Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Rows)
                        {
                            <tr class="qs-row @(r.Producto == SelName ? "qs-row-sel" : "")" @onclick="() => _sel = r.Producto" style="border-bottom:1px solid var(--line-200);">
                                <td style="padding:6px 10px;font-family:var(--font-sans);font-weight:600;font-size:0.78rem;text-transform:uppercase;letter-spacing:-0.2px;">@r.Producto</td>
                                <td style="padding:6px 8px;font-family:var(--font-mono);font-size:0.66rem;color:var(--text-secondary);white-space:nowrap;">@r.MaqSlot</td>
                                <td style="padding:6px 8px;text-align:center;font-family:var(--font-mono);font-weight:700;font-size:0.74rem;"><span style="color:var(--signal-danger);">@r.Stock</span><span style="color:var(--text-muted);">/@r.Cap</span></td>
                                <td style="padding:6px 8px;font-family:var(--font-mono);font-size:0.66rem;color:var(--text-secondary);white-space:nowrap;">@r.UltVenta</td>
                                <td style="padding:6px 8px;text-align:right;font-family:var(--font-mono);font-weight:700;font-size:0.74rem;">@r.Dias</td>
                                <td style="padding:6px 8px;text-align:right;font-family:var(--font-mono);font-size:0.72rem;color:var(--text-secondary);">@r.Vel</td>
                                <td style="padding:6px 8px;text-align:right;font-family:var(--font-mono);font-weight:700;font-size:0.72rem;color:var(--signal-danger);">@r.Perdido</td>
                                <td style="padding:6px 10px;text-align:center;">
                                    @switch (r.Est)
                                    {
                                        case "critico":
                                            <span style="display:inline-block;background:var(--signal-danger);color:#fff;font-family:var(--font-mono);font-weight:700;font-size:0.58rem;text-transform:uppercase;letter-spacing:0.4px;padding:3px 7px;">Crítico</span>
                                            break;
                                        case "alerta":
                                            <span style="display:inline-block;background:var(--signal-warning);color:var(--ink-900);font-family:var(--font-mono);font-weight:700;font-size:0.58rem;text-transform:uppercase;letter-spacing:0.4px;padding:3px 7px;">Alerta</span>
                                            break;
                                        case "dead":
                                            <span style="display:inline-block;background:var(--ink-500);color:#fff;font-family:var(--font-mono);font-weight:700;font-size:0.58rem;text-transform:uppercase;letter-spacing:0.4px;padding:3px 7px;">Dead slot</span>
                                            break;
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot style="position:sticky;bottom:0;z-index:2;">
                        <tr style="background:var(--ink-900);color:#fff;font-family:var(--font-mono);font-weight:700;text-transform:uppercase;font-size:0.66rem;letter-spacing:0.4px;">
                            <td colspan="4" style="padding:7px 10px;">Total · @Rows.Count alertas</td>
                            <td colspan="2" style="padding:7px 8px;text-align:right;">Pérdida acum.</td>
                            <td colspan="2" style="padding:7px 10px;text-align:right;color:#ff5a67;">@KPerdido</td>
                        </tr>
                    </tfoot>
                </table>
                @if (Datos == null)
                {
                    <div style="padding:34px 16px;text-align:center;font-family:var(--font-mono);color:var(--text-muted);">
                        <i class="bi bi-radar" style="font-size:1.6rem;color:var(--ink-500);"></i>
                        <div style="margin-top:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;font-size:0.8rem;color:var(--ink-900);">Sin análisis todavía</div>
                        <div style="margin-top:4px;font-size:0.66rem;">Elegí un template. Ejecutá el análisis para ver los quiebres.</div>
                    </div>
                }
                else if (Rows.Count == 0)
                {
                    <div style="padding:34px 16px;text-align:center;font-family:var(--font-mono);color:var(--text-muted);">
                        <i class="bi bi-check-circle-fill" style="font-size:1.6rem;color:var(--signal-success);"></i>
                        <div style="margin-top:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;font-size:0.8rem;color:var(--ink-900);">¡Todo en orden!</div>
                        <div style="margin-top:4px;font-size:0.66rem;">Ningún producto cumple los filtros activos.</div>
                    </div>
                }
            </div>
        </section>

        <!-- ----- Derecha: Mapa + Timeline + Ventas diarias ----- -->
        <aside class="qs-aside" style="flex:1.2;min-width:0;display:flex;flex-direction:column;gap:11px;overflow:hidden;">

            <!-- Mapa de agotamiento (esquema de la máquina; los slots se colorean al vaciarse) -->
            <section style="flex:1.3;min-height:0;display:flex;flex-direction:column;border:2px solid var(--ink-900);box-shadow:var(--shadow-card);background:var(--paper-0);overflow:hidden;">
                <div style="flex-shrink:0;background:var(--ink-900);color:#fff;display:flex;justify-content:space-between;align-items:center;gap:8px;padding:0.45rem 0.8rem;">
                    <div style="font-family:var(--font-mono);font-weight:700;text-transform:uppercase;letter-spacing:0.5px;font-size:0.74rem;display:flex;align-items:center;gap:8px;"><i class="bi bi-diagram-3-fill"></i>Mapa de agotamiento</div>
                    <div style="display:flex;align-items:center;gap:6px;">
                        <span style="font-family:var(--font-mono);font-weight:700;font-size:0.54rem;letter-spacing:0.5px;background:rgba(255,255,255,0.14);border:1px solid rgba(255,255,255,0.4);padding:2px 6px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:140px;">MÁQ @FocusMaqLabel</span>
                        <button type="button" @onclick="OpenMap" title="Ver en grande con línea de tiempo" style="flex-shrink:0;display:inline-flex;align-items:center;gap:5px;background:#fff;color:var(--ink-900);border:2px solid var(--ink-900);cursor:pointer;font-family:var(--font-mono);font-weight:700;font-size:0.54rem;text-transform:uppercase;letter-spacing:0.5px;padding:3px 7px;"><i class="bi bi-arrows-fullscreen"></i>Timeline</button>
                    </div>
                </div>
                @if (FocusSlots.Count == 0)
                {
                    <div style="flex:1;display:flex;align-items:center;justify-content:center;padding:16px;text-align:center;font-family:var(--font-mono);font-size:0.62rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.4px;">Sin slots para mapear</div>
                }
                else
                {
                    <div style="flex-shrink:0;padding:5px 10px 2px;font-family:var(--font-mono);font-size:0.55rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.4px;">@SchematicMeta</div>
                    <div style="flex:1;min-height:0;overflow:auto;padding:4px 10px 8px;display:flex;flex-direction:column;gap:7px;">
                        @foreach (var fl in SchematicFloors)
                        {
                            <div>
                                <div style="font-family:var(--font-mono);font-weight:700;font-size:0.5rem;text-transform:uppercase;letter-spacing:0.6px;color:var(--text-muted);margin-bottom:3px;">@fl.Label</div>
                                <div style="display:grid;grid-template-columns:repeat(10,1fr);gap:3px;">
                                    @foreach (var s in fl.Slots)
                                    {
                                        <button type="button" class="qs-slot" title="@s.Num · @s.Prod · @s.Stock/@s.Cap" @onclick="() => _sel = s.Prod" style="position:relative;height:26px;border:1px solid var(--ink-900);background:var(--paper-0);cursor:pointer;padding:0;overflow:hidden;@(s.Selected ? "box-shadow:inset 0 0 0 2px var(--ink-900);" : "")">
                                            <span style="position:absolute;left:0;right:0;bottom:0;height:@(s.FillPct)%;background:@s.Color;transition:height .2s ease;"></span>
                                            @if (!string.IsNullOrEmpty(s.Badge))
                                            {
                                                <span style="position:absolute;top:1px;right:2px;font-family:var(--font-mono);font-weight:700;font-size:0.42rem;color:@(s.Light ? "#fff" : "var(--ink-900)");z-index:1;">@s.Badge</span>
                                            }
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                    <div style="flex-shrink:0;border-top:2px solid var(--ink-900);background:var(--paper-50);padding:4px 10px;display:flex;gap:9px;flex-wrap:wrap;font-family:var(--font-mono);font-size:0.5rem;text-transform:uppercase;letter-spacing:0.3px;color:var(--text-secondary);">
                        <span style="display:inline-flex;align-items:center;gap:3px;"><span style="width:9px;height:9px;background:var(--signal-success);"></span>OK</span>
                        <span style="display:inline-flex;align-items:center;gap:3px;"><span style="width:9px;height:9px;background:var(--signal-warning);"></span>Alerta</span>
                        <span style="display:inline-flex;align-items:center;gap:3px;"><span style="width:9px;height:9px;background:var(--signal-danger);"></span>Crítico</span>
                        <span style="display:inline-flex;align-items:center;gap:3px;"><span style="width:9px;height:9px;background:var(--ink-500);"></span>Dead</span>
                    </div>
                }
            </section>

            <!-- Timeline de agotamiento -->
            <section style="flex:0.85;min-height:0;display:flex;flex-direction:column;border:2px solid var(--ink-900);box-shadow:var(--shadow-card);background:var(--paper-0);overflow:hidden;">
                <div style="flex-shrink:0;background:var(--ink-900);color:#fff;display:flex;align-items:center;gap:8px;padding:0.45rem 0.8rem;font-family:var(--font-mono);font-weight:700;text-transform:uppercase;letter-spacing:0.5px;font-size:0.74rem;"><i class="bi bi-clock-history"></i>Timeline de agotamiento</div>
                <div style="flex:1;min-height:0;overflow:auto;padding:4px 0;">
                    @foreach (var t in Timeline)
                    {
                        <div class="qs-tl-item" style="display:flex;align-items:center;gap:9px;padding:6px 10px;border-bottom:1px solid var(--line-200);">
                            <span style="flex-shrink:0;width:18px;height:18px;background:var(--ink-900);color:#fff;font-family:var(--font-mono);font-weight:700;font-size:0.6rem;display:flex;align-items:center;justify-content:center;">@t.Rank</span>
                            <div style="flex:1;min-width:0;">
                                <div style="font-family:var(--font-sans);font-weight:700;font-size:0.7rem;text-transform:uppercase;letter-spacing:-0.2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@t.Name</div>
                                <div style="height:7px;background:var(--line-200);margin-top:3px;overflow:hidden;"><div style="height:100%;width:@(t.Pct)%;background:@t.Color;"></div></div>
                            </div>
                            <div style="flex-shrink:0;text-align:right;font-family:var(--font-mono);">
                                <div style="font-family:var(--font-mono);font-weight:700;font-size:0.78rem;line-height:1;color:@t.Color;">@t.Dias d</div>
                                <div style="font-size:0.54rem;color:var(--text-muted);text-transform:uppercase;">@t.MaqText</div>
                            </div>
                        </div>
                    }
                </div>
            </section>

            <!-- Ventas diarias por producto -->
            <section style="flex:1;min-height:0;display:flex;flex-direction:column;border:2px solid var(--ink-900);box-shadow:var(--shadow-card);background:var(--paper-0);overflow:hidden;">
                <div style="flex-shrink:0;background:var(--ink-900);color:#fff;display:flex;justify-content:space-between;align-items:center;gap:8px;padding:0.4rem 0.8rem;">
                    <div style="font-family:var(--font-mono);font-weight:700;text-transform:uppercase;letter-spacing:0.5px;font-size:0.74rem;display:flex;align-items:center;gap:8px;"><i class="bi bi-graph-up"></i>Ventas diarias</div>
                    <div style="max-width:180px;">
                        <VmSelect Value="@SelName" Options="ProdOptions" ValueChanged="@((string v) => _sel = v)" />
                    </div>
                </div>
                <div style="flex-shrink:0;padding:6px 10px 2px;display:flex;justify-content:space-between;align-items:baseline;">
                    <span style="font-family:var(--font-sans);font-weight:700;font-size:0.84rem;text-transform:uppercase;letter-spacing:-0.3px;">@SelName</span>
                    <span style="font-family:var(--font-mono);font-size:0.58rem;color:var(--text-muted);text-transform:uppercase;">@SelMeta</span>
                </div>
                <div style="flex:1;min-height:0;display:flex;padding:6px 10px 2px;">
                    <div style="flex:1;min-height:0;display:flex;align-items:flex-end;gap:3px;width:100%;">
                        @foreach (var b in Bars)
                        {
                            <div style="flex:1;height:100%;display:flex;flex-direction:column;justify-content:flex-end;align-items:center;background:@b.ColBg;">
                                <span style="font-family:var(--font-mono);font-size:0.5rem;color:var(--text-muted);line-height:1;margin-bottom:2px;">@b.Val</span>
                                <div style="width:78%;height:@(b.Hpct)%;min-height:2px;background:@b.Col;"></div>
                            </div>
                        }
                    </div>
                </div>
                <div style="flex-shrink:0;display:flex;gap:3px;padding:0 10px 5px;">
                    @foreach (var b in Bars)
                    {
                        <span style="flex:1;text-align:center;font-family:var(--font-mono);font-size:0.5rem;color:var(--text-muted);">@b.Day</span>
                    }
                </div>
                <div style="flex-shrink:0;border-top:2px solid var(--ink-900);background:var(--paper-50);padding:5px 10px;display:flex;justify-content:space-between;font-family:var(--font-mono);font-size:0.58rem;text-transform:uppercase;letter-spacing:0.3px;">
                    <span style="color:var(--text-muted);">Quiebre: <strong style="color:var(--signal-danger);">@SelDias d</strong> sin venta</span>
                    <span style="color:var(--text-muted);">Pérdida: <strong style="color:var(--ink-900);">@SelPerdido</strong></span>
                </div>
            </section>
        </aside>
    </div>
    </div>

    <!-- ===== Modal: Mapa de agotamiento con línea de tiempo ===== -->
    @if (mapOpen)
    {
        <div @onclick="CloseMap" style="position:fixed;inset:0;z-index:50;background:rgba(20,22,24,0.62);display:flex;align-items:center;justify-content:center;padding:3vh 3vw;">
            <div @onclick:stopPropagation="true" style="width:min(1000px,94vw);height:min(760px,94vh);display:flex;flex-direction:column;background:var(--paper-0);border:3px solid var(--ink-900);box-shadow:10px 10px 0 rgba(0,0,0,0.35);overflow:hidden;">

                <!-- Header modal -->
                <div style="flex-shrink:0;background:var(--ink-900);color:#fff;display:flex;justify-content:space-between;align-items:center;gap:10px;padding:0.6rem 1rem;">
                    <div style="font-family:var(--font-mono);font-weight:700;text-transform:uppercase;letter-spacing:0.5px;font-size:0.92rem;display:flex;align-items:center;gap:9px;"><i class="bi bi-diagram-3-fill"></i>Mapa de agotamiento<span style="font-family:var(--font-mono);font-weight:700;font-size:0.58rem;letter-spacing:0.5px;background:rgba(255,255,255,0.16);border:1px solid rgba(255,255,255,0.4);padding:2px 7px;">MÁQ @FocusMaqLabel</span></div>
                    <button type="button" @onclick="CloseMap" title="Cerrar" style="width:34px;height:34px;flex-shrink:0;border:2px solid rgba(255,255,255,0.6);background:transparent;color:#fff;cursor:pointer;font-size:1.1rem;display:flex;align-items:center;justify-content:center;"><i class="bi bi-x-lg"></i></button>
                </div>

                <!-- Esquema grande -->
                <div style="flex:1;min-height:0;overflow:auto;padding:14px 18px;display:flex;flex-direction:column;gap:14px;background:var(--paper-50);">
                    @foreach (var fl in ModalFloors)
                    {
                        <div>
                            <div style="font-family:var(--font-mono);font-weight:700;font-size:0.62rem;text-transform:uppercase;letter-spacing:0.8px;color:var(--text-secondary);margin-bottom:5px;display:flex;align-items:center;gap:7px;"><span style="width:5px;height:14px;background:var(--ink-900);display:inline-block;"></span>@fl.Label</div>
                            <div style="display:grid;grid-template-columns:repeat(10,1fr);gap:6px;">
                                @foreach (var s in fl.Slots)
                                {
                                    <button type="button" class="qs-slot" title="@s.Num · @s.Prod · @s.Stock/@s.Cap" @onclick="() => _sel = s.Prod" style="position:relative;height:80px;border:2px solid var(--ink-900);background:var(--paper-0);cursor:pointer;padding:0;overflow:hidden;@(s.Selected ? "box-shadow:inset 0 0 0 3px var(--ink-900);" : "")">
                                        <span style="position:absolute;left:0;right:0;bottom:0;height:@(s.FillPct)%;background:@s.Color;transition:height .2s ease, background .2s ease;"></span>
                                        <span style="position:absolute;top:4px;left:5px;font-family:var(--font-mono);font-weight:700;font-size:0.56rem;color:var(--ink-900);z-index:1;">@s.Num</span>
                                        @if (!string.IsNullOrEmpty(s.Badge))
                                        {
                                            <span style="position:absolute;top:3px;right:3px;background:@s.Color;color:@s.BadgeTx;font-family:var(--font-mono);font-weight:700;font-size:0.52rem;line-height:1;padding:1px 3px;z-index:1;">@s.Badge</span>
                                        }
                                        <span style="position:absolute;left:5px;right:5px;bottom:15px;font-family:var(--font-sans);font-weight:700;font-size:0.5rem;line-height:1.05;color:@(s.Light ? "#fff" : "var(--ink-900)");text-transform:uppercase;z-index:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;@(s.Light ? "text-shadow:0 1px 1px rgba(0,0,0,.3);" : "")">@s.Prod</span>
                                        <span style="position:absolute;left:5px;bottom:3px;font-family:var(--font-mono);font-weight:700;font-size:0.54rem;color:@(s.Light ? "#fff" : "var(--ink-900)");z-index:1;@(s.Light ? "text-shadow:0 1px 1px rgba(0,0,0,.3);" : "")">@s.Stock/@s.Cap</span>
                                    </button>
                                }
                            </div>
                        </div>
                    }
                </div>

                <!-- Barra de tiempo (scrubber) -->
                <div style="flex-shrink:0;border-top:3px solid var(--ink-900);background:var(--paper-50);padding:0.7rem 1rem 0.85rem;">
                    <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:7px;">
                        <div style="font-family:var(--font-mono);font-weight:700;font-size:0.62rem;text-transform:uppercase;letter-spacing:0.6px;color:var(--text-secondary);display:flex;align-items:center;gap:7px;"><i class="bi bi-clock-history"></i>Línea de tiempo · desde la recarga</div>
                        <div style="font-family:var(--font-mono);font-weight:700;font-size:0.62rem;text-transform:uppercase;letter-spacing:0.4px;color:var(--signal-danger);">@ModalQuiebreN en quiebre</div>
                    </div>
                    <div style="display:flex;align-items:center;gap:12px;">
                        <button type="button" @onclick="TogglePlayback" title="Reproducir agotamiento" style="width:44px;height:44px;flex-shrink:0;border:2px solid var(--ink-900);background:var(--ink-900);color:#fff;cursor:pointer;font-size:1.15rem;display:flex;align-items:center;justify-content:center;"><i class="bi @(IsPlaying ? "bi-pause-fill" : "bi-play-fill")"></i></button>
                        <div style="flex:1;min-width:0;">
                            <input type="range" min="0" max="@TotalSteps" step="1" value="@CurrentStepIndex" @oninput="OnScrubInput" style="width:100%;accent-color:var(--ink-900);cursor:pointer;" />
                            <div style="display:flex;justify-content:space-between;font-family:var(--font-mono);font-size:0.52rem;text-transform:uppercase;letter-spacing:0.4px;color:var(--text-muted);margin-top:2px;">
                                <span><i class="bi bi-box-seam" style="margin-right:3px;"></i>Recarga</span>
                                <span>Hoy<i class="bi bi-geo-alt-fill" style="margin-left:3px;"></i></span>
                            </div>
                        </div>
                        <div style="flex-shrink:0;text-align:right;min-width:112px;">
                            <div style="font-family:var(--font-sans);font-weight:700;font-size:1.15rem;line-height:1;letter-spacing:-0.5px;">@ScrubDateLabel</div>
                            <div style="font-family:var(--font-mono);font-size:0.55rem;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);margin-top:3px;">@ScrubDayLabel</div>
                        </div>
                    </div>
                    <!-- Leyenda -->
                    <div style="display:flex;gap:14px;flex-wrap:wrap;font-family:var(--font-mono);font-size:0.55rem;text-transform:uppercase;letter-spacing:0.3px;color:var(--text-secondary);margin-top:9px;padding-top:8px;border-top:1px solid var(--line-200);">
                        <span style="display:inline-flex;align-items:center;gap:4px;"><span style="width:11px;height:11px;background:var(--signal-success);"></span>OK</span>
                        <span style="display:inline-flex;align-items:center;gap:4px;"><span style="width:11px;height:11px;background:var(--signal-warning);"></span>Bajo</span>
                        <span style="display:inline-flex;align-items:center;gap:4px;"><span style="width:11px;height:11px;background:var(--signal-danger);"></span>Quiebre</span>
                        <span style="display:inline-flex;align-items:center;gap:4px;"><span style="width:11px;height:11px;background:var(--ink-500);"></span>Dead slot</span>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
