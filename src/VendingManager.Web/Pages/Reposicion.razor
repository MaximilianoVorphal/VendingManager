@page "/reposicion"
@using VendingManager.Web.Components.Shared
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>INVENTARIO MAQUINAS</PageTitle>

    <div class="industrial-wrapper container-fluid px-4 mt-4">

    <!-- DEPRECATION BANNER -->
    <div class="deprecation-banner alert alert-warning border-2 border-dark rounded-0 fw-bold mb-4 shadow-sm">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
            <div class="d-flex align-items-center gap-2">
                <i class="bi bi-exclamation-triangle-fill fs-4"></i>
                <span>
                    ⚠️ ESTA PÁGINA SERÁ DESCONTINUADA. Usá
                    <a href="/templates-recarga" class="alert-link fw-bold">Templates de Recarga</a>
                    para gestionar la carga de máquinas.
                </span>
            </div>
            <a href="/templates-recarga" class="btn btn-sm btn-dark rounded-0 fw-bold border-dark">
                <i class="bi bi-arrow-right-circle me-1"></i> IR A TEMPLATES DE RECARGA
            </a>
        </div>
    </div>

    <!-- HEADER: TITLE + MACHINE SELECT -->
    <!-- HEADER: TITLE ONLY -->
    <div class="row align-items-center mb-4 border-bottom border-3 border-dark pb-3">
        <div class="col-12">
            <h2 class="m-0 fw-bold text-uppercase" style="letter-spacing: -1px; color: #333;">
                <i class="bi bi-grid-3x3-gap-fill me-2"></i>INVENTARIO MAQUINAS
            </h2>
            <small class="text-muted fw-bold">CARGA POR PISOS & HERRAMIENTAS</small>
        </div>
    </div>

    <!-- STICKY TOOLBAR (shared component) -->
    <CargaToolbar CurrentTool="@CurrentTool" OnToolSelected="SelectTool" />

    <!-- MACHINE SELECTOR (SCROLLS AWAY) -->
    <div class="row mb-4">
        <div class="col-12">
            <select class="form-select border-dark rounded-0 fw-bold shadow-sm py-2" style="width: 100%;"
                    @onchange="CargarSlotsMaquina">
                <option value="0">:: SELECCIONE MÁQUINA A GESTIONAR ::</option>
                @if (Maquinas != null)
                {
                    @foreach (var m in Maquinas)
                    {
                        <option value="@m.Id">@m.Nombre.ToUpper()</option>
                    }
                }
            </select>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Mensaje))
    {
        <div class="alert @AlertClass border-dark rounded-0 fw-bold mb-4 shadow-sm fade show">
            @Mensaje
        </div>
    }

    @if (MaquinaIdSeleccionada > 0)
    {
         <div class="card border-2 border-dark rounded-0 shadow my-4">
            <div class="card-header bg-dark text-white rounded-0 fw-bold d-flex justify-content-between align-items-center">
                <span>VISTA DE ESTANTERÍA (SHELVES)</span>
                <PendingActionsQueue Count="@PendingActions.Count" Disabled="@(PendingActions.Count == 0)" OnConfirm="ConfirmarAcciones" />
            </div>
            
            <div class="card-body bg-secondary bg-opacity-10 p-4">
                @if (Slots.Count == 0)
                {
                    <div class="text-center text-muted">No hay slots configurados para visualizar.</div>
                }
                else
                {
                    // GROUP BY SHELF (Using (n-1)/10 to ensure 11-20 -> 1, 51-60 -> 5)
                    var shelves = Slots.GroupBy(s => (s.SlotNumberSort - 1) / 10).OrderBy(g => g.Key);

                    <div class="d-flex flex-column gap-4 machine-chassis">
                        @foreach (var shelf in shelves)
                        {
                            <div class="shelf-container p-2 border border-dark bg-white shadow-sm">
                                <div class="shelf-label badge bg-dark text-white rounded-0 mb-2">PISO @shelf.Key</div>
                                
                                <!-- FLEX WRAP CONTAINER FOR SLOTS -->
                                <div class="inventory-grid">
                                    @foreach (var s in shelf.OrderBy(x => x.SlotNumberSort))
                                    {
                                        var action = PendingActions.FirstOrDefault(a => a.SlotId == s.Id);
                                        string statusClass = GetSlotStatusClass(s, action);
                                        
                                        <div class="slot-unit @statusClass" @onclick="() => HandleSlotClick(s)">
                                            <!-- TOP: Number & Icon -->
                                            <div class="d-flex justify-content-between align-items-start border-bottom border-dark pb-1 mb-1 w-100">
                                                <span class="font-monospace fw-bold bg-white text-dark px-1 border border-dark rounded-0" style="font-size:0.8rem;">@s.NumeroSlot</span>
                                                @if(action != null) 
                                                { 
                                                    @if(action.ActionType == "REFILL") { <i class="bi bi-plus-circle-fill"></i> }
                                                    else if(action.ActionType == "EMPTY") { <i class="bi bi-trash-fill text-white"></i> }
                                                    else if(action.ActionType == "SWAP") { <i class="bi bi-arrow-repeat text-white"></i> }
                                                }
                                            </div>

                                            <!-- MIDDLE: Product Name -->
                                            <div class="slot-product-name text-center lh-1 my-1" style="font-weight: 600;">
                                                @if (action?.ActionType == "SWAP" && action.NewProductoDto != null)
                                                {
                                                    <span class="text-warning fw-bold">@action.NewProductoDto.Nombre</span>
                                                }
                                                else
                                                {
                                                     @(s.Producto?.Nombre ?? "VACÍO")
                                                }
                                            </div>

                                            <!-- BOTTOM: Stock Info -->
                                            <div class="mt-auto w-100 pt-1 border-top border-dark d-flex justify-content-between align-items-end" style="font-size:0.75rem;">
                                                <div class="d-flex flex-column lh-1">
                                                    <span class="opacity-75">STOCK</span>
                                                    <span class="fw-bold" style="font-size: 0.85rem;">@Math.Max(0, s.StockActual)</span>
                                                </div>
                                                
                                                @if (action?.ActionType == "REFILL")
                                                {
                                                    <div class="badge bg-white text-primary border border-dark rounded-0">+@action.Cantidad</div>
                                                }
                                                else
                                                {
                                                    <span class="opacity-50">/@s.CapacidadMaxima</span>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }
    else
    {
         <div class="text-center py-5 text-muted border border-2 border-dark border-dashed my-4 bg-light">
             <i class="bi bi-ui-checks-grid display-1 mb-3"></i>
            <h4 class="fw-bold">SELECCIONE UNA MÁQUINA</h4>
            <p class="mb-0">Visualice y gestione los slots de forma visual.</p>
        </div>
    }

</div>

<!-- FLOATING ACTION BUTTON (Mobile) -->
<div class="fab-container">
    <button class="fab-main @(_isFabOpen ? "fab-open" : "")" @onclick="ToggleFab">
        <i class="bi @(_isFabOpen ? "bi-x-lg" : "bi-plus-lg")"></i>
    </button>
    
    @if (_isFabOpen)
    {
        <div class="fab-menu">
            <button class="fab-option @(CurrentTool == "REFILL" ? "fab-active" : "")" 
                    @onclick="@(() => { SelectTool("REFILL"); ToggleFab(); })">
                <i class="bi bi-box-seam"></i>
                <span>Rellenar</span>
            </button>
            <button class="fab-option @(CurrentTool == "EMPTY" ? "fab-active" : "")" 
                    @onclick="@(() => { SelectTool("EMPTY"); ToggleFab(); })">
                <i class="bi bi-trash"></i>
                <span>Vaciar</span>
            </button>
            <button class="fab-option @(CurrentTool == "SWAP" ? "fab-active" : "")" 
                    @onclick="@(() => { SelectTool("SWAP"); ToggleFab(); })">
                <i class="bi bi-arrow-repeat"></i>
                <span>Cambiar</span>
            </button>
        </div>
    }
</div>

<!-- MODAL SWAP PRODUCTO -->
@if (ShowSwapModal && SlotForSwap != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-0 border-2 border-dark shadow-lg">
                <div class="modal-header bg-warning text-dark rounded-0 border-bottom border-dark">
                    <h5 class="modal-title fw-bold"><i class="bi bi-arrow-repeat me-2"></i>CAMBIAR PRODUCTO SLOT @SlotForSwap.NumeroSlot</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body p-4">
                    <label class="form-label fw-bold">SELECCIONE NUEVO PRODUCTO:</label>
                    <select class="form-select rounded-0 border-dark mb-3" @bind="SelectedSwapProductId">
                        <option value="0">-- ELIMINAR PRODUCTO (VACÍO) --</option>
                        @if(ProductosDisponibles != null)
                        {
                            @foreach(var p in ProductosDisponibles.OrderBy(x=>x.Nombre))
                            {
                                <option value="@p.Id">@p.Nombre (Bodega: @p.StockBodega)</option>
                            }
                        }
                    </select>

                    <label class="form-label fw-bold">PRECIO VENTA:</label>
                    <div class="input-group mb-3">
                        <span class="input-group-text rounded-0 border-dark">$</span>
                        <input type="number" class="form-control rounded-0 border-dark" @bind="SelectedSwapPrice" />
                    </div>

                    <label class="form-label fw-bold">CANTIDAD INICIAL:</label>
                    <div class="input-group mb-3">
                         <span class="input-group-text rounded-0 border-dark">#</span>
                        <input type="number" class="form-control rounded-0 border-dark fw-bold" @bind="SelectedSwapQuantity" min="0" />
                    </div>

                </div>
                <div class="modal-footer bg-light rounded-0">
                    <button type="button" class="btn btn-outline-dark rounded-0 fw-bold" @onclick="CloseModal">CANCELAR</button>
                    <button type="button" class="btn btn-warning rounded-0 border-dark fw-bold px-4" @onclick="ConfirmSwap">
                        CONFIRMAR CAMBIO
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    // --- MODELS ---
    class MaquinaSimpleDto { public int Id { get; set; } public string Nombre { get; set; } = ""; }
    class ProductoSlotDto { public int Id { get; set; } public string Nombre { get; set; } = ""; public int StockBodega { get; set; } }
    
    // Using local SlotActionDto to ensure compilation success
    class SlotActionDto
    {
        public int SlotId { get; set; }
        public string ActionType { get; set; } = "REFILL"; 
        public int Cantidad { get; set; }
        public int? NewProductoId { get; set; }
        public decimal? NewPrecioVenta { get; set; } // Added Price
        
        // Helper for UI only
        public ProductoSlotDto? NewProductoDto { get; set; }
    }

    class ConfiguracionSlotDto
    {
        public int Id { get; set; }
        public int MaquinaId { get; set; }
        public string NumeroSlot { get; set; } = "";
        public int? ProductoId { get; set; }
        public ProductoSlotDto? Producto { get; set; }
        public int StockActual { get; set; }
        public int CapacidadMaxima { get; set; }
        public decimal PrecioVenta { get; set; } // Existing price for pre-fill
        public int SlotNumberSort => int.TryParse(NumeroSlot, out int n) ? n : int.MaxValue;
    }

    // --- STATE ---
    private List<MaquinaSimpleDto> Maquinas = new();
    private List<ConfiguracionSlotDto> Slots = new();
    private List<ProductoSlotDto> ProductosDisponibles = new();
    
    private int MaquinaIdSeleccionada = 0;
    private string Mensaje = "";
    private string AlertClass = "alert-info";
    private string CurrentTool = ""; // Empty - require explicit selection
    
    // FAB State
    private bool _isFabOpen = false;
    private void ToggleFab() => _isFabOpen = !_isFabOpen;

    private List<SlotActionDto> PendingActions = new();

    // SWAP MODAL STATE
    private bool ShowSwapModal = false;
    private ConfiguracionSlotDto? SlotForSwap;
    private int SelectedSwapProductId = 0;
    private decimal SelectedSwapPrice = 0; // State for price input
    private int SelectedSwapQuantity = 0; // State for quantity input

    protected override async Task OnInitializedAsync()
    {
        await CargarMaquinas();
        await CargarProductos();
    }

    private async Task CargarMaquinas()
    {
        try { Maquinas = await Http.GetFromJsonAsync<List<MaquinaSimpleDto>>("api/Maquinas") ?? new(); }
        catch { }
    }

    private async Task CargarProductos()
    {
        try { ProductosDisponibles = await Http.GetFromJsonAsync<List<ProductoSlotDto>>("api/Inventario/lista") ?? new(); }
        catch { }
    }

    private async Task CargarSlotsMaquina(ChangeEventArgs e)
    {
        PendingActions.Clear();
        Mensaje = "";
        
        if (int.TryParse(e.Value?.ToString(), out int id) && id > 0)
        {
            MaquinaIdSeleccionada = id;
            Slots = await Http.GetFromJsonAsync<List<ConfiguracionSlotDto>>($"api/Maquinas/{id}/slots") ?? new();
        }
        else
        {
            MaquinaIdSeleccionada = 0;
            Slots.Clear();
        }
    }

    private void SelectTool(string tool)
    {
        CurrentTool = tool;
    }

    private void HandleSlotClick(ConfiguracionSlotDto slot)
    {
        // 1. Remove existing action if any
        var existing = PendingActions.FirstOrDefault(a => a.SlotId == slot.Id);
        if (existing != null)
        {
            PendingActions.Remove(existing);
            // If clicking same slot allows toggle OFF.
            // If tool is different, maybe overwrite? For now toggle off is intuitive.
            return;
        }

        // 2. Add new action based on Tool
        if (CurrentTool == "REFILL")
        {
            if (slot.ProductoId == null) return; // Can't refill empty slot
            int maxFill = slot.CapacidadMaxima - slot.StockActual;
            if (maxFill <= 0) return; // Full

            PendingActions.Add(new SlotActionDto
            {
                SlotId = slot.Id,
                ActionType = "REFILL",
                Cantidad = maxFill
            });
        }
        else if (CurrentTool == "EMPTY")
        {
             // Allow empty if there is stock OR if there is a product assigned (to unassign it)
             if (slot.StockActual == 0 && slot.ProductoId == null) return; 

             PendingActions.Add(new SlotActionDto
             {
                 SlotId = slot.Id,
                 ActionType = "EMPTY"
             });
        }
        else if (CurrentTool == "SWAP")
        {
            // Open Modal
            SlotForSwap = slot;
            SelectedSwapProductId = slot.ProductoId ?? 0;
            SelectedSwapPrice = slot.PrecioVenta; // Pre-fill with current price
            SelectedSwapQuantity = slot.CapacidadMaxima; // Default to max capacity or let user choose
            JS.InvokeVoidAsync("modalScrollLock.lock");
            ShowSwapModal = true;
        }
    }

    // --- HELPER ---
    private string GetSlotStatusClass(ConfiguracionSlotDto slot, SlotActionDto? action)
    {
        if (action != null)
            return action.ActionType switch
            {
                "REFILL" => "slot-pending-refill",
                "EMPTY" => "slot-pending-empty",
                "SWAP" => "slot-pending-swap",
                _ => ""
            };
        if (slot.StockActual <= 0 && slot.ProductoId == null)
            return "slot-empty";
        if (slot.StockActual <= 0 && slot.ProductoId != null)
            return "slot-critical";
        if (slot.CapacidadMaxima > 0 && (double)slot.StockActual / slot.CapacidadMaxima <= 0.25)
            return "slot-low";
        return "";
    }

    // --- SWAP LOGIC ---
    private async Task CloseModal()
    {
        await JS.InvokeVoidAsync("modalScrollLock.unlock");
        ShowSwapModal = false;
        SlotForSwap = null;
    }



    private void ConfirmSwap()
    {
        if (SlotForSwap == null) return;

        var newProd = ProductosDisponibles.FirstOrDefault(p => p.Id == SelectedSwapProductId);
        
        PendingActions.Add(new SlotActionDto
        {
            SlotId = SlotForSwap.Id,
            ActionType = "SWAP",
            NewProductoId = SelectedSwapProductId,
            NewProductoDto = newProd,
            Cantidad = SelectedSwapQuantity, // User requested quantity
            NewPrecioVenta = SelectedSwapPrice // Send new price
        });

        if (SelectedSwapProductId > 0 && SelectedSwapQuantity > 0)
        {
             PendingActions.Add(new SlotActionDto
            {
                SlotId = SlotForSwap.Id,
                ActionType = "REFILL",
                Cantidad = SelectedSwapQuantity
            });
        }

        JS.InvokeVoidAsync("modalScrollLock.unlock");
        ShowSwapModal = false;
        SlotForSwap = null;
    }

    private async Task ConfirmarAcciones()
    {
        if (PendingActions.Count == 0) return;

        try
        {
            var response = await Http.PostAsJsonAsync($"api/Maquinas/{MaquinaIdSeleccionada}/batch-actions", PendingActions);
            if (response.IsSuccessStatusCode)
            {
                Mensaje = $"✅ Acciones procesadas correctamente: {PendingActions.Count}";
                AlertClass = "alert-success";
                PendingActions.Clear();
                // Reload
                Slots = await Http.GetFromJsonAsync<List<ConfiguracionSlotDto>>($"api/Maquinas/{MaquinaIdSeleccionada}/slots") ?? new();
            }
            else
            {
                var err = await response.Content.ReadAsStringAsync();
                Mensaje = $"❌ Error: {err}";
                AlertClass = "alert-danger";
            }
        }
        catch (Exception ex)
        {
             Mensaje = $"❌ Error: {ex.Message}";
             AlertClass = "alert-danger";
        }
    }
}
