@page "/informe-ventas"
@inject HttpClient Http
@inject IJSRuntime JS
@implements IDisposable
@using System.Globalization
@using System.Net.Http.Json
@using VendingManager.Shared.DTOs
@using VendingManager.Web.Components.Shared

@* =============================================================================
   Informe de Ventas — port fiel de templates/ventas/Ventas.dc.html.
   Layout sin scroll de página: la ruta es "fullscreen" en MainLayout, el scroll
   vive dentro de la tabla de operaciones y del rail de análisis.
   Cableado a HttpClient contra api/Ventas/* endpoints.
   Estilos inline con var(--token) copiados del template; el bloque
   <style> cubre solo lo que inline no puede: keyframes, hover y responsive.
   ============================================================================= *@

<style>
    @@keyframes ivBlink { 50% { opacity: 0; } }
    @@keyframes ivFade { from { opacity: 0; transform: translateY(-8px); } to { opacity: 1; transform: translateY(0); } }
    @@keyframes ivBack { from { opacity: 0; } to { opacity: 1; } }
    @@keyframes ivSpin { to { transform: rotate(360deg); } }
    .iv-cursor { animation: ivBlink 1s steps(1) infinite; }
    .iv-spin { display: inline-block; animation: ivSpin .8s linear infinite; }
    .iv-tbl td { padding: 8px 12px; }
    .iv-tbl.iv-compacta td { padding: 3px 12px; }
    .iv-row:hover { background: var(--paper-50) !important; }
    .iv-modal-back { animation: ivBack .15s ease-out; }
    .iv-modal { animation: ivFade .15s ease-out; }
    @@media (prefers-reduced-motion: reduce) {
        .iv-cursor, .iv-spin, .iv-modal, .iv-modal-back { animation: none !important; }
    }
    @@media (max-width: 1080px) {
        .iv-body { flex-direction: column !important; }
        .iv-rail {
            flex: none !important; width: 100% !important;
            border-left: none !important; border-top: 2px solid var(--ink-900) !important;
            max-height: 320px;
        }
    }
    /* El título y su cursor parpadeante no deben poder seleccionarse. */
    .iv-page h1 { user-select: none; }
    /* Foco solo visible con teclado (accesible), no la caja al click de mouse. */
    .iv-page :is(button, select, input, [role="switch"]):focus:not(:focus-visible) { outline: none; }
    .iv-page :is(button, select, input, [role="switch"]):focus-visible {
        outline: 2px solid var(--ink-900); outline-offset: 2px;
    }
</style>

<div class="iv-page" style="flex:1;min-height:0;display:flex;flex-direction:column;overflow:hidden;padding:0.95rem 1.4rem 1.1rem;">

    <!-- ===== Header + barra de comando ===== -->
    <div style="flex-shrink:0;display:flex;justify-content:space-between;align-items:flex-end;gap:14px;flex-wrap:wrap;border-bottom:3px solid var(--ink-900);padding-bottom:11px;">
        <div>
            <div style="display:inline-block;background:var(--ink-900);color:#fff;font-family:var(--font-mono);font-weight:700;font-size:0.58rem;letter-spacing:2px;padding:3px 9px;text-transform:uppercase;margin-bottom:7px;">Gestión · Ventas</div>
            <h1 style="margin:0;font-family:var(--font-mono);font-weight:700;text-transform:uppercase;letter-spacing:-1px;font-size:1.55rem;line-height:1;">Informe de Ventas<span class="iv-cursor">_</span></h1>
            <p style="margin:5px 0 0;font-family:var(--font-mono);font-size:0.68rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.4px;">Análisis de rendimiento y transacciones</p>
        </div>
        <div style="display:flex;gap:9px;align-items:center;flex-wrap:wrap;justify-content:flex-end;">
            <!-- Estado de sincronización -->
            <div style="display:flex;flex-direction:column;align-items:flex-end;gap:2px;padding-right:2px;">
                <span style="font-family:var(--font-mono);font-weight:700;font-size:0.56rem;text-transform:uppercase;letter-spacing:0.6px;color:var(--text-muted);">Fuente · OurVend</span>
                <span style="display:flex;align-items:center;gap:5px;font-family:var(--font-mono);font-weight:700;font-size:0.62rem;text-transform:uppercase;letter-spacing:0.4px;">
                    @if (_syncing)
                    {
                        <span style="width:7px;height:7px;border-radius:50%;background:var(--signal-warning);"></span>
                        <text>Sincronizando…</text>
                    }
                    else
                    {
                        <span style="width:7px;height:7px;border-radius:50%;background:var(--signal-success);"></span>
                        <text>Sincronizado @LastSyncLabel</text>
                    }
                </span>
            </div>
            <!-- Botón de sincronización -->
            @if (_syncing)
            {
                <button disabled style="display:inline-flex;align-items:center;justify-content:center;gap:0.5rem;font-family:var(--font-mono);font-weight:700;text-transform:uppercase;letter-spacing:0.5px;line-height:1;border-radius:0;border:2px solid var(--ink-900);background:transparent;color:var(--ink-900);padding:0.5rem 1rem;font-size:var(--fs-sm);opacity:0.65;cursor:wait;">
                    <i class="bi bi-arrow-repeat iv-spin"></i>Sincronizando…
                </button>
            }
            else
            {
                <VmButton Variant="outline" Bar="true" Width="160px" Icon="bi-cloud-arrow-down" OnClick="Sincronizar">Sincronizar</VmButton>
            }
            <span style="width:1px;height:30px;background:var(--line-300);"></span>
            @if (_exporting)
            {
                <button disabled style="display:inline-flex;align-items:center;justify-content:center;gap:0.5rem;font-family:var(--font-mono);font-weight:700;text-transform:uppercase;letter-spacing:0.5px;line-height:1;border-radius:0;border:2px solid var(--ink-900);background:transparent;color:var(--ink-900);padding:0.5rem 1rem;font-size:var(--fs-sm);opacity:0.65;cursor:wait;">
                    <i class="bi bi-arrow-repeat iv-spin"></i>Exportando…
                </button>
            }
            else
            {
                <VmButton Variant="outline" Bar="true" Width="160px" Icon="bi-file-earmark-spreadsheet" OnClick="Exportar">Exportar XLS</VmButton>
            }
            <VmButton Variant="dark" Bar="true" Width="160px" Icon="bi-play-fill" OnClick="EjecutarQuery">Ejecutar query</VmButton>
        </div>
    </div>

    <!-- Strip de filtros -->
    <div style="flex-shrink:0;display:flex;gap:14px;align-items:flex-end;flex-wrap:wrap;padding:10px 0 12px;">
        <div style="min-width:230px;">
            <VmSelect Label="Unidad" Value="_unit" Options="UnitOptions" ValueChanged="@((string v) => { _unit = v; _ = OnFilterChanged(); })" />
        </div>
        <div style="display:flex;flex-direction:column;gap:0.35rem;">
            <label style="font-family:var(--font-mono);font-size:0.66rem;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;">Desde</label>
            <input type="date" value="@_desde" @onchange="e => { _desde = e.Value?.ToString() ?? _desde; _ = OnFilterChanged(); }" style="font-family:var(--font-mono);font-size:0.8rem;font-weight:700;border:2px solid var(--ink-900);border-radius:0;background:var(--paper-0);padding:0.45rem 0.6rem;outline:none;" />
        </div>
        <div style="display:flex;flex-direction:column;gap:0.35rem;">
            <label style="font-family:var(--font-mono);font-size:0.66rem;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;">Hasta</label>
            <input type="date" value="@_hasta" @onchange="e => { _hasta = e.Value?.ToString() ?? _hasta; _ = OnFilterChanged(); }" style="font-family:var(--font-mono);font-size:0.8rem;font-weight:700;border:2px solid var(--ink-900);border-radius:0;background:var(--paper-0);padding:0.45rem 0.6rem;outline:none;" />
        </div>
    </div>

    @if (_error is not null)
    {
        <IndustrialAlert Message="@_error" Variant="IndustrialAlert.AlertVariant.Danger" />
    }

    @if (_success is not null)
    {
        <IndustrialAlert Message="@_success" Variant="IndustrialAlert.AlertVariant.Success" IsDismissible="true" OnDismiss="@(EventCallback.Factory.Create(this, () => _success = null))" />
    }

    <!-- ===== KPIs ===== -->
    <div style="flex-shrink:0;display:grid;grid-template-columns:repeat(auto-fit,minmax(210px,1fr));gap:12px;margin-bottom:12px;">

        <!-- Utilidad -->
        <div style="border:2px solid var(--ink-900);background:var(--ink-900);padding:0.8rem 0.95rem;display:flex;flex-direction:column;gap:0.4rem;">
            <div style="display:flex;justify-content:space-between;align-items:center;gap:8px;">
                <span style="font-family:var(--font-mono);font-weight:700;font-size:0.66rem;text-transform:uppercase;letter-spacing:0.5px;color:rgba(255,255,255,0.72);">Utilidad (real / pagada)</span>
                <span style="font-family:var(--font-mono);font-weight:700;font-size:0.6rem;text-transform:uppercase;border:1px solid rgba(255,255,255,0.55);color:#fff;padding:2px 7px;">Margen @Margen</span>
            </div>
            <span style="font-family:var(--font-sans);font-weight:700;font-size:1.85rem;letter-spacing:-1px;line-height:1;color:#fff;">@UtilidadFmt</span>
            <small style="font-family:var(--font-mono);font-size:0.66rem;color:rgba(255,255,255,0.5);text-transform:uppercase;">Ganancia neta del período</small>
        </div>

        <!-- Ventas confirmadas -->
        <div style="border:2px solid var(--ink-900);background:var(--paper-0);padding:0.8rem 0.95rem;display:flex;flex-direction:column;gap:0.4rem;">
            <div style="display:flex;justify-content:space-between;align-items:center;gap:8px;">
                <span style="font-family:var(--font-mono);font-weight:700;font-size:0.66rem;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-secondary);">Ventas confirmadas</span>
                <span style="font-family:var(--font-mono);font-weight:700;font-size:0.6rem;text-transform:uppercase;background:var(--signal-success);color:#fff;padding:2px 7px;">@TxCount tx</span>
            </div>
            <span style="font-family:var(--font-sans);font-weight:700;font-size:1.85rem;letter-spacing:-1px;line-height:1;color:var(--signal-success);">@VentasFmt</span>
            <small style="font-family:var(--font-mono);font-size:0.66rem;color:var(--text-muted);text-transform:uppercase;">Total operado en el rango</small>
        </div>

        <!-- Diferencias Transbank -->
        <div style="border:2px solid var(--ink-900);background:var(--paper-0);padding:0.8rem 0.95rem;display:flex;flex-direction:column;gap:0.4rem;">
            <div style="display:flex;justify-content:space-between;align-items:center;gap:8px;">
                <span style="font-family:var(--font-mono);font-weight:700;font-size:0.66rem;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-secondary);">Diferencias Transbank</span>
                <span style="font-family:var(--font-mono);font-weight:700;font-size:0.6rem;text-transform:uppercase;border:1px solid var(--ink-900);color:var(--ink-900);padding:2px 7px;">Sin errores</span>
            </div>
            <span style="font-family:var(--font-sans);font-weight:700;font-size:1.85rem;letter-spacing:-1px;line-height:1;color:var(--ink-900);">$0</span>
            <small style="font-family:var(--font-mono);font-size:0.66rem;color:var(--text-muted);text-transform:uppercase;">Conciliación cuadrada</small>
        </div>

        <!-- Pendiente / cash -->
        <div style="border:2px solid var(--ink-900);background:var(--paper-0);padding:0.8rem 0.95rem;display:flex;flex-direction:column;gap:0.4rem;border-left:6px solid var(--signal-warning);">
            <div style="display:flex;justify-content:space-between;align-items:center;gap:8px;">
                <span style="font-family:var(--font-mono);font-weight:700;font-size:0.66rem;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-secondary);">Pendiente / cash</span>
                <span style="font-family:var(--font-mono);font-weight:700;font-size:0.6rem;text-transform:uppercase;background:var(--signal-warning);color:var(--ink-900);padding:2px 7px;">Por confirmar</span>
            </div>
            <span style="font-family:var(--font-sans);font-weight:700;font-size:1.85rem;letter-spacing:-1px;line-height:1;color:var(--ink-900);">@PendienteFmt</span>
            <small style="font-family:var(--font-mono);font-size:0.66rem;color:var(--text-muted);text-transform:uppercase;">Efectivo aún no arqueado</small>
        </div>
    </div>

    <!-- ===== Cuerpo: tabla + panel de análisis ===== -->
    <div class="iv-body" style="flex:1;min-height:0;display:flex;gap:12px;overflow:hidden;">

        <!-- Detalle de operaciones -->
        <section style="flex:1;min-width:0;display:flex;flex-direction:column;border:2px solid var(--ink-900);box-shadow:var(--shadow-card);background:var(--paper-0);overflow:hidden;">
            <div style="flex-shrink:0;background:var(--ink-900);color:#fff;display:flex;justify-content:space-between;align-items:center;gap:10px;flex-wrap:wrap;padding:0.5rem 0.85rem;">
                <div style="font-family:var(--font-mono);font-weight:700;text-transform:uppercase;letter-spacing:0.5px;font-size:0.86rem;display:flex;align-items:center;gap:8px;"><i class="bi bi-table"></i>Detalle de operaciones <span style="color:rgba(255,255,255,0.55);font-weight:400;font-size:0.78rem;">@FilteredOps.Count ítems</span></div>
                <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
                    <select @bind="_estado" style="border:2px solid var(--paper-0);background:var(--paper-0);color:var(--ink-900);font-family:var(--font-mono);font-weight:700;font-size:0.68rem;text-transform:uppercase;padding:4px 8px;border-radius:0;cursor:pointer;">
                        <option value="TODOS">Todos</option>
                        <option value="CONF">Confirmadas</option>
                        <option value="PEND">Pendientes</option>
                        <option value="DIFF">Diferencias</option>
                    </select>
                    <div style="display:flex;align-items:center;background:var(--paper-0);border:2px solid var(--paper-0);padding:0 8px;">
                        <i class="bi bi-search" style="color:var(--ink-500);font-size:0.78rem;"></i>
                        <input type="text" placeholder="Filtrar producto…" @bind="_search" @bind:event="oninput" style="border:none;background:transparent;color:var(--ink-900);font-family:var(--font-mono);font-size:0.74rem;padding:5px 6px;width:140px;outline:none;" />
                    </div>
                </div>
            </div>

            <div style="flex:1;min-height:0;overflow:auto;">
                <table class="iv-tbl" style="width:100%;border-collapse:collapse;">
                    <thead style="position:sticky;top:0;z-index:2;">
                        <tr style="background:var(--ink-700);color:#fff;font-family:var(--font-mono);text-transform:uppercase;font-size:0.62rem;letter-spacing:0.5px;">
                            <th style="text-align:left;padding:7px 12px;font-weight:700;">Fecha local</th>
                            <th style="text-align:left;padding:7px 12px;font-weight:700;">Unidad</th>
                            <th style="text-align:center;padding:7px 12px;font-weight:700;">Slot</th>
                            <th style="text-align:left;padding:7px 12px;font-weight:700;">Producto</th>
                            <th style="text-align:right;padding:7px 12px;font-weight:700;">Costo</th>
                            <th style="text-align:right;padding:7px 12px;font-weight:700;">Monto</th>
                            <th style="text-align:right;padding:7px 12px;font-weight:700;">Ganancia</th>
                            <th style="text-align:center;padding:7px 12px;font-weight:700;">Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var o in FilteredOps)
                        {
                            <tr class="iv-row" @onclick="() => OpenDetail(o)" style="border-bottom:1px solid var(--line-200);cursor:pointer;">
                                <td style="font-family:var(--font-mono);font-size:0.74rem;color:var(--text-secondary);white-space:nowrap;">@o.Fecha</td>
                                <td style="font-family:var(--font-mono);font-weight:700;font-size:0.76rem;">@o.Unidad</td>
                                <td style="text-align:center;font-family:var(--font-mono);font-size:0.74rem;color:var(--text-muted);">@o.Slot</td>
                                <td style="font-family:var(--font-sans);font-weight:600;font-size:0.8rem;text-transform:uppercase;">@o.Prod</td>
                                <td style="text-align:right;font-family:var(--font-mono);font-weight:700;font-size:0.78rem;color:var(--text-muted);">@Fmt(o.Costo)</td>
                                <td style="text-align:right;font-family:var(--font-mono);font-weight:700;font-size:0.78rem;">@Fmt(o.Monto)</td>
                                <td style="text-align:right;font-family:var(--font-mono);font-weight:700;font-size:0.78rem;">
                                    <span style="color:@(o.Gan >= 0 ? "var(--signal-success)" : "var(--signal-danger)");">@FmtGan(o.Gan)</span>
                                </td>
                                <td style="text-align:center;">
                                    @switch (o.Estado)
                                    {
                                        case "CONF":
                                            <span style="font-family:var(--font-mono);font-weight:700;font-size:0.6rem;background:var(--signal-success);color:#fff;padding:2px 7px;text-transform:uppercase;">Conf</span>
                                            break;
                                        case "PEND":
                                            <span style="font-family:var(--font-mono);font-weight:700;font-size:0.6rem;background:var(--signal-warning);color:var(--ink-900);padding:2px 7px;text-transform:uppercase;">Pend</span>
                                            break;
                                        case "DIFF":
                                            <span style="font-family:var(--font-mono);font-weight:700;font-size:0.6rem;background:var(--signal-danger);color:#fff;padding:2px 7px;text-transform:uppercase;">Diff</span>
                                            break;
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                @if (FilteredOps.Count == 0)
                {
                    <div style="padding:2.5rem 1rem;text-align:center;font-family:var(--font-mono);font-size:0.78rem;color:var(--text-muted);text-transform:uppercase;">Sin datos en el rango_</div>
                }
            </div>
        </section>

        <!-- Panel de análisis (rail lateral con pestañas) -->
        <aside class="iv-rail" style="flex:0 0 360px;display:flex;flex-direction:column;border:2px solid var(--ink-900);box-shadow:var(--shadow-card);background:var(--paper-0);overflow:hidden;">
            <div style="flex-shrink:0;display:flex;border-bottom:2px solid var(--ink-900);">
                <button @onclick='() => _tab = "maquinas"' style="flex:1;font-family:var(--font-mono);font-weight:700;font-size:0.7rem;text-transform:uppercase;letter-spacing:0.5px;padding:0.6rem 0.4rem;border:none;border-radius:0;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:6px;background:@(_tab == "maquinas" ? "var(--ink-900)" : "var(--paper-0)");color:@(_tab == "maquinas" ? "#fff" : "var(--ink-900)");"><i class="bi bi-hdd-stack"></i>Por máquina</button>
                <button @onclick='() => _tab = "productos"' style="flex:1;font-family:var(--font-mono);font-weight:700;font-size:0.7rem;text-transform:uppercase;letter-spacing:0.5px;padding:0.6rem 0.4rem;border:none;border-left:2px solid var(--ink-900);border-radius:0;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:6px;background:@(_tab == "productos" ? "var(--ink-900)" : "var(--paper-0)");color:@(_tab == "productos" ? "#fff" : "var(--ink-900)");"><i class="bi bi-star"></i>Top productos</button>
            </div>

            @if (_tab == "maquinas")
            {
                <!-- Rendimiento por máquina -->
                <div style="flex:1;min-height:0;overflow:auto;padding:0.6rem;">
                    @foreach (var m in MaquinasGrouped)
                    {
                        <div style="border:1px solid var(--line-200);box-shadow:var(--shadow-card);margin-bottom:8px;padding:0.65rem 0.75rem;">
                            <div style="display:flex;justify-content:space-between;align-items:baseline;gap:8px;">
                                <span style="font-family:var(--font-mono);font-weight:700;font-size:0.74rem;text-transform:uppercase;">@m.Codigo</span>
                                <span style="font-family:var(--font-mono);font-size:0.6rem;color:var(--text-muted);text-transform:uppercase;">—</span>
                            </div>
                            <div style="height:7px;background:var(--paper-100);border:1px solid var(--ink-900);margin:8px 0 7px;overflow:hidden;">
                                <div style="height:100%;background:var(--signal-success);width:@(BarPct(m.Total))%;"></div>
                            </div>
                            <div style="display:flex;justify-content:space-between;font-family:var(--font-mono);font-size:0.66rem;">
                                <span style="color:var(--text-muted);text-transform:uppercase;">@m.Vtas vtas · @Fmt(m.Total)</span>
                                <span style="font-weight:700;color:var(--signal-success);">@Fmt(m.Gan)</span>
                            </div>
                        </div>
                    }
                    <div style="border-top:2px solid var(--ink-900);margin-top:4px;padding-top:9px;display:flex;justify-content:space-between;align-items:baseline;">
                        <span style="font-family:var(--font-mono);font-weight:700;font-size:0.66rem;text-transform:uppercase;color:var(--text-muted);">Total flota</span>
                        <span style="font-family:var(--font-sans);font-weight:700;font-size:1.15rem;letter-spacing:-0.5px;">@VentasFmt</span>
                    </div>
                </div>
            }
            else
            {
                <!-- Top productos -->
                <div style="flex:1;min-height:0;overflow:auto;">
                    <table style="width:100%;border-collapse:collapse;">
                        <thead style="position:sticky;top:0;">
                            <tr style="background:var(--ink-700);color:#fff;font-family:var(--font-mono);text-transform:uppercase;font-size:0.6rem;letter-spacing:0.5px;">
                                <th style="text-align:left;padding:7px 10px;font-weight:700;">#</th>
                                <th style="text-align:left;padding:7px 6px;font-weight:700;">Producto</th>
                                <th style="text-align:right;padding:7px 8px;font-weight:700;">Cant</th>
                                <th style="text-align:right;padding:7px 10px;font-weight:700;">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ var rank = 0; }
                            @foreach (var p in ProductosRanked)
                            {
                                rank++;
                                <tr class="iv-row" style="border-bottom:1px solid var(--line-200);">
                                    <td style="padding:6px 10px;font-family:var(--font-mono);font-weight:700;font-size:0.7rem;color:var(--text-muted);">@rank.ToString("D2")</td>
                                    <td style="padding:6px 6px;font-family:var(--font-sans);font-weight:600;font-size:0.74rem;text-transform:uppercase;">@p.Prod</td>
                                    <td style="padding:6px 8px;text-align:right;font-family:var(--font-mono);font-size:0.72rem;">@p.Cant</td>
                                    <td style="padding:6px 10px;text-align:right;font-family:var(--font-mono);font-weight:700;font-size:0.72rem;">@Fmt(p.Total)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </aside>
    </div>
</div>

<!-- ===== MODAL: detalle de operación ===== -->
@if (_detail is not null)
{
    var d = _detail!;
    <div class="iv-modal-back" style="position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:2000;display:flex;align-items:flex-start;justify-content:center;padding:8vh 16px;overflow:auto;" @onclick="CloseDetail">
        <div class="iv-modal" style="width:100%;max-width:420px;background:var(--paper-0);border:2px solid var(--ink-900);box-shadow:4px 4px 0 #000;" @onclick:stopPropagation="true">
            <div style="background:var(--ink-900);color:#fff;display:flex;justify-content:space-between;align-items:center;padding:0.6rem 0.9rem;font-family:var(--font-mono);font-weight:700;text-transform:uppercase;letter-spacing:1px;">
                <span>Detalle de operación</span>
                <span style="cursor:pointer;font-size:1.2rem;line-height:1;" @onclick="CloseDetail">×</span>
            </div>
            <div style="padding:1.2rem;">
                <div style="text-align:center;margin-bottom:1rem;">
                    <div style="font-family:var(--font-mono);font-size:0.66rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.5px;">@d.Prod</div>
                    <div style="font-family:var(--font-sans);font-weight:700;font-size:2.1rem;letter-spacing:-1px;">@Fmt(d.Monto)</div>
                </div>
                <div style="display:grid;grid-template-columns:auto 1fr;gap:8px 16px;font-family:var(--font-mono);font-size:0.78rem;align-items:baseline;">
                    <span style="color:var(--text-muted);font-weight:700;text-transform:uppercase;font-size:0.64rem;">Fecha local</span><span style="font-weight:600;">@d.Fecha</span>
                    <span style="color:var(--text-muted);font-weight:700;text-transform:uppercase;font-size:0.64rem;">Unidad</span><span style="font-weight:600;">@d.Unidad</span>
                    <span style="color:var(--text-muted);font-weight:700;text-transform:uppercase;font-size:0.64rem;">Slot</span><span style="font-weight:600;">@d.Slot</span>
                    <span style="color:var(--text-muted);font-weight:700;text-transform:uppercase;font-size:0.64rem;">Costo unit.</span><span style="font-weight:600;">@Fmt(d.Costo)</span>
                    <span style="color:var(--text-muted);font-weight:700;text-transform:uppercase;font-size:0.64rem;">Ganancia</span><span style="font-weight:700;">@FmtGan(d.Gan)</span>
                    <span style="color:var(--text-muted);font-weight:700;text-transform:uppercase;font-size:0.64rem;">Estado</span><span style="font-weight:700;text-transform:uppercase;">@EstadoLabel(d.Estado)</span>
                </div>
                <div style="margin-top:1.1rem;border:2px dashed var(--line-200);background:repeating-linear-gradient(45deg,#fafafa,#fafafa 8px,#f0f0f0 8px,#f0f0f0 16px);padding:0.85rem;text-align:center;font-family:var(--font-mono);font-size:0.7rem;color:var(--text-muted);text-transform:uppercase;">
                    <i class="bi bi-upc-scan"></i> Trazabilidad Transbank · @EstadoLabel(d.Estado)
                </div>
                <div style="display:flex;gap:10px;margin-top:1.1rem;">
                    <VmButton Variant="outline" Icon="bi-receipt" Block="true" OnClick="CloseDetail">Ver comprobante</VmButton>
                    <VmButton Variant="dark" Icon="bi-check2" Block="true" OnClick="CloseDetail">Conciliar</VmButton>
                </div>
            </div>
        </div>
    </div>
}

@code {
    // ── Estado de UI ──────────────────────────────────────────────────────────
    private string _unit = "0";
    private string _search = "";
    private string _estado = "TODOS";
    private string _tab = "maquinas";
    private string _desde = DateTime.Today.AddDays(-7).ToString("yyyy-MM-dd");
    private string _hasta = DateTime.Today.ToString("yyyy-MM-dd");
    private OpRow? _detail;
    private bool _syncing = false;
    private bool _exporting = false;
    private DateTime? _lastSyncAt;
    private string LastSyncLabel => _lastSyncAt is null ? "nunca" : TimeAgoHelper.Format(_lastSyncAt.Value, DateTime.Now);
    private string? _error;
    private string? _success;
    private CancellationTokenSource? _loadCts;
    private CancellationTokenSource? _pollingCts;

    /// <summary>Polling interval in milliseconds. Exposed for testing.</summary>
    [System.ComponentModel.EditorBrowsable(System.ComponentModel.EditorBrowsableState.Never)]
    [Parameter] public int PollingIntervalMs { get; set; } = 30_000;

    // ── Query string binding (set by Home KPI click: ?start=&end=&maquinaId=) ─
    [SupplyParameterFromQuery(Name = "start")] public string? QueryStart { get; set; }
    [SupplyParameterFromQuery(Name = "end")] public string? QueryEnd { get; set; }
    [SupplyParameterFromQuery(Name = "maquinaId")] public string? QueryMaquinaId { get; set; }

    /// <summary>Current polling CancellationTokenSource. Exposed for testing.</summary>
    [System.ComponentModel.EditorBrowsable(System.ComponentModel.EditorBrowsableState.Never)]
    public CancellationTokenSource? PollingCts => _pollingCts;

    // ── API state ─────────────────────────────────────────────────────────────
    private ReporteDto? _reporte;
    private InformeFinancieroDto? _financiero;
    private List<AnalisisProductoDto> _productos = new();
    private List<MaquinaSimpleDto> _maquinas = new();

    // ── View-models ───────────────────────────────────────────────────────────
    private record OpRow(string Fecha, string Unidad, string Slot, string Prod, decimal Monto, decimal Costo, decimal Gan, string Estado);
    private record MaquinaRailRow(string Codigo, int Vtas, decimal Total, decimal Gan);
    private record ProductoRow(string Prod, int Cant, decimal Total);

    private List<VmSelect.VmSelectOption> UnitOptions = new()
    {
        new("0", ":: Todas las unidades ::")
    };

    // ── Derived ───────────────────────────────────────────────────────────────
    private IReadOnlyList<OpRow> FilteredOps
    {
        get
        {
            var all = (_reporte?.Detalle ?? new()).Select(d => new OpRow(
                d.FechaRaw.ToString("dd/MM/yyyy HH:mm"),
                MachineHelpers.ExtractShortCode(d.Maquina, d.IdInternoMaquina),
                d.Slot,
                d.Producto,
                d.Monto,
                d.CostoUnitario,
                d.Ganancia,
                d.Estado
            ));
            var q = _search.Trim().ToLowerInvariant();
            return all
                .Where(o => (_estado == "TODOS" || o.Estado == _estado)
                            && (q == "" || o.Prod.ToLowerInvariant().Contains(q)))
                .ToList();
        }
    }

    private IReadOnlyList<MaquinaRailRow> MaquinasGrouped
    {
        get
        {
            var maxTotal = (_reporte?.Detalle ?? new()).Any()
                ? _reporte!.Detalle
                    .GroupBy(d => MachineHelpers.ExtractShortCode(d.Maquina, d.IdInternoMaquina))
                    .Max(g => g.Sum(d => d.Monto))
                : 1m;
            return (_reporte?.Detalle ?? new())
                .GroupBy(d => MachineHelpers.ExtractShortCode(d.Maquina, d.IdInternoMaquina))
                .Select(g => new MaquinaRailRow(
                    g.Key,
                    g.Count(),
                    g.Sum(d => d.Monto),
                    g.Sum(d => d.Ganancia)))
                .OrderByDescending(m => m.Total)
                .Take(5)
                .ToList();
        }
    }

    private IReadOnlyList<ProductoRow> ProductosRanked =>
        _productos
            .OrderByDescending(p => p.CantidadVendida)
            .Select(p => new ProductoRow(p.Nombre, p.CantidadVendida, p.TotalVentas))
            .ToList();

    // ── KPI bindings ──────────────────────────────────────────────────────────
    private string UtilidadFmt => _financiero is not null ? Fmt(_financiero.UtilidadNeta) : "$0";
    private string Margen => _financiero is not null ? $"{_financiero.MargenPorcentaje:F1}%" : "0%";
    private string VentasFmt => _reporte is not null ? Fmt(_reporte.MontoTotal) : "$0";
    private string TxCount => _reporte is not null ? _reporte.TotalVentas.ToString("N0", Nfi) : "0";
    private string PendienteFmt => _reporte is not null ? Fmt(_reporte.MontoPendiente) : "$0";
    private int MaxMaquinaTotal => MaquinasGrouped.Any() ? (int)MaquinasGrouped.Max(m => m.Total) : 1;

    // ── Formato de moneda (es-CL: punto como separador de miles) ──────────────
    private static readonly NumberFormatInfo Nfi = new() { NumberGroupSeparator = ".", NumberDecimalDigits = 0 };
    private static string Fmt(decimal n) => (n < 0 ? "-$" : "$") + Math.Abs(n).ToString("N0", Nfi);
    private static string FmtGan(decimal g) => (g >= 0 ? "$" : "-$") + Math.Abs(g).ToString("N0", Nfi);

    private int BarPct(decimal total) => MaxMaquinaTotal > 0 ? (int)Math.Round(total / MaxMaquinaTotal * 100) : 0;

    private static string EstadoLabel(string estado) => estado switch
    {
        "CONF" => "Confirmada",
        "PEND" => "Pendiente / cash",
        "DIFF" => "Diferencia Transbank",
        _ => estado,
    };

    // ── Lifecycle ─────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        ApplyQueryStringFilters();
        await CargarMaquinas();
        _loadCts = new CancellationTokenSource();
        await CargarReportesAsync(_loadCts.Token);
    }

    private void ApplyQueryStringFilters()
    {
        if (!string.IsNullOrEmpty(QueryStart) && DateTime.TryParse(QueryStart, out var dStart))
            _desde = dStart.ToString("yyyy-MM-dd");
        if (!string.IsNullOrEmpty(QueryEnd) && DateTime.TryParse(QueryEnd, out var dEnd))
            _hasta = dEnd.ToString("yyyy-MM-dd");
        if (!string.IsNullOrEmpty(QueryMaquinaId))
            _unit = QueryMaquinaId;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _pollingCts = new CancellationTokenSource();
            await RefreshLastSyncAsync();
            StateHasChanged();

            _ = Task.Run(async () =>
            {
                while (!_pollingCts.Token.IsCancellationRequested)
                {
                    try
                    {
                        await Task.Delay(PollingIntervalMs, _pollingCts.Token);
                        await RefreshLastSyncAsync();
                        await InvokeAsync(StateHasChanged);
                    }
                    catch (OperationCanceledException) { break; }
                    catch { /* silent */ }
                }
            });
        }
    }

    private record LastSyncResponse(DateTime? LastSync);

    private async Task RefreshLastSyncAsync()
    {
        try
        {
            var resp = await Http.GetFromJsonAsync<LastSyncResponse>("api/Ventas/last-sync");
            if (resp?.LastSync is not null)
            {
                _lastSyncAt = resp.LastSync.Value.ToLocalTime();
            }
        }
        catch { /* silent */ }
    }

    private async Task CargarMaquinas()
    {
        try
        {
            var data = await Http.GetFromJsonAsync<List<MaquinaSimpleDto>>("api/Ventas/lista-maquinas");
            if (data is not null)
            {
                _maquinas = data;
                UnitOptions = new List<VmSelect.VmSelectOption> { new("0", ":: Todas las unidades ::") };
                UnitOptions.AddRange(_maquinas.Select(m =>
                    new VmSelect.VmSelectOption(m.Id.ToString(), m.Nombre)));
            }
        }
        catch (Exception ex)
        {
            _error = "No se pudo cargar el catálogo de máquinas.";
            Logger?.LogError(ex, "InformeVentas: error cargando lista-maquinas");
        }
    }

    private async Task CargarReportesAsync(CancellationToken ct)
    {
        var inicio = _desde;
        var fin = _hasta;
        var maqId = _unit;

        var reporteUrl = $"api/Ventas/reporte-rango?inicio={inicio}&fin={fin}&maquinaId={maqId}&includePhantom=false";
        var financieroUrl = $"api/Ventas/informe-financiero?inicio={inicio}&fin={fin}&maquinaId={maqId}";
        var productosUrl = $"api/Ventas/analisis-productos?inicio={inicio}&fin={fin}&maquinaId={maqId}";

        _error = null;

        await Task.WhenAll(
            FetchWithErrorHandling(reporteUrl, ct, async (HttpResponseMessage resp) =>
            {
                _reporte = await resp.Content.ReadFromJsonAsync<ReporteDto>(cancellationToken: ct);
            }),
            FetchWithErrorHandling(financieroUrl, ct, async (HttpResponseMessage resp) =>
            {
                _financiero = await resp.Content.ReadFromJsonAsync<InformeFinancieroDto>(cancellationToken: ct);
            }),
            FetchWithErrorHandling(productosUrl, ct, async (HttpResponseMessage resp) =>
            {
                var data = await resp.Content.ReadFromJsonAsync<List<AnalisisProductoDto>>(cancellationToken: ct);
                if (data is not null) _productos = data;
            })
        );

        await InvokeAsync(StateHasChanged);
    }

    private async Task FetchWithErrorHandling(string url, CancellationToken ct, Func<HttpResponseMessage, Task> onSuccess)
    {
        try
        {
            var resp = await Http.GetAsync(url, ct);
            if (resp.IsSuccessStatusCode)
            {
                await onSuccess(resp);
            }
            else
            {
                _error = "Error al cargar datos del servidor.";
                Logger?.LogWarning("InformeVentas: {Url} retornó {Status}", url, resp.StatusCode);
            }
        }
        catch (OperationCanceledException) { throw; }
        catch (Exception ex)
        {
            _error = "Error al cargar datos del servidor.";
            Logger?.LogError(ex, "InformeVentas: excepción en {Url}", url);
        }
    }

    // ── Debounce + cancellation ───────────────────────────────────────────────
    private async Task OnFilterChanged()
    {
        _loadCts?.Cancel();
        _loadCts = new CancellationTokenSource();
        var ct = _loadCts.Token;
        try
        {
            await Task.Delay(300, ct);
            await CargarReportesAsync(ct);
        }
        catch (OperationCanceledException) { /* debounce cancelled */ }
    }

    private async Task EjecutarQuery()
    {
        _loadCts?.Cancel();
        _loadCts = new CancellationTokenSource();
        await CargarReportesAsync(_loadCts.Token);
    }

    // ── ILogger injection (placeholder — will be wired in WU-4) ──────────────
    [Inject] private Microsoft.Extensions.Logging.ILogger<InformeVentas>? Logger { get; set; }

    // ── IDisposable ───────────────────────────────────────────────────────────
    public void Dispose()
    {
        _pollingCts?.Cancel();
        _pollingCts?.Dispose();
        _loadCts?.Cancel();
        _loadCts?.Dispose();
    }

    // ── Acciones ──────────────────────────────────────────────────────────────
    private void OpenDetail(OpRow o) => _detail = o;
    private void CloseDetail() => _detail = null;
    private async Task Exportar()
    {
        if (_exporting) return;

        _error = null;
        _success = null;

        if (!DateTime.TryParse(_desde, out _))
        {
            _error = "Fecha Desde inválida.";
            StateHasChanged();
            return;
        }
        if (!DateTime.TryParse(_hasta, out _))
        {
            _error = "Fecha Hasta inválida.";
            StateHasChanged();
            return;
        }

        _exporting = true;
        StateHasChanged();

        _loadCts?.Cancel();
        _loadCts = new CancellationTokenSource();
        var ct = _loadCts.Token;

        try
        {
            var url = $"api/Ventas/exportar?inicio={_desde}&fin={_hasta}&maquinaId=0&includePhantom=false";
            var response = await Http.GetAsync(url, ct);
            if (response.IsSuccessStatusCode)
            {
                var content = await response.Content.ReadAsByteArrayAsync(ct);
                var fileName = $"Reporte_{_desde}_{_hasta}.xlsx";
                await JS.InvokeVoidAsync("descargarArchivo", content, fileName);
            }
            else
            {
                _error = "Error al exportar: " + response.StatusCode;
            }
        }
        catch (OperationCanceledException) { /* disposed or cancelled */ }
        catch (Exception ex)
        {
            _error = "Error al exportar: " + ex.Message;
        }
        finally
        {
            _exporting = false;
            StateHasChanged();
        }
    }

    private async Task Sincronizar()
    {
        if (_syncing) return;

        if (!DateTime.TryParse(_hasta, out var fechaLimite))
        {
            _error = "Fecha Hasta inválida.";
            StateHasChanged();
            return;
        }

        _syncing = true;
        _error = null;
        _success = null;
        StateHasChanged();

        _loadCts?.Cancel();
        _loadCts = new CancellationTokenSource();
        var ct = _loadCts.Token;

        try
        {
            var fechaParam = fechaLimite.ToString("yyyy-MM-ddTHH:mm:ss");
            var response = await Http.PostAsync($"api/Ventas/sync-portal?maquinaId=0&fechaLimite={fechaParam}", null, ct);
            if (response.IsSuccessStatusCode)
            {
                var msg = await response.Content.ReadAsStringAsync(ct);
                _success = "Sincronización completada: " + msg;
                _lastSyncAt = DateTime.Now;
                _loadCts?.Cancel();
                _loadCts = new CancellationTokenSource();
                await CargarReportesAsync(_loadCts.Token);
            }
            else
            {
                var msg = await response.Content.ReadAsStringAsync(ct);
                _error = "Error al sincronizar: " + msg;
            }
        }
        catch (OperationCanceledException) { /* disposed or cancelled */ }
        catch (Exception ex)
        {
            _error = "Error al sincronizar: " + ex.Message;
        }
        finally
        {
            _syncing = false;
            StateHasChanged();
        }
    }
}
