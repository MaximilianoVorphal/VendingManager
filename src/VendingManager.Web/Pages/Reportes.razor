@page "/informe-ventas"
@using Microsoft.AspNetCore.WebUtilities

<div class="industrial-wrapper container-fluid px-4 mt-4">

    <!-- HEADER -->
    <div class="row align-items-center mb-4 border-bottom border-3 border-dark pb-3 industrial-page-header">
        <div class="col-12">
            <h2 class="m-0 fw-bold text-uppercase" style="letter-spacing: -1px;">INFORME DE VENTAS</h2>
            <small class="text-muted fw-bold">ANÁLISIS DE RENDIMIENTO Y TRANSACCIONES</small>
        </div>
    </div>

    <!-- CONTROL PANEL -->
    <VmCard Header="CONTROL DE INFORME" HeaderVariant="dark" Style="margin-bottom:1.5rem;">
        <div class="row align-items-end g-3">
            <div class="col-md-3 col-12">
                <VmSelect Label="TEMPLATE (OPCIONAL):"
                          Value="@TemplateSeleccionado.ToString()"
                          ValueChanged="OnTemplateChanged"
                          Options="@TemplateOptions" />
            </div>
            <div class="col-md-3 col-12">
                <VmSelect Label="UNIDAD:"
                          Value="@MaquinaSeleccionada.ToString()"
                          ValueChanged="OnMaquinaChanged"
                          Options="@MaquinaOptions" />
            </div>
            <div class="col-6 col-md-2">
                <VmInput Type="date" Label="DESDE" @bind-Value="FechaInicioString" Disabled="@(TemplateSeleccionado > 0)" />
            </div>
            <div class="col-6 col-md-2">
                <VmInput Type="date" Label="HASTA" @bind-Value="FechaFinString" Disabled="@(TemplateSeleccionado > 0)" />
            </div>
            <div class="col-12 col-md-2">
                <VmButton Variant="dark" Block="true" OnClick="CargarReporte" Disabled="Cargando" Icon="bi-play-fill">
                    @(Cargando ? "PROCESANDO..." : "EJECUTAR QUERY")
                </VmButton>
            </div>
        </div>
        <div class="row mt-3 align-items-center">
            <div class="col-12 d-flex flex-wrap gap-2 align-items-center">
                <VmButton Variant="primary" OnClick="VerInformeFinanciero" Icon="bi-graph-up-arrow" />
                <VmButton Variant="success" OnClick="ExportarExcel" Icon="bi-file-earmark-excel" />
                <VmButton Variant="info" OnClick="AbrirModalSync" Disabled="Sincronizando" Icon="@(Sincronizando ? null : "bi-cloud-arrow-down-fill")">
                    @if (Sincronizando)
                    {
                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                    }
                </VmButton>
                <VmButton Variant="secondary" OnClick="AbrirModalFiltroProductos" Icon="bi-funnel-fill">
                    @if (ProductosExcluidos.Any())
                    {
                        <VmBadge Variant="danger">@ProductosExcluidos.Count</VmBadge>
                    }
                </VmButton>
                <AuthorizeView Roles="Admin">
                    <Authorized>
                        <VmButton Variant="dark" OnClick="AbrirModalAdmin" Icon="bi-gear-fill text-danger" />
                    </Authorized>
                </AuthorizeView>
                <div class="form-check form-switch ms-md-auto">
                    <input class="form-check-input" type="checkbox" id="checkFantasmas" @bind="MostrarFantasmas">
                    <label class="form-check-label fw-bold small text-uppercase" for="checkFantasmas">
                        Incluir Ventas Fantasma (Diferencias Transbank)
                    </label>
                </div>
            </div>
        </div>
    </VmCard>

    @if (!string.IsNullOrEmpty(MensajeError))
    {
            <div class="alert alert-danger border-2 border-dark rounded-0 mb-4 shadow-sm fw-bold">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> ERROR DE SISTEMA: @MensajeError
            </div>
    }

    @if (Cargando)
    {
            <div class="text-center py-5 border border-dark border-2 bg-light">
                <div class="spinner-grow text-dark" role="status"></div>
                <p class="mt-2 fw-bold text-uppercase" style="letter-spacing: 2px;">Conectando Base de Datos...</p>
            </div>
    }
    else if (Datos != null)
    {
            <!-- KPI CARDS -->
            <div class="industrial-kpi-grid mb-4">
            @{
                var datosParaKpi = DetalleFiltrado;
                var gananciaConfirmada = datosParaKpi.Where(d => d.Estado == "Pagado").Sum(d => d.Ganancia);
                var ventasConfirmadas = datosParaKpi.Where(d => d.Estado == "Pagado").Sum(d => d.Monto);
                var montoPendiente = datosParaKpi.Where(d => d.Estado != "Pagado").Sum(d => d.Monto);
                var montoPhantom = Datos.MontoPhantom;
            }

                <VmKpiCard Header="UTILIDAD (REAL / PAGADA)" Caption="Ganancia neta del período" Value="@($"${gananciaConfirmada:N0}")" ValueColor="var(--signal-success)">
                    <FooterContent>
                        <small class="fw-bold text-uppercase" style="font-size:0.7rem;">Margen Neto Real</small>
                        @if (ventasConfirmadas > 0)
                        {
                            <VmBadge Variant="light">@((gananciaConfirmada / ventasConfirmadas * 100).ToString("F1"))%</VmBadge>
                        }
                        else
                        {
                            <VmBadge Variant="light">0.0%</VmBadge>
                        }
                    </FooterContent>
                </VmKpiCard>

                <VmKpiCard Header="VENTAS CONFIRMADAS" Caption="Total operado en el rango" Value="@($"${ventasConfirmadas:N0}")" ValueColor="var(--signal-success)">
                    <FooterContent>
                        <small class="text-uppercase" style="font-size:0.7rem;">@datosParaKpi.Count(x => x.Estado == "Pagado") Transacciones</small>
                    </FooterContent>
                </VmKpiCard>

                <VmKpiCard Header="DIFERENCIAS TRANSBANK" Value="@($"${montoPhantom:N0}")" ValueColor="var(--signal-danger)" OnClick="VerFantasmas">
                    <FooterContent>
                        @if (montoPhantom > 0)
                        {
                            <small class="text-uppercase" style="font-size:0.7rem;">Requiere Revisión (Click para ver)</small>
                        }
                        else
                        {
                            <small class="text-uppercase" style="font-size:0.7rem;">Sin Errores</small>
                        }
                    </FooterContent>
                </VmKpiCard>

                <VmKpiCard Header="PENDIENTE / CASH" Value="@($"${montoPendiente:N0}")" ValueColor="var(--ink-900)">
                    <FooterContent>
                        <small class="text-uppercase" style="font-size:0.7rem;">Por Confirmar</small>
                    </FooterContent>
                </VmKpiCard>
            </div>

            <!-- MAIN DATA TABLE -->
            <VmCard Header="@($"DETALLE DE OPERACIONES ({DetalleFiltrado.Count})")" HeaderVariant="dark" Style="margin-bottom:1.5rem;">
                <div style="display:flex;justify-content:flex-end;margin-bottom:0.75rem;">
                    <input type="text" @bind="FiltroProducto" @bind:event="oninput"
                           class="form-control form-control-sm border-dark rounded-0 font-monospace"
                           style="max-width:250px;background:var(--paper-100);"
                           placeholder="🔍 Filtrar producto..." />
                </div>
                <div style="overflow-x:auto;overflow-y:auto;max-height:550px;-webkit-overflow-scrolling:touch;">
                    <table style="width:100%;border-collapse:collapse;border:2px solid var(--ink-900);font-family:var(--font-sans);min-width:700px;">
                        <thead style="position:sticky;top:0;z-index:2;background:var(--ink-900);color:var(--paper-0);font-family:var(--font-mono);text-transform:uppercase;font-size:var(--fs-2xs);letter-spacing:0.5px;">
                            <tr>
                                <th role="button" @onclick='() => OrdenarPor("Fecha")' style="text-align:left;padding:8px 12px;font-weight:700;background:var(--ink-900);">FECHA LOCAL @RenderIcono("Fecha")</th>
                                <th role="button" @onclick='() => OrdenarPor("Maquina")' style="text-align:left;padding:8px 12px;font-weight:700;background:var(--ink-900);">UNIDAD @RenderIcono("Maquina")</th>
                                <th role="button" @onclick='() => OrdenarPor("Slot")' style="text-align:center;padding:8px 12px;font-weight:700;background:var(--ink-900);">SLOT @RenderIcono("Slot")</th>
                                <th style="text-align:left;padding:8px 12px;font-weight:700;background:var(--ink-900);">PRODUCTO</th>
                                <th role="button" @onclick='() => OrdenarPor("Monto")' style="text-align:right;padding:8px 12px;font-weight:700;background:var(--ink-900);">MONTO @RenderIcono("Monto")</th>
                                <th style="text-align:right;padding:8px 12px;font-weight:700;background:var(--ink-900);">GANANCIA</th>
                                <th role="button" @onclick='() => OrdenarPor("Estado")' style="text-align:center;padding:8px 12px;font-weight:700;background:var(--ink-900);">ESTADO @RenderIcono("Estado")</th>
                            </tr>
                        </thead>
                        <tbody>
                        @if (DetalleFiltrado.Count > 0)
                        {
                            <Virtualize Items="@DetalleFiltrado" Context="v" SpacerElement="tr" OverscanCount="20">
                                <tr style="@RowStyle(v)">
                                    <td style="font-family:var(--font-mono);font-size:var(--fs-sm);white-space:nowrap;padding:8px 12px;">@v.FechaRaw.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td style="font-family:var(--font-mono);font-weight:var(--fw-bold);font-size:var(--fs-sm);padding:8px 12px;">@ExtractMachineCode(v.Maquina)</td>
                                    <td style="text-align:center;font-family:var(--font-mono);font-size:var(--fs-sm);padding:8px 12px;">@v.Slot</td>
                                    <td style="font-family:var(--font-sans);font-weight:var(--fw-bold);font-size:0.84rem;text-transform:uppercase;letter-spacing:-0.2px;padding:8px 12px;">@v.Producto</td>
                                    <td style="text-align:right;font-family:var(--font-mono);font-weight:var(--fw-bold);font-size:var(--fs-sm);padding:8px 12px;">$@v.Monto.ToString("N0")</td>
                                    <td style="text-align:right;font-family:var(--font-mono);font-weight:var(--fw-bold);font-size:var(--fs-sm);padding:8px 12px;color:@GananciaColor(v.Ganancia);">$@v.Ganancia.ToString("N0")</td>
                                    <td style="text-align:center;padding:8px 12px;">
                                        @if (v.Estado == "Pagado")
                                        {
                                            <VmBadge Variant="success">OK</VmBadge>
                                        }
                                        else
                                        {
                                            <VmBadge Variant="warning">PEND</VmBadge>
                                        }
                                    </td>
                                </tr>
                            </Virtualize>
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-4 text-muted fw-bold fst-italic">NO SE ENCONTRARON REGISTROS EN ESTE RANGO.</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </VmCard>

            <!-- TABLAS AGRUPADAS -->
            <div class="row g-4 mb-4">
                <!-- POR MAQUINA -->
        <div class="col-md-6">
                    <div class="card border-2 border-dark rounded-0 h-100 shadow-sm">
                        <div class="card-header bg-dark text-white rounded-0 fw-bold text-uppercase">
                            <i class="bi bi-hdd-rack me-2"></i>Rendimiento por Máquina
                        </div>
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered border-dark m-0 table-hover">
                                <thead class="bg-light text-uppercase small">
                                    <tr>
                                        <th>MÁQUINA</th>
                                        <th class="text-end">VTAS</th>
                                        <th class="text-end">TOTAL</th>
                                        <th class="text-end">GANANCIA</th>
                                    </tr>
                                </thead>
                                <tbody>
                                @foreach (var m in (Datos.Detalle ?? new List<DetalleVentaDto>()).GroupBy(x =>
                              x.Maquina).Select(g => new
                              {
                                  Nombre = g.Key,
                                  Count = g.Count(),
                                  Total = g.Sum(x => x.Monto),
                                  Ganancia = g.Sum(x => x.Ganancia)
                              }).OrderByDescending(x => x.Total))
                                {
                                            <tr>
                                                <td class="small fw-bold">@m.Nombre</td>
                                                <td class="text-end font-monospace">@m.Count</td>
                                                <td class="text-end font-monospace">$@m.Total.ToString("N0")</td>
                                                <td class="text-end font-monospace text-success">$@m.Ganancia.ToString("N0")</td>
                                            </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- TOP PRODUCTOS -->
        <div class="col-md-6">
                    <div class="card border-2 border-dark rounded-0 h-100 shadow-sm">
                        <div class="card-header bg-dark text-white rounded-0 fw-bold text-uppercase">
                            <i class="bi bi-star-fill me-2"></i>Top Productos
                        </div>
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered border-dark m-0 table-hover">
                                <thead class="bg-light text-uppercase small">
                                    <tr>
                                        <th>PRODUCTO</th>
                                        <th class="text-end">CANT</th>
                                        <th class="text-end">TOTAL</th>
                                    </tr>
                                </thead>
                                <tbody>
                                @foreach (var p in (Datos.Detalle ?? new List<DetalleVentaDto>()).GroupBy(x =>
                              x.Producto).Select(g => new
                              {
                                  Nombre = g.Key,
                                  Count = g.Count(),
                                  Total = g.Sum(x => x.Monto)
                              }).OrderByDescending(x => x.Count).Take(10))
                                {
                                            <tr>
                                                <td class="small fw-bold text-uppercase">@p.Nombre</td>
                                                <td class="text-end font-monospace">@p.Count</td>
                                                <td class="text-end font-monospace">$@p.Total.ToString("N0")</td>
                                            </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
    }
</div>

<!-- MODAL INFORME FINANCIERO -->
@if (MostrarModalFinanciero && Financiero != null)
{
    <div class="modal show d-block" style="background: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 bg-transparent shadow-none">
                <VmCard Header="ESTADO DE RESULTADOS" HeaderVariant="dark">
                    <div style="font-family:var(--font-sans);">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="fw-bold">Ingresos por Ventas:</span>
                            <span class="font-monospace text-dark">$@Financiero.VentasTotales.ToString("N0")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3">
                            <span class="fw-bold text-muted">(-) Costo de Ventas (COGS):</span>
                            <span class="font-monospace" style="color:var(--signal-danger);">-$@Financiero.CostoVentas.ToString("N0")</span>
                        </div>

                        <div class="border-top border-dark my-2"></div>

                        <div class="d-flex justify-content-between mb-3 p-2 border border-secondary" style="background:var(--paper-0);">
                            <span class="fw-bold">MARGEN BRUTO:</span>
                            <span class="font-monospace fw-bold" style="color:var(--signal-success);">$@Financiero.MargenBruto.ToString("N0")
                                (@Financiero.MargenPorcentaje.ToString("F1")%)</span>
                        </div>

                        <div class="d-flex justify-content-between mb-3">
                            <span class="fw-bold text-muted">(-) Gastos Operativos (Caja):</span>
                            <span class="font-monospace" style="color:var(--signal-danger);">-$@Financiero.GastosOperativos.ToString("N0")</span>
                        </div>

                        <div class="border-top border-3 border-dark my-2"></div>

                        <div class="d-flex justify-content-between mt-3 p-3 border border-dark" style="background:var(--signal-success);color:var(--paper-0);">
                            <h4 class="m-0 fw-bold text-uppercase">UTILIDAD NETA:</h4>
                            <h4 class="m-0 font-monospace fw-bold">$@Financiero.UtilidadNeta.ToString("N0")</h4>
                        </div>

                        <div style="display:flex;justify-content:flex-end;gap:0.5rem;margin-top:1rem;">
                            <VmButton Variant="success" OnClick="CerrarModalFinanciero">CERRAR</VmButton>
                        </div>
                    </div>
                </VmCard>
            </div>
        </div>
    </div>
}

<!-- MODAL FANTASMAS -->
@if (MostrarModalFantasmas && Datos?.Fantasmas != null)
{
    <div class="modal show d-block" style="background: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 bg-transparent shadow-none">
                <VmCard Header="DIFERENCIAS TRANSBANK" HeaderVariant="danger" BodyStyle="padding:0;">
                    <div class="alert alert-warning rounded-0 m-0 border-0 border-bottom border-dark" style="padding:1rem;">
                        <small class="fw-bold">
                            <i class="bi bi-info-circle-fill me-1"></i> Estos montos fueron cobrados en Transbank pero NO tienen una venta de máquina asociada. Verifica inventario.
                        </small>
                    </div>
                    <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                        <table class="table table-striped table-hover m-0">
                            <thead class="bg-light sticky-top">
                                <tr>
                                    <th>FECHA Y HORA</th>
                                    <th>MÁQUINA ASIGNADA</th>
                                    <th class="text-end">MONTO COBRADO</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Datos.Fantasmas.Any())
                                {
                                    @foreach (var f in Datos.Fantasmas.OrderByDescending(x => x.FechaRaw))
                                    {
                                        <tr>
                                            <td class="font-monospace">@f.FechaRaw.ToString("dd/MM/yyyy HH:mm:ss")</td>
                                            <td>@f.Maquina</td>
                                            <td class="text-end font-monospace fw-bold" style="color:var(--signal-danger);">$@f.Monto.ToString("N0")</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr><td colspan="3" class="text-center py-4">No hay diferencias registradas en este período.</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div style="display:flex;justify-content:flex-end;gap:0.5rem;padding:1rem;">
                        <VmButton Variant="dark" OnClick="CerrarModalFantasmas">CERRAR</VmButton>
                    </div>
                </VmCard>
            </div>
        </div>
    </div>
}

<!-- MODAL CONFIG SYNC -->
@if (MostrarModalSync)
{
    <div class="modal show d-block" style="background: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 bg-transparent shadow-none">
                <VmCard Header="SINCRONIZACIÓN OURVEND" HeaderVariant="dark">
                    <p class="mb-3 fw-bold small text-uppercase text-muted">Configuración de Importación</p>

                    <div class="alert alert-warning border-dark rounded-0 mb-3 small">
                        <i class="bi bi-info-circle-fill me-1"></i> Se descargarán las ventas desde el portal.
                        Puedes limitar hasta qué fecha/hora importar para evitar duplicados o datos parciales.
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold small">IMPORTAR VENTAS HASTA (FECHA LOCAL):</label>
                        <input type="datetime-local" @bind="FechaLimiteSync" class="form-control border-dark rounded-0 fw-bold font-monospace" />
                        <div class="form-text small fst-italic">Cualquier venta posterior a esta hora será ignorada.</div>
                    </div>

                    <div style="display:flex;justify-content:flex-end;gap:0.5rem;margin-top:1rem;">
                        <VmButton Variant="outline" OnClick="CerrarModalSync">CANCELAR</VmButton>
                        <VmButton Variant="dark" OnClick="EjecutarSync" Icon="bi-play-fill">EJECUTAR</VmButton>
                    </div>
                </VmCard>
            </div>
        </div>
    </div>
}

<!-- MODAL FILTRO PRODUCTOS -->
@if (MostrarModalFiltroProductos)
{
    <div class="modal show d-block" style="background: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 bg-transparent shadow-none">
                <VmCard Header="FILTRAR PRODUCTOS" HeaderVariant="dark">
                    <div class="alert alert-info rounded-0 small mb-3">
                        <i class="bi bi-info-circle-fill me-1"></i> Desmarca los productos que NO quieres ver en el reporte.
                    </div>

                    <div class="d-flex flex-wrap gap-2 mb-3">
                        <VmButton Variant="outline" Size="sm" OnClick="SeleccionarTodosProductos" Icon="bi-check-all">SELECCIONAR TODOS</VmButton>
                        <VmButton Variant="outline" Size="sm" OnClick="DeseleccionarTodosProductos" Icon="bi-x-lg">DESELECCIONAR TODOS</VmButton>
                        <VmButton Variant="outline" Size="sm" OnClick="ExcluirProductosVacios" Icon="bi-dash-circle">EXCLUIR VACÍOS</VmButton>
                    </div>

                    <div class="border border-dark p-2" style="max-height: 400px; overflow-y: auto;">
                        @if (ProductosUnicos != null && ProductosUnicos.Any())
                        {
                            @foreach (var producto in ProductosUnicos.OrderBy(p => p))
                            {
                                var isExcluded = ProductosExcluidos.Contains(producto);
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox"
                                           checked="@(!isExcluded)"
                                           @onchange="() => ToggleProducto(producto)"
                                           id="@($"chk_{producto.GetHashCode()}")">
                                    <label class="form-check-label small @(string.IsNullOrWhiteSpace(producto) ? "text-muted fst-italic" : "")"
                                           for="@($"chk_{producto.GetHashCode()}")">
                                        @(string.IsNullOrWhiteSpace(producto) ? "(Sin nombre / Vacío)" : producto)
                                    </label>
                                </div>
                            }
                        }
                        else
                        {
                            <p class="text-muted text-center py-4">Carga un reporte primero para ver los productos disponibles.</p>
                        }
                    </div>

                    <div style="display:flex;justify-content:space-between;align-items:center;gap:0.5rem;margin-top:1rem;">
                        <span class="text-muted small">
                            @ProductosExcluidos.Count producto(s) excluido(s)
                        </span>
                        <VmButton Variant="dark" OnClick="CerrarModalFiltroProductos">APLICAR</VmButton>
                    </div>
                </VmCard>
            </div>
        </div>
    </div>
}

<!-- MODAL ADMIN -->
@if (MostrarModalAdmin)
{
    <div class="modal show d-block" style="background: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 bg-transparent shadow-none">
                <VmCard Header="ZONA PELIGROSA" HeaderVariant="danger">
                    <div class="alert alert-danger border-danger rounded-0 mb-3 small fw-bold">
                        <i class="bi bi-exclamation-octagon-fill me-1"></i> ADVERTENCIA CRÍTICA<br/>
                        Esta acción ELIMINARÁ permanentemente las ventas en el rango seleccionado y RESTAURARÁ el stock de los productos afectados.<br/>
                        NO HAY DESHACER.
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold small" style="color:var(--signal-danger);">1. SELECCIONAR MÁQUINA OBJETIVO:</label>
                        <select class="form-select border-danger rounded-0 fw-bold" @bind="AdminMaquinaId">
                            <option value="0">-- SELECCIONAR --</option>
                            @if (ListaMaquinas != null)
                            {
                                @foreach (var m in ListaMaquinas)
                                {
                                    <option value="@m.Id">@m.Nombre.ToUpper()</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <label class="form-label fw-bold small" style="color:var(--signal-danger);">2. DESDE:</label>
                            <input type="datetime-local" @bind="AdminFechaInicio" class="form-control border-danger rounded-0 fw-bold" />
                        </div>
                        <div class="col-6">
                            <label class="form-label fw-bold small" style="color:var(--signal-danger);">3. HASTA:</label>
                            <input type="datetime-local" @bind="AdminFechaFin" class="form-control border-danger rounded-0 fw-bold" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold small" style="color:var(--signal-danger);">4. CONFIRMACIÓN:</label>
                        <input type="text" class="form-control border-danger rounded-0" placeholder="Escribe 'BORRAR' para confirmar" @bind="AdminConfirmacion" />
                    </div>

                    <div style="display:flex;justify-content:flex-end;gap:0.5rem;margin-top:1rem;">
                        <VmButton Variant="outline" OnClick="CerrarModalAdmin">CANCELAR</VmButton>
                        <VmButton Variant="danger" OnClick="EjecutarBorradoAdmin"
                                  Disabled='@(AdminMaquinaId == 0 || AdminConfirmacion != "BORRAR" || ProcesandoAdmin)'>
                            @if (ProcesandoAdmin)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                <span>PROCESANDO...</span>
                            }
                            else
                            {
                                <span><i class="bi bi-trash-fill me-1"></i> ELIMINAR Y RESTAURAR STOCK</span>
                            }
                        </VmButton>
                    </div>
                </VmCard>
            </div>
        </div>
    </div>
}


