@page "/reportes"
@using Microsoft.AspNetCore.WebUtilities

<div class="industrial-wrapper container-fluid px-4 mt-4">

    <!-- HEADER -->
    <div class="row align-items-center mb-4 border-bottom border-3 border-dark pb-3 industrial-page-header">
        <div class="col-12">
            <h2 class="m-0 fw-bold text-uppercase" style="letter-spacing: -1px;">INFORME DE VENTAS</h2>
            <small class="text-muted fw-bold">ANÁLISIS DE RENDIMIENTO Y TRANSACCIONES</small>
        </div>
    </div>

    <!-- CONTROL PANEL -->
    <div class="card border-2 border-dark rounded-0 shadow-sm mb-4">
        <div class="card-body bg-light p-3">
            <div class="row align-items-end g-3">
                <div class="col-md-3 col-12">
                    <label class="fw-bold small text-uppercase mb-1">TEMPLATE (OPCIONAL):</label>
                    <select class="form-select border-dark rounded-0 fw-bold py-2" @bind="TemplateSeleccionado">
                        <option value="0">-- NINGUNO --</option>
                        @if (ListaTemplates != null)
                        {
                            @foreach (var t in ListaTemplates)
                            {
                                <option value="@t.Id">@t.Nombre.ToUpper()</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3 col-12">
                    <label class="fw-bold small text-uppercase mb-1">UNIDAD:</label>
                    <select class="form-select border-dark rounded-0 fw-bold py-2" @bind="MaquinaSeleccionada">
                        <option value="0">:: TODAS LAS UNIDADES ::</option>
                        @if (ListaMaquinasFiltradas.Count == 0 && TemplateSeleccionado > 0)
                        {
                            <option value="0" disabled>SIN MÁQUINAS CONFIGURADAS</option>
                        }
                        else if (ListaMaquinasFiltradas.Count > 0)
                        {
                            @foreach (var m in ListaMaquinasFiltradas)
                            {
                                        <option value="@m.Id">@m.Nombre.ToUpper()</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-6 col-md-3">
                    <label class="fw-bold small text-uppercase mb-1">DESDE:</label>
                    <input type="date" @bind="FechaInicio" class="form-control border-dark rounded-0 fw-bold py-2" disabled="@(TemplateSeleccionado > 0)" />
                </div>
                <div class="col-6 col-md-3">
                    <label class="fw-bold small text-uppercase mb-1">HASTA:</label>
                    <input type="date" @bind="FechaFin" class="form-control border-dark rounded-0 fw-bold py-2" disabled="@(TemplateSeleccionado > 0)" />
                </div>
                <div class="col-12 col-md-7 d-flex gap-2 align-items-center">
                    <button class="btn btn-dark flex-grow-1 rounded-0 fw-bold py-2" @onclick="CargarReporte"
                        disabled="@Cargando">
                        @(Cargando ? "PROCESANDO..." : "EJECUTAR QUERY")
                    </button>
                    <!-- Financiero Button -->
                    <button class="btn btn-primary rounded-0 fw-bold border-dark py-2" @onclick="VerInformeFinanciero"
                        title="Ver Estado de Resultados">
                        <i class="bi bi-graph-up-arrow"></i>
                    </button>
                    <!-- Excel Button -->
                    <button class="btn btn-success rounded-0 fw-bold border-dark py-2" @onclick="ExportarExcel"
                        title="Exportar a Excel">
                        <i class="bi bi-file-earmark-excel"></i>
                    </button>
                    <!-- SYNC BUTTON (ORIGINAL) -->
                    <button class="btn btn-info rounded-0 fw-bold border-dark py-2" @onclick="AbrirModalSync"
                        disabled="@Sincronizando" title="Sincronizar con Ourvend (original)">
                        @if (Sincronizando)
                        {
                                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                        }
                        else
                        {
                                <i class="bi bi-cloud-arrow-down-fill text-white"></i>
                        }
                    </button>
                    
                    <!-- FILTER BUTTON -->
                    <button class="btn btn-secondary rounded-0 fw-bold border-dark py-2" @onclick="AbrirModalFiltroProductos"
                        title="Filtrar Productos">
                        <i class="bi bi-funnel-fill"></i>
                        @if (ProductosExcluidos.Any())
                        {
                            <span class="badge bg-danger ms-1">@ProductosExcluidos.Count</span>
                        }
                    </button>
                    <!-- ADMIN BUTTON -->
                    <AuthorizeView Roles="Admin">
                        <Authorized>
                            <button class="btn btn-dark rounded-0 fw-bold border-dark py-2" @onclick="AbrirModalAdmin"
                                title="Opciones Avanzadas">
                                <i class="bi bi-gear-fill text-danger"></i>
                            </button>
                        </Authorized>
                    </AuthorizeView>
                </div>
            </div>
            <div class="row mt-2">
                <div class="col-12 d-flex align-items-center">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="checkFantasmas" @bind="MostrarFantasmas">
                        <label class="form-check-label fw-bold small text-uppercase" for="checkFantasmas">
                            Incluir Ventas Fantasma (Diferencias Transbank)
                        </label>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(MensajeError))
    {
            <div class="alert alert-danger border-2 border-dark rounded-0 mb-4 shadow-sm fw-bold">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> ERROR DE SISTEMA: @MensajeError
            </div>
    }

    @if (Cargando)
    {
            <div class="text-center py-5 border border-dark border-2 bg-light">
                <div class="spinner-grow text-dark" role="status"></div>
                <p class="mt-2 fw-bold text-uppercase" style="letter-spacing: 2px;">Conectando Base de Datos...</p>
            </div>
    }
    else if (Datos != null)
    {
            <!-- KPI CARDS -->
            <div class="industrial-kpi-grid mb-4">
            @{
                // CALCULO EN CALIENTE BASADO EN DATOS FILTRADOS
                var datosParaKpi = DetalleFiltrado;
                
                var gananciaConfirmada = datosParaKpi
                    .Where(d => d.Estado == "Pagado")
                    .Sum(d => d.Ganancia);

                var ventasConfirmadas = datosParaKpi
                    .Where(d => d.Estado == "Pagado")
                    .Sum(d => d.Monto);
                    
                var montoPendiente = datosParaKpi
                    .Where(d => d.Estado != "Pagado")
                    .Sum(d => d.Monto);

                var montoPhantom = Datos.MontoPhantom; // Fantasmas no se filtran
            }

<!-- 1. UTILIDAD REAL (SOLO CONFIRMADO) -->
                <div class="industrial-card p-3 text-white" style="background: linear-gradient(45deg, #0d6efd, #0a58ca);">
                    <div class="fw-bold text-uppercase small" style="letter-spacing: 1px; opacity: 0.9;">Utilidad (Real / Pagada)</div>
                    <h3 class="fw-bold mt-2 text-white" style="letter-spacing: -1px;">
                        $@gananciaConfirmada.ToString("N0")
                    </h3>
                    <div class="mt-2 border-top pt-2 d-flex justify-content-between align-items-center"
                         style="opacity: 0.9; border-color: rgba(255,255,255,0.3);">
                        <small class="fw-bold text-uppercase" style="font-size: 0.7rem;">Margen Neto Real</small>
                        @if (ventasConfirmadas > 0)
                        {
                            <span class="industrial-badge industrial-badge--light" style="color: #0d6efd;">
                                @((gananciaConfirmada / ventasConfirmadas * 100).ToString("F1"))%
                            </span>
                        }
                        else
                        {
                            <span class="industrial-badge industrial-badge--light" style="color: var(--industrial-gray-500);">0.0%</span>
                        }
                    </div>
                </div>

<!-- 2. VENTAS CONFIRMADAS (SOLO PAGADO) -->
                <div class="industrial-card p-3 text-white" style="background-color: #198754;">
                    <div class="fw-bold text-uppercase small" style="letter-spacing: 1px; opacity: 0.9;">Ventas Confirmadas</div>
                    <h3 class="fw-bold mt-2 text-white" style="letter-spacing: -1px;">
                        $@ventasConfirmadas.ToString("N0")
                    </h3>
                    <div class="mt-2 border-top pt-2" style="opacity: 0.9; border-color: rgba(255,255,255,0.3);">
                        <small class="text-white fw-bold text-uppercase" style="font-size: 0.7rem;">
                            @datosParaKpi.Count(x => x.Estado == "Pagado") Transacciones
                        </small>
                    </div>
                </div>

<!-- 3. LA DIFERENCIA (FANTASMA) -->
                <div role="button" @onclick="VerFantasmas" class="industrial-card p-3 text-white" style="background-color: #e6007e; cursor: pointer;">
                    <div class="fw-bold text-uppercase small" style="letter-spacing: 1px; opacity: 0.9;">Diferencias Transbank</div>
                    <h3 class="fw-bold mt-2 text-white" style="letter-spacing: -1px;">
                        $@montoPhantom.ToString("N0")
                    </h3>
                    <div class="mt-2 border-top pt-2" style="opacity: 0.9; border-color: rgba(255,255,255,0.3);">
                        @if (montoPhantom > 0)
                        {
                            <small class="text-white fw-bold text-uppercase" style="font-size: 0.7rem;">Requiere Revisión (Click para ver)</small>
                        }
                        else
                        {
                            <small class="text-white fw-bold text-uppercase" style="font-size: 0.7rem;">Sin Errores</small>
                        }
                    </div>
                </div>

<!-- 4. PENDIENTE -->
                <div class="industrial-card p-3" style="background-color: #ffc107; color: var(--industrial-black);">
                    <div class="text-dark fw-bold text-uppercase small" style="letter-spacing: 1px; opacity: 0.8;">Pendiente / Cash</div>
                    <h3 class="fw-bold mt-2 text-dark" style="letter-spacing: -1px;">
                        $@montoPendiente.ToString("N0")
                    </h3>
                    <div class="mt-2 border-top pt-2" style="opacity: 0.8; border-color: rgba(0,0,0,0.2);">
                        <small class="text-dark fw-bold text-uppercase" style="font-size: 0.7rem;">Por Confirmar</small>
                    </div>
                </div>
            </div>


            <!-- MAIN DATA TABLE -->
            <div class="card border-2 border-dark rounded-0 shadow-sm mb-4">
                <div class="card-header bg-dark text-white rounded-0 fw-bold border-bottom border-dark text-uppercase d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-table me-2"></i>Detalle de Operaciones (@DetalleFiltrado.Count)</span>
                    <input type="text" @bind="FiltroProducto" @bind:event="oninput" 
                        class="form-control form-control-sm border-0 bg-secondary text-white rounded-0" 
                        style="max-width: 250px; placeholder: #aaa;" 
                        placeholder="🔍 Filtrar producto..." />
                </div>
                <div class="table-responsive" style="max-height: 550px; overflow-y: auto;">
                    <table class="industrial-table table-hover table-bordered border-dark m-0" style="min-width: 600px;">
                        <thead class="bg-secondary text-white text-uppercase small">
                            <tr>
                                <th role="button" class="industrial-sortable-header" @onclick='() => OrdenarPor("Fecha")'>
                                    FECHA LOCAL @RenderIcono("Fecha")
                                </th>
                                <th role="button" class="industrial-sortable-header" @onclick='() => OrdenarPor("Maquina")'>
                                    UNIDAD @RenderIcono("Maquina")
                                </th>
                                <th role="button" class="industrial-sortable-header text-center" @onclick='() => OrdenarPor("Slot")'>
                                    SLOT @RenderIcono("Slot")
                                </th>
                                <th>PRODUCTO</th>
                                <th role="button" class="industrial-sortable-header text-end" @onclick='() => OrdenarPor("Monto")'>
                                    MONTO @RenderIcono("Monto")
                                </th>
                                <th class="text-end">GANANCIA</th>
                                <th role="button" class="industrial-sortable-header text-center" @onclick='() => OrdenarPor("Estado")'>
                                    ESTADO @RenderIcono("Estado")
                                </th>
                            </tr>
                        </thead>
                        <tbody class="bg-white">
                        @if (DetalleFiltrado.Count > 0)
                        {
                                    <Virtualize Items="@DetalleFiltrado" Context="v" SpacerElement="tr" OverscanCount="20">
                                        <tr>
                                            <td class="font-monospace small">@v.FechaRaw.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td class="fw-bold small font-monospace">@ExtractMachineCode(v.Maquina)</td>
                                            <td class="text-center font-monospace small">@v.Slot</td>
                                            <td class="fw-bold small text-uppercase">@v.Producto</td>
                                            <td class="text-end font-monospace">$@v.Monto.ToString("N0")</td>
                                            <td class="text-end font-monospace text-success">$@v.Ganancia.ToString("N0")</td>
                                            <td class="text-center">
                                        @if (v.Estado == "Pagado")
                                {
                                        <span class="badge bg-success rounded-0 border border-dark text-white">OK</span>
                                }
                                else
                                {
                                        <span class="badge bg-warning rounded-0 border border-dark text-dark">PEND</span>
                                }
                            </td>
                        </tr>
                    </Virtualize>
                        }
                        else
                        {
                                    <tr>
                                        <td colspan="7" class="text-center py-4 text-muted fw-bold fst-italic">NO SE ENCONTRARON
                                            REGISTROS EN ESTE RANGO.</td>
                                    </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- TABLAS AGRUPADAS -->
            <div class="row g-4 mb-4">
                <!-- POR MAQUINA -->
        <div class="col-md-6">
                    <div class="card border-2 border-dark rounded-0 h-100 shadow-sm">
                        <div class="card-header bg-dark text-white rounded-0 fw-bold text-uppercase">
                            <i class="bi bi-hdd-rack me-2"></i>Rendimiento por Máquina
                        </div>
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered border-dark m-0 table-hover">
                                <thead class="bg-light text-uppercase small">
                                    <tr>
                                        <th>MÁQUINA</th>
                                        <th class="text-end">VTAS</th>
                                        <th class="text-end">TOTAL</th>
                                        <th class="text-end">GANANCIA</th>
                                    </tr>
                                </thead>
                                <tbody>
                                @foreach (var m in (Datos.Detalle ?? new List<DetalleVentaDto>()).GroupBy(x =>
                              x.Maquina).Select(g => new
                              {
                                  Nombre = g.Key,
                                  Count = g.Count(),
                                  Total = g.Sum(x => x.Monto),
                                  Ganancia = g.Sum(x => x.Ganancia)
                              }).OrderByDescending(x => x.Total))
                                {
                                            <tr>
                                                <td class="small fw-bold">@m.Nombre</td>
                                                <td class="text-end font-monospace">@m.Count</td>
                                                <td class="text-end font-monospace">$@m.Total.ToString("N0")</td>
                                                <td class="text-end font-monospace text-success">$@m.Ganancia.ToString("N0")</td>
                                            </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- TOP PRODUCTOS -->
        <div class="col-md-6">
                    <div class="card border-2 border-dark rounded-0 h-100 shadow-sm">
                        <div class="card-header bg-dark text-white rounded-0 fw-bold text-uppercase">
                            <i class="bi bi-star-fill me-2"></i>Top Productos
                        </div>
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered border-dark m-0 table-hover">
                                <thead class="bg-light text-uppercase small">
                                    <tr>
                                        <th>PRODUCTO</th>
                                        <th class="text-end">CANT</th>
                                        <th class="text-end">TOTAL</th>
                                    </tr>
                                </thead>
                                <tbody>
                                @foreach (var p in (Datos.Detalle ?? new List<DetalleVentaDto>()).GroupBy(x =>
                              x.Producto).Select(g => new
                              {
                                  Nombre = g.Key,
                                  Count = g.Count(),
                                  Total = g.Sum(x => x.Monto)
                              }).OrderByDescending(x => x.Count).Take(10))
                                {
                                            <tr>
                                                <td class="small fw-bold text-uppercase">@p.Nombre</td>
                                                <td class="text-end font-monospace">@p.Count</td>
                                                <td class="text-end font-monospace">$@p.Total.ToString("N0")</td>
                                            </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
    }
</div>

<!-- MODAL INFORME FINANCIERO -->
@if (MostrarModalFinanciero && Financiero != null)
{
        <div class="modal show d-block" style="background: rgba(0,0,0,0.5);" tabindex="-1">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content rounded-0 border-2 border-dark shadow-lg">
                    <div class="modal-header bg-dark text-white rounded-0">
                        <h5 class="modal-title fw-bold text-uppercase">💰 Estado de Resultados</h5>
                        <button type="button" class="btn-close btn-close-white" @onclick="CerrarModalFinanciero"></button>
                    </div>
                    <div class="modal-body p-4" style="background-color: #f8f9fa;">

                        <div class="d-flex justify-content-between mb-2">
                            <span class="fw-bold">Ingresos por Ventas:</span>
                            <span class="font-monospace text-dark">$@Financiero.VentasTotales.ToString("N0")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3">
                            <span class="fw-bold text-muted">(-) Costo de Ventas (COGS):</span>
                            <span class="font-monospace text-danger">-$@Financiero.CostoVentas.ToString("N0")</span>
                        </div>

                        <div class="border-top border-dark my-2"></div>

                        <div class="d-flex justify-content-between mb-3 bg-white p-2 border border-secondary">
                            <span class="fw-bold">MARGEN BRUTO:</span>
                            <span class="font-monospace fw-bold text-primary">$@Financiero.MargenBruto.ToString("N0")
                                (@Financiero.MargenPorcentaje.ToString("F1")%)</span>
                        </div>

                        <div class="d-flex justify-content-between mb-3">
                            <span class="fw-bold text-muted">(-) Gastos Operativos (Caja):</span>
                            <span class="font-monospace text-danger">-$@Financiero.GastosOperativos.ToString("N0")</span>
                        </div>

                        <div class="border-top border-3 border-dark my-2"></div>

                        <div class="d-flex justify-content-between mt-3 p-3 bg-success text-white border border-dark">
                            <h4 class="m-0 fw-bold text-uppercase">UTILIDAD NETA:</h4>
                            <h4 class="m-0 font-monospace fw-bold">$@Financiero.UtilidadNeta.ToString("N0")</h4>
                        </div>

                    </div>
                    <div class="modal-footer bg-light rounded-0">
                        <button type="button" class="btn btn-dark rounded-0 fw-bold"
                    @onclick="CerrarModalFinanciero">CERRAR</button>
                    </div>
                </div>
            </div>
        </div>
}

<!-- MODAL FANTASMAS -->
@if (MostrarModalFantasmas && Datos?.Fantasmas != null)
{
    <div class="modal show d-block" style="background: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content rounded-0 border-2 border-dark shadow-lg">
                <div class="modal-header bg-danger text-white rounded-0">
                    <h5 class="modal-title fw-bold text-uppercase">⚠️ Diferencias Transbank (Ventas Fantasma)</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarModalFantasmas"></button>
                </div>
                <div class="modal-body p-0">
                    <div class="alert alert-warning rounded-0 m-0 border-0 border-bottom border-dark">
                        <small class="fw-bold">
                            <i class="bi bi-info-circle-fill me-1"></i> Estos montos fueron cobrados en Transbank pero NO tienen una venta de máquina asociada. Verifica inventario.
                        </small>
                    </div>
                    <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                        <table class="table table-striped table-hover m-0">
                            <thead class="bg-light sticky-top">
                                <tr>
                                    <th>FECHA Y HORA</th>
                                    <th>MÁQUINA ASIGNADA</th>
                                    <th class="text-end">MONTO COBRADO</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Datos.Fantasmas.Any())
                                {
                                    @foreach (var f in Datos.Fantasmas.OrderByDescending(x => x.FechaRaw))
                                    {
                                        <tr>
                                            <td class="font-monospace">@f.FechaRaw.ToString("dd/MM/yyyy HH:mm:ss")</td>
                                            <td>@f.Maquina</td>
                                            <td class="text-end font-monospace fw-bold text-danger">$@f.Monto.ToString("N0")</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr><td colspan="3" class="text-center py-4">No hay diferencias registradas en este período.</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="modal-footer bg-light rounded-0">
                    <button type="button" class="btn btn-dark rounded-0 fw-bold" @onclick="CerrarModalFantasmas">CERRAR</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- MODAL CONFIG SYNC -->
@if (MostrarModalSync)
{
    <div class="modal show d-block" style="background: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-0 border-2 border-dark shadow-lg">
                <div class="modal-header bg-info text-dark rounded-0 border-bottom border-dark">
                    <h5 class="modal-title fw-bold text-uppercase"><i class="bi bi-cloud-download-fill me-2"></i>Sincronización Ourvend</h5>
                    <button type="button" class="btn-close" @onclick="CerrarModalSync"></button>
                </div>
                <div class="modal-body p-4" style="background-color: #f8f9fa;">
                    <p class="mb-3 fw-bold small text-uppercase text-muted">Configuración de Importación</p>
                    
                    <div class="alert alert-warning border-dark rounded-0 mb-3 small">
                        <i class="bi bi-info-circle-fill me-1"></i> Se descargarán las ventas desde el portal.
                        Puedes limitar hasta qué fecha/hora importar para evitar duplicados o datos parciales.
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold small">IMPORTAR VENTAS HASTA (FECHA LOCAL):</label>
                        <input type="datetime-local" @bind="FechaLimiteSync" class="form-control border-dark rounded-0 fw-bold font-monospace" />
                        <div class="form-text small fst-italic">Cualquier venta posterior a esta hora será ignorada.</div>
                    </div>
                </div>
                <div class="modal-footer bg-light rounded-0 border-top border-dark">
                    <button type="button" class="btn btn-outline-dark rounded-0 fw-bold" @onclick="CerrarModalSync">CANCELAR</button>
                    <button type="button" class="btn btn-info rounded-0 fw-bold border-dark" @onclick="EjecutarSync">
                        <i class="bi bi-play-fill me-1"></i> EJECUTAR
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- MODAL FILTRO PRODUCTOS -->
@if (MostrarModalFiltroProductos)
{
    <div class="modal show d-block" style="background: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content rounded-0 border-2 border-dark shadow-lg">
                <div class="modal-header bg-secondary text-white rounded-0 border-bottom border-dark">
                    <h5 class="modal-title fw-bold text-uppercase"><i class="bi bi-funnel-fill me-2"></i>Filtrar Productos</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarModalFiltroProductos"></button>
                </div>
                <div class="modal-body p-3">
                    <div class="alert alert-info rounded-0 small mb-3">
                        <i class="bi bi-info-circle-fill me-1"></i> Desmarca los productos que NO quieres ver en el reporte.
                    </div>
                    
                    <div class="d-flex gap-2 mb-3">
                        <button class="btn btn-sm btn-outline-success rounded-0" @onclick="SeleccionarTodosProductos">
                            <i class="bi bi-check-all"></i> Seleccionar Todos
                        </button>
                        <button class="btn btn-sm btn-outline-danger rounded-0" @onclick="DeseleccionarTodosProductos">
                            <i class="bi bi-x-lg"></i> Deseleccionar Todos
                        </button>
                        <button class="btn btn-sm btn-outline-warning rounded-0" @onclick="ExcluirProductosVacios">
                            <i class="bi bi-dash-circle"></i> Excluir Vacíos
                        </button>
                    </div>

                    <div class="border border-dark p-2" style="max-height: 400px; overflow-y: auto;">
                        @if (ProductosUnicos != null && ProductosUnicos.Any())
                        {
                            @foreach (var producto in ProductosUnicos.OrderBy(p => p))
                            {
                                var isExcluded = ProductosExcluidos.Contains(producto);
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" 
                                        checked="@(!isExcluded)"
                                        @onchange="() => ToggleProducto(producto)" 
                                        id="@($"chk_{producto.GetHashCode()}")">
                                    <label class="form-check-label small @(string.IsNullOrWhiteSpace(producto) ? "text-muted fst-italic" : "")" 
                                        for="@($"chk_{producto.GetHashCode()}")">
                                        @(string.IsNullOrWhiteSpace(producto) ? "(Sin nombre / Vacío)" : producto)
                                    </label>
                                </div>
                            }
                        }
                        else
                        {
                            <p class="text-muted text-center py-4">Carga un reporte primero para ver los productos disponibles.</p>
                        }
                    </div>
                </div>
                <div class="modal-footer bg-light rounded-0 border-top border-dark">
                    <span class="text-muted small me-auto">
                        @ProductosExcluidos.Count producto(s) excluido(s)
                    </span>
                    <button type="button" class="btn btn-dark rounded-0 fw-bold" @onclick="CerrarModalFiltroProductos">APLICAR</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- MODAL ADMIN -->
@if (MostrarModalAdmin)
{
    <div class="modal show d-block" style="background: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-0 border-2 border-danger shadow-lg">
                <div class="modal-header bg-danger text-white rounded-0 border-bottom border-dark">
                    <h5 class="modal-title fw-bold text-uppercase"><i class="bi bi-radioactive me-2"></i>ZONA PELIGROSA</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarModalAdmin"></button>
                </div>
                <div class="modal-body p-4" style="background-color: #fff0f0;">
                    <div class="alert alert-danger border-danger rounded-0 mb-3 small fw-bold">
                        <i class="bi bi-exclamation-octagon-fill me-1"></i> ADVERTENCIA CRÍTICA<br/>
                        Esta acción ELIMINARÁ permanentemente las ventas en el rango seleccionado y RESTAURARÁ el stock de los productos afectados.<br/>
                        NO HAY DESHACER.
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold small text-danger">1. SELECCIONAR MÁQUINA OBJETIVO:</label>
                        <select class="form-select border-danger rounded-0 fw-bold" @bind="AdminMaquinaId">
                            <option value="0">-- SELECCIONAR --</option>
                            @if (ListaMaquinas != null)
                            {
                                @foreach (var m in ListaMaquinas)
                                {
                                    <option value="@m.Id">@m.Nombre.ToUpper()</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <label class="form-label fw-bold small text-danger">2. DESDE:</label>
                            <input type="datetime-local" @bind="AdminFechaInicio" class="form-control border-danger rounded-0 fw-bold" />
                        </div>
                        <div class="col-6">
                            <label class="form-label fw-bold small text-danger">3. HASTA:</label>
                            <input type="datetime-local" @bind="AdminFechaFin" class="form-control border-danger rounded-0 fw-bold" />
                        </div>
                    </div>

                    <div class="mb-3">
                         <label class="form-label fw-bold small text-danger">4. CONFIRMACIÓN:</label>
                         <input type="text" class="form-control border-danger rounded-0" placeholder="Escribe 'BORRAR' para confirmar" @bind="AdminConfirmacion" />
                    </div>

                </div>
                <div class="modal-footer bg-light rounded-0 border-top border-danger">
                    <button type="button" class="btn btn-outline-dark rounded-0 fw-bold" @onclick="CerrarModalAdmin">CANCELAR</button>
                    <button type="button" class="btn btn-danger rounded-0 fw-bold border-dark" 
                        disabled="@(AdminMaquinaId == 0 || AdminConfirmacion != "BORRAR" || ProcesandoAdmin)"
                        @onclick="EjecutarBorradoAdmin">
                        @if (ProcesandoAdmin)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span> <span>PROCESANDO...</span>
                        }
                        else
                        {
                            <span><i class="bi bi-trash-fill me-1"></i> ELIMINAR Y RESTAURAR STOCK</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}


