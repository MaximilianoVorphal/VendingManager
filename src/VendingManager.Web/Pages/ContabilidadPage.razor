@page "/contabilidad"
@using VendingManager.Shared.DTOs
@using VendingManager.Shared.Enums
@using VendingManager.Web.Pages.Contabilidad.State
@using VendingManager.Web.Components.Contabilidad
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>CONCILIACIÓN</PageTitle>

<div class="industrial-wrapper container-fluid px-4 mt-4">

    @* ====== HEADER ====== *@
    <div class="row align-items-center mb-4 border-bottom border-3 border-dark pb-3">
        <div class="col-12 d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <h2 class="m-0 fw-bold text-uppercase" style="letter-spacing: -1px;">CONCILIACIÓN DE FONDOS</h2>
                <small class="text-muted fw-bold">JUSTIFICACIÓN DE GASTOS POR PERÍODO</small>
            </div>
            @if (State.PeriodoActivo != null)
            {
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <span class="badge bg-dark rounded-0 fw-bold text-uppercase">
                        <i class="bi bi-calendar-range"></i> @State.PeriodoActivo.Name.ToUpper()
                    </span>
                    <span class="badge @(State.PeriodoActivo.Estado == AccountingPeriodEstado.Abierto ? "bg-success" : "bg-secondary") rounded-0 fw-bold text-uppercase">
                        @(State.PeriodoActivo.Estado == AccountingPeriodEstado.Abierto ? "ABIERTO" : "CERRADO")
                    </span>
                </div>
            }
        </div>
    </div>

    @* ====== ERROR / SUCCESS ALERTS ====== *@
    @if (!string.IsNullOrEmpty(Error))
    {
        <div class="alert alert-danger border-dark rounded-0 fw-bold mb-4 shadow-sm">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @Error
        </div>
    }

    @if (!string.IsNullOrEmpty(SuccessMessage))
    {
        <div class="alert alert-success border-dark rounded-0 fw-bold mb-4 shadow-sm">
            <i class="bi bi-check-circle-fill me-2"></i> @SuccessMessage
        </div>
    }

    @if (CargandoInicial)
    {
        <div class="row">
            <div class="col-12 text-center p-5">
                <div class="spinner-border text-dark mb-3" role="status"></div>
                <p class="fw-bold text-muted">CARGANDO PERÍODOS...</p>
            </div>
        </div>
    }
    else
    {
        @* ====== PERIOD SELECTOR + QUICK ACTIONS ====== *@
        <div class="row g-4 mb-4">
            @* Left: Period selector *@
            <div class="col-lg-4">
                <div class="card border-2 border-dark rounded-0 shadow">
                    <div class="card-header bg-dark text-white rounded-0 fw-bold py-2">
                        <i class="bi bi-calendar3 me-2"></i>PERÍODOS
                    </div>
                    <div class="card-body bg-light p-3">
                        @* Date range filter *@
                        <div class="row g-2 mb-3">
                            <div class="col-6">
                                <label class="fw-bold small text-uppercase mb-1 text-muted">DESDE</label>
                                <input type="date" class="form-control form-control-sm border-dark rounded-0"
                                       @bind="FiltroDesde" />
                            </div>
                            <div class="col-6">
                                <label class="fw-bold small text-uppercase mb-1 text-muted">HASTA</label>
                                <input type="date" class="form-control form-control-sm border-dark rounded-0"
                                       @bind="FiltroHasta" />
                            </div>
                            <div class="col-12 mt-2">
                                <button class="btn btn-sm btn-outline-dark rounded-0 fw-bold w-100"
                                        @onclick="FiltrarPeriodos">
                                    <i class="bi bi-search me-1"></i>FILTRAR
                                </button>
                            </div>
                        </div>

                        @* Period list *@
                        @if (State.Periodos.Any())
                        {
                            <div class="list-group" style="max-height: 300px; overflow-y: auto;">
                                @foreach (var p in State.Periodos)
                                {
                                    <button class="list-group-item list-group-item-action border-dark rounded-0 fw-bold py-2 @(State.PeriodoActivo?.Id == p.Id ? "active bg-dark text-white" : "")"
                                            @onclick="() => SeleccionarPeriodo(p.Id)">
                                        <div class="d-flex w-100 justify-content-between align-items-center">
                                            <span class="small">@p.Name</span>
                                            <span class="badge @(p.Estado == AccountingPeriodEstado.Abierto ? "bg-success" : "bg-secondary") rounded-0">
                                                @(p.Estado == AccountingPeriodEstado.Abierto ? "ABIERTO" : "CERRADO")
                                            </span>
                                        </div>
                                        <small class="d-block text-muted" style="font-size: 0.7rem;">
                                            @p.FechaInicio.ToString("dd/MM/yyyy") - @p.FechaFin.ToString("dd/MM/yyyy")
                                        </small>
                                    </button>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="text-center text-muted p-3">
                                <i class="bi bi-inbox display-6 mb-2 d-block"></i>
                                <p class="fw-bold small">No hay períodos para el filtro seleccionado.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>

            @* Right: Quick actions + New period *@
            <div class="col-lg-4">
                <div class="card border-2 border-dark rounded-0 shadow">
                    <div class="card-header bg-dark text-white rounded-0 fw-bold py-2">
                        <i class="bi bi-lightning-charge me-2"></i>ACCIONES RÁPIDAS
                    </div>
                    <div class="card-body bg-light p-3">
                        <div class="d-grid gap-2">
                            @if (!MostrarNuevoPeriodo)
                            {
                                <button class="btn btn-outline-dark rounded-0 fw-bold text-start"
                                        @onclick="() => MostrarNuevoPeriodo = true">
                                    <i class="bi bi-plus-circle me-2"></i>+ NUEVO PERÍODO
                                </button>
                            }
                            else
                            {
                                @* New period form inline *@
                                <div class="border border-dark p-2 rounded-0 bg-white mb-2">
                                    <div class="mb-2">
                                        <label class="fw-bold small text-uppercase mb-1 text-muted">NOMBRE</label>
                                        <input type="text" class="form-control form-control-sm border-dark rounded-0"
                                               @bind="NuevoPeriodoName" placeholder="Ej: Junio 2026" />
                                    </div>
                                    <div class="row g-1 mb-2">
                                        <div class="col-6">
                                            <label class="fw-bold small text-uppercase mb-1 text-muted">INICIO</label>
                                            <input type="date" class="form-control form-control-sm border-dark rounded-0"
                                                   @bind="NuevoPeriodoInicio" />
                                        </div>
                                        <div class="col-6">
                                            <label class="fw-bold small text-uppercase mb-1 text-muted">FIN</label>
                                            <input type="date" class="form-control form-control-sm border-dark rounded-0"
                                                   @bind="NuevoPeriodoFin" />
                                        </div>
                                    </div>
                                    <div class="d-flex gap-1">
                                        <button class="btn btn-sm btn-dark rounded-0 fw-bold flex-grow-1"
                                                @onclick="CrearPeriodo" disabled="@CreandoPeriodo">
                                            @if (CreandoPeriodo)
                                            {
                                                <span class="spinner-border spinner-border-sm me-1"></span>
                                            }
                                            else
                                            {
                                                <i class="bi bi-check me-1"></i>
                                            }
                                            GUARDAR
                                        </button>
                                        <button class="btn btn-sm btn-outline-secondary rounded-0 fw-bold"
                                                @onclick="() => MostrarNuevoPeriodo = false">
                                            CANCELAR
                                        </button>
                                    </div>
                                </div>
                            }

                            <button class="btn btn-outline-dark rounded-0 fw-bold text-start"
                                    @onclick="MostrarFormTransferencia" disabled="@(State.PeriodoActivo?.Estado != AccountingPeriodEstado.Abierto)">
                                <i class="bi bi-bank me-2"></i>+ NUEVA TRANSFERENCIA
                            </button>

                            <button class="btn btn-outline-dark rounded-0 fw-bold text-start"
                                    @onclick="MostrarFormCompra" disabled="@(State.PeriodoActivo?.Estado != AccountingPeriodEstado.Abierto || !State.Transferencias.Any())">
                                <i class="bi bi-cart4 me-2"></i>+ VINCULAR COMPRA
                            </button>

                            <button class="btn btn-outline-dark rounded-0 fw-bold text-start"
                                    @onclick="MostrarFormGasto" disabled="@(State.PeriodoActivo?.Estado != AccountingPeriodEstado.Abierto)">
                                <i class="bi bi-fuel-pump me-2"></i>+ VINCULAR GASTO
                            </button>

                            <hr class="my-2" />

                            <button class="btn btn-outline-primary rounded-0 fw-bold text-start"
                                    @onclick="NavegarACaja">
                                <i class="bi bi-box-arrow-up-right me-2"></i>IR A CAJA →
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            @* Rightmost: Reconciliation Panel (KPI summary) *@
            <div class="col-lg-4">
                <ReconciliationPanel State="@State" OnCerrar="CerrarPeriodo" />
            </div>
        </div>

        @* ====== FORMS (shown when action buttons are clicked) ====== *@
        @if (ShowTransferenciaForm && State.PeriodoActivoFull != null)
        {
            <div class="card border-2 border-dark rounded-0 shadow mb-4">
                <div class="card-header bg-dark text-white rounded-0 fw-bold d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-bank me-2"></i>REGISTRAR TRANSFERENCIA</span>
                    <button class="btn btn-sm btn-outline-light rounded-0 fw-bold"
                            @onclick="() => ShowTransferenciaForm = false">
                        <i class="bi bi-x"></i> CERRAR
                    </button>
                </div>
                <div class="card-body bg-light">
                    @{
                        // For period-based transfers, use the period's Trabajador
                        var trabajador = State.PeriodoActivoFull.Transferencias.FirstOrDefault()?.Trabajador
                                        ?? State.PeriodoActivo?.Trabajador
                                        ?? string.Empty;
                    }
                    <TransferenciaForm OnTransferenciaCreated="OnTransferenciaCreada"
                                       Trabajador="@trabajador"
                                       RendicionId="@(State.PeriodoActivoFull.Transferencias.FirstOrDefault()?.RendicionId ?? 0)"
                                       PeriodoId="@State.PeriodoActivo?.Id" />
                </div>
            </div>
        }

        @if (ShowCompraForm && State.PeriodoActivoFull != null)
        {
            <div class="card border-2 border-dark rounded-0 shadow mb-4">
                <div class="card-header bg-dark text-white rounded-0 fw-bold d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-cart4 me-2"></i>REGISTRAR COMPRA VINCULADA</span>
                    <button class="btn btn-sm btn-outline-light rounded-0 fw-bold"
                            @onclick="() => ShowCompraForm = false">
                        <i class="bi bi-x"></i> CERRAR
                    </button>
                </div>
                <div class="card-body bg-light">
                    @{
                        var compraTrabajador = State.PeriodoActivoFull.Transferencias.FirstOrDefault()?.Trabajador
                                               ?? State.PeriodoActivo?.Trabajador
                                               ?? string.Empty;
                    }
                    <CompraForm OnCompraCreated="OnCompraCreada"
                                Trabajador="@compraTrabajador"
                                Transferencias="@State.Transferencias"
                                RendicionId="@(State.PeriodoActivoFull.Transferencias.FirstOrDefault()?.RendicionId ?? 0)" />
                </div>
            </div>
        }

        @if (ShowGastoForm && State.PeriodoActivoFull != null)
        {
            <div class="card border-2 border-dark rounded-0 shadow mb-4">
                <div class="card-header bg-dark text-white rounded-0 fw-bold d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-fuel-pump me-2"></i>REGISTRAR GASTO</span>
                    <button class="btn btn-sm btn-outline-light rounded-0 fw-bold"
                            @onclick="() => ShowGastoForm = false">
                        <i class="bi bi-x"></i> CERRAR
                    </button>
                </div>
                <div class="card-body bg-light">
                    <GastoForm OnGastoCreated="OnGastoCreado"
                               RendicionId="@(State.PeriodoActivoFull.Transferencias.FirstOrDefault()?.RendicionId ?? 0)" />
                </div>
            </div>
        }

        @* ====== MAIN DATA SECTIONS ====== *@
        @if (State.PeriodoActivoFull != null)
        {
            @* ── Side-by-side comprobantes verification ── *@
            <ComprobantesPanel State="@State" OnUpdated="RecargarPeriodoActivo" />

            @* ── Saldo breakdown + Registrar Devolución ── *@
            <DevolucionPanel State="@State" OnUpdated="RecargarPeriodoActivo" />

            @* ── Detailed tables (read-only audit) ── *@
            <CuadrarView Transferencias="@State.Transferencias"
                         Compras="@State.Compras"
                         Gastos="@State.Gastos"
                         RendicionId="@(State.Transferencias.FirstOrDefault()?.RendicionId ?? 0)"
                         OnItemUpdated="RecargarPeriodoActivo"
                         OnAvanzar="CerrarPeriodo" />
        }
        else if (State.PeriodoActivo != null && State.PeriodoActivoFull == null)
        {
            <div class="row">
                <div class="col-12 text-center p-5">
                    <div class="spinner-border text-dark mb-3" role="status"></div>
                    <p class="fw-bold text-muted">CARGANDO DATOS DEL PERÍODO...</p>
                </div>
            </div>
        }
        else
        {
            <div class="row">
                <div class="col-12 text-center p-5">
                    <i class="bi bi-hand-index-thumb display-4 text-muted mb-3 d-block"></i>
                    <p class="fw-bold text-muted">Seleccioná un período contable de la lista para ver sus datos.</p>
                </div>
            </div>
        }
    }

</div>

@code {
    [SupplyParameterFromQuery(Name = "periodoId")]
    public int? QueryPeriodoId { get; set; }

    public ContabilidadPageState State { get; set; } = new();
    private bool CargandoInicial { get; set; } = true;
    private bool CreandoPeriodo { get; set; }
    private string? Error { get; set; }
    private string? SuccessMessage { get; set; }

    // Filter state
    private DateTime? FiltroDesde { get; set; }
    private DateTime? FiltroHasta { get; set; }

    // New period form
    private bool MostrarNuevoPeriodo { get; set; }
    private string NuevoPeriodoName { get; set; } = string.Empty;
    private DateTime NuevoPeriodoInicio { get; set; } = DateTime.Today;
    private DateTime NuevoPeriodoFin { get; set; } = DateTime.Today.AddMonths(1).AddDays(-1);

    // Form toggles
    private bool ShowTransferenciaForm { get; set; }
    private bool ShowCompraForm { get; set; }
    private bool ShowGastoForm { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (QueryPeriodoId.HasValue)
        {
            await CargarPeriodos();
            await SeleccionarPeriodo(QueryPeriodoId.Value);
        }
        else
        {
            await CargarPeriodos();
            CargandoInicial = false;
        }
    }

    private async Task CargarPeriodos()
    {
        try
        {
            Error = null;
            var url = "api/contabilidad/periodos";
            var queryParams = new List<string>();

            if (FiltroDesde.HasValue)
                queryParams.Add($"desde={FiltroDesde.Value:yyyy-MM-dd}");
            if (FiltroHasta.HasValue)
                queryParams.Add($"hasta={FiltroHasta.Value:yyyy-MM-dd}");

            if (queryParams.Any())
                url += "?" + string.Join("&", queryParams);

            State.Periodos = await Http.GetFromJsonAsync<List<AccountingPeriodDto>>(url) ?? new();
        }
        catch (Exception ex)
        {
            Error = $"Error al cargar períodos: {ex.Message}";
        }
    }

    private async Task FiltrarPeriodos()
    {
        CargandoInicial = true;
        await CargarPeriodos();
        CargandoInicial = false;
    }

    private void NavegarACaja()
    {
        Navigation.NavigateTo("/caja");
    }

    private async Task SeleccionarPeriodo(int periodoId, bool keepMessages = false)
    {
        try
        {
            Error = null;
            if (!keepMessages) SuccessMessage = null;
            if (!keepMessages)
            {
                ShowTransferenciaForm = false;
                ShowCompraForm = false;
                ShowGastoForm = false;
            }

            // Find the basic DTO
            State.PeriodoActivo = State.Periodos.FirstOrDefault(p => p.Id == periodoId);

            // Load full data
            var full = await Http.GetFromJsonAsync<AccountingPeriodFullDto>($"api/contabilidad/periodos/{periodoId}");
            if (full != null)
            {
                State.PeriodoActivoFull = full;
                State.PeriodoActivo = full; // override with full data
            }
        }
        catch (Exception ex)
        {
            Error = $"Error al cargar período: {ex.Message}";
        }
    }

    private async Task CrearPeriodo()
    {
        if (string.IsNullOrWhiteSpace(NuevoPeriodoName))
        {
            Error = "El nombre del período es obligatorio.";
            return;
        }

        try
        {
            CreandoPeriodo = true;
            Error = null;

            var request = new CreatePeriodoRequest
            {
                Name = NuevoPeriodoName,
                FechaInicio = NuevoPeriodoInicio,
                FechaFin = NuevoPeriodoFin
            };

            var response = await Http.PostAsJsonAsync("api/contabilidad/periodos", request);
            if (response.IsSuccessStatusCode)
            {
                var dto = await response.Content.ReadFromJsonAsync<AccountingPeriodDto>();
                SuccessMessage = $"Período \"{dto?.Name}\" creado exitosamente.";
                MostrarNuevoPeriodo = false;
                NuevoPeriodoName = string.Empty;
                NuevoPeriodoInicio = DateTime.Today;
                NuevoPeriodoFin = DateTime.Today.AddMonths(1).AddDays(-1);
                await CargarPeriodos();
                if (dto != null) await SeleccionarPeriodo(dto.Id);
            }
            else
            {
                Error = "Error al crear período: " + await response.Content.ReadAsStringAsync();
            }
        }
        catch (Exception ex)
        {
            Error = $"Error: {ex.Message}";
        }
        finally
        {
            CreandoPeriodo = false;
        }
    }

    private async Task CerrarPeriodo()
    {
        if (State.PeriodoActivo == null) return;

        try
        {
            Error = null;
            SuccessMessage = null;
            var response = await Http.PostAsync($"api/contabilidad/periodos/{State.PeriodoActivo.Id}/cerrar", null);
            if (response.IsSuccessStatusCode)
            {
                SuccessMessage = "Período cerrado exitosamente.";
                await CargarPeriodos();
                if (State.PeriodoActivo != null)
                    await SeleccionarPeriodo(State.PeriodoActivo.Id);
            }
            else
            {
                Error = "Error al cerrar período: " + await response.Content.ReadAsStringAsync();
            }
        }
        catch (Exception ex)
        {
            Error = $"Error: {ex.Message}";
        }
    }

    private async Task RecargarPeriodoActivo()
    {
        if (State.PeriodoActivo != null)
        {
            await SeleccionarPeriodo(State.PeriodoActivo.Id, keepMessages: true);
        }
    }

    private void MostrarFormTransferencia()
    {
        ShowTransferenciaForm = true;
        ShowCompraForm = false;
        ShowGastoForm = false;
    }

    private void MostrarFormCompra()
    {
        ShowCompraForm = true;
        ShowTransferenciaForm = false;
        ShowGastoForm = false;
    }

    private void MostrarFormGasto()
    {
        ShowGastoForm = true;
        ShowTransferenciaForm = false;
        ShowCompraForm = false;
    }

    private async Task OnTransferenciaCreada(TransferenciaDto t)
    {
        SuccessMessage = $"Transferencia ${t.Monto.ToString("N0")} registrada.";
        Error = null;
        // Stay on the form to allow multiple transfers per period (partial deliveries)
        await RecargarPeriodoActivo();
    }

    private async Task OnCompraCreada(CompraDto c)
    {
        SuccessMessage = $"Compra a {c.Proveedor} por ${c.MontoTotal.ToString("N0")} vinculada.";
        Error = null;
        ShowCompraForm = false;
        await RecargarPeriodoActivo();
    }

    private async Task OnGastoCreado(MovimientoCajaDto g)
    {
        SuccessMessage = $"Gasto {g.Categoria} por ${Math.Abs(g.Monto).ToString("N0")} vinculado.";
        Error = null;
        ShowGastoForm = false;
        await RecargarPeriodoActivo();
    }
}
