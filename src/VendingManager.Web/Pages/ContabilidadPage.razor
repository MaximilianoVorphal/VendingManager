@page "/contabilidad"
@using VendingManager.Shared.DTOs
@using VendingManager.Shared.Enums
@using VendingManager.Web.Pages.Contabilidad.State
@using VendingManager.Web.Components.Contabilidad
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>CONCILIACIÓN</PageTitle>

<div class="container-fluid px-4" style="height: 100%; display: flex; flex-direction: column; padding-top: 0.75rem;">

    @* ====== ERROR / SUCCESS ALERTS ====== *@
    @if (!string.IsNullOrEmpty(Error))
    {
        <div class="alert alert-danger border-dark rounded-0 fw-bold mb-3 shadow-sm">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @Error
        </div>
    }
    @if (!string.IsNullOrEmpty(SuccessMessage))
    {
        <div class="alert alert-success border-dark rounded-0 fw-bold mb-3 shadow-sm">
            <i class="bi bi-check-circle-fill me-2"></i> @SuccessMessage
        </div>
    }

    @if (CargandoInicial)
    {
        <div class="text-center p-5">
            <div class="spinner-border text-dark mb-3" role="status"></div>
            <p class="fw-bold text-muted">CARGANDO TRANSFERENCIAS...</p>
        </div>
    }
    else
    {
        @* ====== CONTEXT BAR: rendicion selector + actions ====== *@
        <div class="card border-2 border-dark rounded-0 shadow mb-3">
            <div class="card-body bg-light p-2 d-flex justify-content-between align-items-center flex-wrap gap-2">

                @* Rendicion selector dropdown *@
                <div class="position-relative d-flex align-items-center gap-2 flex-wrap">
                    <button class="btn btn-dark rounded-0 fw-bold text-uppercase" @onclick="ToggleSelectorRendiciones">
                        <i class="bi bi-bank me-2"></i>
                        @if (State.RendicionActiva != null)
                        {
                            <span>$@State.RendicionActiva.Transferencias.Sum(t => t.Monto).ToString("N0") — @State.RendicionActiva.Trabajador</span>
                        }
                        else
                        {
                            <span>SELECCIONAR TRANSFERENCIA</span>
                        }
                        <i class="bi bi-chevron-down ms-2"></i>
                    </button>
                    @if (State.RendicionActiva != null)
                    {
                        <span class="badge @(State.RendicionActiva.Estado == RendicionEstado.Abierta ? "bg-success" : "bg-secondary") rounded-0 fw-bold text-uppercase">
                            @(State.RendicionActiva.Estado == RendicionEstado.Abierta ? "ABIERTA" : "CERRADA")
                        </span>
                    }

                    @if (MostrarSelectorRendiciones)
                    {
                        @* click-outside backdrop *@
                        <div class="position-fixed top-0 start-0 w-100 h-100" style="z-index: 1040;"
                             @onclick="() => MostrarSelectorRendiciones = false"></div>

                        <div class="position-absolute bg-light border-2 border-dark shadow rounded-0 p-3"
                             style="top: calc(100% + 4px); left: 0; z-index: 1050; width: 380px; max-height: 70vh; overflow-y: auto;">

                            @* Date range filter *@
                            <div class="row g-2 mb-3">
                                <div class="col-6">
                                    <label class="fw-bold small text-uppercase mb-1 text-muted">DESDE</label>
                                    <input type="date" class="form-control form-control-sm border-dark rounded-0" @bind="FiltroDesde" />
                                </div>
                                <div class="col-6">
                                    <label class="fw-bold small text-uppercase mb-1 text-muted">HASTA</label>
                                    <input type="date" class="form-control form-control-sm border-dark rounded-0" @bind="FiltroHasta" />
                                </div>
                                <div class="col-12">
                                    <button class="btn btn-sm btn-outline-dark rounded-0 fw-bold w-100" @onclick="FiltrarRendiciones">
                                        <i class="bi bi-search me-1"></i>FILTRAR
                                    </button>
                                </div>
                            </div>

                            @* Rendicion list *@
                            @if (State.Rendiciones.Any())
                            {
                                <div class="list-group">
                                    @foreach (var r in State.Rendiciones)
                                    {
                                        var monto = r.Transferencias.Sum(t => t.Monto);
                                        <button class="list-group-item list-group-item-action border-dark rounded-0 fw-bold py-2 @(State.RendicionActiva?.Id == r.Id ? "active bg-dark text-white" : "")"
                                                @onclick="() => SeleccionarRendicion(r.Id)">
                                            <div class="d-flex w-100 justify-content-between align-items-center">
                                                <span class="font-monospace small">$@monto.ToString("N0")</span>
                                                <div class="d-flex align-items-center gap-2">
                                                    <span class="badge @(r.Estado == RendicionEstado.Abierta ? "bg-success" : "bg-secondary") rounded-0">
                                                        @(r.Estado == RendicionEstado.Abierta ? "ABIERTA" : "CERRADA")
                                                    </span>
                                                    <button class="btn btn-sm btn-outline-danger rounded-0 p-1 lh-1 border-0"
                                                            @onclick="() => ConfirmarEliminarRendicion(r)"
                                                            @onclick:stopPropagation
                                                            title="Eliminar transferencia (desvincula compras y elimina movimientos)">
                                                        <i class="bi bi-trash3" style="font-size: 0.8rem;"></i>
                                                    </button>
                                                </div>
                                            </div>
                                            <small class="d-block @(State.RendicionActiva?.Id == r.Id ? "text-white-50" : "text-muted")" style="font-size: 0.7rem;">
                                                @r.Trabajador — @r.FechaInicio.ToString("dd/MM/yyyy")
                                            </small>
                                        </button>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="text-center text-muted p-3">
                                    <i class="bi bi-inbox display-6 mb-2 d-block"></i>
                                    <p class="fw-bold small">No hay transferencias para el filtro seleccionado.</p>
                                </div>
                            }
                        </div>
                    }
                </div>

                @* Action toolbar *@
                <div class="d-flex gap-2 flex-wrap">
                    <button class="btn btn-outline-dark rounded-0 fw-bold"
                            @onclick="MostrarFormTransferencia">
                        <i class="bi bi-bank me-1"></i>TRANSFERENCIA
                    </button>
                    <button class="btn btn-outline-dark rounded-0 fw-bold"
                            @onclick="MostrarFormCompra" disabled="@(!State.EstaAbierta || !State.Transferencias.Any())">
                        <i class="bi bi-cart4 me-1"></i>COMPRA
                    </button>
                    <button class="btn btn-outline-dark rounded-0 fw-bold"
                            @onclick="MostrarFormGasto" disabled="@(!State.EstaAbierta)">
                        <i class="bi bi-fuel-pump me-1"></i>GASTO
                    </button>
                    <button class="btn btn-outline-primary rounded-0 fw-bold" @onclick="NavegarACaja">
                        <i class="bi bi-box-arrow-up-right me-1"></i>IR A CAJA →
                    </button>
                </div>
            </div>
        </div>

        @* ====== KPI STRIP (always visible) ====== *@
        <ReconciliationPanel State="@State" OnCerrar="CerrarRendicion" />

        @* ====== WORK AREA: tabbed ====== *@
        <div style="flex: 1; min-height: 0; display: flex; flex-direction: column; margin-top: 0.75rem;">
        @if (State.RendicionActivaFull != null)
        {
            <div class="card border-2 border-dark rounded-0 shadow" style="flex: 1; display: flex; flex-direction: column; min-height: 0;">
                <div class="card-header bg-dark rounded-0 p-0">
                    <div class="d-flex">
                        <button class="btn rounded-0 fw-bold text-uppercase flex-fill py-2 @TabClass("CUADRE")"
                                @onclick='() => TabActivo = "CUADRE"'>
                            <i class="bi bi-table me-2"></i>CUADRE
                        </button>
                        <button class="btn rounded-0 fw-bold text-uppercase flex-fill py-2 @TabClass("COMPROBANTES")"
                                @onclick='() => TabActivo = "COMPROBANTES"'>
                            <i class="bi bi-card-checklist me-2"></i>COMPROBANTES
                        </button>
                        <button class="btn rounded-0 fw-bold text-uppercase flex-fill py-2 @TabClass("SALDO")"
                                @onclick='() => TabActivo = "SALDO"'>
                            <i class="bi bi-cash-coin me-2"></i>SALDO A DEVOLVER
                        </button>
                    </div>
                </div>
                <div class="card-body bg-light p-3" style="flex: 1; overflow-y: auto; min-height: 0;">
                    @switch (TabActivo)
                    {
                        case "COMPROBANTES":
                            <ComprobantesPanel State="@State" OnUpdated="RecargarRendicionActiva" />
                            break;
                        case "SALDO":
                            <DevolucionPanel State="@State" OnUpdated="RecargarRendicionActiva" />
                            break;
                        default:
                            <CuadrarView Transferencias="@State.Transferencias"
                                         Compras="@State.Compras"
                                         Gastos="@State.Gastos"
                                         RendicionId="@(State.RendicionActiva?.Id ?? 0)"
                                         OnItemUpdated="RecargarRendicionActiva"
                                         OnAvanzar="CerrarRendicion" />
                            break;
                    }
                </div>
            </div>
        }
        else if (State.RendicionActiva != null && State.RendicionActivaFull == null)
        {
            <div class="text-center p-5">
                <div class="spinner-border text-dark mb-3" role="status"></div>
                <p class="fw-bold text-muted">CARGANDO DATOS DE LA TRANSFERENCIA...</p>
            </div>
        }
        else
        {
            <div class="text-center p-5">
                <i class="bi bi-hand-index-thumb display-4 text-muted mb-3 d-block"></i>
                <p class="fw-bold text-muted">Seleccioná una transferencia para ver su justificación.</p>
            </div>
        }
        </div>@* end work-area flex wrapper *@
    }
</div>

@* ====== MODALS (floating data-entry forms) ====== *@
@if (ShowTransferenciaForm)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5); z-index: 1060;">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content rounded-0 border-2 border-dark shadow-lg">
                <div class="modal-header bg-dark text-white rounded-0 border-bottom border-dark">
                    <h5 class="modal-title fw-bold text-uppercase"><i class="bi bi-bank me-2"></i>REGISTRAR TRANSFERENCIA</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarFormularios"></button>
                </div>
                <div class="modal-body p-4 bg-light">
                    <TransferenciaForm OnTransferenciaCreated="OnTransferenciaCreada"
                                       Trabajador="@(State.RendicionActiva?.Trabajador ?? string.Empty)"
                                       RendicionId="0"
                                       PeriodoId="@null" />
                </div>
            </div>
        </div>
    </div>
}

@if (ShowCompraForm && State.RendicionActivaFull != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5); z-index: 1060;">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content rounded-0 border-2 border-dark shadow-lg">
                <div class="modal-header bg-dark text-white rounded-0 border-bottom border-dark">
                    <h5 class="modal-title fw-bold text-uppercase"><i class="bi bi-cart4 me-2"></i>REGISTRAR COMPRA VINCULADA</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarFormularios"></button>
                </div>
                <div class="modal-body p-4 bg-light">
                    <CompraForm OnCompraCreated="OnCompraCreada"
                                Trabajador="@(State.RendicionActiva?.Trabajador ?? string.Empty)"
                                Transferencias="@State.Transferencias"
                                RendicionId="@(State.RendicionActiva?.Id ?? 0)" />
                </div>
            </div>
        </div>
    </div>
}

@if (ShowGastoForm && State.RendicionActivaFull != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5); z-index: 1060;">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content rounded-0 border-2 border-dark shadow-lg">
                <div class="modal-header bg-dark text-white rounded-0 border-bottom border-dark">
                    <h5 class="modal-title fw-bold text-uppercase"><i class="bi bi-fuel-pump me-2"></i>REGISTRAR GASTO</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarFormularios"></button>
                </div>
                <div class="modal-body p-4 bg-light">
                    <GastoForm OnGastoCreated="OnGastoCreado"
                               RendicionId="@(State.RendicionActiva?.Id ?? 0)" />
                </div>
            </div>
        </div>
    </div>
}

@code {
    public ContabilidadPageState State { get; set; } = new();
    private bool CargandoInicial { get; set; } = true;
    private string? Error { get; set; }
    private string? SuccessMessage { get; set; }

    // Filter state
    private DateTime? FiltroDesde { get; set; }
    private DateTime? FiltroHasta { get; set; }

    // Rendicion selector dropdown
    private bool MostrarSelectorRendiciones { get; set; }

    // Work area tab
    private string TabActivo { get; set; } = "CUADRE";

    // Form modals
    private bool ShowTransferenciaForm { get; set; }
    private bool ShowCompraForm { get; set; }
    private bool ShowGastoForm { get; set; }

    private bool AnyFormOpen => ShowTransferenciaForm || ShowCompraForm || ShowGastoForm;

    private string TabClass(string tab) =>
        TabActivo == tab ? "bg-light text-dark" : "btn-dark text-white-50";

    protected override async Task OnInitializedAsync()
    {
        await CargarRendiciones();
        CargandoInicial = false;
    }

    private void ToggleSelectorRendiciones() => MostrarSelectorRendiciones = !MostrarSelectorRendiciones;

    private async Task CargarRendiciones()
    {
        try
        {
            Error = null;
            var url = "api/rendicion";
            var queryParams = new List<string>();

            if (FiltroDesde.HasValue)
                queryParams.Add($"desde={FiltroDesde.Value:yyyy-MM-dd}");
            if (FiltroHasta.HasValue)
                queryParams.Add($"hasta={FiltroHasta.Value:yyyy-MM-dd}");

            if (queryParams.Any())
                url += "?" + string.Join("&", queryParams);

            State.Rendiciones = await Http.GetFromJsonAsync<List<RendicionDto>>(url) ?? new();
        }
        catch (Exception ex)
        {
            Error = $"Error al cargar transferencias: {ex.Message}";
        }
    }

    private async Task FiltrarRendiciones()
    {
        await CargarRendiciones();
    }

    private void NavegarACaja()
    {
        Navigation.NavigateTo("/caja");
    }

    private async Task SeleccionarRendicion(int rendicionId, bool keepMessages = false)
    {
        try
        {
            Error = null;
            if (!keepMessages) SuccessMessage = null;
            MostrarSelectorRendiciones = false;
            if (!keepMessages) await CerrarFormularios();

            State.RendicionActiva = State.Rendiciones.FirstOrDefault(r => r.Id == rendicionId);

            var full = await Http.GetFromJsonAsync<RendicionFullDto>($"api/rendicion/{rendicionId}/full");
            if (full != null)
            {
                State.RendicionActivaFull = full;
                State.RendicionActiva = full;
            }
        }
        catch (Exception ex)
        {
            Error = $"Error al cargar transferencia: {ex.Message}";
        }
    }

    private async Task CerrarRendicion()
    {
        if (State.RendicionActiva == null) return;

        try
        {
            Error = null;
            SuccessMessage = null;
            var response = await Http.PostAsync($"api/rendicion/{State.RendicionActiva.Id}/cerrar", null);
            if (response.IsSuccessStatusCode)
            {
                SuccessMessage = "Rendición cerrada exitosamente.";
                await CargarRendiciones();
                if (State.RendicionActiva != null)
                    await SeleccionarRendicion(State.RendicionActiva.Id, keepMessages: true);
            }
            else
            {
                Error = "Error al cerrar: " + await response.Content.ReadAsStringAsync();
            }
        }
        catch (Exception ex)
        {
            Error = $"Error: {ex.Message}";
        }
    }

    private async Task RecargarRendicionActiva()
    {
        if (State.RendicionActiva != null)
        {
            await SeleccionarRendicion(State.RendicionActiva.Id, keepMessages: true);
        }
    }

    private async Task ConfirmarEliminarRendicion(RendicionDto rendicion)
    {
        var monto = rendicion.Transferencias.Sum(t => t.Monto).ToString("N0");
        var confirmado = await JS.InvokeAsync<bool>("confirm",
            $"¿Eliminar la transferencia de ${monto} ({rendicion.Trabajador} — {rendicion.FechaInicio:dd/MM/yyyy})?\n\n" +
            "Las compras vinculadas se DESVINCULARÁN y los movimientos de caja se ELIMINARÁN.\n\n" +
            "¿Estás seguro? Esta operación no se puede deshacer.");

        if (confirmado)
            await EjecutarEliminarRendicion(rendicion.Id);
    }

    private async Task EjecutarEliminarRendicion(int rendicionId)
    {
        try
        {
            Error = null;
            SuccessMessage = null;
            var response = await Http.DeleteAsync($"api/rendicion/{rendicionId}");
            if (response.IsSuccessStatusCode)
            {
                SuccessMessage = "Transferencia eliminada.";
                if (State.RendicionActiva?.Id == rendicionId)
                {
                    State.RendicionActiva = null;
                    State.RendicionActivaFull = null;
                }
                await CargarRendiciones();
            }
            else if ((int)response.StatusCode == 404)
            {
                await CargarRendiciones();
                Error = "La transferencia ya no existe.";
            }
            else
            {
                Error = "Error al eliminar: " + await response.Content.ReadAsStringAsync();
            }
        }
        catch (Exception ex)
        {
            Error = $"Error: {ex.Message}";
        }
    }

    // ===== Modal open/close (with body scroll lock) =====
    private async Task MostrarFormTransferencia() => await AbrirModal(() => ShowTransferenciaForm = true);
    private async Task MostrarFormCompra() => await AbrirModal(() => ShowCompraForm = true);
    private async Task MostrarFormGasto() => await AbrirModal(() => ShowGastoForm = true);

    private async Task AbrirModal(Action abrir)
    {
        var yaAbierto = AnyFormOpen;
        ShowTransferenciaForm = ShowCompraForm = ShowGastoForm = false;
        abrir();
        MostrarSelectorRendiciones = false;
        if (!yaAbierto) await JS.InvokeVoidAsync("modalScrollLock.lock");
    }

    private async Task CerrarFormularios()
    {
        if (AnyFormOpen) await JS.InvokeVoidAsync("modalScrollLock.unlock");
        ShowTransferenciaForm = ShowCompraForm = ShowGastoForm = false;
    }

    private async Task OnTransferenciaCreada(TransferenciaDto t)
    {
        SuccessMessage = $"Transferencia ${t.Monto.ToString("N0")} registrada.";
        Error = null;
        await CerrarFormularios();
        await CargarRendiciones();
        if (t.RendicionId.HasValue)
            await SeleccionarRendicion(t.RendicionId.Value, keepMessages: true);
    }

    private async Task OnCompraCreada(CompraDto c)
    {
        SuccessMessage = $"Compra a {c.Proveedor} por ${c.MontoTotal.ToString("N0")} vinculada.";
        Error = null;
        await CerrarFormularios();
        await RecargarRendicionActiva();
    }

    private async Task OnGastoCreado(MovimientoCajaDto g)
    {
        SuccessMessage = $"Gasto {g.Categoria} por ${Math.Abs(g.Monto).ToString("N0")} vinculado.";
        Error = null;
        await CerrarFormularios();
        await RecargarRendicionActiva();
    }
}
