@page "/conciliacion-movil"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using VendingManager.Shared.Constants
@using VendingManager.Shared.DTOs
@using VendingManager.Shared.Enums
@attribute [Authorize(Roles = Roles.Admin)]

@* =========================================================================
   ConciliacionMovil.razor — port fiel de
   templates/conciliacion-movil/ConciliacionMovil.dc.html.
   4 vistas (Lista → Resumen → Agregar boleta → Comprobante) + bottom sheet
   de "Agregar transferencia" + toast. Estilos inline con var(--token); el
   bloque <style> cubre keyframes y estados :active (clases cm-*).
   Lógica en ConciliacionMovil.razor.cs.
   ========================================================================= *@

<style>
    @@keyframes cmBlink { 50% { opacity: 0; } }
    @@keyframes cmScan { 0% { top: 6px; } 100% { top: 150px; } }
    @@keyframes cmSheet { from { transform: translateY(100%); } to { transform: translateY(0); } }
    @@keyframes cmToast { from { transform: translateY(10px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
    @@keyframes cmDots { 0%, 20% { opacity: .25; } 50% { opacity: 1; } 100% { opacity: .25; } }
    .cm-cursor { animation: cmBlink 1s steps(1) infinite; }
    .cm-card:active { transform: scale(.985); }
    .cm-press:active { opacity: .72; }
    .cm-page input, .cm-page select, .cm-page button, .cm-page textarea { font-size: max(16px, 1em); }
    @@media (prefers-reduced-motion: reduce) {
        .cm-cursor, .cm-line, .cm-dot { animation: none !important; }
    }
</style>

<div class="cm-page" style="flex:1 1 auto;min-height:0;display:flex;flex-direction:column;background:var(--bg-canvas);font-family:var(--font-sans);overflow:hidden;max-width:520px;width:100%;margin:0 auto;position:relative;border-left:1px solid var(--line-200);border-right:1px solid var(--line-200);">

    @if (_loading)
    {
        <div style="position:absolute;top:0;left:0;right:0;z-index:3000;display:flex;align-items:center;justify-content:center;gap:8px;background:var(--ink-900);color:#fff;font-family:var(--font-mono);font-size:0.72rem;text-transform:uppercase;letter-spacing:1px;padding:8px;">
            <span class="spinner-border spinner-border-sm" role="status"></span> Cargando…
        </div>
    }

    @if (_error is not null)
    {
        <div style="position:absolute;top:0;left:0;right:0;z-index:3000;display:flex;align-items:center;gap:8px;background:var(--signal-danger);color:#fff;font-family:var(--font-mono);font-size:0.72rem;padding:10px 12px;">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <span style="flex:1;">@_error</span>
            <button class="cm-press" style="border:1px solid #fff;background:transparent;color:#fff;width:28px;height:28px;border-radius:0;cursor:pointer;"
                    @onclick="() => { _error = null; StateHasChanged(); }">×</button>
        </div>
    }

    @switch (_view)
    {
        case View.List: @ViewListFragment; break;
        case View.Overview: @ViewOverviewFragment; break;
        case View.AddBoleta: @ViewAddBoletaFragment; break;
        case View.Comprobante: @ViewComprobanteFragment; break;
    }

    @* ── BOTTOM SHEET: Agregar transferencia ─────────────────────────── *@
    @if (_transfSheetVisible)
    {
        <div style="position:absolute;inset:0;z-index:2600;background:rgba(0,0,0,0.45);display:flex;align-items:flex-end;" @onclick="CloseTransfSheet">
            <div style="width:100%;background:var(--paper-0);border-top:3px solid var(--ink-900);animation:cmSheet .2s ease-out;padding:12px 16px calc(16px + env(safe-area-inset-bottom));display:flex;flex-direction:column;gap:11px;max-height:92%;overflow:auto;"
                 @onclick:stopPropagation="true">
                <div style="width:44px;height:4px;background:var(--line-200);border-radius:2px;margin:2px auto 6px;"></div>
                <div style="font-family:var(--font-mono);font-weight:700;text-transform:uppercase;font-size:0.9rem;letter-spacing:-0.3px;">
                    @(_creatingNewRendicion ? "Nueva rendición" : "Agregar transferencia")
                </div>
                <div style="font-family:var(--font-mono);font-size:0.62rem;color:var(--text-muted);line-height:1.5;">
                    @(_creatingNewRendicion
                        ? "Registrá la transferencia recibida. Se abre una rendición nueva a nombre del operario."
                        : "Sumá otra transferencia recibida a esta rendición.")
                </div>

                <label style="display:flex;flex-direction:column;gap:5px;">
                    <span style="font-family:var(--font-mono);font-weight:700;text-transform:uppercase;font-size:0.56rem;letter-spacing:1px;color:var(--text-muted);">Comprobante (foto)</span>
                    <div style="display:flex;border:2px solid var(--ink-900);">
                        <span style="background:var(--bg-surface-inset);border-right:2px solid var(--ink-900);font-family:var(--font-mono);font-weight:700;font-size:0.64rem;text-transform:uppercase;letter-spacing:.5px;padding:9px 11px;white-space:nowrap;">Elegir</span>
                        <span style="flex:1;font-family:var(--font-mono);font-size:0.66rem;color:var(--text-muted);padding:9px 10px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@(_transfFoto?.Name ?? "Sin archivo")</span>
                        <InputFile OnChange="OnTransfFotoSelected" accept="image/*,application/pdf" style="display:none;" id="cm-transf-foto" />
                        <label for="cm-transf-foto" class="cm-press" style="display:flex;align-items:center;padding:0 12px;background:var(--ink-900);color:#fff;cursor:pointer;"><i class="bi bi-camera"></i></label>
                    </div>
                </label>

                <label style="display:flex;flex-direction:column;gap:5px;">
                    <span style="font-family:var(--font-mono);font-weight:700;text-transform:uppercase;font-size:0.56rem;letter-spacing:1px;color:var(--text-muted);">Beneficiario / Operario</span>
                    <input value="@_transfBeneficiario" @oninput="e => _transfBeneficiario = e.Value?.ToString() ?? string.Empty"
                           style="border:2px solid var(--ink-900);padding:10px;font-family:var(--font-sans);font-weight:600;font-size:0.9rem;border-radius:0;outline:none;" />
                </label>

                <div style="display:flex;gap:9px;">
                    <label style="flex:1;display:flex;flex-direction:column;gap:5px;min-width:0;">
                        <span style="font-family:var(--font-mono);font-weight:700;text-transform:uppercase;font-size:0.56rem;letter-spacing:1px;color:var(--text-muted);">Fecha</span>
                        <input type="date" @bind="_transfFecha"
                               style="border:2px solid var(--ink-900);padding:10px;font-family:var(--font-mono);font-size:0.82rem;border-radius:0;outline:none;background:var(--paper-0);min-width:0;" />
                    </label>
                    <label style="flex:1;display:flex;flex-direction:column;gap:5px;min-width:0;">
                        <span style="font-family:var(--font-mono);font-weight:700;text-transform:uppercase;font-size:0.56rem;letter-spacing:1px;color:var(--text-muted);">Monto</span>
                        <input inputmode="decimal" value="@_transfMontoText" @onchange="OnTransfMontoChanged" placeholder="ej: 340.000"
                               style="border:2px solid var(--ink-900);padding:10px;font-family:var(--font-mono);font-weight:700;font-size:0.85rem;border-radius:0;outline:none;min-width:0;" />
                    </label>
                </div>

                @if (_transfError is not null)
                {
                    <div style="background:var(--signal-danger);color:#fff;font-family:var(--font-mono);font-size:0.68rem;padding:8px 10px;">@_transfError</div>
                }

                <button class="cm-press" disabled="@(_transfSaving || _transfMonto <= 0)"
                        @onclick="SaveTransferencia"
                        style="width:100%;height:52px;display:flex;align-items:center;justify-content:center;gap:9px;border:2px solid var(--ink-900);background:@((_transfSaving || _transfMonto <= 0) ? "var(--line-200)" : "var(--ink-900)");color:@((_transfSaving || _transfMonto <= 0) ? "var(--text-muted)" : "#fff");font-family:var(--font-mono);font-weight:700;text-transform:uppercase;font-size:0.8rem;letter-spacing:.5px;cursor:@((_transfSaving || _transfMonto <= 0) ? "not-allowed" : "pointer");border-radius:0;">
                    <i class="bi bi-bank"></i>@(_transfSaving ? "Guardando…" : (_creatingNewRendicion ? "Crear rendición" : "Agregar transferencia"))
                </button>
            </div>
        </div>
    }

    @* ── Toast ────────────────────────────────────────────────────────── *@
    @if (_toastMessage is not null)
    {
        <div style="position:absolute;left:50%;bottom:calc(78px + env(safe-area-inset-bottom));transform:translateX(-50%);z-index:3200;display:flex;align-items:center;gap:8px;background:var(--ink-900);color:#fff;font-family:var(--font-mono);font-weight:700;font-size:0.72rem;text-transform:uppercase;letter-spacing:.5px;padding:10px 16px;border:2px solid var(--ink-900);animation:cmToast .2s ease-out;white-space:nowrap;">
            <i class="bi @_toastIcon"></i> @_toastMessage
        </div>
    }
</div>

@code {

    // ═══════════════════════════════════════════════════════════════════
    // VISTA 1 · LISTA DE RENDICIONES
    // ═══════════════════════════════════════════════════════════════════
    private RenderFragment ViewListFragment => @<text>
        <header style="flex-shrink:0;background:var(--ink-900);color:#fff;padding:12px 16px 14px;">
            <div style="font-family:var(--font-mono);font-weight:700;font-size:0.6rem;letter-spacing:2px;text-transform:uppercase;opacity:.75;">Terreno · Conciliación</div>
            <h1 style="margin:6px 0 0;font-family:var(--font-mono);font-weight:700;text-transform:uppercase;letter-spacing:-0.5px;font-size:1.2rem;line-height:1.1;">Rendiciones<span class="cm-cursor">_</span></h1>
        </header>

        <div style="flex:1;min-height:0;overflow:auto;padding:12px 16px 90px;display:flex;flex-direction:column;gap:12px;-webkit-overflow-scrolling:touch;">
            @if (_rendiciones is null || _rendiciones.Count == 0)
            {
                <div style="border:1px dashed var(--line-200);padding:34px 18px;text-align:center;font-family:var(--font-mono);font-size:0.7rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:.5px;line-height:1.6;">
                    Sin rendiciones registradas.<br>Tocá «Nueva rendición».
                </div>
            }
            else
            {
                @foreach (var r in _rendiciones)
                {
                    var abierta = r.Estado == AccountingPeriodEstado.Abierto;
                    <button class="cm-card" @onclick="() => OpenRendicion(r.Id)"
                            style="text-align:left;width:100%;border:2px solid var(--ink-900);background:var(--paper-0);padding:14px;display:flex;flex-direction:column;gap:11px;cursor:pointer;border-radius:0;transition:transform .1s;">
                        <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:10px;">
                            <div style="min-width:0;">
                                <span style="font-family:var(--font-mono);font-weight:700;text-transform:uppercase;font-size:0.92rem;display:block;line-height:1.2;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@(r.Trabajador ?? r.Name)</span>
                                <span style="font-family:var(--font-sans);color:var(--text-muted);font-size:0.78rem;">@r.FechaInicio.ToString("dd/MM/yyyy")</span>
                            </div>
                            <span style="flex-shrink:0;background:@(abierta ? "var(--signal-success)" : "var(--ink-900)");color:#fff;font-family:var(--font-mono);font-size:0.56rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;padding:3px 8px;border:1px solid var(--ink-900);white-space:nowrap;">@EstadoLabel(r.Estado)</span>
                        </div>
                        <div style="display:flex;align-items:stretch;border:1px solid var(--line-200);">
                            <div style="flex:1;padding:7px 9px;border-right:1px solid var(--line-200);">
                                <div style="font-family:var(--font-mono);font-weight:700;font-size:0.5rem;text-transform:uppercase;letter-spacing:.5px;color:var(--text-muted);">Transf.</div>
                                <div style="font-family:var(--font-mono);font-weight:700;font-size:0.82rem;color:var(--signal-success);">@Fmt(r.TotalTransferido)</div>
                            </div>
                            <div style="flex:1;padding:7px 9px;border-right:1px solid var(--line-200);">
                                <div style="font-family:var(--font-mono);font-weight:700;font-size:0.5rem;text-transform:uppercase;letter-spacing:.5px;color:var(--text-muted);">Gastado</div>
                                <div style="font-family:var(--font-mono);font-weight:700;font-size:0.82rem;color:var(--signal-danger);">@Fmt(r.TotalCompras + r.TotalGastos)</div>
                            </div>
                            <div style="flex:1;padding:7px 9px;">
                                <div style="font-family:var(--font-mono);font-weight:700;font-size:0.5rem;text-transform:uppercase;letter-spacing:.5px;color:var(--text-muted);">Saldo</div>
                                <div style="font-family:var(--font-mono);font-weight:700;font-size:0.82rem;">@Fmt(r.Diferencia)</div>
                            </div>
                        </div>
                        <div style="display:flex;justify-content:space-between;align-items:center;gap:8px;">
                            <span style="font-family:var(--font-mono);font-size:0.66rem;color:var(--text-muted);white-space:nowrap;"><i class="bi bi-calendar3" style="margin-right:5px;"></i>@r.FechaInicio.ToString("dd/MM")</span>
                            <span style="font-family:var(--font-mono);font-size:0.62rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text-muted);white-space:nowrap;">Abrir <i class="bi bi-chevron-right" style="margin-left:3px;"></i></span>
                        </div>
                    </button>
                }
            }
        </div>

        <div style="background:var(--paper-0);border-top:3px solid var(--ink-900);padding:10px 16px calc(10px + env(safe-area-inset-bottom));">
            <button class="cm-press" @onclick="OpenNewRendicionSheet"
                    style="width:100%;height:52px;display:flex;align-items:center;justify-content:center;gap:9px;border:2px solid var(--ink-900);background:var(--ink-900);color:#fff;font-family:var(--font-mono);font-weight:700;text-transform:uppercase;font-size:0.82rem;letter-spacing:1px;cursor:pointer;border-radius:0;">
                <i class="bi bi-plus-lg"></i>Nueva rendición
            </button>
        </div>
    </text>;

    // ═══════════════════════════════════════════════════════════════════
    // VISTA 2 · RESUMEN DE LA RENDICIÓN
    // ═══════════════════════════════════════════════════════════════════
    private RenderFragment ViewOverviewFragment => @<text>
        @if (_periodo is not null)
        {
            var (verif, total) = VerifStats();
            <header style="flex-shrink:0;display:flex;align-items:center;gap:10px;padding:10px 12px;border-bottom:3px solid var(--ink-900);background:var(--paper-0);">
                <button class="cm-press" aria-label="Volver" @onclick="GoToList"
                        style="width:44px;height:44px;flex-shrink:0;border:2px solid var(--ink-900);background:var(--paper-0);cursor:pointer;border-radius:0;display:flex;align-items:center;justify-content:center;font-size:1.1rem;"><i class="bi bi-arrow-left"></i></button>
                <div style="flex:1;min-width:0;">
                    <div style="font-family:var(--font-mono);font-weight:700;text-transform:uppercase;font-size:0.6rem;letter-spacing:2px;color:var(--text-muted);">Rendición</div>
                    <div style="font-family:var(--font-mono);font-weight:700;text-transform:uppercase;font-size:0.98rem;letter-spacing:-0.3px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@(_periodo.Trabajador ?? _periodo.Name)</div>
                </div>
                <span style="flex-shrink:0;background:@(RendicionAbierta ? "var(--signal-success)" : "var(--ink-900)");color:#fff;font-family:var(--font-mono);font-size:0.54rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;padding:4px 8px;border:2px solid var(--ink-900);">@EstadoLabel(_periodo.Estado)</span>
            </header>

            @* franja KPI *@
            <div style="flex-shrink:0;display:flex;border-bottom:2px solid var(--ink-900);background:var(--paper-0);">
                <div style="flex:1;padding:9px 11px;border-right:1px solid var(--line-200);">
                    <div style="font-family:var(--font-mono);font-weight:700;font-size:0.5rem;text-transform:uppercase;letter-spacing:1px;color:var(--text-muted);">Transferido</div>
                    <div style="font-family:var(--font-sans);font-weight:700;font-size:1.02rem;line-height:1.1;letter-spacing:-0.5px;color:var(--signal-success);">@Fmt(Transferido)</div>
                </div>
                <div style="flex:1;padding:9px 11px;border-right:1px solid var(--line-200);">
                    <div style="font-family:var(--font-mono);font-weight:700;font-size:0.5rem;text-transform:uppercase;letter-spacing:1px;color:var(--text-muted);">Compras + Gastos</div>
                    <div style="font-family:var(--font-sans);font-weight:700;font-size:1.02rem;line-height:1.1;letter-spacing:-0.5px;color:var(--signal-danger);">@Fmt(ComprasGastos)</div>
                </div>
                <div style="flex:1;padding:9px 11px;background:var(--signal-warning);">
                    <div style="font-family:var(--font-mono);font-weight:700;font-size:0.5rem;text-transform:uppercase;letter-spacing:1px;color:rgba(0,0,0,.65);">Saldo</div>
                    <div style="font-family:var(--font-sans);font-weight:700;font-size:1.02rem;line-height:1.1;letter-spacing:-0.5px;color:var(--ink-900);">@Fmt(Saldo)</div>
                </div>
            </div>

            <div style="flex:1;min-height:0;overflow:auto;padding:14px 14px 120px;display:flex;flex-direction:column;gap:16px;-webkit-overflow-scrolling:touch;">

                @* ── Sección Transferencias ── *@
                @{ var transfList = _periodo.Transferencias; }
                <div style="display:flex;flex-direction:column;gap:9px;">
                    <div style="display:flex;align-items:center;gap:8px;">
                        <span style="display:flex;align-items:center;gap:7px;font-family:var(--font-mono);font-weight:700;font-size:0.72rem;text-transform:uppercase;letter-spacing:1px;"><i class="bi bi-bank"></i>Transferencias</span>
                        <span style="font-family:var(--font-mono);font-weight:700;font-size:0.56rem;background:var(--ink-900);color:#fff;padding:2px 6px;">@transfList.Count</span>
                        <span style="margin-left:auto;font-family:var(--font-mono);font-weight:700;font-size:0.74rem;color:var(--signal-success);">+@Fmt(Transferido)</span>
                    </div>
                    @foreach (var t in transfList)
                    {
                        @ItemRow(ItemKind.Transferencia, t.Id, "bi-bank", $"Transferencia · {Fmt(t.Monto)}",
                            $"{t.Trabajador} · {t.Fecha:dd/MM/yyyy}", t.Monto, positive: true, verified: t.Verificada,
                            pending: !t.Verificada, fromCompras: false)
                    }
                    @if (transfList.Count == 0)
                    {
                        @EmptySlot("transferencias")
                    }
                    @if (RendicionAbierta)
                    {
                        @AddSectionBtn("transferencia", OpenAddTransferenciaSheet)
                    }
                </div>

                @* ── Sección Compras ── *@
                @{ var comprasList = AllCompras.Where(c => !string.Equals(c.TipoFactura, "GASTO_GENERAL", StringComparison.OrdinalIgnoreCase)).ToList(); }
                <div style="display:flex;flex-direction:column;gap:9px;">
                    <div style="display:flex;align-items:center;gap:8px;">
                        <span style="display:flex;align-items:center;gap:7px;font-family:var(--font-mono);font-weight:700;font-size:0.72rem;text-transform:uppercase;letter-spacing:1px;"><i class="bi bi-cart"></i>Compras</span>
                        <span style="font-family:var(--font-mono);font-weight:700;font-size:0.56rem;background:var(--ink-900);color:#fff;padding:2px 6px;">@comprasList.Count</span>
                        <span style="margin-left:auto;font-family:var(--font-mono);font-weight:700;font-size:0.74rem;color:var(--signal-danger);">-@Fmt(comprasList.Sum(c => c.MontoTotal))</span>
                    </div>
                    @foreach (var c in comprasList)
                    {
                        @ItemRow(ItemKind.Compra, c.Id, "bi-receipt",
                            string.IsNullOrWhiteSpace(c.ProveedorCanonical) ? c.Proveedor : c.ProveedorCanonical!,
                            $"Nº {c.NumeroDocumento ?? "—"} · {c.FechaCompra:dd/MM/yyyy}", c.MontoTotal,
                            positive: false, verified: c.Verificada, pending: !c.Verificada, fromCompras: true)
                    }
                    @if (comprasList.Count == 0)
                    {
                        @EmptySlot("compras")
                    }
                    @if (RendicionAbierta)
                    {
                        @AddSectionBtn("compra", () => _ = OpenAddBoleta(BoletaKind.Compra))
                    }
                </div>

                @* ── Sección Gastos ── *@
                @{ var gastosCompra = AllCompras.Where(c => string.Equals(c.TipoFactura, "GASTO_GENERAL", StringComparison.OrdinalIgnoreCase)).ToList(); }
                @{ var gastosMov = _periodo.Gastos; }
                @{ var gastosTotal = gastosCompra.Sum(c => c.MontoTotal) + gastosMov.Sum(g => g.Monto); }
                <div style="display:flex;flex-direction:column;gap:9px;">
                    <div style="display:flex;align-items:center;gap:8px;">
                        <span style="display:flex;align-items:center;gap:7px;font-family:var(--font-mono);font-weight:700;font-size:0.72rem;text-transform:uppercase;letter-spacing:1px;"><i class="bi bi-fuel-pump"></i>Gastos</span>
                        <span style="font-family:var(--font-mono);font-weight:700;font-size:0.56rem;background:var(--ink-900);color:#fff;padding:2px 6px;">@(gastosCompra.Count + gastosMov.Count)</span>
                        <span style="margin-left:auto;font-family:var(--font-mono);font-weight:700;font-size:0.74rem;color:var(--signal-danger);">-@Fmt(gastosTotal)</span>
                    </div>
                    @foreach (var c in gastosCompra)
                    {
                        @ItemRow(ItemKind.Compra, c.Id, "bi-receipt",
                            string.IsNullOrWhiteSpace(c.ProveedorCanonical) ? c.Proveedor : c.ProveedorCanonical!,
                            $"Nº {c.NumeroDocumento ?? "—"} · {c.FechaCompra:dd/MM/yyyy}", c.MontoTotal,
                            positive: false, verified: c.Verificada, pending: !c.Verificada, fromCompras: true)
                    }
                    @foreach (var g in gastosMov)
                    {
                        @ItemRow(ItemKind.Gasto, g.Id, "bi-fuel-pump",
                            string.IsNullOrWhiteSpace(g.Descripcion) ? "Gasto" : g.Descripcion,
                            $"{g.Categoria} · {g.Fecha:dd/MM/yyyy}", g.Monto,
                            positive: false, verified: false, pending: false, fromCompras: false)
                    }
                    @if (gastosCompra.Count == 0 && gastosMov.Count == 0)
                    {
                        @EmptySlot("gastos")
                    }
                    @if (RendicionAbierta)
                    {
                        @AddSectionBtn("gasto", () => _ = OpenAddBoleta(BoletaKind.Gasto))
                    }
                </div>
            </div>

            @* barra inferior: saldo + nota de cierre en escritorio *@
            <div style="background:var(--paper-0);border-top:3px solid var(--ink-900);padding:9px 14px calc(9px + env(safe-area-inset-bottom));display:flex;align-items:center;gap:12px;">
                <div style="min-width:0;">
                    <div style="font-family:var(--font-mono);font-weight:700;font-size:0.52rem;text-transform:uppercase;letter-spacing:1px;color:var(--text-muted);">Saldo a devolver</div>
                    <div style="font-family:var(--font-sans);font-weight:700;font-size:1.35rem;letter-spacing:-1px;line-height:1;">@Fmt(Saldo)</div>
                </div>
                <div style="margin-left:auto;flex-shrink:0;display:flex;flex-direction:column;align-items:flex-end;gap:3px;text-align:right;">
                    <span style="font-family:var(--font-mono);font-weight:700;font-size:0.58rem;text-transform:uppercase;letter-spacing:.5px;color:var(--text-muted);">@verif/@total verif.</span>
                    <span style="display:flex;align-items:center;gap:5px;font-family:var(--font-mono);font-weight:700;font-size:0.56rem;text-transform:uppercase;letter-spacing:.5px;background:var(--bg-surface-inset);border:1px solid var(--line-200);padding:3px 7px;"><i class="bi bi-display"></i>Cierre en escritorio</span>
                </div>
            </div>
        }
    </text>;

    // ── helper: fila de ítem en el Resumen ──
    private RenderFragment ItemRow(ItemKind kind, int id, string thumbIcon, string titulo, string sub,
        decimal monto, bool positive, bool verified, bool pending, bool fromCompras) => @<text>
        <button class="cm-card" @onclick="() => OpenComprobante(kind, id)"
                style="text-align:left;width:100%;cursor:pointer;border:2px solid var(--ink-900);background:var(--paper-0);padding:11px 12px;display:flex;align-items:center;gap:11px;border-radius:0;transition:transform .1s;">
            <div style="flex-shrink:0;width:40px;height:48px;border:1px solid var(--ink-900);background-image:repeating-linear-gradient(45deg,#f0f0f0,#f0f0f0 5px,#e2e2e2 5px,#e2e2e2 10px);display:flex;align-items:center;justify-content:center;"><i class="bi @thumbIcon" style="font-size:1rem;color:var(--ink-700);"></i></div>
            <div style="flex:1;min-width:0;display:flex;flex-direction:column;gap:3px;">
                <span style="font-family:var(--font-sans);font-weight:700;font-size:0.84rem;text-transform:uppercase;letter-spacing:-0.2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@titulo</span>
                <span style="font-family:var(--font-mono);font-size:0.64rem;color:var(--text-muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@sub</span>
                <div style="display:flex;align-items:center;gap:7px;margin-top:1px;">
                    @if (verified)
                    {
                        <span style="display:flex;align-items:center;gap:3px;font-family:var(--font-mono);font-weight:700;font-size:0.54rem;text-transform:uppercase;letter-spacing:.5px;color:var(--signal-success);"><i class="bi bi-check-circle-fill"></i>Verif.</span>
                    }
                    else if (pending)
                    {
                        <span style="display:flex;align-items:center;gap:3px;font-family:var(--font-mono);font-weight:700;font-size:0.54rem;text-transform:uppercase;letter-spacing:.5px;color:#92400e;"><span style="width:9px;height:9px;border:2px solid var(--signal-warning);border-radius:50%;"></span>Pend.</span>
                    }
                    @if (fromCompras)
                    {
                        <span style="font-family:var(--font-mono);font-weight:700;font-size:0.5rem;text-transform:uppercase;letter-spacing:.5px;border:1px solid var(--ink-900);padding:1px 5px;white-space:nowrap;">De Compras</span>
                    }
                </div>
            </div>
            <div style="flex-shrink:0;display:flex;flex-direction:column;align-items:flex-end;gap:5px;">
                <span style="font-family:var(--font-mono);font-weight:700;font-size:0.86rem;color:@(positive ? "var(--signal-success)" : "var(--signal-danger)");">@(positive ? "+" : "-")@Fmt(monto)</span>
                <i class="bi bi-chevron-right" style="color:var(--ink-500);font-size:0.8rem;"></i>
            </div>
        </button>
    </text>;

    private RenderFragment EmptySlot(string what) => @<text>
        <div style="border:1px dashed var(--line-200);padding:14px;text-align:center;font-family:var(--font-mono);font-size:0.62rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:.5px;">Sin @what aún</div>
    </text>;

    private RenderFragment AddSectionBtn(string label, Action onClick) => @<text>
        <button class="cm-press" @onclick="onClick"
                style="width:100%;height:46px;display:flex;align-items:center;justify-content:center;gap:8px;border:2px dashed var(--ink-900);background:transparent;font-family:var(--font-mono);font-weight:700;text-transform:uppercase;font-size:0.72rem;letter-spacing:.5px;cursor:pointer;border-radius:0;"><i class="bi bi-plus-lg"></i>Agregar @label</button>
    </text>;

    // ═══════════════════════════════════════════════════════════════════
    // VISTA 3 · AGREGAR BOLETA (Compra / Gasto)
    // ═══════════════════════════════════════════════════════════════════
    private RenderFragment ViewAddBoletaFragment => @<text>
        <header style="flex-shrink:0;display:flex;align-items:center;gap:10px;padding:10px 12px;border-bottom:3px solid var(--ink-900);background:var(--paper-0);">
            <button class="cm-press" aria-label="Volver" @onclick="GoToOverview"
                    style="width:44px;height:44px;flex-shrink:0;border:2px solid var(--ink-900);background:var(--paper-0);cursor:pointer;border-radius:0;display:flex;align-items:center;justify-content:center;font-size:1.1rem;"><i class="bi bi-arrow-left"></i></button>
            <div style="flex:1;min-width:0;">
                <div style="font-family:var(--font-mono);font-weight:700;text-transform:uppercase;font-size:0.6rem;letter-spacing:2px;color:var(--text-muted);">Agregar a la rendición</div>
                <div style="font-family:var(--font-mono);font-weight:700;text-transform:uppercase;font-size:0.98rem;letter-spacing:-0.3px;">@(_boletaKind == BoletaKind.Gasto ? "Gasto" : "Compra")</div>
            </div>
        </header>

        @* toggle *@
        <div style="flex-shrink:0;display:flex;border-bottom:2px solid var(--ink-900);">
            <button @onclick="() => SetTab(AddTab.Pool)"
                    style="flex:1;padding:11px 8px;border:none;border-right:1px solid var(--ink-900);background:@(_addTab == AddTab.Pool ? "var(--ink-900)" : "var(--paper-0)");color:@(_addTab == AddTab.Pool ? "#fff" : "var(--ink-900)");font-family:var(--font-mono);font-weight:700;font-size:0.68rem;text-transform:uppercase;letter-spacing:.5px;cursor:pointer;border-radius:0;"><i class="bi bi-folder2-open" style="margin-right:6px;"></i>De Compras</button>
            <button @onclick="() => SetTab(AddTab.Nueva)"
                    style="flex:1;padding:11px 8px;border:none;background:@(_addTab == AddTab.Nueva ? "var(--ink-900)" : "var(--paper-0)");color:@(_addTab == AddTab.Nueva ? "#fff" : "var(--ink-900)");font-family:var(--font-mono);font-weight:700;font-size:0.68rem;text-transform:uppercase;letter-spacing:.5px;cursor:pointer;border-radius:0;"><i class="bi bi-camera" style="margin-right:6px;"></i>Subir nueva</button>
        </div>

        @if (_boletaError is not null)
        {
            <div style="flex-shrink:0;margin:10px 14px 0;background:var(--signal-danger);color:#fff;font-family:var(--font-mono);font-size:0.68rem;padding:8px 10px;">@_boletaError</div>
        }

        @if (_addTab == AddTab.Pool)
        {
            <div style="flex-shrink:0;padding:12px 14px 8px;">
                <div style="font-family:var(--font-mono);font-size:0.64rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:.5px;line-height:1.5;margin-bottom:9px;"><i class="bi bi-info-circle" style="margin-right:5px;"></i>Boletas ya subidas a Compras que aún no se vinculan a ninguna transferencia.</div>
                <input placeholder="Buscar proveedor o documento…" value="@_poolSearch" @oninput="OnPoolSearchChanged"
                       style="width:100%;border:2px solid var(--ink-900);padding:11px 12px;font-family:var(--font-mono);font-size:0.84rem;border-radius:0;outline:none;" />
            </div>
            <div style="flex:1;min-height:0;overflow:auto;padding:0 14px 24px;display:flex;flex-direction:column;gap:10px;-webkit-overflow-scrolling:touch;">
                @if (_poolLoading)
                {
                    <div style="padding:30px;text-align:center;font-family:var(--font-mono);font-size:0.7rem;color:var(--text-muted);">Cargando…</div>
                }
                else if (_pool.Count == 0)
                {
                    <div style="padding:40px 20px;text-align:center;font-family:var(--font-mono);color:var(--text-muted);text-transform:uppercase;font-size:0.72rem;letter-spacing:.5px;line-height:1.6;">No hay boletas sin vincular en Compras. Usá «Subir nueva».</div>
                }
                else
                {
                    @foreach (var p in _pool)
                    {
                        <button class="cm-press" @onclick="() => VincularPool(p.Id)"
                                style="text-align:left;width:100%;display:flex;align-items:center;gap:11px;border:2px solid var(--ink-900);background:var(--paper-0);padding:12px;cursor:pointer;border-radius:0;">
                            <div style="flex-shrink:0;width:40px;height:48px;border:1px solid var(--ink-900);background-image:repeating-linear-gradient(45deg,#f0f0f0,#f0f0f0 5px,#e2e2e2 5px,#e2e2e2 10px);display:flex;align-items:center;justify-content:center;"><i class="bi bi-receipt" style="font-size:1rem;color:var(--ink-700);"></i></div>
                            <div style="flex:1;min-width:0;display:flex;flex-direction:column;gap:3px;">
                                <span style="font-family:var(--font-sans);font-weight:700;font-size:0.84rem;text-transform:uppercase;letter-spacing:-0.2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@(string.IsNullOrWhiteSpace(p.ProveedorCanonical) ? p.Proveedor : p.ProveedorCanonical)</span>
                                <span style="font-family:var(--font-mono);font-size:0.64rem;color:var(--text-muted);">Nº @(p.NumeroDocumento ?? "—") · @p.FechaCompra.ToString("dd/MM/yyyy")</span>
                                <span style="font-family:var(--font-mono);font-weight:700;font-size:0.5rem;text-transform:uppercase;letter-spacing:.5px;border:1px solid var(--ink-900);padding:1px 5px;align-self:flex-start;">@p.TipoFactura</span>
                            </div>
                            <div style="flex-shrink:0;display:flex;flex-direction:column;align-items:flex-end;gap:6px;">
                                <span style="font-family:var(--font-mono);font-weight:700;font-size:0.84rem;color:var(--signal-danger);">-@Fmt(p.MontoTotal)</span>
                                <span style="display:flex;align-items:center;gap:4px;font-family:var(--font-mono);font-weight:700;font-size:0.56rem;text-transform:uppercase;letter-spacing:.5px;background:var(--ink-900);color:#fff;padding:3px 7px;"><i class="bi bi-link-45deg"></i>Vincular</span>
                            </div>
                        </button>
                    }
                }
            </div>
        }
        else
        {
            @* Subir nueva (OCR) *@
            <div style="flex:1;min-height:0;overflow:auto;padding:14px 14px 24px;-webkit-overflow-scrolling:touch;">
                @if (_ocrState == OcrState.Idle)
                {
                    <label class="cm-press" style="display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px;width:100%;min-height:230px;padding:28px 20px;border:2px dashed var(--ink-900);background:var(--paper-50);cursor:pointer;border-radius:0;">
                        <i class="bi bi-camera" style="font-size:2.6rem;color:var(--ink-500);"></i>
                        <div style="text-align:center;">
                            <div style="font-family:var(--font-mono);font-weight:700;font-size:0.86rem;text-transform:uppercase;letter-spacing:.5px;">Tomar foto de la boleta</div>
                            <div style="font-family:var(--font-mono);font-size:0.66rem;color:var(--text-muted);margin-top:6px;line-height:1.5;">La IA lee proveedor, Nº documento,<br>fecha y el detalle de productos</div>
                        </div>
                        <span style="display:flex;align-items:center;gap:6px;font-family:var(--font-mono);font-weight:700;font-size:0.6rem;text-transform:uppercase;letter-spacing:.5px;background:var(--ink-900);color:#fff;padding:5px 10px;"><i class="bi bi-stars"></i>OCR con IA (Gemini)</span>
                        <InputFile OnChange="OnOcrPhotoSelected" accept="image/*,application/pdf" style="display:none;" />
                    </label>
                }
                else if (_ocrState == OcrState.Reading)
                {
                    <div style="text-align:center;padding:16px 0 8px;">
                        <div style="position:relative;width:210px;height:180px;margin:0 auto;border:2px solid var(--ink-900);background:#0a0a0a;overflow:hidden;">
                            <i class="bi bi-receipt" style="color:#fff;font-size:3.4rem;position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);opacity:.35;"></i>
                            <div class="cm-line" style="position:absolute;left:0;right:0;top:6px;height:2px;background:var(--signal-info);box-shadow:0 0 8px var(--signal-info);animation:cmScan 1.1s linear infinite;"></div>
                        </div>
                        <p style="font-family:var(--font-mono);font-weight:700;text-transform:uppercase;font-size:0.85rem;margin:18px 0 4px;letter-spacing:1px;display:flex;align-items:center;justify-content:center;gap:8px;"><i class="bi bi-stars"></i>Leyendo con IA<span class="cm-dot" style="animation:cmDots 1.2s infinite;">.</span><span class="cm-dot" style="animation:cmDots 1.2s infinite .2s;">.</span><span class="cm-dot" style="animation:cmDots 1.2s infinite .4s;">.</span></p>
                        <p style="font-family:var(--font-mono);font-size:0.64rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:.5px;">Gemini · extrayendo datos de la boleta</p>
                    </div>
                }
                else
                {
                    @* OcrState.Done — formulario prellenado *@
                    <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px;">
                        <span style="display:flex;align-items:center;gap:6px;font-family:var(--font-mono);font-weight:700;font-size:0.58rem;text-transform:uppercase;letter-spacing:.5px;background:var(--signal-success);color:#fff;padding:4px 8px;border:1px solid var(--ink-900);"><i class="bi bi-stars"></i>Leído por IA</span>
                        <button class="cm-press" @onclick="RetakeOcr" style="margin-left:auto;display:flex;align-items:center;gap:5px;font-family:var(--font-mono);font-weight:700;font-size:0.58rem;text-transform:uppercase;letter-spacing:.5px;background:var(--paper-0);color:var(--ink-900);border:1px solid var(--ink-900);padding:5px 9px;cursor:pointer;border-radius:0;"><i class="bi bi-arrow-repeat"></i>Otra foto</button>
                    </div>

                    <div style="border:2px solid var(--ink-900);background:var(--paper-0);margin-bottom:14px;">
                        <div style="height:96px;background:#000;display:flex;align-items:center;justify-content:center;gap:8px;color:rgba(255,255,255,.7);font-family:var(--font-mono);border-bottom:2px solid var(--ink-900);"><i class="bi bi-image-fill" style="font-size:1.5rem;"></i><span style="font-size:0.64rem;text-transform:uppercase;letter-spacing:.5px;">Boleta capturada</span></div>
                        <div style="padding:12px;display:flex;flex-direction:column;gap:11px;">
                            <label style="display:flex;flex-direction:column;gap:5px;">
                                <span style="font-family:var(--font-mono);font-weight:700;text-transform:uppercase;font-size:0.56rem;letter-spacing:1px;color:var(--text-muted);">Proveedor</span>
                                <input value="@_ocrProveedor" @oninput="e => _ocrProveedor = e.Value?.ToString() ?? string.Empty" style="border:2px solid var(--ink-900);padding:10px;font-family:var(--font-sans);font-weight:600;font-size:0.9rem;border-radius:0;outline:none;" />
                            </label>
                            <div style="display:flex;gap:9px;">
                                <label style="flex:1;display:flex;flex-direction:column;gap:5px;min-width:0;">
                                    <span style="font-family:var(--font-mono);font-weight:700;text-transform:uppercase;font-size:0.56rem;letter-spacing:1px;color:var(--text-muted);">Nº documento</span>
                                    <input value="@_ocrDoc" @oninput="e => _ocrDoc = e.Value?.ToString() ?? string.Empty" style="border:2px solid var(--ink-900);padding:10px;font-family:var(--font-mono);font-size:0.85rem;border-radius:0;outline:none;min-width:0;" />
                                </label>
                                <label style="flex:1;display:flex;flex-direction:column;gap:5px;min-width:0;">
                                    <span style="font-family:var(--font-mono);font-weight:700;text-transform:uppercase;font-size:0.56rem;letter-spacing:1px;color:var(--text-muted);">Fecha</span>
                                    <input type="date" @bind="_ocrFecha" style="border:2px solid var(--ink-900);padding:10px;font-family:var(--font-mono);font-size:0.82rem;border-radius:0;outline:none;background:var(--paper-0);min-width:0;" />
                                </label>
                            </div>

                            @* Detalle de productos *@
                            <div style="border:2px solid var(--ink-900);">
                                <div style="background:var(--ink-900);color:#fff;display:flex;justify-content:space-between;align-items:center;gap:8px;padding:8px 10px;">
                                    <span style="font-family:var(--font-mono);font-weight:700;font-size:0.62rem;text-transform:uppercase;letter-spacing:.5px;"><i class="bi bi-box-seam" style="margin-right:5px;"></i>Detalle de productos</span>
                                    <span style="flex-shrink:0;display:flex;align-items:center;gap:4px;font-family:var(--font-mono);font-weight:700;font-size:0.52rem;text-transform:uppercase;letter-spacing:.5px;border:1px solid rgba(255,255,255,.5);padding:2px 6px;"><i class="bi bi-stars"></i>@_ocrItems.Count ítems</span>
                                </div>
                                <div style="padding:9px;display:flex;flex-direction:column;gap:8px;">
                                    @foreach (var li in _ocrItems)
                                    {
                                        <div style="border:1px solid var(--line-200);background:var(--paper-0);padding:8px;display:flex;flex-direction:column;gap:7px;">
                                            <div style="display:flex;gap:7px;align-items:center;">
                                                <input value="@li.Producto" @oninput="e => li.Producto = e.Value?.ToString() ?? string.Empty" style="flex:1;min-width:0;border:1.5px solid var(--ink-900);padding:7px 8px;font-family:var(--font-sans);font-weight:600;font-size:0.82rem;text-transform:uppercase;letter-spacing:-0.2px;border-radius:0;outline:none;" />
                                                <button class="cm-press" aria-label="Quitar ítem" @onclick="() => RemoveOcrItem(li)" style="flex-shrink:0;width:34px;height:34px;border:1.5px solid var(--signal-danger);background:var(--paper-0);color:var(--signal-danger);cursor:pointer;border-radius:0;display:flex;align-items:center;justify-content:center;font-size:0.8rem;"><i class="bi bi-trash3"></i></button>
                                            </div>
                                            <div style="display:flex;gap:7px;align-items:flex-end;">
                                                <label style="width:54px;flex-shrink:0;display:flex;flex-direction:column;gap:3px;">
                                                    <span style="font-family:var(--font-mono);font-weight:700;font-size:0.5rem;text-transform:uppercase;letter-spacing:.5px;color:var(--text-muted);">Cant.</span>
                                                    <input type="number" min="1" @bind="li.Cantidad" style="width:100%;border:1.5px solid var(--ink-900);padding:6px;font-family:var(--font-mono);font-weight:700;font-size:0.82rem;text-align:center;border-radius:0;outline:none;" />
                                                </label>
                                                <label style="flex:1;min-width:0;display:flex;flex-direction:column;gap:3px;">
                                                    <span style="font-family:var(--font-mono);font-weight:700;font-size:0.5rem;text-transform:uppercase;letter-spacing:.5px;color:var(--text-muted);">Precio unit. $</span>
                                                    <input type="number" min="0" @bind="li.CostoUnitario" style="width:100%;border:1.5px solid var(--ink-900);padding:6px;font-family:var(--font-mono);font-weight:700;font-size:0.82rem;border-radius:0;outline:none;" />
                                                </label>
                                                <div style="flex-shrink:0;text-align:right;min-width:66px;">
                                                    <div style="font-family:var(--font-mono);font-weight:700;font-size:0.5rem;text-transform:uppercase;letter-spacing:.5px;color:var(--text-muted);">Subtotal</div>
                                                    <div style="font-family:var(--font-mono);font-weight:700;font-size:0.86rem;color:var(--signal-success);">@Fmt(li.Subtotal)</div>
                                                </div>
                                            </div>
                                        </div>
                                    }

                                    @if (_ocrItems.Count == 0)
                                    {
                                        <div style="border:1px dashed var(--line-200);padding:14px;text-align:center;font-family:var(--font-mono);font-size:0.6rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:.5px;line-height:1.5;">La IA no detectó líneas. Agregá los productos manualmente.</div>
                                    }

                                    @* añadir ítem manual *@
                                    <div style="border:1px dashed var(--ink-900);padding:8px;display:flex;flex-direction:column;gap:7px;">
                                        <input placeholder="Añadir ítem (ej: Maní 2kg)…" value="@_ocrDraftDesc" @oninput="e => _ocrDraftDesc = e.Value?.ToString() ?? string.Empty" style="width:100%;border:1.5px solid var(--ink-900);padding:7px 8px;font-family:var(--font-sans);font-size:0.82rem;border-radius:0;outline:none;" />
                                        <div style="display:flex;gap:7px;align-items:flex-end;">
                                            <label style="width:54px;flex-shrink:0;display:flex;flex-direction:column;gap:3px;">
                                                <span style="font-family:var(--font-mono);font-weight:700;font-size:0.5rem;text-transform:uppercase;letter-spacing:.5px;color:var(--text-muted);">Cant.</span>
                                                <input type="number" min="1" @bind="_ocrDraftCant" style="width:100%;border:1.5px solid var(--ink-900);padding:6px;font-family:var(--font-mono);font-weight:700;font-size:0.82rem;text-align:center;border-radius:0;outline:none;" />
                                            </label>
                                            <label style="flex:1;min-width:0;display:flex;flex-direction:column;gap:3px;">
                                                <span style="font-family:var(--font-mono);font-weight:700;font-size:0.5rem;text-transform:uppercase;letter-spacing:.5px;color:var(--text-muted);">Precio $</span>
                                                <input type="number" min="0" @bind="_ocrDraftPrecio" style="width:100%;border:1.5px solid var(--ink-900);padding:6px;font-family:var(--font-mono);font-weight:700;font-size:0.82rem;border-radius:0;outline:none;" />
                                            </label>
                                            <button class="cm-press" aria-label="Añadir ítem" @onclick="AddOcrItem" style="flex-shrink:0;width:40px;height:34px;border:1.5px solid var(--ink-900);background:var(--ink-900);color:#fff;cursor:pointer;border-radius:0;display:flex;align-items:center;justify-content:center;font-size:0.9rem;"><i class="bi bi-plus-lg"></i></button>
                                        </div>
                                    </div>

                                    <div style="display:flex;justify-content:space-between;align-items:center;border-top:2px solid var(--ink-900);padding-top:9px;">
                                        <span style="font-family:var(--font-mono);font-weight:700;font-size:0.66rem;text-transform:uppercase;letter-spacing:1px;">Total</span>
                                        <span style="font-family:var(--font-sans);font-weight:700;font-size:1.2rem;letter-spacing:-0.5px;">@Fmt(OcrTotal)</span>
                                    </div>
                                </div>
                            </div>

                            @if (_boletaKind == BoletaKind.Gasto)
                            {
                                <label style="display:flex;flex-direction:column;gap:5px;">
                                    <span style="font-family:var(--font-mono);font-weight:700;text-transform:uppercase;font-size:0.56rem;letter-spacing:1px;color:var(--text-muted);">Subcategoría de gasto</span>
                                    <select @bind="_ocrSubcat" style="border:2px solid var(--ink-900);padding:10px;font-family:var(--font-mono);font-weight:700;font-size:0.82rem;text-transform:uppercase;border-radius:0;outline:none;background:var(--paper-0);cursor:pointer;">
                                        <option value="LOGISTICA">Logística (bencina)</option>
                                        <option value="PEAJES">Peajes / TAG</option>
                                        <option value="GENERALES">Gastos generales</option>
                                    </select>
                                </label>
                            }

                            <div style="display:flex;align-items:flex-start;gap:8px;border:1px solid var(--line-200);background:var(--bg-surface-inset);padding:9px 10px;color:var(--text-muted);">
                                <i class="bi bi-box-arrow-in-down" style="font-size:0.8rem;margin-top:1px;flex-shrink:0;"></i>
                                <span style="font-family:var(--font-mono);font-size:0.62rem;line-height:1.45;">Al agregar, esta boleta se <b>registra en Compras</b> y queda vinculada a esta rendición.</span>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (_ocrState == OcrState.Done)
            {
                <div style="background:var(--paper-0);border-top:3px solid var(--ink-900);padding:10px 14px calc(10px + env(safe-area-inset-bottom));">
                    <button class="cm-press" disabled="@_ocrSaving" @onclick="SaveNueva"
                            style="width:100%;height:52px;display:flex;align-items:center;justify-content:center;gap:9px;border:2px solid var(--ink-900);background:@(_ocrSaving ? "var(--line-200)" : "var(--ink-900)");color:@(_ocrSaving ? "var(--text-muted)" : "#fff");font-family:var(--font-mono);font-weight:700;text-transform:uppercase;font-size:0.8rem;letter-spacing:.5px;cursor:@(_ocrSaving ? "not-allowed" : "pointer");border-radius:0;"><i class="bi bi-check2-circle"></i>@(_ocrSaving ? "Registrando…" : "Agregar y registrar en Compras")</button>
                </div>
            }
        }
    </text>;

    // ═══════════════════════════════════════════════════════════════════
    // VISTA 4 · COMPROBANTE (verificar / rechazar)
    // ═══════════════════════════════════════════════════════════════════
    private RenderFragment ViewComprobanteFragment => @<text>
        @if (_periodo is not null)
        {
            // Resolve selected item
                TransferenciaDto? selT = _selKind == ItemKind.Transferencia ? _periodo.Transferencias.FirstOrDefault(t => t.Id == _selId) : null;
                CompraDto? selC = _selKind == ItemKind.Compra ? AllCompras.FirstOrDefault(c => c.Id == _selId) : null;
                MovimientoCajaDto? selG = _selKind == ItemKind.Gasto ? _periodo.Gastos.FirstOrDefault(g => g.Id == _selId) : null;

                string kindLabel = _selKind switch { ItemKind.Transferencia => "Transferencia", ItemKind.Compra => "Compra", _ => "Gasto" };
                string bigIcon = _selKind switch { ItemKind.Transferencia => "bi-bank", ItemKind.Compra => "bi-receipt", _ => "bi-fuel-pump" };
                bool positive = _selKind == ItemKind.Transferencia;
                decimal monto = selT?.Monto ?? selC?.MontoTotal ?? selG?.Monto ?? 0;
                bool verified = selT?.Verificada ?? selC?.Verificada ?? false;
                bool canVerify = _selKind != ItemKind.Gasto;
                string titulo = _selKind switch {
                    ItemKind.Transferencia => $"Transferencia · {(selT?.Trabajador ?? "")}",
                    ItemKind.Compra => (string.IsNullOrWhiteSpace(selC?.ProveedorCanonical) ? (selC?.Proveedor ?? "Compra") : selC!.ProveedorCanonical!),
                    _ => (string.IsNullOrWhiteSpace(selG?.Descripcion) ? "Gasto" : selG!.Descripcion)
                };
                string tipoTag = _selKind switch { ItemKind.Transferencia => "Ingreso", ItemKind.Compra => (selC?.TipoFactura ?? "Compra"), _ => (selG?.Categoria ?? "Gasto") };
                (string l1, string v1) = _selKind switch {
                    ItemKind.Transferencia => ("Fecha", selT?.Fecha.ToString("dd/MM/yyyy") ?? "—"),
                    ItemKind.Compra => ("Nº documento", selC?.NumeroDocumento ?? "—"),
                    _ => ("Fecha", selG?.Fecha.ToString("dd/MM/yyyy") ?? "—")
                };
                (string l2, string v2) = _selKind switch {
                    ItemKind.Transferencia => ("Beneficiario", selT?.Trabajador ?? "—"),
                    ItemKind.Compra => ("Fecha", selC?.FechaCompra.ToString("dd/MM/yyyy") ?? "—"),
                    _ => ("Categoría", selG?.Categoria ?? "—")
                };
                string? imgUrl = _selKind switch {
                    ItemKind.Transferencia => (!string.IsNullOrWhiteSpace(selT?.ComprobanteImagenPath) ? $"api/contabilidad/transferencia/{_selId}/comprobante" : null),
                    ItemKind.Compra => (!string.IsNullOrWhiteSpace(selC?.FacturaImagenPath) ? $"api/compras/{_selId}/factura" : null),
                    _ => null
                };

            <header style="flex-shrink:0;display:flex;align-items:center;gap:10px;padding:10px 12px;border-bottom:3px solid var(--ink-900);background:var(--paper-0);">
                <button class="cm-press" aria-label="Volver" @onclick="GoToOverview"
                        style="width:44px;height:44px;flex-shrink:0;border:2px solid var(--ink-900);background:var(--paper-0);cursor:pointer;border-radius:0;display:flex;align-items:center;justify-content:center;font-size:1.1rem;"><i class="bi bi-arrow-left"></i></button>
                <div style="flex:1;min-width:0;">
                    <div style="font-family:var(--font-mono);font-weight:700;text-transform:uppercase;font-size:0.6rem;letter-spacing:2px;color:var(--text-muted);">Comprobante</div>
                    <div style="font-family:var(--font-mono);font-weight:700;text-transform:uppercase;font-size:0.98rem;letter-spacing:-0.3px;">@kindLabel</div>
                </div>
                <span style="flex-shrink:0;font-family:var(--font-mono);font-weight:700;font-size:0.54rem;text-transform:uppercase;letter-spacing:.5px;border:2px solid var(--ink-900);padding:4px 8px;">@tipoTag</span>
            </header>

            <div style="flex:1;min-height:0;overflow:auto;padding:14px 14px 24px;-webkit-overflow-scrolling:touch;">
                <div style="border:2px solid var(--ink-900);background-image:repeating-linear-gradient(45deg,#fafafa,#fafafa 9px,#eee 9px,#eee 18px);height:220px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:9px;margin-bottom:14px;overflow:hidden;">
                    @if (imgUrl is not null)
                    {
                        <a href="@imgUrl" target="_blank" rel="noopener" style="display:flex;align-items:center;justify-content:center;width:100%;height:100%;">
                            <img src="@imgUrl" alt="@kindLabel" style="max-width:100%;max-height:100%;object-fit:contain;" />
                        </a>
                    }
                    else
                    {
                        <i class="bi @bigIcon" style="font-size:2.4rem;color:var(--text-muted);"></i>
                        <span style="font-family:var(--font-mono);font-weight:700;font-size:0.68rem;text-transform:uppercase;letter-spacing:1px;color:var(--text-muted);">Sin comprobante</span>
                    }
                </div>

                <div style="font-family:var(--font-sans);font-weight:700;font-size:1.05rem;text-transform:uppercase;letter-spacing:-0.3px;line-height:1.15;margin-bottom:12px;">@titulo</div>

                <div style="border:2px solid var(--ink-900);background:var(--paper-0);padding:12px 14px;display:grid;grid-template-columns:auto 1fr;gap:9px 14px;font-family:var(--font-mono);font-size:0.78rem;align-items:baseline;margin-bottom:14px;">
                    <span style="color:var(--text-muted);font-weight:700;text-transform:uppercase;font-size:0.6rem;">@l1</span><span style="font-weight:700;text-align:right;">@v1</span>
                    <span style="color:var(--text-muted);font-weight:700;text-transform:uppercase;font-size:0.6rem;">@l2</span><span style="font-weight:700;text-align:right;">@v2</span>
                    <span style="color:var(--text-muted);font-weight:700;text-transform:uppercase;font-size:0.6rem;">Tipo</span><span style="font-weight:700;text-align:right;text-transform:uppercase;">@tipoTag</span>
                    <span style="color:var(--text-muted);font-weight:700;text-transform:uppercase;font-size:0.6rem;">Monto</span>
                    <span style="font-weight:700;text-align:right;font-size:1.05rem;color:@(positive ? "var(--signal-success)" : "var(--signal-danger)");">@(positive ? "+" : "-")@Fmt(monto)</span>
                </div>

                @if (selC is not null && selC.Detalles.Count > 0)
                {
                    <div style="border:2px solid var(--ink-900);margin-bottom:14px;">
                        <div style="background:var(--ink-900);color:#fff;padding:8px 10px;font-family:var(--font-mono);font-weight:700;font-size:0.62rem;text-transform:uppercase;letter-spacing:.5px;"><i class="bi bi-box-seam" style="margin-right:5px;"></i>Detalle de productos</div>
                        @foreach (var d in selC.Detalles)
                        {
                            <div style="display:flex;align-items:center;gap:10px;padding:9px 10px;border-bottom:1px solid var(--line-200);">
                                <span style="flex:1;min-width:0;font-family:var(--font-sans);font-weight:600;font-size:0.78rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@(d.ProductoNombre ?? d.DescripcionItem ?? "—")</span>
                                <span style="font-family:var(--font-mono);font-size:0.66rem;color:var(--text-muted);">@d.Cantidad × @Fmt(d.CostoUnitario)</span>
                                <span style="font-family:var(--font-mono);font-weight:700;font-size:0.78rem;">@Fmt(d.Subtotal)</span>
                            </div>
                        }
                    </div>
                }

                @if (_comprobanteError is not null)
                {
                    <div style="background:var(--signal-danger);color:#fff;font-family:var(--font-mono);font-size:0.68rem;padding:8px 10px;margin-bottom:12px;">@_comprobanteError</div>
                }

                @if (!canVerify)
                {
                    <div style="display:flex;align-items:flex-start;gap:8px;border:1px solid var(--line-200);background:var(--bg-surface-inset);padding:9px 10px;color:var(--text-muted);">
                        <i class="bi bi-info-circle" style="font-size:0.8rem;margin-top:1px;flex-shrink:0;"></i>
                        <span style="font-family:var(--font-mono);font-size:0.62rem;line-height:1.45;">Los gastos se registran directo en caja; no requieren verificación por ítem.</span>
                    </div>
                }
            </div>

            @if (canVerify)
            {
                <div style="flex-shrink:0;border-top:2px solid var(--ink-900);padding:0.7rem 0.85rem;background:var(--paper-0);">
                    @if (verified)
                    {
                        <div style="display:flex;align-items:center;gap:10px;">
                            <div style="flex:1;display:flex;align-items:center;justify-content:center;gap:8px;background:var(--signal-success);color:#fff;font-family:var(--font-mono);font-weight:700;font-size:0.8rem;text-transform:uppercase;letter-spacing:1px;padding:11px;"><i class="bi bi-check-circle-fill"></i> Verificada</div>
                            <button class="cm-press" disabled="@_verifBusy" @onclick="Unverify" style="font-family:var(--font-mono);font-weight:700;font-size:0.66rem;text-transform:uppercase;letter-spacing:.5px;background:transparent;color:var(--text-muted);border:1px solid var(--line-200);border-radius:0;cursor:pointer;padding:11px 13px;">Quitar</button>
                        </div>
                    }
                    else
                    {
                        <button class="cm-press" disabled="@_verifBusy" @onclick="VerifyAndNext"
                                style="width:100%;display:flex;align-items:center;justify-content:center;gap:8px;font-family:var(--font-mono);font-weight:700;font-size:0.82rem;text-transform:uppercase;letter-spacing:.5px;background:var(--ink-900);color:#fff;border:2px solid var(--ink-900);border-radius:0;cursor:pointer;padding:13px;"><i class="bi bi-check2-all"></i> Verificar y seguir</button>
                    }
                </div>
            }
        }
    </text>;
}
