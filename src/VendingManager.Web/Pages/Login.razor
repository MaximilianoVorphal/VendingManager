@page "/login"
@using VendingManager.Shared.DTOs
@using VendingManager.Web.Auth
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@inject HttpClient Http
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@layout Layout.LoginLayout

<div style="width:100%;max-width:480px;">
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <VmCard Header="ERROR" HeaderVariant="danger" BodyStyle="margin-bottom:1rem;">
            <p style="font-family:var(--font-mono);font-size:var(--fs-sm);margin:0;">
                @errorMessage
            </p>
        </VmCard>
    }

    <VmCard>
        <div style="display:flex;justify-content:center;margin-bottom:1.5rem;">
            <span style="font-family:var(--font-mono);font-weight:800;font-size:1.75rem;
                         letter-spacing:-1px;text-transform:uppercase;
                         border:2px solid var(--ink-900);padding:6px 12px;
                         background:var(--ink-900);color:var(--paper-0);border-radius:0;">
                VENDING
            </span>
        </div>

        <EditForm Model="@loginDto" OnValidSubmit="HandleLogin" FormName="loginForm">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <VmInput Label="Usuario" @bind-Value="loginDto.Username" />
            </div>

            <div class="mb-4">
                <VmInput Label="Contraseña" Type="password" @bind-Value="loginDto.Password" />
            </div>

            <VmButton Type="submit" Variant="dark" Block="true" Size="lg">Ingresar</VmButton>
        </EditForm>
    </VmCard>
</div>

@code {
    private LoginDto loginDto = new LoginDto();
    private string? errorMessage;

    private async Task HandleLogin()
    {
        errorMessage = null;
        try
        {
            var response = await Http.PostAsJsonAsync("api/account/login", loginDto);
            if (response.IsSuccessStatusCode)
            {
                // Force a reload or notify state provider
                // Reloading is safer for cookies to "stick" in some WASM scenarios, 
                // but notifying is better SPA experience if possible. 
                // Since this is WASM hosted, we need the cookie to be sent on subsequent requests.
                // Re-checking auth state is enough.
                
                if (AuthStateProvider is CookieAuthenticationStateProvider customAuthProvider)
                {
                    customAuthProvider.NotifyAuthenticationStateChanged();
                }
                
                // Navigate to home
                Navigation.NavigateTo("/", true); // Force load to ensure cookies are sent? Usually not needed if Http client handles it, but refreshing ensures everything is clean.
            }
            else
            {
                errorMessage = "Usuario o contraseña incorrectos.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Error al iniciar sesión: " + ex.Message;
        }
    }
}
