@page "/login"
@using VendingManager.Shared.DTOs
@using VendingManager.Web.Auth
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@inject HttpClient Http
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@layout Layout.LoginLayout

<div class="pt-2">
    <h3 class="fw-bold text-uppercase mb-4" style="letter-spacing: -1px;">Iniciar Sesión</h3>

    <div class="row">
        <div class="col-md-4 col-lg-3 offset-md-4 offset-lg-4">
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger border-dark rounded-0 fw-bold">@errorMessage</div>
            }

            <div class="card border-2 border-dark rounded-0 shadow">
                <div class="card-body p-4">
                    <EditForm Model="@loginDto" OnValidSubmit="HandleLogin" FormName="loginForm">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="mb-3">
                            <label for="username" class="form-label fw-bold">Usuario</label>
                            <InputText id="username" class="form-control border-dark rounded-0" @bind-Value="loginDto.Username" />
                        </div>

                        <div class="mb-3">
                            <label for="password" class="form-label fw-bold">Contraseña</label>
                            <InputText id="password" type="password" class="form-control border-dark rounded-0" @bind-Value="loginDto.Password" />
                        </div>

                        <button type="submit" class="btn btn-dark w-100 fw-bold rounded-0">Ingresar</button>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private LoginDto loginDto = new LoginDto();
    private string? errorMessage;

    private async Task HandleLogin()
    {
        errorMessage = null;
        try
        {
            var response = await Http.PostAsJsonAsync("api/account/login", loginDto);
            if (response.IsSuccessStatusCode)
            {
                // Force a reload or notify state provider
                // Reloading is safer for cookies to "stick" in some WASM scenarios, 
                // but notifying is better SPA experience if possible. 
                // Since this is WASM hosted, we need the cookie to be sent on subsequent requests.
                // Re-checking auth state is enough.
                
                if (AuthStateProvider is CookieAuthenticationStateProvider customAuthProvider)
                {
                    customAuthProvider.NotifyAuthenticationStateChanged();
                }
                
                // Navigate to home
                Navigation.NavigateTo("/", true); // Force load to ensure cookies are sent? Usually not needed if Http client handles it, but refreshing ensures everything is clean.
            }
            else
            {
                errorMessage = "Usuario o contraseña incorrectos.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Error al iniciar sesión: " + ex.Message;
        }
    }
}
