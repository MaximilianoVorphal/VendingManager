@page "/finanzas"
@using Microsoft.AspNetCore.Authorization
@using VendingManager.Shared.Constants
@using VendingManager.Shared.DTOs
@attribute [Authorize(Roles = Roles.Admin)]
@inject HttpClient Http

<PageTitle>FINANZAS</PageTitle>

<div class="container-fluid px-4 mt-4" style="font-family: 'Segoe UI', Consolas, monospace;">

    <div class="row align-items-center mb-4 border-bottom border-3 border-dark pb-3">
        <div class="col-12 d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <h2 class="m-0 fw-bold text-uppercase" style="letter-spacing: -1px;">ESTADO DE RESULTADOS</h2>
                <small class="text-muted fw-bold">ANÁLISIS DE RENTABILIDAD MENSUAL</small>
            </div>

            <div class="d-flex align-items-center gap-2 flex-wrap justify-content-end">
                <button class="btn btn-dark rounded-0 btn-sm" @onclick="() => ChangeMonth(-1)">◀</button>
                <div class="bg-dark text-white px-3 py-2 fw-bold rounded-0 text-uppercase text-center" style="min-width: 180px;">
                    @SelectedDate.ToString("MMMM yyyy")
                </div>
                <button class="btn btn-dark rounded-0 btn-sm" @onclick="() => ChangeMonth(1)">▶</button>
                <button class="btn btn-outline-dark rounded-0 btn-sm" @onclick="GoToToday" title="Ir a Hoy">Hoy</button>
            </div>
        </div>
    </div>

    <!-- GLOBAL KPIs (SNAPSHOT) -->
    @if (Valorizacion != null)
    {
        <div class="row mb-4">
            <div class="col-12">
                 <div class="card border-2 border-dark rounded-0 shadow-sm">
                     <div class="card-header bg-white border-bottom border-dark rounded-0 py-2">
                         <h6 class="m-0 fw-bold text-uppercase text-dark"><i class="bi bi-graph-up-arrow me-2"></i>Indicadores de Capital (Snapshot Actual)</h6>
                     </div>
                     <div class="card-body p-3">
                         <div class="row g-3">
                             <div class="col-md-4">
                                 <div class="d-flex flex-column border-end border-dark pe-3">
                                     <small class="text-muted fw-bold text-uppercase" style="font-size: 0.7rem;">Stock en Máquinas</small>
                                     <span class="fs-5 fw-bold font-monospace text-dark">$@Valorizacion.ValorMaquinas.ToString("N0")</span>
                                 </div>
                             </div>
                             <div class="col-md-4">
                                 <div class="d-flex flex-column border-end border-dark pe-3">
                                      <small class="text-muted fw-bold text-uppercase" style="font-size: 0.7rem;">Stock en Bodega</small>
                                      <span class="fs-5 fw-bold font-monospace text-dark">$@Valorizacion.ValorBodega.ToString("N0")</span>
                                 </div>
                             </div>
                             <div class="col-md-4">
                                 <div class="d-flex flex-column bg-light p-2 border border-secondary rounded-0">
                                      <small class="text-success fw-bold text-uppercase" style="font-size: 0.7rem;">Capital Total Mercadería</small>
                                      <span class="fs-4 fw-bold font-monospace text-success">$@Valorizacion.ValorTotal.ToString("N0")</span>
                                 </div>
                             </div>
                         </div>
                     </div>
                 </div>
            </div>
        </div>
    }

    @if (Resumen != null)
    {
        <!-- 1. BLOQUE DE VENTAS (INGRESOS) -->
        <div class="row mb-2">
            <div class="col-12">
                <div class="card border-2 border-dark rounded-0 shadow-sm mb-2">
                    <div class="card-header bg-primary text-white rounded-0 p-2 cursor-pointer" @onclick="ToggleVentas" style="cursor: pointer;">
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center gap-2">
                                <span class="bg-white text-primary px-2 py-1 rounded-0 fw-bold" style="font-size: 0.75rem;">01</span>
                                <span class="fw-bold text-uppercase">VENTAS NETAS</span>
                            </div>
                            <div class="d-flex align-items-center gap-3">
                                <span class="fs-5 fw-bold font-monospace">$@((Resumen.IngresosVentas - Resumen.Mermas).ToString("N0"))</span>
                                <i class="bi @(_isVentasExpanded ? "bi-chevron-up" : "bi-chevron-down")"></i>
                            </div>
                        </div>
                    </div>
                    @if (_isVentasExpanded)
                    {
                        <div class="card-body bg-light p-3">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="text-muted fw-bold text-uppercase small">Ventas Brutas</span>
                                <span class="fw-bold fs-6 text-dark font-monospace">$@Resumen.IngresosVentas.ToString("N0")</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="text-danger fw-bold text-uppercase small">(-) Mermas / Pérdidas</span>
                                <span class="fw-bold fs-6 text-danger font-monospace">-$@Resumen.Mermas.ToString("N0")</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- 2. BLOQUE DE COSTO DIRECTO -->
        <div class="row mb-2">
            <div class="col-12">
                <div class="card border-2 border-dark rounded-0 shadow-sm mb-2">
                    <div class="card-header bg-warning text-dark rounded-0 p-2 cursor-pointer" @onclick="ToggleCosto" style="cursor: pointer;">
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center gap-2">
                                <span class="bg-dark text-white px-2 py-1 rounded-0 fw-bold" style="font-size: 0.75rem;">02</span>
                                <span class="fw-bold text-uppercase">MARGEN BRUTO</span>
                            </div>
                            <div class="d-flex align-items-center gap-3">
                                <span class="fs-5 fw-bold font-monospace">$@Resumen.UtilidadTotal.ToString("N0")</span>
                                <span class="badge bg-dark text-white rounded-0 small">@GetMarginPercentage()%</span>
                                <i class="bi @(_isCostoExpanded ? "bi-chevron-up" : "bi-chevron-down")"></i>
                            </div>
                        </div>
                    </div>
                    @if (_isCostoExpanded)
                    {
                        <div class="card-body bg-light p-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <span class="text-muted fw-bold text-uppercase small d-block">(-) Costo de Venta</span>
                                    <small class="text-muted">Reposición de Mercadería</small>
                                </div>
                                <span class="fw-bold fs-5 text-danger font-monospace">-$@Resumen.TotalCostoVenta.ToString("N0")</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- 3. BLOQUE DE GASTOS DE OPERACIÓN -->
        <div class="row mb-2">
            <div class="col-12">
                <div class="card border-2 border-danger rounded-0 shadow-sm mb-2">
                    <div class="card-header bg-danger text-white rounded-0 p-2 cursor-pointer" @onclick="ToggleGastos" style="cursor: pointer;">
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center gap-2">
                                <span class="bg-white text-danger px-2 py-1 rounded-0 fw-bold" style="font-size: 0.75rem;">03</span>
                                <span class="fw-bold text-uppercase">GASTOS OPERACIÓN</span>
                            </div>
                            <div class="d-flex align-items-center gap-3">
                                <span class="fs-5 fw-bold font-monospace">-$@((Resumen.GastosVariables + Resumen.GastosFijos).ToString("N0"))</span>
                                <i class="bi @(_isGastosExpanded ? "bi-chevron-up" : "bi-chevron-down")"></i>
                            </div>
                        </div>
                    </div>
                    @if (_isGastosExpanded)
                    {
                        <div class="card-body p-3" style="background-color: rgba(220, 53, 69, 0.1);">
                            <div class="row g-2 mb-3">
                                <div class="col-6">
                                    <div class="bg-white border border-danger rounded-0 p-2 text-center h-100">
                                        <span class="fw-bold small text-dark text-uppercase d-block mb-1"><i class="bi bi-truck me-1"></i>Variables</span>
                                        <span class="fw-bold text-danger font-monospace fs-5">-$@Resumen.GastosVariables.ToString("N0")</span>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="bg-white border border-danger rounded-0 p-2 text-center h-100">
                                        <span class="fw-bold small text-dark text-uppercase d-block mb-1"><i class="bi bi-building me-1"></i>Fijos</span>
                                        <span class="fw-bold text-danger font-monospace fs-5">-$@Resumen.GastosFijos.ToString("N0")</span>
                                    </div>
                                </div>
                            </div>

                            @if (MovimientosGastos != null && MovimientosGastos.Any())
                            {
                                <h6 class="fw-bold text-uppercase border-bottom border-danger pb-1 mb-2 text-danger small">Detalle de Gastos</h6>
                                <div class="table-responsive" style="max-height: 250px;">
                                    <table class="table table-sm table-borderless small mb-0">
                                        <tbody>
                                            @foreach (var g in MovimientosGastos)
                                            {
                                                <tr class="border-bottom border-white">
                                                    <td class="text-muted">@g.Fecha.ToString("dd/MM")</td>
                                                    <td class="fw-bold text-dark">@g.Categoria</td>
                                                    <td class="text-truncate" style="max-width: 150px;" title="@g.Descripcion">@g.Descripcion</td>
                                                    <td class="text-end fw-bold text-danger font-monospace">-$@Math.Abs(g.Monto).ToString("N0")</td>
                                                </tr>
                                            }
                                        </tbody>
                                        <tfoot>
                                            @if (_descontarTransbank)
                                            {
                                                 <tr class="bg-white border-top border-danger">
                                                    <td class="text-muted">-</td>
                                                    <td class="fw-bold text-dark">COMISIONES</td>
                                                    <td>Comisión Transbank (Estimada)</td>
                                                    <td class="text-end fw-bold text-danger font-monospace">-$@Resumen.CostoTransbank.ToString("N0")</td>
                                                </tr>                                           
                                            }
                                        </tfoot>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <div class="text-center text-muted small py-2">
                                    Cargando detalle o sin gastos registrados...
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- 4. RESULTADO FINAL -->
        <div class="row mb-2">
             <div class="col-12">
                 <h5 class="fw-bold text-uppercase border-bottom border-2 border-dark pb-2 mb-3 d-flex align-items-center gap-2 text-success">
                     <span class="bg-dark text-white px-2 py-1 rounded-0" style="font-size: 0.8rem;">04</span>
                     RESULTADO FINAL
                </h5>
            </div>

            <div class="col-12 mb-3">
                 <div class="card border-2 border-dark shadow rounded-0 bg-dark text-white">
                     <div class="card-body d-flex flex-column flex-md-row justify-content-between align-items-center p-3 p-md-4">
                        <div class="text-center text-md-start mb-2 mb-md-0">
                             <small class="text-white-50 fw-bold text-uppercase d-block mb-1" style="font-size: 0.7rem;">Resultado Operacional (EBITDA)</small>
                             <h4 class="m-0 fw-bold text-uppercase">(=) UTILIDAD OPERACIONAL</h4>
                        </div>
                        <h2 class="m-0 fw-bold text-white font-monospace">$@Resumen.UtilidadOperacional.ToString("N0")</h2>
                     </div>
                 </div>
            </div>
        </div>

        <!-- TOGGLE TRANSBANK -->
        <div class="row mb-3">
             <div class="col-12 d-flex justify-content-end">
                 <div class="form-check form-switch">
                      <input class="form-check-input" type="checkbox" id="toggleTB" @bind="_descontarTransbank" style="cursor: pointer;">
                      <label class="form-check-label fw-bold user-select-none" for="toggleTB" style="cursor: pointer;">
                          Descontar Comisión Transbank (@Resumen.CantidadVentasTransbank tx ≈ $@Resumen.CostoTransbank.ToString("N0"))
                      </label>
                 </div>
             </div>
        </div>

        <div class="row mb-5">
             <div class="col-12">
                 <div class="card border-2 border-dark shadow-lg h-100 rounded-0 bg-success text-white">
                     <div class="card-body d-flex flex-column justify-content-center align-items-center text-center text-white py-4">
                          <small class="text-uppercase fw-bold text-white opacity-75 mb-2">RESULTADO NETO FINAL</small>
                          <h1 class="display-3 fw-bold m-0 font-monospace">$@GetUtilidadNetaFinal().ToString("N0")</h1>
                          @if (_descontarTransbank)
                          {
                              <small class="text-white-50 mt-2">(Incluye descuento comisión TB)</small>
                          }
                     </div>
                 </div>
             </div>
        </div>

    }
    else
    {
        <div class="d-flex justify-content-center align-items-center border-2 border-dark border bg-light" style="height: 300px;">
            <div class="text-center">
                 <div class="spinner-border text-dark mb-3" role="status"></div>
                 <h5 class="fw-bold text-uppercase">Calculando Finanzas...</h5>
            </div>
        </div>
    }

</div>

@code {
    private DateTime SelectedDate = DateTime.Now;
    private CajaResumenDto? Resumen;
    
    // State for Transbank Toggle
    private bool _descontarTransbank = false;

    // Accordion state
    private bool _isVentasExpanded = false;
    private bool _isCostoExpanded = false;
    private bool _isGastosExpanded = false;

    private void ToggleVentas() => _isVentasExpanded = !_isVentasExpanded;
    private void ToggleCosto() => _isCostoExpanded = !_isCostoExpanded;
    private void ToggleGastos() => _isGastosExpanded = !_isGastosExpanded;

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task ChangeMonth(int months)
    {
        SelectedDate = SelectedDate.AddMonths(months);
        await CargarDatos();
    }

    private async Task GoToToday()
    {
        SelectedDate = DateTime.Now;
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        try
        {
            string query = $"?month={SelectedDate.Month}&year={SelectedDate.Year}";
            Resumen = await Http.GetFromJsonAsync<CajaResumenDto>($"api/caja/resumen{query}");

            // Fetch detail for breakdown
            var allMovs = await Http.GetFromJsonAsync<List<MovimientoCajaDto>>($"api/caja/movimientos{query}");
            if (allMovs != null)
            {
                MovimientosGastos = allMovs
                    .Where(m => _targetCategories.Contains(m.Categoria) && m.Monto < 0)
                    .OrderBy(m => m.Fecha)
                    .ToList();
            }

            // Fetch KPI Stock (Snapshot) - Only fetch once or always? Always is fine.
            Valorizacion = await Http.GetFromJsonAsync<ValorizacionStockDto>("api/caja/valorizacion");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
    }

    private string GetMarginPercentage()
    {
        if (Resumen == null || Resumen.IngresosVentas == 0) return "0.0";
        double margin = (double)Resumen.UtilidadTotal / (double)Resumen.IngresosVentas;
        return (margin * 100).ToString("F1");
    }

    private decimal GetUtilidadNetaFinal()
    {
        if (Resumen == null) return 0;
        decimal neta = Resumen.UtilidadNeta;
        if (_descontarTransbank)
        {
            neta -= Resumen.CostoTransbank;
        }
        return neta;
    }

    // List of Expenses for Breakdown
    private List<MovimientoCajaDto>? MovimientosGastos;
    private ValorizacionStockDto? Valorizacion;

    // Categories to include in "Gastos Operativos" breakdown
    private readonly string[] _targetCategories = new[] 
    { 
        "LOGISTICA", "PEAJES", "INSUMOS", "MANTENCION", // Variables
        "INFRA", "ARRIENDO_POS", "INTERNET", "COMISIONES", "OTROS" // Fijos
    };
}
```
