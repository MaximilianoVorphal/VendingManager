@page "/test-costos"
@using VendingManager.Shared.DTOs
@inject HttpClient Http
@inject IJSRuntime JS

<div class="container-fluid px-4 py-4" style="font-family: 'Segoe UI', sans-serif;">
    <h2 class="fw-bold mb-4"><i class="bi bi-graph-up me-2"></i> Historial de Costos de Productos</h2>

    <div class="row mb-4">
        <div class="col-md-4">
            <label class="form-label fw-bold">Seleccione un Producto</label>
            <select class="form-select border-dark border-2 rounded-0" @onchange="OnProductoSeleccionado">
                <option value="0">-- Elija un Producto --</option>
                @if (Productos != null)
                {
                    @foreach (var prod in Productos)
                    {
                        <option value="@prod.Id">@prod.Nombre</option>
                    }
                }
            </select>
        </div>
    </div>

    @if (Cargando)
    {
        <div class="text-center py-5">
            <div class="spinner-grow text-dark" role="status"></div>
            <p class="mt-2 fw-bold">Cargando historial...</p>
        </div>
    }
    else if (Historial != null)
    {
        if (!Historial.Any())
        {
            <div class="alert alert-warning border-dark border-2 rounded-0 fw-bold">
                <i class="bi bi-info-circle me-2"></i> No hay historial de compras registrado para este producto.
            </div>
        }
        else
        {
            <div class="card border-dark border-2 rounded-0 shadow-sm">
                <div class="card-header bg-dark text-white rounded-0">
                    <h5 class="mb-0 fw-bold">Variación de Costo de Compra</h5>
                </div>
                <div class="card-body">
                    <canvas id="costoChart" width="400" height="150"></canvas>
                </div>
                <div class="card-footer bg-light border-dark border-top">
                    <small class="text-muted fw-bold">
                        <i class="bi bi-clock-history me-1"></i> Mostrando @Historial.Count registros de compras.
                    </small>
                </div>
            </div>
        }
    }
</div>

@code {
    private List<ProductoSimpleDto>? Productos;
    private List<HistorialCostoViewDto>? Historial;
    private bool Cargando = false;
    private int SeleccionActual = 0;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Reutilizamos el endpoint existente
            Productos = await Http.GetFromJsonAsync<List<ProductoSimpleDto>>("api/Ventas/lista-productos");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando productos: {ex.Message}");
        }
    }

    private async Task OnProductoSeleccionado(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id))
        {
            SeleccionActual = id;
            if (id > 0)
            {
                await CargarHistorial(id);
            }
            else
            {
                Historial = null;
            }
        }
    }

    private async Task CargarHistorial(int id)
    {
        Cargando = true;
        Historial = null;
        StateHasChanged();

        try
        {
            Historial = await Http.GetFromJsonAsync<List<HistorialCostoViewDto>>($"api/Productos/{id}/historial-costos");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando historial: {ex.Message}");
        }
        finally
        {
            Cargando = false;
            StateHasChanged();
        }

        if (Historial != null && Historial.Any())
        {
            await DibujarGrafico();
        }
    }

    private async Task DibujarGrafico()
    {
        if (Historial == null || !Historial.Any()) return;

        // Formatear datos para Chart.js
        var labels = Historial.Select(h => h.Fecha.ToString("dd/MM/yyyy HH:mm")).ToArray();
        var dataValues = Historial.Select(h => h.CostoUnitario).ToArray();
        
        // Vamos a incluir el Origen como tooltip
        var dataOrigenes = Historial.Select(h => h.Origen).ToArray();

        var config = new
        {
            type = "line",
            data = new
            {
                labels = labels,
                datasets = new[]
                {
                    new
                    {
                        label = "Costo Unitario ($)",
                        data = dataValues,
                        borderColor = "#ffc107", // btn-warning color
                        backgroundColor = "rgba(255, 193, 7, 0.2)",
                        borderWidth = 3,
                        pointRadius = 5,
                        pointBackgroundColor = "#212529",
                        tension = 0.1,
                        fill = true
                    }
                }
            },
            options = new
            {
                responsive = true,
                plugins = new
                {
                    title = new
                    {
                        display = false
                    },
                    tooltip = new {
                        callbacks = new {
                            // Dejamos que ChartJS maneje los tooltips estándar
                        }
                    }
                },
                scales = new
                {
                    y = new
                    {
                        beginAtZero = false,
                        grid = new { color = "#e9ecef" }
                    },
                    x = new
                    {
                        grid = new { display = false }
                    }
                }
            }
        };

        // Darle un pequeÃ±o delay para asegurar que el canvas se haya renderizado en DOM tras el Update de Blazor
        await Task.Delay(50);
        await JS.InvokeVoidAsync("ChartJsInterop.setupChart", "costoChart", config);
    }

    public class ProductoSimpleDto
    {
        public int Id { get; set; }
        public string Nombre { get; set; } = string.Empty;
    }
}
