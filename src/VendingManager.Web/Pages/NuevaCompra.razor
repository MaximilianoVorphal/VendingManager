@page "/compras/nueva"
@using VendingManager.Shared.DTOs
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>NUEVA COMPRA</PageTitle>

    <div class="industrial-wrapper container-fluid px-4 mt-4">
    <div class="row align-items-center mb-4 border-bottom border-3 border-dark pb-3 g-3">
        <div class="col-md-8 col-12">
            <h2 class="m-0 fw-bold text-uppercase" style="letter-spacing: -1px; color: #333;">
                <i class="bi bi-cart-plus me-2"></i>REGISTRAR NUEVA COMPRA
            </h2>
            <small class="text-muted fw-bold">INGRESO DE FACTURAS O BOLETAS AL SISTEMA</small>
        </div>
        <div class="col-md-4 col-12 text-md-end">
            <button class="btn btn-outline-dark rounded-0 fw-bold shadow-sm" @onclick='() => Navigation.NavigateTo("/compras")'>
                <i class="bi bi-arrow-left me-2"></i>VOLVER A COMPRAS
            </button>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-4">
            <div class="card border-2 border-dark rounded-0 shadow my-4">
                <div class="card-header bg-dark text-white rounded-0 fw-bold d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-receipt"></i> DATOS DEL DOCUMENTO</span>
                    <div class="d-flex gap-2">
                        <label class="btn btn-sm btn-outline-info rounded-0 fw-bold mb-0">
                            <i class="bi bi-camera"></i> ESCANEAR (IA)
                            <InputFile OnChange="HandleImageUpload" accept="image/*" style="display: none;" />
                        </label>
                    </div>
                </div>
                <div class="card-body bg-light">
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted">PROVEEDOR *</label>
                        <input type="text" class="form-control border-dark rounded-0" @bind="factura.Proveedor" placeholder="Ej: ALVI, EL MOLINO..." />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted">Nº FACTURA / BOLETA</label>
                        <input type="text" class="form-control border-dark rounded-0" @bind="factura.NumeroDocumento" placeholder="Ej: F-123456" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted">FECHA DE COMPRA</label>
                        <input type="date" class="form-control border-dark rounded-0" @bind="factura.FechaCompra" />
                    </div>
                    
                    @if (ProcesandoOCR)
                    {
                        <div class="alert alert-info rounded-0 border-dark fw-bold py-2 d-flex align-items-center shadow-sm">
                            <div class="spinner-border text-info spinner-border-sm me-2" role="status"></div>
                            <div>Extrayendo productos con Inteligencia Artificial...</div>
                        </div>
                    }
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted">TIPO DE DOCUMENTO</label>
                        <select class="form-select border-dark rounded-0 fw-bold @(factura.TipoFactura == "MERCADERIA" ? "text-success" : "text-primary")" @bind="factura.TipoFactura">
                            <option value="MERCADERIA">🛒 MERCADERÍA (ABASTECIMIENTO)</option>
                            <option value="GASTO_GENERAL">⛽ GASTO GENERAL (BENCINA, OTROS)</option>
                        </select>
                    </div>

                    <div class="form-check form-switch pt-2 border-top border-dark mt-3 pt-3">
                        <input class="form-check-input border-dark" type="checkbox" id="pagado" @bind="factura.PagadaCaja" />
                        <label class="form-check-label fw-bold small" for="pagado">ESTADO: PAGADA AL CONTADO (Generar Gasto en Caja)</label>
                    </div>

                    @if (!string.IsNullOrEmpty(FacturaPreviewUrl))
                    {
                        <div class="mt-3 p-2 border border-warning rounded-0 bg-warning bg-opacity-25">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="fw-bold small text-muted"><i class="bi bi-paperclip"></i> FACTURA ADJUNTA</span>
                                <button class="btn btn-sm btn-outline-danger rounded-0" @onclick="ClearFacturaPreview"><i class="bi bi-x-lg"></i></button>
                            </div>
                            @if (FacturaPreviewUrl.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase))
                            {
                                <a href="@FacturaPreviewUrl" target="_blank" class="btn btn-sm btn-outline-dark rounded-0">
                                    <i class="bi bi-file-earmark-pdf-fill text-danger me-1"></i> Ver PDF
                                </a>
                            }
                            else
                            {
                                <img src="@FacturaPreviewUrl" class="img-thumbnail border-dark" style="max-height: 120px; object-fit: cover;" />
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card border-2 border-dark rounded-0 shadow my-4">
                <div class="card-header bg-dark text-white rounded-0 fw-bold d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-box-seam"></i> DETALLE DE PRODUCTOS</span>
                    <span class="badge bg-success border border-white text-uppercase" style="font-size: 0.9rem;">Total Requerido: @(CalcularTotal().ToString("C0"))</span>
                </div>
                <div class="card-body">
                    <div class="row align-items-end mb-4 bg-light p-3 border border-dark mx-0">
                        @if (factura.TipoFactura == "MERCADERIA")
                        {
                            <div class="col-md-6 mb-2 mb-md-0">
                                <label class="form-label fw-bold small text-muted">BUSCAR PRODUCTO MANUAL</label>
                                <select class="form-select border-dark rounded-0" @bind="productoSeleccionadoId">
                                    <option value="0">-- SELECCIONE UN PRODUCTO --</option>
                                    @foreach (var p in ProductosDisponibles)
                                    {
                                        <option value="@p.Id">@p.Nombre (Stock: @p.StockBodega)</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6 d-grid">
                                <button class="btn btn-outline-dark rounded-0 fw-bold" @onclick="AgregarProducto" disabled="@(productoSeleccionadoId == 0)">
                                    <i class="bi bi-plus-lg me-1"></i> AÑADIR A LA LISTA
                                </button>
                            </div>
                        }
                        else
                        {
                            <div class="col-md-6 mb-2 mb-md-0">
                                <label class="form-label fw-bold small text-muted">DESCRIPCIÓN DEL GASTO</label>
                                <input type="text" class="form-control border-dark rounded-0" @bind="descripcionGastoLibre" placeholder="Ej: Gasolina Camioneta" />
                            </div>
                            <div class="col-md-3 mb-2 mb-md-0">
                                <label class="form-label fw-bold small text-muted">MONTO $</label>
                                <input type="number" class="form-control border-dark rounded-0" @bind="montoGastoLibre" />
                            </div>
                            <div class="col-md-3 d-grid">
                                <button class="btn btn-primary rounded-0 fw-bold" @onclick="AgregarGastoGeneral" disabled="@(string.IsNullOrWhiteSpace(descripcionGastoLibre) || montoGastoLibre <= 0)">
                                    <i class="bi bi-plus-lg me-1"></i> AÑADIR GASTO
                                </button>
                            </div>
                        }
                    </div>

                    @if (detalles.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-bordered border-dark table-hover align-middle">
                                <thead class="bg-secondary text-white text-uppercase text-center" style="font-size: 0.85rem;">
                                    <tr>
                                        <th class="text-start">PRODUCTO <i class="bi bi-tag"></i></th>
                                        <th style="width: 100px;">CANT <i class="bi bi-hash"></i></th>
                                        <th style="width: 150px;">PRECIO <i class="bi bi-currency-dollar"></i></th>
                                        <th style="width: 130px;">SUBTOTAL</th>
                                        <th style="width: 90px;" class="text-center">PEND. <i class="bi bi-clock"></i></th>
                                        <th style="width: 50px;"></th>
                                    </tr>
                                </thead>
                                <tbody class="fw-bold" style="font-size: 0.9rem;">
                                    @foreach (var d in detalles)
                                    {
                                        <tr class="@(d.EsPendiente ? "pending-row" : "")">
                                            <td>
                                                @if (factura.TipoFactura == "MERCADERIA")
                                                {
                                                    @if (d.ProductoId == 0 || d.ProductoId == null)
                                                    {
                                                        <select class="form-select form-select-sm border-2 border-warning rounded-0 fw-bold bg-light text-dark" @bind="d.ProductoId">
                                                            <option value="0">⚠️ ASIGNAR: "@d.ProductoNombre"</option>
                                                            @foreach (var p in ProductosDisponibles)
                                                            {
                                                                <option value="@p.Id">@p.Nombre</option>
                                                            }
                                                        </select>
                                                    }
                                                    else
                                                    {
                                                        <div class="d-flex align-items-center justify-content-between">
                                                            <span>@d.ProductoNombre</span>
                                                            <button class="btn btn-sm btn-link text-dark p-0 ms-2" @onclick="() => d.ProductoId = 0" title="Corregir asociación">
                                                                <i class="bi bi-pencil-square"></i>
                                                            </button>
                                                        </div>
                                                    }
                                                }
                                                else
                                                {
                                                    <input type="text" class="form-control form-control-sm border-dark rounded-0" @bind="d.DescripcionItem" placeholder="Descripción del gasto..." />
                                                }
                                            </td>
                                            <td>
                                                <input type="number" class="form-control form-control-sm border-dark rounded-0 text-center font-monospace" @bind="d.Cantidad" @bind:event="oninput" min="1" disabled="@(factura.TipoFactura == "GASTO_GENERAL")" />
                                            </td>
                                            <td>
                                                <div class="input-group input-group-sm">
                                                    <span class="input-group-text bg-dark text-white border-dark rounded-0">$</span>
                                                    <input type="number" class="form-control border-dark rounded-0 font-monospace text-end" @bind="d.CostoUnitario" @bind:event="oninput" min="0" />
                                                </div>
                                            </td>
                                            <td class="text-end text-success font-monospace fs-6">
                                                @((d.Cantidad * d.CostoUnitario).ToString("C0"))
                                            </td>
                                            <td class="text-center">
                                                <div class="form-check form-switch d-flex justify-content-center m-0 p-0">
                                                    <input class="form-check-input m-0" type="checkbox" @bind="d.EsPendiente" title="Dejar pendiente" />
                                                </div>
                                            </td>
                                            <td class="text-center">
                                                <button class="btn btn-sm btn-outline-danger border-dark rounded-0" @onclick="() => EliminarDetalle(d)">
                                                    <i class="bi bi-trash-fill"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        
                        <div class="d-grid mt-4">
                            <button class="btn btn-success btn-lg rounded-0 border-dark fw-bold shadow-sm" @onclick="GuardarCompra" disabled="@Guardando">
                                @if (Guardando)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span>
                                    <span> PROCESANDO REGISTRO...</span>
                                }
                                else
                                {
                                    <i class="bi bi-save-fill me-2"></i> <span>CONFIRMAR COMPRA ($@(CalcularTotal().ToString("N0")))</span>
                                }
                            </button>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted my-5 py-5 border border-dark border-1 rounded-0 bg-light">
                            <i class="bi bi-cart-x display-1 mb-3 text-secondary"></i>
                            <h5 class="fw-bold text-uppercase">CANASTA VACÍA</h5>
                            <p class="small">Aún no hay productos en esta factura. Escanea una imagen o búscalos manualmente.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(MensajeError))
    {
        <div class="alert alert-danger border-dark rounded-0 fw-bold shadow-sm fade show mb-4">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @MensajeError
        </div>
    }
</div>

@code {
    private RegistrarCompraRequestDto factura = new();
    private List<ProductoSimpleDto> ProductosDisponibles = new();
    
    // Lista temporal para la UI (necesitamos el nombre)
    private List<DetalleUI> detalles = new();
    
    private int productoSeleccionadoId = 0;
    private string descripcionGastoLibre = "";
    private decimal montoGastoLibre = 0;
    
    private bool Guardando = false;
    private bool ProcesandoOCR = false;
    private string? MensajeError;
    private IBrowserFile? FacturaFile;
    private string? FacturaPreviewUrl;
    private byte[]? FacturaPreviewData;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var prods = await Http.GetFromJsonAsync<List<ProductoSimpleDto>>("api/productos");
            if (prods != null)
                ProductosDisponibles = prods.OrderBy(p => p.Nombre).ToList();
        }
        catch (Exception ex)
        {
            MensajeError = "Error al cargar productos: " + ex.Message;
        }
    }

    private void AgregarProducto()
    {
        if (productoSeleccionadoId == 0) return;

        // Verificar si ya está en la lista para no duplicar fila
        if (detalles.Any(d => d.ProductoId == productoSeleccionadoId))
        {
            var existente = detalles.First(d => d.ProductoId == productoSeleccionadoId);
            existente.Cantidad++;
        }
        else
        {
            var p = ProductosDisponibles.FirstOrDefault(x => x.Id == productoSeleccionadoId);
            if (p != null)
            {
                detalles.Add(new DetalleUI
                {
                    ProductoId = p.Id,
                    ProductoNombre = p.Nombre,
                    DescripcionItem = p.Nombre,
                    Cantidad = 1,
                    CostoUnitario = p.CostoPromedio // Usar el costo promedio actual como sugerencia
                });
            }
        }

        productoSeleccionadoId = 0; // Resetear selector
    }

    private void AgregarGastoGeneral()
    {
        if (string.IsNullOrWhiteSpace(descripcionGastoLibre)) return;

        detalles.Add(new DetalleUI
        {
            ProductoId = null,
            ProductoNombre = descripcionGastoLibre,
            DescripcionItem = descripcionGastoLibre,
            Cantidad = 1,
            CostoUnitario = montoGastoLibre
        });

        descripcionGastoLibre = "";
        montoGastoLibre = 0;
    }

    private void EliminarDetalle(DetalleUI d)
    {
        detalles.Remove(d);
    }

    private decimal CalcularTotal()
    {
        return detalles.Where(d => !d.EsPendiente).Sum(d => d.Cantidad * d.CostoUnitario);
    }

    private async Task GuardarCompra()
    {
        MensajeError = null;

        if (string.IsNullOrWhiteSpace(factura.Proveedor))
        {
            MensajeError = "Debe ingresar el nombre del Proveedor.";
            return;
        }

        if (!detalles.Any())
        {
            MensajeError = "Debe agregar al menos un producto o gasto a la factura.";
            return;
        }

        if (factura.TipoFactura == "MERCADERIA" && detalles.Any(d => !d.EsPendiente && (d.ProductoId == 0 || d.ProductoId == null)))
        {
            MensajeError = "Debe asignar un producto del sistema a cada ítem (selecciónelos en los recuadros amarillos).";
            return;
        }

        if (factura.TipoFactura == "GASTO_GENERAL" && detalles.Any(d => string.IsNullOrWhiteSpace(d.DescripcionItem)))
        {
            MensajeError = "Todos los gastos deben tener una descripción.";
            return;
        }

        Guardando = true;

        try
        {
            factura.Estado = factura.PagadaCaja ? "PAGADA" : "PENDIENTE";
            factura.Detalles = detalles.Select(d => new RegistrarDetalleCompraRequestDto
            {
                ProductoId = d.ProductoId,
                DescripcionItem = d.DescripcionItem,
                Cantidad = d.Cantidad,
                CostoUnitario = d.CostoUnitario,
                EsPendiente = d.EsPendiente
            }).ToList();

            var response = await Http.PostAsJsonAsync("api/compras", factura);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<System.Text.Json.JsonElement>();
                int compraId = result.GetProperty("id").GetInt32();

                // Upload factura image if attached
                bool uploadOk = true;
                if (FacturaPreviewData != null)
                {
                    uploadOk = await UploadFacturaImagen(compraId);
                }

                // Only navigate if upload succeeded (or wasn't needed)
                if (uploadOk)
                {
                    ClearFacturaPreview();
                    Navigation.NavigateTo("/compras");
                }
                // If upload failed, MensajeError was already set by UploadFacturaImagen
                // Stay on page so user can see the error and retry
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                MensajeError = $"Error al registrar: {error}";
            }
        }
        catch (Exception ex)
        {
            MensajeError = $"Ocurrió un error inesperado: {ex.Message}";
        }
        finally
        {
            Guardando = false;
        }
    }

    private async Task<bool> UploadFacturaImagen(int compraId)
    {
        if (FacturaPreviewData == null) return true;

        try
        {
            using var content = new MultipartFormDataContent();
            var byteContent = new ByteArrayContent(FacturaPreviewData);
            byteContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(FacturaFile?.ContentType ?? "image/jpeg");
            content.Add(byteContent, "file", FacturaFile?.Name ?? "factura.jpg");

            var uploadResponse = await Http.PostAsync($"api/compras/{compraId}/factura", content);
            if (!uploadResponse.IsSuccessStatusCode)
            {
                MensajeError = "Compra guardada (ID: " + compraId + "), pero falló la carga de la imagen de factura: " + await uploadResponse.Content.ReadAsStringAsync();
                return false;
            }
            return true;
        }
        catch (Exception ex)
        {
            MensajeError = "Compra guardada (ID: " + compraId + "), pero falló la carga de la imagen de factura: " + ex.Message;
            return false;
        }
    }

    private async Task HandleImageUpload(InputFileChangeEventArgs e)
    {
        MensajeError = null;
        var file = e.File;
        if (file == null) return;

        const long maxSize = 10 * 1024 * 1024; // max 10MB
        if (file.Size > maxSize)
        {
            MensajeError = "La imagen supera los 10MB.";
            return;
        }

        ProcesandoOCR = true;

        try
        {
            // 1. Leer el archivo a memoria primero
            byte[] fileBytes;
            using (var stream = file.OpenReadStream(maxSize))
            using (var memoryStream = new MemoryStream())
            {
                await stream.CopyToAsync(memoryStream);
                fileBytes = memoryStream.ToArray();
            }

            // 2. Guardar como factura adjunta automáticamente
            FacturaFile = file;
            FacturaPreviewData = fileBytes;
            FacturaPreviewUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(fileBytes)}";

            // 3. Enviar a OCR con los bytes en memoria
            using var content = new MultipartFormDataContent();
            var byteContent = new ByteArrayContent(fileBytes);
            var mimeType = ResolveMimeType(file.Name, file.ContentType);
            byteContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(mimeType);
            content.Add(byteContent, "file", file.Name);

            var response = await Http.PostAsync("api/compras/upload-factura", content);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<OcrInvoiceResultDto>();
                if (result != null)
                {
                    // Llenar campos base
                    if (!string.IsNullOrEmpty(result.Proveedor)) factura.Proveedor = result.Proveedor;
                    if (!string.IsNullOrEmpty(result.NumeroDocumento)) factura.NumeroDocumento = result.NumeroDocumento;

                    if (TryParseFechaChile(result.Fecha, out DateTime dtOut))
                    {
                        factura.FechaCompra = dtOut;
                    }

                    // Mapear items
                    foreach (var item in result.Items)
                    {
                        int idProducto = 0;
                        string nombreProd = item.Producto ?? "Desconocido";

                        if (item.ProductoIdMatch.HasValue && item.ProductoIdMatch.Value > 0)
                        {
                            var matchDb = ProductosDisponibles.FirstOrDefault(p => p.Id == item.ProductoIdMatch.Value);
                            if (matchDb != null)
                            {
                                idProducto = matchDb.Id;
                                nombreProd = matchDb.Nombre; // Usar el nombre oficial
                            }
                        }

                        detalles.Add(new DetalleUI
                        {
                            ProductoId = idProducto > 0 ? idProducto : null,
                            ProductoNombre = nombreProd,
                            DescripcionItem = nombreProd,
                            Cantidad = item.Cantidad > 0 ? (int)Math.Round(item.Cantidad) : 1,
                            CostoUnitario = item.CostoUnitario
                        });
                    }
                }
            }
            else
            {
                MensajeError = "Error al escanear la imagen. " + await response.Content.ReadAsStringAsync();
            }
        }
        catch(Exception ex)
        {
            MensajeError = "Error procesando IA: " + ex.Message;
        }
        finally
        {
            ProcesandoOCR = false;
        }
    }

    private void ClearFacturaPreview()
    {
        FacturaFile = null;
        FacturaPreviewUrl = null;
        FacturaPreviewData = null;
    }

    // Resuelve el MIME type: si el ContentType viene vacío (ej: extensión no reconocida),
    // lo infiere de la extensión del archivo.
    private static string ResolveMimeType(string fileName, string? contentType)
    {
        if (!string.IsNullOrEmpty(contentType))
            return contentType;

        var ext = Path.GetExtension(fileName)?.ToLowerInvariant();
        return ext switch
        {
            ".jpg" or ".jpeg" or ".jpge" => "image/jpeg",
            ".png" => "image/png",
            ".webp" => "image/webp",
            ".bmp" => "image/bmp",
            ".gif" => "image/gif",
            ".pdf" => "application/pdf",
            _ => "application/octet-stream"
        };
    }

    /// <summary>
    /// Parsea fechas en formato chileno/ISO sin ambigüedad día↔año.
    /// Prioriza dd-MM-yyyy y dd/MM/yyyy, luego intenta ISO 8601.
    /// </summary>
    private static bool TryParseFechaChile(string? fecha, out DateTime result)
    {
        result = default;
        if (string.IsNullOrWhiteSpace(fecha)) return false;

        // Formatos en orden de prioridad (el más común en boletas chilenas primero)
        string[] formats = { "dd-MM-yyyy", "dd/MM/yyyy", "dd-MM-yy", "dd/MM/yy",
                             "yyyy-MM-dd", "yyyy/MM/dd", "d-M-yyyy", "d/M/yyyy" };

        return DateTime.TryParseExact(fecha.Trim(), formats,
            System.Globalization.CultureInfo.InvariantCulture,
            System.Globalization.DateTimeStyles.None, out result);
    }

    // Clase auxiliar para la UI
    private class DetalleUI
    {
        public int? ProductoId { get; set; }
        public string ProductoNombre { get; set; } = string.Empty;
        public string DescripcionItem { get; set; } = string.Empty;
        public int Cantidad { get; set; }
        public decimal CostoUnitario { get; set; }
        public bool EsPendiente { get; set; }
    }
}
