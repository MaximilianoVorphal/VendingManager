@page "/compras"
@using VendingManager.Shared.DTOs
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>COMPRAS</PageTitle>

    <div class="industrial-wrapper container-fluid px-4 mt-4">
    <div class="row align-items-center mb-4 border-bottom border-3 border-dark pb-3">
        <div class="col-12 d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <h2 class="m-0 fw-bold text-uppercase" style="letter-spacing: -1px;">CENTRO DE COMPRAS</h2>
                <small class="text-muted fw-bold">GESTIÓN DE FACTURAS Y BOLETAS</small>
            </div>

            <div class="d-flex flex-wrap gap-2 justify-content-end">
                <!-- SEARCH BAR -->
                <div class="input-group" style="max-width: 300px;">
                    <span class="input-group-text bg-white border-dark rounded-0"><i class="bi bi-search"></i></span>
                    <input type="text" class="form-control border-dark rounded-0 shadow-sm"
                        placeholder="Buscar proveedor o documento..." @bind="SearchTerm" @bind:event="oninput" />
                </div>
                <button class="btn btn-dark rounded-0 fw-bold shadow animate__animated animate__fadeIn" @onclick='() => Navigation.NavigateTo("/compras/nueva")'>
                    <i class="bi bi-plus-lg me-2"></i>NUEVA COMPRA
                </button>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Error))
    {
        <div class="alert alert-danger border-dark rounded-0 fw-bold mb-4 shadow-sm fade show">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @Error
        </div>
    }
    
    @if (!string.IsNullOrEmpty(MensajeExito))
    {
        <div class="alert alert-success border-dark rounded-0 fw-bold mb-4 shadow-sm fade show">
            <i class="bi bi-check-circle-fill me-2"></i> @MensajeExito
        </div>
    }

    <div class="card border-2 border-dark rounded-0 shadow my-4">
        <div class="card-header bg-dark text-white rounded-0 fw-bold d-flex justify-content-between align-items-center flex-wrap">
            <span>HISTORIAL DE COMPRAS: @FilteredCompras.Count() REGISTROS</span>
            <span>TOTAL GASTADO: @FilteredCompras.Sum(c => c.MontoTotal).ToString("C0")</span>
        </div>
        <div class="table-responsive">
            <table class="table table-hover table-bordered border-dark m-0 align-middle">
                <thead class="bg-secondary text-white text-uppercase small font-monospace fw-bold">
                    <tr>
                        <th>FECHA <i class="bi bi-calendar"></i></th>
                        <th>PROVEEDOR <i class="bi bi-shop"></i></th>
                        <th class="text-center">TIPO <i class="bi bi-tag"></i></th>
                        <th>Nº DOCUMENTO <i class="bi bi-file-earmark-text"></i></th>
                        <th class="text-end">MONTO TOTAL <i class="bi bi-currency-dollar"></i></th>
                        <th class="text-center">ESTADO <i class="bi bi-info-circle"></i></th>
                        <th class="text-center" style="min-width: 140px;">ACCIONES</th>
                    </tr>
                </thead>
                <tbody class="bg-white fw-bold" style="font-size: 0.9rem;">
                    @if (Cargando)
                    {
                        <tr>
                            <td colspan="7" class="text-center p-4">
                                <div class="spinner-border text-dark spinner-border-sm me-2" role="status"></div>
                                Cargando datos...
                            </td>
                        </tr>
                    }
                    else if (!ListaCompras.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center p-4 text-muted">No se han registrado compras.</td>
                        </tr>
                    }
                    else if (!FilteredCompras.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center p-4 text-muted">No se encontraron resultados para "@SearchTerm".</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var c in FilteredCompras)
                        {
                            <tr>
                                <td>@c.FechaCompra.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@c.Proveedor</td>
                                <td class="text-center">
                                    @if (c.TipoFactura == "GASTO_GENERAL")
                                    {
                                        <span class="badge bg-primary rounded-0 small px-2 py-1"><i class="bi bi-fuel-pump-fill me-1"></i>GASTO</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success rounded-0 small px-2 py-1"><i class="bi bi-box-seam-fill me-1"></i>ABASTECER</span>
                                    }
                                </td>
                                <td><span class="font-monospace">@(string.IsNullOrEmpty(c.NumeroDocumento) ? "S/N" : c.NumeroDocumento)</span></td>
                                <td class="text-end text-success font-monospace">@c.MontoTotal.ToString("C0")</td>
                                <td class="text-center">
                                    @if(c.Estado == "PAGADA")
                                    {
                                        <span class="badge bg-success border border-dark rounded-0 text-white"><i class="bi bi-check-circle-fill me-1"></i>PAGADA</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning border border-dark rounded-0 text-dark"><i class="bi bi-clock-history me-1"></i>PENDIENTE</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-2 flex-wrap">
                                        @if (!string.IsNullOrEmpty(c.FacturaImagenPath))
                                        {
                                            <a href="api/compras/@c.Id/factura" target="_blank" 
                                               class="btn btn-sm btn-outline-info rounded-0 fw-bold border-dark" title="Ver factura escaneada">
                                                <i class="bi bi-file-earmark-arrow-down-fill"></i> VER FACTURA
                                            </a>
                                        }
                                        <button class="btn btn-sm btn-outline-dark rounded-0 fw-bold border-dark" title="Ver Detalles" @onclick="() => VerDetalles(c)">
                                            <i class="bi bi-eye-fill"></i> DETALLES
                                        </button>
                                        <button class="btn btn-sm btn-outline-warning rounded-0 fw-bold border-dark text-dark" title="Editar Compra" @onclick='() => Navigation.NavigateTo($"/compras/editar/{c.Id}")'>
                                            <i class="bi bi-pencil-square"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger rounded-0 fw-bold border-dark" title="Eliminar Compra" @onclick="() => ConfirmarEliminacion(c)">
                                            <i class="bi bi-trash-fill"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- MODAL VER DETALLES -->
@if (CompraSeleccionada != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content rounded-0 border-2 border-dark shadow-lg">
                <div class="modal-header bg-dark text-white rounded-0">
                    <h5 class="modal-title fw-bold"><i class="bi bi-receipt me-2"></i>DETALLE DE COMPRA</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarModalDetalles"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="row mb-4 bg-light border border-dark p-3 mx-0">
                        <div class="col-md-6">
                            <p class="mb-1 text-muted small fw-bold">PROVEEDOR:</p>
                            <span class="fw-bold fs-5">@CompraSeleccionada.Proveedor</span>
                            <br/>
                            <p class="mb-1 mt-2 text-muted small fw-bold">Nº FACTURA/BOLETA:</p>
                            <span class="font-monospace fw-bold">@(string.IsNullOrEmpty(CompraSeleccionada.NumeroDocumento) ? "S/N" : CompraSeleccionada.NumeroDocumento)</span>
                        </div>
                        <div class="col-md-6 text-md-end">
                            <p class="mb-1 text-muted small fw-bold">FECHA:</p>
                            <span class="fw-bold fs-5">@CompraSeleccionada.FechaCompra.ToString("dd/MM/yyyy HH:mm")</span>
                            <br/>
                            <p class="mb-1 mt-2 text-muted small fw-bold">TOTAL PAGADO:</p>
                            <span class="text-success fw-bold fs-4 font-monospace">@CompraSeleccionada.MontoTotal.ToString("C0")</span>
                        </div>
                    </div>
                    
                    @if (!string.IsNullOrEmpty(CompraSeleccionada.FacturaImagenPath))
                    {
                        <div class="mb-4 p-3 border border-dark bg-white">
                            <h6 class="fw-bold mb-2"><i class="bi bi-file-earmark-arrow-down-fill me-2"></i>FACTURA ESCANEADA</h6>
                            <a href="api/compras/@CompraSeleccionada.Id/factura" target="_blank">
                                <img src="api/compras/@CompraSeleccionada.Id/factura" 
                                     class="img-fluid border border-dark" 
                                     style="max-height: 400px; width: 100%; object-fit: contain; background: #f5f5f5;"
                                     alt="Factura de @CompraSeleccionada.Proveedor" />
                            </a>
                            <div class="mt-2">
                                <a href="api/compras/@CompraSeleccionada.Id/factura" target="_blank" 
                                   class="btn btn-sm btn-outline-dark rounded-0 fw-bold">
                                    <i class="bi bi-arrows-fullscreen me-1"></i> ABRIR EN PANTALLA COMPLETA
                                </a>
                            </div>
                        </div>
                    }

                    <h6 class="fw-bold mb-3 border-bottom border-dark pb-2">
                        @(CompraSeleccionada.TipoFactura == "MERCADERIA" ? "PRODUCTOS ADQUIRIDOS" : "DETALLE DE GASTOS")
                    </h6>
                    <div class="table-responsive">
                        <table class="table table-bordered border-dark table-sm align-middle">
<thead class="bg-secondary text-white text-uppercase">
                                <tr>
                                    <th>PRODUCTO</th>
                                    <th class="text-center">CANTIDAD</th>
                                    <th class="text-end">COSTO UNIT.</th>
                                    <th class="text-end">SUBTOTAL</th>
                                </tr>
                            </thead>
                            <tbody class="fw-bold" style="font-size: 0.9rem;">
                                @foreach (var d in CompraSeleccionada.Detalles)
                                {
                                    <tr>
                                        <td>@(string.IsNullOrEmpty(d.ProductoNombre) ? d.DescripcionItem : d.ProductoNombre)</td>
                                        <td class="text-center text-primary">@d.Cantidad</td>
                                        <td class="text-end font-monospace text-muted">@d.CostoUnitario.ToString("C0")</td>
                                        <td class="text-end text-success font-monospace">@((d.Cantidad * d.CostoUnitario).ToString("C0"))</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="modal-footer bg-light rounded-0">
                    <button type="button" class="btn btn-outline-dark rounded-0 fw-bold" @onclick="CerrarModalDetalles">CERRAR</button>
                    @if (CompraSeleccionada.Estado != "PAGADA")
                    {
                        <button type="button" class="btn btn-success fw-bold border-dark rounded-0" @onclick="MarcarPagada" disabled="@ProcesandoPago">
                            @if(ProcesandoPago)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                            }
                            else
                            {
                                <i class="bi bi-check-circle me-2"></i>
                            }
                            MARCAR COMO PAGADA
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
}

<!-- MODAL ELIMINAR COMPRA -->
@if (CompraAEliminar != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-0 border-2 border-dark shadow-lg">
                <div class="modal-header bg-danger text-white rounded-0 border-bottom border-dark">
                    <h5 class="modal-title fw-bold"><i class="bi bi-exclamation-triangle-fill me-2"></i>ELIMINAR COMPRA</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CancelarEliminacion"></button>
                </div>
                <div class="modal-body p-4 text-center">
                    <p class="fs-5">¿Estás seguro de que deseas eliminar esta compra de <strong>@CompraAEliminar.Proveedor</strong>?</p>
                    <p class="text-danger fw-bold"><i class="bi bi-info-circle-fill me-1"></i>Esta acción revertirá el stock de los productos y eliminará el movimiento de caja asociado.</p>
                </div>
                <div class="modal-footer bg-light rounded-0">
                    <button type="button" class="btn btn-outline-dark rounded-0 fw-bold" @onclick="CancelarEliminacion" disabled="@ProcesandoEliminacion">CANCELAR</button>
                    <button type="button" class="btn btn-danger rounded-0 border-dark fw-bold px-4" @onclick="EliminarCompra" disabled="@ProcesandoEliminacion">
                        @if(ProcesandoEliminacion)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                        }
                        else
                        {
                            <i class="bi bi-trash-fill me-2"></i>
                        }
                        SÍ, ELIMINAR CORREGIR
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<CompraDto> ListaCompras = new();
    private bool Cargando = true;
    private string? Error;
    private string? MensajeExito;
    private string SearchTerm = "";
    
    // Filtro basado en búsqueda
    private IEnumerable<CompraDto> FilteredCompras
    {
        get
        {
            if (string.IsNullOrWhiteSpace(SearchTerm))
                return ListaCompras;
                
            var term = SearchTerm.ToLower();
            return ListaCompras.Where(c => 
                (c.Proveedor?.ToLower().Contains(term) ?? false) ||
                (c.NumeroDocumento?.ToLower().Contains(term) ?? false));
        }
    }
    
    // Modal Ver Detalles
    private CompraDto? CompraSeleccionada;
    private bool ProcesandoPago = false;

    protected override async Task OnInitializedAsync()
    {
        await CargarCompras();
    }

    private async Task CargarCompras()
    {
        try
        {
            Cargando = true;
            Error = null;
            MensajeExito = null;
            ListaCompras = await Http.GetFromJsonAsync<List<CompraDto>>("api/compras") ?? new();
        }
        catch (Exception ex)
        {
            Error = $"Error al cargar compras: {ex.Message}";
        }
        finally
        {
            Cargando = false;
        }
    }

    private async Task VerDetalles(CompraDto compra)
    {
        await JS.InvokeVoidAsync("modalScrollLock.lock");
        CompraSeleccionada = compra;
        Error = null;
        MensajeExito = null;
    }

    private async Task CerrarModalDetalles()
    {
        await JS.InvokeVoidAsync("modalScrollLock.unlock");
        CompraSeleccionada = null;
    }
    
    // Modal Eliminar
    private CompraDto? CompraAEliminar;
    private bool ProcesandoEliminacion = false;

    private async Task ConfirmarEliminacion(CompraDto compra)
    {
        await JS.InvokeVoidAsync("modalScrollLock.lock");
        CompraAEliminar = compra;
        Error = null;
        MensajeExito = null;
    }

    private async Task CancelarEliminacion()
    {
        await JS.InvokeVoidAsync("modalScrollLock.unlock");
        CompraAEliminar = null;
    }

    private async Task EliminarCompra()
    {
        if (CompraAEliminar == null) return;

        try
        {
            ProcesandoEliminacion = true;
            var response = await Http.DeleteAsync($"api/compras/{CompraAEliminar.Id}");

            if (response.IsSuccessStatusCode)
            {
                MensajeExito = "La compra ha sido eliminada y se ha revertido el stock y la caja.";
                await CancelarEliminacion();
                await CargarCompras();
            }
            else
            {
                Error = "Error al eliminar la compra: " + await response.Content.ReadAsStringAsync();
            }
        }
        catch (Exception ex)
        {
            Error = $"Error: {ex.Message}";
        }
        finally
        {
            ProcesandoEliminacion = false;
        }
    }



    private async Task MarcarPagada()
    {
        if (CompraSeleccionada == null) return;
        
        try
        {
            ProcesandoPago = true;
            var response = await Http.PostAsync($"api/compras/{CompraSeleccionada.Id}/pagar", null);
            
            if (response.IsSuccessStatusCode)
            {
                MensajeExito = $"La factura de {CompraSeleccionada.Proveedor} fue marcada como pagada. Se ha registrado el egreso en Caja.";
                await CerrarModalDetalles();
                await CargarCompras();
            }
            else
            {
                Error = "Error al registrar el pago: " + await response.Content.ReadAsStringAsync();
            }
        }
        catch (Exception ex)
        {
            Error = $"Error interno: {ex.Message}";
        }
        finally
        {
            ProcesandoPago = false;
            if(CompraSeleccionada != null) await CerrarModalDetalles();
        }
    }
}
