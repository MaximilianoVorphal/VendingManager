@page "/compras"
@using VendingManager.Shared.DTOs
@using VendingManager.Web.Components
@using VendingManager.Web.Components.Mobile
@using Microsoft.AspNetCore.Components.Forms
@inject HttpClient Http
@inject NavigationManager Navigation

@* =============================================================================
   Compras v2 — port fiel de templates/compras/Compras.dc.html al lenguaje
   industrial. Una sola pantalla sin scroll de página (la tabla scrollea
   internamente): franja de 3 KPIs siempre visibles, barra negra con filtros de
   estado/tipo + buscador, y modales de Detalle, Confirmación (eliminar /
   desvincular / reconstruir) y Nueva compra (con escaneo IA, catálogo, texto
   libre y gasto general). Ruta "compras" es fullscreen en MainLayout.
   ============================================================================= *@

<PageTitle>COMPRAS</PageTitle>

<MobileShell>

<div class="cp-page" style="flex:1;min-height:0;display:flex;flex-direction:column;overflow:hidden;padding:0.95rem 1.4rem 1.1rem;gap:12px;position:relative;">

    <!-- ===== Toast de confirmación ===== -->
    @if (!string.IsNullOrEmpty(MensajeExito))
    {
        <div class="cp-toast" style="position:absolute;top:4px;left:50%;transform:translateX(-50%);z-index:1500;background:var(--ink-900);color:#fff;border:2px solid var(--ink-900);box-shadow:4px 4px 0 #000;padding:0.55rem 1rem;font-family:var(--font-mono);font-weight:700;font-size:0.72rem;text-transform:uppercase;letter-spacing:0.4px;display:flex;align-items:center;gap:8px;max-width:80vw;">
            <i class="bi bi-check-circle-fill" style="color:var(--signal-success);"></i><span>@MensajeExito</span>
        </div>
    }

    <!-- ===== Header ===== -->
    <div style="flex-shrink:0;display:flex;justify-content:space-between;align-items:flex-end;gap:14px;flex-wrap:wrap;border-bottom:3px solid var(--ink-900);padding-bottom:10px;">
        <div>
            <div style="display:inline-block;background:var(--ink-900);color:#fff;font-family:var(--font-mono);font-weight:700;font-size:0.58rem;letter-spacing:2px;padding:3px 9px;text-transform:uppercase;margin-bottom:7px;">Operaciones · Compras</div>
            <h1 style="margin:0;font-family:var(--font-mono);font-weight:700;text-transform:uppercase;letter-spacing:-1px;font-size:1.5rem;line-height:1;display:flex;align-items:center;gap:9px;"><i class="bi bi-receipt" style="font-size:1.2rem;"></i>Centro de Compras<span class="cp-cursor">_</span></h1>
            <p style="margin:5px 0 0;font-family:var(--font-mono);font-size:0.68rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.4px;">Gestión de facturas y boletas de abastecimiento</p>
        </div>
        <div style="display:flex;align-items:center;gap:9px;flex-wrap:wrap;">
            <VmButton Variant="danger" Icon="bi-database-fill-gear" Disabled="@EjecutandoReconstruccion" OnClick="ConfirmarReconstruirCostos">Reconstruir costos</VmButton>
            <VmButton Variant="dark" Icon="bi-plus-lg" OnClick="AbrirNuevaCompra">Nueva compra</VmButton>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Error))
    {
        <div style="flex-shrink:0;">
            <IndustrialAlert Message="@Error" Variant="IndustrialAlert.AlertVariant.Danger" />
        </div>
    }

    <!-- ===== KPIs ===== -->
    <div class="cp-kpis" style="flex-shrink:0;display:grid;grid-template-columns:repeat(3,1fr);gap:12px;">

        <!-- Total gastado -->
        <div style="border:2px solid var(--ink-900);background:var(--ink-900);color:#fff;box-shadow:var(--shadow-card);padding:0.85rem 1rem;display:flex;flex-direction:column;gap:0.5rem;">
            <div style="display:flex;justify-content:space-between;align-items:center;gap:8px;">
                <span style="font-family:var(--font-mono);font-weight:700;font-size:0.68rem;text-transform:uppercase;letter-spacing:0.5px;opacity:0.75;">Total gastado</span>
                <span style="font-family:var(--font-mono);font-weight:700;font-size:0.58rem;text-transform:uppercase;letter-spacing:0.5px;border:1px solid rgba(255,255,255,0.55);padding:2px 7px;white-space:nowrap;">@TotalComprasN compras</span>
            </div>
            <span style="font-family:var(--font-sans);font-weight:700;font-size:1.85rem;letter-spacing:-1px;line-height:1;">@TotalGastado.ToString("C0")</span>
            <small style="font-family:var(--font-mono);font-size:0.66rem;opacity:0.6;">Mercadería + gastos generales</small>
        </div>

        <!-- Costo mercadería -->
        <div style="border:2px solid var(--ink-900);background:var(--paper-0);box-shadow:var(--shadow-card);padding:0.85rem 1rem;display:flex;flex-direction:column;gap:0.5rem;">
            <div style="display:flex;justify-content:space-between;align-items:center;gap:8px;">
                <span style="font-family:var(--font-mono);font-weight:700;font-size:0.68rem;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-secondary);">Costo mercadería</span>
                <span style="font-family:var(--font-mono);font-weight:700;font-size:0.58rem;text-transform:uppercase;letter-spacing:0.5px;background:var(--ink-900);color:#fff;padding:2px 7px;white-space:nowrap;">@MercN facturas</span>
            </div>
            <span style="font-family:var(--font-sans);font-weight:700;font-size:1.85rem;letter-spacing:-1px;line-height:1;">@MontoMerc.ToString("C0")</span>
            <small style="font-family:var(--font-mono);font-size:0.66rem;color:var(--text-muted);">Gasto general: @MontoGasto.ToString("C0")</small>
        </div>

        <!-- Sin vincular -->
        <div style="border:2px solid var(--ink-900);background:var(--paper-0);box-shadow:var(--shadow-card);padding:0.85rem 1rem;display:flex;flex-direction:column;gap:0.5rem;">
            <div style="display:flex;justify-content:space-between;align-items:center;gap:8px;">
                <span style="font-family:var(--font-mono);font-weight:700;font-size:0.68rem;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-secondary);">Sin vincular</span>
                <span style="font-family:var(--font-mono);font-weight:700;font-size:0.58rem;text-transform:uppercase;letter-spacing:0.5px;border:1px solid var(--ink-900);padding:2px 7px;white-space:nowrap;">Transferencia</span>
            </div>
            <span style="font-family:var(--font-sans);font-weight:700;font-size:1.85rem;letter-spacing:-1px;line-height:1;">@SinVincN</span>
            <small style="font-family:var(--font-mono);font-size:0.66rem;color:var(--text-muted);">Facturas por conciliar en Caja</small>
        </div>
    </div>

    <!-- ===== Historial de compras ===== -->
    <section style="flex:1;min-height:0;display:flex;flex-direction:column;border:2px solid var(--ink-900);box-shadow:var(--shadow-card);background:var(--paper-0);overflow:hidden;">

        <!-- Barra negra: título + filtros + búsqueda -->
        <div class="cp-bar" style="flex-shrink:0;background:var(--ink-900);color:#fff;display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap;padding:0.55rem 0.9rem;">
            <div style="font-family:var(--font-mono);font-weight:700;text-transform:uppercase;letter-spacing:1px;font-size:0.84rem;display:flex;align-items:center;gap:8px;white-space:nowrap;"><i class="bi bi-folder2-open"></i>Historial de compras<span style="color:rgba(255,255,255,0.55);font-size:0.72rem;font-weight:400;text-transform:none;letter-spacing:0;">&nbsp;@FilteredCompras.Count() registros</span></div>
            <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
                <select @bind="FilterEstado" style="border:2px solid #fff;background:var(--ink-900);color:#fff;font-family:var(--font-mono);font-weight:700;font-size:0.7rem;text-transform:uppercase;padding:5px 8px;border-radius:0;cursor:pointer;">
                    <option value="TODAS">Todos los estados</option>
                    <option value="PAGADA">Pagadas</option>
                    <option value="PENDIENTE">Pendientes</option>
                </select>
                <select @bind="FilterTipo" style="border:2px solid #fff;background:var(--ink-900);color:#fff;font-family:var(--font-mono);font-weight:700;font-size:0.7rem;text-transform:uppercase;padding:5px 8px;border-radius:0;cursor:pointer;">
                    <option value="TODOS">Todos los tipos</option>
                    <option value="ABASTECER">Abastecimiento</option>
                    <option value="GASTO">Gasto general</option>
                </select>
                <input type="text" placeholder="Buscar proveedor o documento…" @bind="SearchTerm" @bind:event="oninput" style="border:2px solid #fff;background:#fff;color:var(--ink-900);font-family:var(--font-mono);font-size:0.75rem;padding:5px 8px;width:220px;border-radius:0;outline:none;" />
            </div>
        </div>

        <!-- Tabla -->
        <div style="flex:1;min-height:0;overflow:auto;">
            <table class="vm-accordion-table" style="width:100%;border-collapse:collapse;">
                <thead>
                    <tr>
                        <th style="position:sticky;top:0;background:var(--ink-700);color:#fff;text-align:left;padding:8px 12px;font-family:var(--font-mono);font-weight:700;font-size:0.62rem;text-transform:uppercase;letter-spacing:0.5px;white-space:nowrap;">Fecha</th>
                        <th style="position:sticky;top:0;background:var(--ink-700);color:#fff;text-align:left;padding:8px 12px;font-family:var(--font-mono);font-weight:700;font-size:0.62rem;text-transform:uppercase;letter-spacing:0.5px;">Proveedor</th>
                        <th class="cp-hide-sm" style="position:sticky;top:0;background:var(--ink-700);color:#fff;text-align:center;padding:8px 12px;font-family:var(--font-mono);font-weight:700;font-size:0.62rem;text-transform:uppercase;letter-spacing:0.5px;white-space:nowrap;">Tipo</th>
                        <th class="cp-hide-sm" style="position:sticky;top:0;background:var(--ink-700);color:#fff;text-align:left;padding:8px 12px;font-family:var(--font-mono);font-weight:700;font-size:0.62rem;text-transform:uppercase;letter-spacing:0.5px;white-space:nowrap;">Nº Documento</th>
                        <th style="position:sticky;top:0;background:var(--ink-700);color:#fff;text-align:right;padding:8px 12px;font-family:var(--font-mono);font-weight:700;font-size:0.62rem;text-transform:uppercase;letter-spacing:0.5px;white-space:nowrap;">Monto total</th>
                        <th style="position:sticky;top:0;background:var(--ink-700);color:#fff;text-align:center;padding:8px 12px;font-family:var(--font-mono);font-weight:700;font-size:0.62rem;text-transform:uppercase;letter-spacing:0.5px;white-space:nowrap;">Estado</th>
                        <th style="position:sticky;top:0;background:var(--ink-700);color:#fff;text-align:center;padding:8px 12px;font-family:var(--font-mono);font-weight:700;font-size:0.62rem;text-transform:uppercase;letter-spacing:0.5px;white-space:nowrap;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Cargando)
                    {
                        <tr><td colspan="7" style="padding:2.5rem;text-align:center;font-family:var(--font-mono);color:var(--text-muted);text-transform:uppercase;font-size:0.8rem;"><span class="cp-spin" style="width:14px;height:14px;display:inline-block;border:2px solid var(--line-300);border-top-color:var(--ink-900);border-radius:50%;margin-right:8px;vertical-align:middle;"></span>Cargando datos…</td></tr>
                    }
                    else if (!ListaCompras.Any())
                    {
                        <tr><td colspan="7" style="padding:2.5rem;text-align:center;font-family:var(--font-mono);color:var(--text-muted);text-transform:uppercase;font-size:0.8rem;">No se han registrado compras.</td></tr>
                    }
                    else if (!FilteredCompras.Any())
                    {
                        <tr><td colspan="7" style="padding:2.5rem;text-align:center;font-family:var(--font-mono);color:var(--text-muted);text-transform:uppercase;font-size:0.8rem;">No se encontraron compras para el filtro actual.</td></tr>
                    }
                    else
                    {
                        @foreach (var c in FilteredCompras)
                        {
                            <tr class="cp-row" style="border-bottom:1px solid var(--line-200);">
                                <td style="padding:9px 12px;"><span style="font-family:var(--font-mono);font-size:0.76rem;color:var(--text-secondary);white-space:nowrap;">@c.FechaCompra.ToString("dd/MM/yyyy HH:mm")</span></td>
                                <td style="padding:9px 12px;"><span style="font-family:var(--font-sans);font-weight:600;text-transform:uppercase;font-size:0.84rem;letter-spacing:-0.2px;">@c.Proveedor</span></td>
                                <td class="cp-hide-sm" style="padding:9px 12px;text-align:center;">
                                    @if (c.TipoFactura == "GASTO_GENERAL")
                                    {
                                        <span style="display:inline-flex;align-items:center;gap:5px;font-family:var(--font-mono);font-size:0.6rem;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;padding:3px 7px;border:2px solid var(--ink-900);background:var(--paper-0);color:var(--ink-900);white-space:nowrap;"><i class="bi bi-fuel-pump-fill"></i>Gasto</span>
                                    }
                                    else
                                    {
                                        <span style="display:inline-flex;align-items:center;gap:5px;font-family:var(--font-mono);font-size:0.6rem;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;padding:3px 7px;border:2px solid var(--ink-900);background:var(--ink-900);color:#fff;white-space:nowrap;"><i class="bi bi-box-seam-fill"></i>Abastecer</span>
                                    }
                                </td>
                                <td class="cp-hide-sm" style="padding:9px 12px;"><span style="font-family:var(--font-mono);font-size:0.78rem;">@(string.IsNullOrEmpty(c.NumeroDocumento) ? "S/N" : c.NumeroDocumento)</span></td>
                                <td style="padding:9px 12px;text-align:right;"><span style="font-family:var(--font-mono);font-weight:700;color:var(--signal-success);">@c.MontoTotal.ToString("C0")</span></td>
                                <td style="padding:9px 12px;text-align:center;">
                                    <div style="display:flex;flex-direction:column;gap:3px;align-items:center;">
                                        @if (c.TransferenciaId != null)
                                        {
                                            <span style="display:inline-flex;align-items:center;gap:4px;font-family:var(--font-mono);font-size:0.56rem;font-weight:700;text-transform:uppercase;padding:1px 5px;border:1px solid var(--signal-success);color:var(--signal-success);white-space:nowrap;"><i class="bi bi-link"></i>Vinculada</span>
                                        }
                                        else
                                        {
                                            <span style="display:inline-flex;align-items:center;gap:4px;font-family:var(--font-mono);font-size:0.56rem;font-weight:700;text-transform:uppercase;padding:1px 5px;border:1px solid var(--line-300);color:var(--text-muted);white-space:nowrap;"><i class="bi bi-unlink"></i>Sin vinc.</span>
                                        }
                                    </div>
                                </td>
                                <td style="padding:9px 12px;">
                                    <div style="display:flex;justify-content:center;gap:5px;">
                                        @if (!string.IsNullOrEmpty(c.FacturaImagenPath))
                                        {
                                            <a href="api/compras/@c.Id/factura" target="_blank" aria-label="Ver factura" title="Ver factura escaneada" class="cp-icon-btn" style="width:28px;height:28px;border:1px solid var(--ink-900);background:var(--paper-0);cursor:pointer;border-radius:0;display:flex;align-items:center;justify-content:center;font-size:0.75rem;color:var(--ink-900);text-decoration:none;"><i class="bi bi-file-earmark-arrow-down-fill"></i></a>
                                        }
                                        <button aria-label="Detalles" title="Ver detalles" @onclick="() => VerDetalles(c)" class="cp-icon-btn" style="width:28px;height:28px;border:1px solid var(--ink-900);background:var(--paper-0);cursor:pointer;border-radius:0;display:flex;align-items:center;justify-content:center;font-size:0.75rem;"><i class="bi bi-eye-fill"></i></button>
                                        <button aria-label="Editar" title="Editar compra" @onclick='() => Navigation.NavigateTo($"/compras/editar/{c.Id}")' class="cp-icon-btn" style="width:28px;height:28px;border:1px solid var(--ink-900);background:var(--paper-0);cursor:pointer;border-radius:0;display:flex;align-items:center;justify-content:center;font-size:0.75rem;"><i class="bi bi-pencil-square"></i></button>
                                        @if (c.TransferenciaId != null)
                                        {
                                            <button aria-label="Desvincular" title="Desvincular transferencia" @onclick="() => ConfirmarDesvinculacion(c)" class="cp-icon-btn" style="width:28px;height:28px;border:1px solid var(--ink-900);background:var(--paper-0);cursor:pointer;border-radius:0;display:flex;align-items:center;justify-content:center;font-size:0.75rem;"><i class="bi bi-link-45deg"></i></button>
                                        }
                                        <button aria-label="Eliminar" title="Eliminar compra" @onclick="() => ConfirmarEliminacion(c)" style="width:28px;height:28px;border:1px solid var(--signal-danger);color:var(--signal-danger);background:var(--paper-0);cursor:pointer;border-radius:0;display:flex;align-items:center;justify-content:center;font-size:0.75rem;"><i class="bi bi-trash-fill"></i></button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </section>
</div>

<!-- ===== MODAL: Detalle de compra ===== -->
@if (CompraSeleccionada != null)
{
    var cs = CompraSeleccionada;
    <div style="position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:2000;display:flex;align-items:flex-start;justify-content:center;padding:4vh 16px;overflow:auto;" @onclick="CerrarModalDetalles">
        <div class="cp-modal" style="width:100%;max-width:540px;background:var(--paper-0);border:2px solid var(--ink-900);box-shadow:4px 4px 0 #000;" @onclick:stopPropagation="true">
            <div style="background:var(--ink-900);color:#fff;display:flex;justify-content:space-between;align-items:center;padding:0.6rem 0.9rem;font-family:var(--font-mono);font-weight:700;text-transform:uppercase;letter-spacing:1px;">
                <span><i class="bi bi-receipt" style="margin-right:8px;"></i>Detalle de compra</span>
                <span style="cursor:pointer;font-size:1.2rem;line-height:1;" @onclick="CerrarModalDetalles">×</span>
            </div>
            <div style="background:var(--bg-surface-inset);padding:1.1rem;display:flex;flex-direction:column;gap:1rem;max-height:76vh;overflow:auto;">

                <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;background:var(--paper-0);border:1px solid var(--ink-900);padding:0.9rem 1rem;">
                    <div>
                        <small style="display:block;font-family:var(--font-mono);font-weight:700;color:var(--text-muted);text-transform:uppercase;font-size:0.62rem;">Proveedor</small>
                        <span style="font-family:var(--font-sans);font-weight:700;font-size:1.05rem;">@cs.Proveedor</span>
                        <small style="display:block;margin-top:8px;font-family:var(--font-mono);font-weight:700;color:var(--text-muted);text-transform:uppercase;font-size:0.62rem;">Nº documento</small>
                        <span style="font-family:var(--font-mono);font-weight:700;">@(string.IsNullOrEmpty(cs.NumeroDocumento) ? "S/N" : cs.NumeroDocumento)</span>
                    </div>
                    <div style="text-align:right;">
                        <small style="display:block;font-family:var(--font-mono);font-weight:700;color:var(--text-muted);text-transform:uppercase;font-size:0.62rem;">Fecha</small>
                        <span style="font-family:var(--font-sans);font-weight:700;">@cs.FechaCompra.ToString("dd/MM/yyyy HH:mm")</span>
                        <small style="display:block;margin-top:8px;font-family:var(--font-mono);font-weight:700;color:var(--text-muted);text-transform:uppercase;font-size:0.62rem;">Total pagado</small>
                        <span style="font-family:var(--font-mono);font-weight:700;font-size:1.25rem;color:var(--signal-success);">@cs.MontoTotal.ToString("C0")</span>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(cs.FacturaImagenPath))
                {
                    <div style="border:2px solid var(--ink-900);background:var(--paper-0);padding:0.75rem;display:flex;flex-direction:column;gap:8px;">
                        <span style="font-family:var(--font-mono);font-weight:700;font-size:0.68rem;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);"><i class="bi bi-file-earmark-arrow-down-fill" style="margin-right:6px;"></i>Factura escaneada</span>
                        <a href="api/compras/@cs.Id/factura" target="_blank">
                            <img src="api/compras/@cs.Id/factura" style="max-height:340px;width:100%;object-fit:contain;background:#f5f5f5;border:1px solid var(--ink-900);" alt="Factura de @cs.Proveedor" />
                        </a>
                        <a href="api/compras/@cs.Id/factura" target="_blank" style="align-self:flex-start;display:inline-flex;align-items:center;gap:6px;font-family:var(--font-mono);font-weight:700;font-size:0.64rem;text-transform:uppercase;letter-spacing:0.5px;background:var(--paper-0);color:var(--ink-900);border:2px solid var(--ink-900);border-radius:0;padding:6px 11px;text-decoration:none;"><i class="bi bi-arrows-fullscreen"></i> Abrir en pantalla completa</a>
                    </div>
                }
                else
                {
                    <div style="border:2px dashed var(--line-300);padding:1rem;text-align:center;font-family:var(--font-mono);font-weight:700;font-size:0.72rem;text-transform:uppercase;color:var(--text-muted);">
                        <i class="bi bi-paperclip"></i> Sin comprobante adjunto
                    </div>
                }

                <div>
                    <div style="font-family:var(--font-mono);font-weight:700;text-transform:uppercase;font-size:0.76rem;border-bottom:2px solid var(--ink-900);padding-bottom:6px;margin-bottom:8px;">@(cs.TipoFactura == "MERCADERIA" ? "Productos adquiridos" : "Detalle de gastos")</div>
                    <table style="width:100%;border-collapse:collapse;background:var(--paper-0);">
                        <thead>
                            <tr>
                                <th style="text-align:left;background:var(--ink-700);color:#fff;padding:6px 8px;font-family:var(--font-mono);font-weight:700;font-size:0.6rem;text-transform:uppercase;letter-spacing:0.5px;">Producto</th>
                                <th style="text-align:center;background:var(--ink-700);color:#fff;padding:6px 8px;font-family:var(--font-mono);font-weight:700;font-size:0.6rem;text-transform:uppercase;letter-spacing:0.5px;">Cant.</th>
                                <th style="text-align:right;background:var(--ink-700);color:#fff;padding:6px 8px;font-family:var(--font-mono);font-weight:700;font-size:0.6rem;text-transform:uppercase;letter-spacing:0.5px;">Costo unit.</th>
                                <th style="text-align:right;background:var(--ink-700);color:#fff;padding:6px 8px;font-family:var(--font-mono);font-weight:700;font-size:0.6rem;text-transform:uppercase;letter-spacing:0.5px;">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var d in cs.Detalles)
                            {
                                <tr style="border-bottom:1px solid var(--line-200);">
                                    <td style="padding:7px 8px;"><span style="font-family:var(--font-sans);font-weight:600;text-transform:uppercase;font-size:0.8rem;">@(string.IsNullOrEmpty(d.ProductoNombre) ? d.DescripcionItem : d.ProductoNombre)</span></td>
                                    <td style="padding:7px 8px;text-align:center;font-family:var(--font-mono);font-weight:700;font-size:0.8rem;">@d.Cantidad</td>
                                    <td style="padding:7px 8px;text-align:right;font-family:var(--font-mono);color:var(--text-muted);font-size:0.8rem;">@d.CostoUnitario.ToString("C0")</td>
                                    <td style="padding:7px 8px;text-align:right;font-family:var(--font-mono);font-weight:700;color:var(--signal-success);font-size:0.8rem;">@((d.Cantidad * d.CostoUnitario).ToString("C0"))</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div style="display:flex;gap:10px;">
                    <VmButton Variant="outline" Block="true" OnClick="CerrarModalDetalles">Cerrar</VmButton>
                    @if (cs.Estado != "PAGADA")
                    {
                        <VmButton Variant="dark" Icon="bi-check-circle" Block="true" Disabled="@ProcesandoPago" OnClick="MarcarPagada">Marcar como pagada</VmButton>
                    }
                </div>
            </div>
        </div>
    </div>
}

<!-- ===== MODAL: Confirmación (eliminar / desvincular / reconstruir) ===== -->
@if (_confirmType != null)
{
    var esEliminar = _confirmType == "eliminar";
    var esReconstruir = _confirmType == "reconstruir";
    var headerBg = esEliminar ? "var(--signal-danger)" : "var(--signal-warning)";
    var headerFg = esEliminar ? "#fff" : "var(--ink-900)";
    var headerIcon = esEliminar ? "bi-exclamation-triangle-fill" : (esReconstruir ? "bi-database-fill-gear" : "bi-link-45deg");
    <div style="position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:2000;display:flex;align-items:center;justify-content:center;padding:16px;overflow:auto;" @onclick="CerrarConfirm">
        <div class="cp-modal" style="width:100%;max-width:440px;background:var(--paper-0);border:2px solid var(--ink-900);box-shadow:4px 4px 0 #000;" @onclick:stopPropagation="true">
            <div style="background:@headerBg;color:@headerFg;display:flex;justify-content:space-between;align-items:center;padding:0.6rem 0.9rem;font-family:var(--font-mono);font-weight:700;text-transform:uppercase;letter-spacing:1px;">
                <span><i class="bi @headerIcon" style="margin-right:8px;"></i>@_confirmTitulo</span>
                <span style="cursor:pointer;font-size:1.2rem;line-height:1;" @onclick="CerrarConfirm">×</span>
            </div>
            <div style="padding:1.3rem;text-align:center;background:var(--paper-0);">
                <p style="margin:0;font-family:var(--font-sans);font-size:0.96rem;line-height:1.5;">@((MarkupString)_confirmMensaje)</p>
            </div>
            <div style="display:flex;gap:10px;padding:0 1.3rem 1.3rem;">
                <VmButton Variant="outline" Block="true" Disabled="@_confirmProcesando" OnClick="CerrarConfirm">Cancelar</VmButton>
                @if (esEliminar)
                {
                    <VmButton Variant="danger" Icon="bi-trash-fill" Block="true" Disabled="@_confirmProcesando" OnClick="EjecutarConfirm">@_confirmLabel</VmButton>
                }
                else
                {
                    <VmButton Variant="dark" Icon="bi-check-circle" Block="true" Disabled="@_confirmProcesando" OnClick="EjecutarConfirm">@_confirmLabel</VmButton>
                }
            </div>
        </div>
    </div>
}

<!-- ===== MODAL: Nueva compra ===== -->
@if (_nuevaOpen)
{
    <div style="position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:2000;display:flex;align-items:center;justify-content:center;padding:3.5vh 16px;overflow:auto;" @onclick="CerrarNuevaCompra">
        <div class="cp-modal" style="width:100%;max-width:920px;background:var(--paper-0);border:2px solid var(--ink-900);box-shadow:4px 4px 0 #000;" @onclick:stopPropagation="true">
            <div style="background:var(--ink-900);color:#fff;display:flex;justify-content:space-between;align-items:center;padding:0.6rem 0.9rem;font-family:var(--font-mono);font-weight:700;text-transform:uppercase;letter-spacing:1px;">
                <span><i class="bi bi-cart-plus" style="margin-right:8px;"></i>Registrar nueva compra</span>
                <span style="cursor:pointer;font-size:1.2rem;line-height:1;" @onclick="CerrarNuevaCompra">×</span>
            </div>

            <div class="cp-nueva-grid" style="display:grid;grid-template-columns:300px 1fr;gap:0;max-height:82vh;">

                <!-- Columna izquierda: datos del documento -->
                <div style="background:var(--bg-surface-inset);border-right:2px solid var(--ink-900);padding:1rem;display:flex;flex-direction:column;gap:12px;overflow:auto;">
                    <span style="font-family:var(--font-mono);font-weight:700;font-size:0.72rem;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-secondary);">Datos del documento</span>

                    <label style="display:flex;align-items:center;justify-content:center;gap:8px;font-family:var(--font-mono);font-weight:700;font-size:0.72rem;text-transform:uppercase;letter-spacing:0.5px;padding:8px 10px;background:var(--paper-0);color:var(--ink-900);border:2px solid var(--ink-900);border-radius:0;cursor:@(ProcesandoOCR ? "wait" : "pointer");">
                        @if (ProcesandoOCR)
                        {
                            <span class="cp-spin" style="width:13px;height:13px;border:2px solid var(--line-300);border-top-color:var(--ink-900);border-radius:50%;display:inline-block;"></span><span>Escaneando con IA…</span>
                        }
                        else
                        {
                            <i class="bi bi-camera"></i><span>Escanear factura (IA)</span>
                        }
                        <InputFile OnChange="HandleImageUpload" accept="image/*,application/pdf" disabled="@ProcesandoOCR" style="display:none;" />
                    </label>

                    <VmInput Label="Proveedor *" Placeholder="Ej: Alvi, El Molino…" @bind-Value="factura.Proveedor" />
                    <VmInput Label="Nº Factura / Boleta" Placeholder="Ej: F-123456" @bind-Value="factura.NumeroDocumento" />
                    <VmInput Label="Fecha de compra" Type="date" @bind-Value="FechaCompraText" />

                    <div>
                        <label style="font-family:var(--font-mono);font-weight:700;font-size:0.7rem;text-transform:uppercase;letter-spacing:0.5px;">Tipo de documento</label>
                        <div style="display:flex;border:2px solid var(--ink-900);margin-top:6px;">
                            <button type="button" @onclick="SetTipoMercaderia" style="flex:1;font-family:var(--font-mono);font-weight:700;font-size:0.7rem;text-transform:uppercase;padding:0.5rem 0.2rem;cursor:pointer;border:none;border-radius:0;background:@(factura.TipoFactura == "MERCADERIA" ? "var(--ink-900)" : "var(--paper-0)");color:@(factura.TipoFactura == "MERCADERIA" ? "#fff" : "var(--ink-900)");"><i class="bi bi-box-seam-fill"></i> Mercadería</button>
                            <button type="button" @onclick="SetTipoGasto" style="flex:1;font-family:var(--font-mono);font-weight:700;font-size:0.7rem;text-transform:uppercase;padding:0.5rem 0.2rem;cursor:pointer;border:none;border-left:2px solid var(--ink-900);border-radius:0;background:@(factura.TipoFactura == "GASTO_GENERAL" ? "var(--ink-900)" : "var(--paper-0)");color:@(factura.TipoFactura == "GASTO_GENERAL" ? "#fff" : "var(--ink-900)");"><i class="bi bi-fuel-pump-fill"></i> Gasto</button>
                        </div>
                    </div>

                    @if (factura.TipoFactura == "GASTO_GENERAL")
                    {
                        <div>
                            <label style="font-family:var(--font-mono);font-weight:700;font-size:0.7rem;text-transform:uppercase;letter-spacing:0.5px;">Categoría del gasto</label>
                            <select @bind="factura.SubcategoriaGasto" style="width:100%;margin-top:6px;border:2px solid var(--ink-900);border-radius:0;padding:0.45rem 0.6rem;font-family:var(--font-mono);font-weight:700;font-size:0.75rem;text-transform:uppercase;background:var(--paper-100);">
                                <option value="">Gastos generales</option>
                                <option value="LOGISTICA">Logística (Bencina / Fletes)</option>
                                <option value="PEAJES">Peajes / TAG</option>
                            </select>
                        </div>
                    }

                    <label style="display:flex;align-items:center;gap:8px;font-family:var(--font-mono);font-weight:700;font-size:0.66rem;text-transform:uppercase;letter-spacing:0.4px;border-top:1px solid var(--line-300);padding-top:12px;cursor:pointer;">
                        <input type="checkbox" @bind="factura.PagadaCaja" style="width:16px;height:16px;accent-color:var(--ink-900);" />
                        Pagada al contado (genera gasto en caja)
                    </label>

                    @if (!string.IsNullOrEmpty(FacturaPreviewUrl))
                    {
                        <div style="display:flex;align-items:center;justify-content:space-between;gap:7px;border:1px solid var(--signal-warning);background:rgba(255,193,7,0.18);padding:6px 8px;font-family:var(--font-mono);font-weight:700;font-size:0.64rem;text-transform:uppercase;letter-spacing:0.3px;">
                            <span><i class="bi bi-paperclip"></i> Factura adjunta</span>
                            <button type="button" @onclick="ClearFacturaPreview" style="border:1px solid var(--signal-danger);color:var(--signal-danger);background:var(--paper-0);cursor:pointer;border-radius:0;width:22px;height:22px;"><i class="bi bi-x-lg"></i></button>
                        </div>
                    }
                </div>

                <!-- Columna derecha: detalle de productos -->
                <div style="display:flex;flex-direction:column;min-height:0;overflow:hidden;">
                    <div style="flex-shrink:0;background:var(--ink-900);color:#fff;display:flex;justify-content:space-between;align-items:center;gap:10px;padding:0.5rem 0.9rem;">
                        <span style="font-family:var(--font-mono);font-weight:700;text-transform:uppercase;letter-spacing:0.5px;font-size:0.8rem;"><i class="bi bi-box-seam"></i> Detalle de productos</span>
                        <span style="font-family:var(--font-mono);font-weight:700;font-size:0.62rem;border:1px solid rgba(255,255,255,0.5);padding:3px 8px;text-transform:uppercase;">Total: @CalcularTotal().ToString("C0")</span>
                    </div>

                    <div style="flex-shrink:0;padding:0.85rem 0.9rem;border-bottom:2px solid var(--ink-900);background:var(--paper-50);display:flex;flex-direction:column;gap:9px;">
                        @if (factura.TipoFactura == "MERCADERIA")
                        {
                            <div style="display:flex;gap:8px;align-items:flex-end;flex-wrap:wrap;">
                                <div style="flex:1;min-width:200px;">
                                    <label style="font-family:var(--font-mono);font-weight:700;font-size:0.62rem;text-transform:uppercase;">Añadir producto del catálogo</label>
                                    <select @bind="productoSeleccionadoId" style="width:100%;margin-top:4px;border:2px solid var(--ink-900);border-radius:0;padding:0.4rem 0.6rem;font-family:var(--font-sans);font-size:0.82rem;">
                                        <option value="0">— Seleccione un producto —</option>
                                        @foreach (var p in ProductosDisponibles)
                                        {
                                            <option value="@p.Id">@p.Nombre (Stock: @p.StockBodega)</option>
                                        }
                                    </select>
                                </div>
                                <VmButton Variant="outline" Icon="bi-plus-lg" Disabled="@(productoSeleccionadoId == 0)" OnClick="AgregarProducto">Añadir</VmButton>
                            </div>
                            <div style="display:flex;gap:8px;align-items:flex-end;flex-wrap:wrap;border-top:1px dashed var(--line-300);padding-top:9px;">
                                <div style="flex:2;min-width:160px;">
                                    <label style="font-family:var(--font-mono);font-weight:700;font-size:0.62rem;text-transform:uppercase;">Texto libre (sin producto)</label>
                                    <input type="text" placeholder="Ej: Maní 2kg, bolsas…" @bind="textoLibreDescripcion" style="width:100%;margin-top:4px;border:2px solid var(--ink-900);border-radius:0;padding:0.4rem 0.6rem;font-family:var(--font-sans);font-size:0.82rem;outline:none;" />
                                </div>
                                <div style="width:70px;">
                                    <label style="font-family:var(--font-mono);font-weight:700;font-size:0.62rem;text-transform:uppercase;">Cant.</label>
                                    <input type="number" min="1" @bind="textoLibreCantidad" style="width:100%;margin-top:4px;border:2px solid var(--ink-900);border-radius:0;padding:0.4rem 0.5rem;font-family:var(--font-mono);font-weight:700;text-align:center;outline:none;" />
                                </div>
                                <div style="width:100px;">
                                    <label style="font-family:var(--font-mono);font-weight:700;font-size:0.62rem;text-transform:uppercase;">Precio $</label>
                                    <input type="number" min="0" @bind="textoLibrePrecio" style="width:100%;margin-top:4px;border:2px solid var(--ink-900);border-radius:0;padding:0.4rem 0.5rem;font-family:var(--font-mono);font-weight:700;text-align:right;outline:none;" />
                                </div>
                                <VmButton Variant="outline" Icon="bi-plus-lg" Disabled="@(string.IsNullOrWhiteSpace(textoLibreDescripcion) || textoLibreCantidad < 1)" OnClick="AgregarTextoLibre"></VmButton>
                            </div>
                        }
                        else
                        {
                            <div style="display:flex;gap:8px;align-items:flex-end;flex-wrap:wrap;">
                                <div style="flex:2;min-width:180px;">
                                    <label style="font-family:var(--font-mono);font-weight:700;font-size:0.62rem;text-transform:uppercase;">Descripción del gasto</label>
                                    <input type="text" placeholder="Ej: Gasolina camioneta" @bind="descripcionGastoLibre" style="width:100%;margin-top:4px;border:2px solid var(--ink-900);border-radius:0;padding:0.4rem 0.6rem;font-family:var(--font-sans);font-size:0.82rem;outline:none;" />
                                </div>
                                <div style="width:120px;">
                                    <label style="font-family:var(--font-mono);font-weight:700;font-size:0.62rem;text-transform:uppercase;">Monto $</label>
                                    <input type="number" min="0" @bind="montoGastoLibre" style="width:100%;margin-top:4px;border:2px solid var(--ink-900);border-radius:0;padding:0.4rem 0.5rem;font-family:var(--font-mono);font-weight:700;text-align:right;outline:none;" />
                                </div>
                                <VmButton Variant="dark" Icon="bi-plus-lg" Disabled="@(string.IsNullOrWhiteSpace(descripcionGastoLibre) || montoGastoLibre <= 0)" OnClick="AgregarGastoGeneral">Añadir</VmButton>
                            </div>
                        }
                    </div>

                    <div style="flex:1;min-height:0;overflow:auto;padding:0 0.9rem;">
                        @if (detalles.Any())
                        {
                            <table style="width:100%;border-collapse:collapse;margin-top:9px;">
                                <thead>
                                    <tr>
                                        <th style="position:sticky;top:0;text-align:left;background:var(--ink-700);color:#fff;padding:6px 8px;font-family:var(--font-mono);font-weight:700;font-size:0.6rem;text-transform:uppercase;letter-spacing:0.5px;">Producto</th>
                                        <th style="position:sticky;top:0;text-align:center;background:var(--ink-700);color:#fff;padding:6px 8px;font-family:var(--font-mono);font-weight:700;font-size:0.6rem;text-transform:uppercase;letter-spacing:0.5px;width:60px;">Cant.</th>
                                        <th style="position:sticky;top:0;text-align:right;background:var(--ink-700);color:#fff;padding:6px 8px;font-family:var(--font-mono);font-weight:700;font-size:0.6rem;text-transform:uppercase;letter-spacing:0.5px;width:100px;">Precio</th>
                                        <th style="position:sticky;top:0;text-align:right;background:var(--ink-700);color:#fff;padding:6px 8px;font-family:var(--font-mono);font-weight:700;font-size:0.6rem;text-transform:uppercase;letter-spacing:0.5px;width:100px;">Subtotal</th>
                                        <th style="position:sticky;top:0;text-align:center;background:var(--ink-700);color:#fff;padding:6px 8px;font-family:var(--font-mono);font-weight:700;font-size:0.6rem;text-transform:uppercase;letter-spacing:0.5px;width:50px;">Pend.</th>
                                        <th style="position:sticky;top:0;background:var(--ink-700);color:#fff;padding:6px 8px;width:36px;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var d in detalles)
                                    {
                                        <tr style="border-bottom:1px solid var(--line-200);@(d.EsPendiente ? "background:var(--tint-pending, rgba(255,193,7,0.12));" : "")">
                                            <td style="padding:7px 8px;">
                                                @if (factura.TipoFactura == "MERCADERIA")
                                                {
                                                    @if (d.ProductoId == null || d.ProductoId == 0)
                                                    {
                                                        <select @bind="d.ProductoId" style="width:100%;border:2px solid var(--signal-warning);border-radius:0;padding:0.3rem 0.4rem;font-family:var(--font-sans);font-weight:700;font-size:0.78rem;background:var(--paper-50);">
                                                            <option value="">⚠️ Asignar: "@d.ProductoNombre"</option>
                                                            @foreach (var p in ProductosDisponibles)
                                                            {
                                                                <option value="@p.Id">@p.Nombre</option>
                                                            }
                                                        </select>
                                                    }
                                                    else
                                                    {
                                                        <div style="display:flex;align-items:center;justify-content:space-between;gap:6px;">
                                                            <span style="font-family:var(--font-sans);font-weight:600;text-transform:uppercase;font-size:0.8rem;">@d.ProductoNombre</span>
                                                            <button type="button" title="Corregir asociación" @onclick="() => d.ProductoId = null" style="border:none;background:none;cursor:pointer;color:var(--ink-900);"><i class="bi bi-pencil-square"></i></button>
                                                        </div>
                                                    }
                                                    @if (!string.IsNullOrEmpty(d.Ean))
                                                    {
                                                        <div style="display:flex;align-items:center;gap:6px;margin-top:4px;">
                                                            <span title="EAN detectado por OCR" style="font-family:var(--font-mono);font-size:0.6rem;font-weight:700;background:var(--ink-900);color:#fff;padding:1px 5px;">@d.Ean</span>
                                                            <span style="font-family:var(--font-mono);font-size:0.58rem;text-transform:uppercase;color:var(--text-muted);">Pack</span>
                                                            <input type="number" min="1" placeholder="1" title="Unidades por pack" @bind="d.PackSize" style="width:56px;border:2px solid var(--ink-900);border-radius:0;padding:0.2rem 0.3rem;font-family:var(--font-mono);font-weight:700;text-align:center;" />
                                                        </div>
                                                    }
                                                    @if (d.RequiereConfirmacionPack && d.PackSize > 1)
                                                    {
                                                        <div style="margin-top:4px;font-family:var(--font-mono);font-size:0.62rem;font-weight:700;color:var(--ink-900);">
                                                            📦 Pack de @d.PackSize → @d.Cantidad unids, @d.CostoUnitario.ToString("C0") c/u
                                                            <label style="display:flex;align-items:center;gap:5px;margin-top:3px;cursor:pointer;text-transform:uppercase;">
                                                                <input type="checkbox" @bind="d.PackConfirmado" style="accent-color:var(--ink-900);" /> Confirmar pack
                                                            </label>
                                                        </div>
                                                    }
                                                }
                                                else
                                                {
                                                    <input type="text" placeholder="Descripción del gasto…" @bind="d.DescripcionItem" style="width:100%;border:2px solid var(--ink-900);border-radius:0;padding:0.3rem 0.4rem;font-family:var(--font-sans);font-size:0.8rem;" />
                                                }
                                            </td>
                                            <td style="padding:7px 8px;text-align:center;">
                                                <input type="number" min="1" @bind="d.Cantidad" disabled="@(factura.TipoFactura == "GASTO_GENERAL")" style="width:50px;border:2px solid var(--ink-900);border-radius:0;padding:0.2rem 0.3rem;font-family:var(--font-mono);font-weight:700;text-align:center;" />
                                            </td>
                                            <td style="padding:7px 8px;text-align:right;">
                                                <input type="number" min="0" @bind="d.CostoUnitario" style="width:90px;border:2px solid var(--ink-900);border-radius:0;padding:0.2rem 0.3rem;font-family:var(--font-mono);font-weight:700;text-align:right;" />
                                            </td>
                                            <td style="padding:7px 8px;text-align:right;font-family:var(--font-mono);font-weight:700;color:var(--signal-success);font-size:0.8rem;">@((d.Cantidad * d.CostoUnitario).ToString("C0"))</td>
                                            <td style="padding:7px 8px;text-align:center;">
                                                <input type="checkbox" title="Dejar pendiente" @bind="d.EsPendiente" style="accent-color:var(--ink-900);" />
                                            </td>
                                            <td style="padding:7px 8px;text-align:center;">
                                                <button type="button" aria-label="Eliminar" @onclick="() => EliminarDetalle(d)" style="width:26px;height:26px;border:1px solid var(--signal-danger);color:var(--signal-danger);background:var(--paper-0);cursor:pointer;border-radius:0;"><i class="bi bi-trash-fill" style="font-size:0.7rem;"></i></button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div style="text-align:center;padding:2.4rem 1rem;color:var(--text-muted);">
                                <i class="bi bi-cart-x" style="font-size:2rem;"></i>
                                <div style="font-family:var(--font-mono);font-weight:700;text-transform:uppercase;font-size:0.78rem;margin-top:8px;">Canasta vacía</div>
                                <div style="font-family:var(--font-mono);font-size:0.68rem;margin-top:3px;">Escanea una factura o agrega ítems manualmente.</div>
                            </div>
                        }
                    </div>

                    <div style="flex-shrink:0;padding:0.85rem 0.9rem;border-top:2px solid var(--ink-900);display:flex;flex-direction:column;gap:9px;">
                        @if (!string.IsNullOrEmpty(NuevaError))
                        {
                            <div style="font-family:var(--font-mono);font-weight:700;font-size:0.72rem;color:var(--signal-danger);text-transform:uppercase;display:flex;align-items:center;gap:6px;"><i class="bi bi-exclamation-triangle-fill"></i>@NuevaError</div>
                        }
                        <div style="display:flex;gap:10px;">
                            <VmButton Variant="outline" Block="true" Disabled="@Guardando" OnClick="CerrarNuevaCompra">Cancelar</VmButton>
                            <VmButton Variant="dark" Icon="bi-save-fill" Block="true" Disabled="@(Guardando || detalles.Any(d => d.RequiereConfirmacionPack && !d.PackConfirmado))" OnClick="GuardarNuevaCompra">Confirmar compra (@CalcularTotal().ToString("C0"))</VmButton>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
}

</MobileShell>

@code {
