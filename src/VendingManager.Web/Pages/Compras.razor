    private void EliminarDetalle(DetalleUI d) => detalles.Remove(d);

    private decimal CalcularTotal() => detalles.Where(d => !d.EsPendiente).Sum(d => d.Cantidad * d.CostoUnitario);

    private async Task GuardarNuevaCompra()
    {
        NuevaError = null;

        if (string.IsNullOrWhiteSpace(factura.Proveedor))
        {
            NuevaError = "Debe ingresar el nombre del proveedor.";
            return;
        }

        if (!detalles.Any())
        {
            NuevaError = "Debe agregar al menos un producto o gasto.";
            return;
        }

        if (factura.TipoFactura == "MERCADERIA" && detalles.Any(d => !d.EsPendiente && d.ProductoId == null && string.IsNullOrWhiteSpace(d.DescripcionItem)))
        {
            NuevaError = "Cada ítem debe tener un producto asignado o una descripción (texto libre).";
            return;
        }

        if (factura.TipoFactura == "GASTO_GENERAL" && detalles.Any(d => string.IsNullOrWhiteSpace(d.DescripcionItem)))
        {
            NuevaError = "Todos los gastos deben tener una descripción.";
            return;
        }

        if (detalles.Any(d => d.RequiereConfirmacionPack && !d.PackConfirmado))
        {
            NuevaError = "Debe confirmar los packs detectados antes de guardar.";
            return;
        }

        Guardando = true;

        try
        {
            factura.Estado = factura.PagadaCaja ? "PAGADA" : "PENDIENTE";
            factura.Detalles = detalles.Select(d => new RegistrarDetalleCompraRequestDto
            {
                ProductoId = d.ProductoId,
                DescripcionItem = d.DescripcionItem,
                Cantidad = d.Cantidad,
                CostoUnitario = d.CostoUnitario,
                EsPendiente = d.EsPendiente,
                Ean = d.Ean,
                Sku = d.Sku,
                PackSize = d.RequiereConfirmacionPack ? null : d.PackSize
            }).ToList();

            var response = await Http.PostAsJsonAsync("api/compras", factura);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<System.Text.Json.JsonElement>();
                int compraId = result.GetProperty("id").GetInt32();

                bool uploadOk = true;
                if (FacturaPreviewData != null)
                    uploadOk = await UploadFacturaImagen(compraId);

                if (uploadOk)
                {
                    ClearFacturaPreview();
                    _nuevaOpen = false;
                    MensajeExito = $"Compra de {factura.Proveedor} registrada correctamente.";
                    await CargarCompras();
                }
            }
            else
            {
                NuevaError = $"Error al registrar: {await response.Content.ReadAsStringAsync()}";
            }
        }
        catch (Exception ex)
        {
            NuevaError = $"Ocurrió un error inesperado: {ex.Message}";
        }
        finally
        {
            Guardando = false;
        }
    }

    private async Task<bool> UploadFacturaImagen(int compraId)
    {
        if (FacturaPreviewData == null) return true;

        try
        {
            using var content = new MultipartFormDataContent();
            var byteContent = new ByteArrayContent(FacturaPreviewData);
            byteContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(FacturaFile?.ContentType ?? "image/jpeg");
            content.Add(byteContent, "file", FacturaFile?.Name ?? "factura.jpg");

            var uploadResponse = await Http.PostAsync($"api/compras/{compraId}/factura", content);
            if (!uploadResponse.IsSuccessStatusCode)
            {
                NuevaError = $"Compra guardada (ID: {compraId}), pero falló la carga de la imagen: {await uploadResponse.Content.ReadAsStringAsync()}";
                return false;
            }
            return true;
        }
        catch (Exception ex)
        {
            NuevaError = $"Compra guardada (ID: {compraId}), pero falló la carga de la imagen: {ex.Message}";
            return false;
        }
    }

    private async Task HandleImageUpload(InputFileChangeEventArgs e)
    {
        NuevaError = null;
        var file = e.File;
        if (file == null) return;

        const long maxSize = 10 * 1024 * 1024; // 10MB
        if (file.Size > maxSize)
        {
            NuevaError = "La imagen supera los 10MB.";
            return;
        }

        ProcesandoOCR = true;

        try
        {
            byte[] fileBytes;
            using (var stream = file.OpenReadStream(maxSize))
            using (var memoryStream = new MemoryStream())
            {
                await stream.CopyToAsync(memoryStream);
                fileBytes = memoryStream.ToArray();
            }

            FacturaFile = file;
            FacturaPreviewData = fileBytes;
            FacturaPreviewUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(fileBytes)}";

            using var content = new MultipartFormDataContent();
            var byteContent = new ByteArrayContent(fileBytes);
            var mimeType = ResolveMimeType(file.Name, file.ContentType);
            byteContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(mimeType);
            content.Add(byteContent, "file", file.Name);

            var response = await Http.PostAsync("api/compras/upload-factura", content);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<OcrInvoiceResultDto>();
                if (result != null)
                {
                    if (!string.IsNullOrEmpty(result.Proveedor)) factura.Proveedor = result.Proveedor;
                    if (!string.IsNullOrEmpty(result.NumeroDocumento)) factura.NumeroDocumento = result.NumeroDocumento;

                    if (TryParseFechaChile(result.Fecha, out DateTime dtOut))
                        factura.FechaCompra = dtOut;

                    var provLower = (factura.Proveedor ?? "").ToLowerInvariant();
                    if (provLower.Contains("bencina") || provLower.Contains("copec") || provLower.Contains("shell") ||
                        provLower.Contains("petrobras") || provLower.Contains("petro") || provLower.Contains("gasolin"))
                    {
                        factura.SubcategoriaGasto = "LOGISTICA";
                    }
                    else if (provLower.Contains("peaje") || provLower.Contains("autopista") || provLower.Contains("tag") ||
                             provLower.Contains("costanera") || provLower.Contains("vespucio"))
                    {
                        factura.SubcategoriaGasto = "PEAJES";
                    }

                    foreach (var item in result.Items)
                    {
                        int idProducto = 0;
                        string nombreProd = item.Producto ?? "Desconocido";

                        if (item.ProductoIdMatch.HasValue && item.ProductoIdMatch.Value > 0)
                        {
                            var matchDb = ProductosDisponibles.FirstOrDefault(p => p.Id == item.ProductoIdMatch.Value);
                            if (matchDb != null)
                            {
                                idProducto = matchDb.Id;
                                nombreProd = matchDb.Nombre;
                            }
                        }

                        detalles.Add(new DetalleUI
                        {
                            ProductoId = idProducto > 0 ? idProducto : null,
                            ProductoNombre = nombreProd,
                            DescripcionItem = nombreProd,
                            Cantidad = item.Cantidad > 0 ? (int)Math.Round(item.Cantidad) : 1,
                            CostoUnitario = item.CostoUnitario,
                            Ean = item.Ean,
                            Sku = item.Sku,
                            PackSize = item.PackSize,
                            RequiereConfirmacionPack = item.RequiereConfirmacionPack,
                            PackConfirmado = !item.RequiereConfirmacionPack
                        });
                    }

                    var tieneMatches = result.Items.Any(i => i.ProductoIdMatch.HasValue && i.ProductoIdMatch.Value > 0);
                    if (!tieneMatches && result.Items.Count <= 1)
                    {
                        factura.TipoFactura = "GASTO_GENERAL";
                        if (result.Items.Count == 1)
                        {
                            var unico = result.Items[0];
                            if (!string.IsNullOrEmpty(unico.Producto))
                            {
                                foreach (var d in detalles)
                                {
                                    d.DescripcionItem = unico.Producto;
                                    d.ProductoNombre = unico.Producto;
                                }
                            }
                        }
                    }

                    if (detalles.Count == 0 && result.MontoTotal > 0)
                    {
                        var descripcion = string.IsNullOrEmpty(result.Proveedor) ? "Gasto general" : result.Proveedor;
                        detalles.Add(new DetalleUI
                        {
                            ProductoId = null,
                            ProductoNombre = descripcion,
                            DescripcionItem = descripcion,
                            Cantidad = 1,
                            CostoUnitario = result.MontoTotal
                        });
                        factura.TipoFactura = "GASTO_GENERAL";
                    }
                }
            }
            else
            {
                NuevaError = "Error al escanear la imagen. " + await response.Content.ReadAsStringAsync();
            }
        }
        catch (Exception ex)
        {
            NuevaError = "Error procesando IA: " + ex.Message;
        }
        finally
        {
            ProcesandoOCR = false;
        }
    }

    private void ClearFacturaPreview()
    {
        FacturaFile = null;
        FacturaPreviewUrl = null;
        FacturaPreviewData = null;
    }

    private static string ResolveMimeType(string fileName, string? contentType)
    {
        if (!string.IsNullOrEmpty(contentType))
            return contentType;

        var ext = Path.GetExtension(fileName)?.ToLowerInvariant();
        return ext switch
        {
            ".jpg" or ".jpeg" or ".jpge" => "image/jpeg",
            ".png" => "image/png",
            ".webp" => "image/webp",
            ".bmp" => "image/bmp",
            ".gif" => "image/gif",
            ".pdf" => "application/pdf",
            _ => "application/octet-stream"
        };
    }

    private static bool TryParseFechaChile(string? fecha, out DateTime result)
    {
        result = default;
        if (string.IsNullOrWhiteSpace(fecha)) return false;

        string[] formats = { "yyyy-MM-dd", "yyyy/MM/dd", "dd-MM-yy", "dd/MM/yy",
                             "dd-MM-yyyy", "dd/MM/yyyy", "d-M-yy", "d/M/yy",
                             "d-M-yyyy", "d/M/yyyy" };

        return DateTime.TryParseExact(fecha.Trim(), formats,
            System.Globalization.CultureInfo.InvariantCulture,
            System.Globalization.DateTimeStyles.None, out result);
    }

    private class DetalleUI
    {
        public int? ProductoId { get; set; }
        public string ProductoNombre { get; set; } = string.Empty;
        public string DescripcionItem { get; set; } = string.Empty;
        public int Cantidad { get; set; }
        public decimal CostoUnitario { get; set; }
        public bool EsPendiente { get; set; }
        public string? Ean { get; set; }
        public string? Sku { get; set; }
        public int? PackSize { get; set; }
        public bool RequiereConfirmacionPack { get; set; }
        public bool PackConfirmado { get; set; } = true;
    }
