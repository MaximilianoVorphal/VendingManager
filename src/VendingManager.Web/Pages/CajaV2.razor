@page "/caja"
@page "/caja-v2"
@using System.Globalization
@using VendingManager.Web.Components.Mobile
@using System.Net.Http.Headers
@using Microsoft.AspNetCore.Components.Forms
@inject HttpClient Http
@inject NavigationManager Navigation

@* =============================================================================
   Control de Caja — port fiel de templates/caja/Caja.dc.html, ahora conectado
   al backend real (mismas APIs que Pages/Caja.razor). Pantalla única sin scroll:
   KPIs siempre visibles, movimientos agrupados por día/orden de carga con scroll
   interno, y — sin salir de la vista — Gastos Fijos y Estado de Resultados como
   drawers laterales. Modal de alta + modal de detalle.
   Botones de cabecera con los tamaños del design (size sm + ancho fijo).
   ============================================================================= *@

<style>
    @@keyframes cajaBlink { 50% { opacity: 0; } }
    @@keyframes cajaFade { from { opacity: 0; transform: translateY(-8px); } to { opacity: 1; transform: translateY(0); } }
    @@keyframes cajaDrawer { from { transform: translateX(100%); } to { transform: translateX(0); } }
    @@keyframes cajaBackdrop { from { opacity: 0; } to { opacity: 1; } }
    .caja-cursor { animation: cajaBlink 1s steps(1) infinite; }
    .caja-modal { animation: cajaFade .15s ease-out; }
    .caja-panel { animation: cajaDrawer .2s ease-out; }
    .caja-back { animation: cajaBackdrop .15s ease-out; }
    .caja-row:hover { background: var(--bg-surface-inset) !important; }
    @@media (prefers-reduced-motion: reduce) {
        .caja-cursor, .caja-modal, .caja-panel, .caja-back { animation: none !important; }
    }
    .caja-page h2 { user-select: none; }
    .caja-page :is(button, select, input):focus:not(:focus-visible) { outline: none; }
    .caja-page :is(button, select, input):focus-visible {
        outline: 2px solid var(--ink-900); outline-offset: 2px;
    }
    /* Mobile (max-width 520px): body-based scroll — prevent flex:1 collapse */
    @@media (max-width: 520px) {
        .caja-page,
        .caja-page [style*="flex:1"][style*="min-height:0"] {
            flex: none !important;
        }
    }
</style>

<MobileShell>
<div class="caja-page" style="flex:1;min-height:0;display:flex;flex-direction:column;overflow:hidden;padding:1.1rem 1.5rem 1.25rem;">

    <!-- Header -->
    <div style="display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:14px;border-bottom:3px solid var(--ink-900);padding-bottom:12px;margin-bottom:16px;">
        <div>
            <h2 style="margin:0;font-family:var(--font-mono);font-weight:700;text-transform:uppercase;letter-spacing:-1px;">Control de Caja</h2>
            <small style="font-family:var(--font-mono);font-weight:700;color:var(--text-muted);text-transform:uppercase;">Flujo de caja y rentabilidad</small>
        </div>
        <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
            <VmButton Variant="dark" Size="sm" Width="40px" OnClick="PrevMonth">◀</VmButton>
            <div style="background:var(--ink-900);color:var(--paper-0);padding:0.5rem 0.9rem;font-family:var(--font-mono);font-weight:700;text-transform:uppercase;min-width:150px;text-align:center;">@MesLabel</div>
            <VmButton Variant="dark" Size="sm" Width="40px" OnClick="NextMonth">▶</VmButton>
            <VmButton Variant="outline" Size="sm" Width="60px" OnClick="Today">Hoy</VmButton>
            <VmButton Variant="outline" Size="sm" Width="120px" Icon="bi-download" OnClick="Exportar">Exportar</VmButton>
            <VmButton Variant="dark" Width="190px" Icon="bi-plus-lg" OnClick="AbrirRegistro" Disabled="@(Resumen?.IsLocked == true)">Nuevo movimiento</VmButton>
        </div>
    </div>

    <!-- KPIs -->
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:14px;margin-bottom:16px;">

        <!-- Ventas del mes -->
        <div style="border:2px solid var(--ink-900);background:var(--paper-0);padding:0.95rem 1.05rem;display:flex;flex-direction:column;gap:0.55rem;">
            <div style="display:flex;justify-content:space-between;align-items:center;gap:8px;">
                <span style="font-family:var(--font-mono);font-weight:700;font-size:0.74rem;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-secondary);">Ventas del mes</span>
                <span style="font-family:var(--font-mono);font-weight:700;font-size:0.6rem;text-transform:uppercase;letter-spacing:0.5px;background:var(--signal-success);color:#fff;padding:3px 8px;">Operación</span>
            </div>
            <span style="font-family:var(--font-sans);font-weight:700;font-size:1.95rem;letter-spacing:-1px;line-height:1;color:var(--signal-success);">@Money(Resumen?.IngresosVentas ?? 0)</span>
            <small style="font-family:var(--font-mono);font-size:0.72rem;color:var(--text-muted);">Ingresos por operación</small>
        </div>

        <!-- Gastos del mes -->
        <div style="border:2px solid var(--ink-900);background:var(--paper-0);padding:0.95rem 1.05rem;display:flex;flex-direction:column;gap:0.55rem;">
            <div style="display:flex;justify-content:space-between;align-items:center;gap:8px;">
                <span style="font-family:var(--font-mono);font-weight:700;font-size:0.74rem;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-secondary);">Gastos del mes</span>
                <span style="font-family:var(--font-mono);font-weight:700;font-size:0.6rem;text-transform:uppercase;letter-spacing:0.5px;background:var(--signal-danger);color:#fff;padding:3px 8px;">Salidas</span>
            </div>
            <span style="font-family:var(--font-sans);font-weight:700;font-size:1.95rem;letter-spacing:-1px;line-height:1;color:var(--signal-danger);">@MoneyNeg(Resumen?.GastosOperativos ?? 0)</span>
            <small style="font-family:var(--font-mono);font-size:0.72rem;color:var(--text-muted);">Bencina, peajes, mercadería</small>
        </div>

        <!-- Resultado del mes -->
        <div style="border:2px solid var(--ink-900);background:var(--paper-0);padding:0.95rem 1.05rem;display:flex;flex-direction:column;gap:0.55rem;">
            <div style="display:flex;justify-content:space-between;align-items:center;gap:8px;">
                <span style="font-family:var(--font-mono);font-weight:700;font-size:0.74rem;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-secondary);">Resultado del mes</span>
                <span style="font-family:var(--font-mono);font-weight:700;font-size:0.6rem;text-transform:uppercase;letter-spacing:0.5px;background:var(--ink-900);color:#fff;padding:3px 8px;">Neto</span>
            </div>
            <span style="font-family:var(--font-sans);font-weight:700;font-size:1.95rem;letter-spacing:-1px;line-height:1;color:@(ResultadoMes >= 0 ? "var(--signal-success)" : "var(--signal-danger)");">@MoneySigned(ResultadoMes)</span>
            <small style="font-family:var(--font-mono);font-size:0.72rem;color:var(--text-muted);">Ventas − Gastos</small>
        </div>

        <!-- Disponible en caja -->
        <div style="border:2px solid var(--ink-900);background:var(--ink-900);padding:0.95rem 1.05rem;display:flex;flex-direction:column;gap:0.55rem;">
            <div style="display:flex;justify-content:space-between;align-items:center;gap:8px;">
                <span style="font-family:var(--font-mono);font-weight:700;font-size:0.74rem;text-transform:uppercase;letter-spacing:0.5px;color:rgba(255,255,255,0.7);">Disponible en caja</span>
                <span style="font-family:var(--font-mono);font-weight:700;font-size:0.6rem;text-transform:uppercase;letter-spacing:0.5px;border:1px solid rgba(255,255,255,0.6);color:#fff;padding:3px 8px;">Total</span>
            </div>
            <span style="font-family:var(--font-sans);font-weight:700;font-size:1.95rem;letter-spacing:-1px;line-height:1;color:#fff;">@Money(Resumen?.SaldoFinal ?? 0)</span>
            <small style="font-family:var(--font-mono);font-size:0.72rem;color:rgba(255,255,255,0.55);">Saldo real (incluye histórico)</small>
        </div>
    </div>

    @if (Resumen?.IsLocked == true)
    {
        <div style="border:2px solid var(--signal-warning);background:var(--tint-pending);padding:0.6rem 0.9rem;margin-bottom:12px;font-family:var(--font-mono);font-weight:700;font-size:0.78rem;text-transform:uppercase;">
            <i class="bi bi-lock-fill"></i> Este mes está cerrado. No se pueden agregar nuevos movimientos.
        </div>
    }

    <!-- Movements panel -->
    <div style="flex:1;min-height:0;display:flex;flex-direction:column;border:2px solid var(--ink-900);box-shadow:var(--shadow-card);background:var(--paper-0);">
        <div style="background:var(--ink-900);color:var(--paper-0);display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap;padding:0.55rem 0.9rem;">
            <div style="font-family:var(--font-mono);font-weight:700;text-transform:uppercase;letter-spacing:1px;">Movimientos<span class="caja-cursor">_</span> <span style="color:rgba(255,255,255,0.55);font-size:0.78rem;font-weight:400;">@FilteredMovs.Count ítems</span></div>
            <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
                <input type="text" placeholder="Buscar…" @bind="_search" @bind:event="oninput" style="border:2px solid var(--paper-0);background:var(--paper-0);color:var(--ink-900);font-family:var(--font-mono);font-size:0.75rem;padding:4px 8px;width:150px;border-radius:0;outline:none;" />
                <select @bind="_filter" style="border:2px solid var(--paper-0);background:var(--paper-0);color:var(--ink-900);font-family:var(--font-mono);font-weight:700;font-size:0.72rem;text-transform:uppercase;padding:4px 8px;border-radius:0;cursor:pointer;">
                    <option value="TODOS">Todos</option>
                    <option value="GASTO">Gastos</option>
                    <option value="APORTE">Aportes</option>
                    <option value="RETIRO">Retiros</option>
                </select>
                <button @onclick="AbrirGastosFijos" style="display:flex;align-items:center;gap:6px;font-family:var(--font-mono);font-weight:700;font-size:0.72rem;text-transform:uppercase;padding:5px 10px;background:transparent;color:var(--paper-0);border:2px solid var(--paper-0);border-radius:0;cursor:pointer;"><i class="bi bi-gear"></i><span>Gastos fijos</span>@if (Pendientes.Any()){<span style="background:var(--signal-warning);color:var(--ink-900);border-radius:999px;min-width:17px;height:17px;display:inline-flex;align-items:center;justify-content:center;font-size:0.62rem;padding:0 4px;">@Pendientes.Count</span>}</button>
                <button @onclick="AbrirResultados" style="display:flex;align-items:center;gap:6px;font-family:var(--font-mono);font-weight:700;font-size:0.72rem;text-transform:uppercase;padding:5px 10px;background:transparent;color:var(--paper-0);border:2px solid var(--paper-0);border-radius:0;cursor:pointer;"><i class="bi bi-graph-up-arrow"></i>Estado resultados</button>
            </div>
        </div>

        <div style="flex:1;min-height:0;overflow:auto;background:var(--bg-surface-inset);padding:0.6rem;">
            @if (BuildGrupos() is { Count: > 0 } grupos)
            {
                @foreach (var grupo in grupos)
                {
                    <div style="background:var(--paper-0);border:1px solid var(--line-200);box-shadow:var(--shadow-card);margin-bottom:8px;">
                        <div style="display:flex;justify-content:space-between;align-items:center;padding:9px 11px;border-bottom:1px solid var(--line-200);">
                            <div style="display:flex;align-items:center;gap:12px;">
                                <div style="text-align:center;background:var(--ink-900);color:#fff;padding:5px 8px;min-width:52px;">
                                    <span style="display:block;font-family:var(--font-mono);font-weight:700;font-size:0.6rem;text-transform:uppercase;">@grupo.Mes</span>
                                    <span style="display:block;font-family:var(--font-sans);font-weight:700;font-size:1.3rem;line-height:1;">@grupo.Dia</span>
                                </div>
                                <div>
                                    <div style="display:flex;align-items:center;gap:8px;">
                                        <span style="font-family:var(--font-mono);font-weight:700;text-transform:uppercase;font-size:0.9rem;">@grupo.Titulo</span>
                                        @if (grupo.Orden)
                                        {
                                            <span style="background:var(--signal-warning);color:var(--ink-900);font-family:var(--font-mono);font-size:0.6rem;font-weight:700;padding:2px 6px;text-transform:uppercase;">Orden de carga</span>
                                        }
                                    </div>
                                    <small style="color:var(--text-muted);font-family:var(--font-mono);font-size:0.7rem;">@grupo.Items.Count movimientos</small>
                                </div>
                            </div>
                            <div style="text-align:right;">
                                <small style="display:block;color:var(--text-muted);font-family:var(--font-mono);font-weight:700;font-size:0.6rem;text-transform:uppercase;">Total día</small>
                                <span style="font-family:var(--font-sans);font-weight:700;font-size:1.1rem;color:@(grupo.TotalPos ? "var(--signal-success)" : "var(--signal-danger)");">@MoneySigned(grupo.Total)</span>
                            </div>
                        </div>
                        <table class="vm-accordion-table" style="width:100%;border-collapse:collapse;">
                            <tbody>
                                @foreach (var m in grupo.Items)
                                {
                                    <tr class="caja-row" @onclick="() => _detail = m" style="border-bottom:1px solid var(--line-200);cursor:pointer;">
                                        <td style="padding:7px 12px;width:64px;"><small style="font-family:var(--font-mono);color:var(--text-muted);font-size:0.72rem;">@m.Fecha.ToString("HH:mm")</small></td>
                                        <td style="padding:7px 6px;width:128px;">
                                            <span style="font-family:var(--font-mono);font-size:0.64rem;font-weight:700;text-transform:uppercase;border:1px solid var(--ink-900);padding:2px 6px;background:@(m.Monto > 0 ? "#d1e7dd" : "#f8d7da");display:inline-block;">@m.Categoria</span>
                                        </td>
                                        <td style="padding:7px 6px;"><span style="font-family:var(--font-sans);font-size:0.82rem;font-weight:600;text-transform:uppercase;">@m.Descripcion</span></td>
                                        <td style="padding:7px 12px;text-align:right;width:120px;">
                                            <span style="font-family:var(--font-mono);font-weight:700;color:@(m.Monto > 0 ? "var(--signal-success)" : "var(--signal-danger)");">@MoneySigned(m.Monto)</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            }
            else
            {
                <div style="padding:2rem;text-align:center;font-family:var(--font-mono);font-size:0.8rem;color:var(--text-muted);text-transform:uppercase;">
                    @(string.IsNullOrEmpty(ErrorCarga) ? "No hay movimientos registrados en este mes." : ErrorCarga)
                </div>
            }
        </div>
    </div>
</div>

<!-- ===== MODAL: Nuevo movimiento ===== -->
@if (_entryOpen)
{
    <div class="caja-back" style="position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:2000;display:flex;align-items:flex-start;justify-content:center;padding:4vh 16px;overflow:auto;" @onclick="CloseEntry">
        <div class="caja-modal" style="width:100%;max-width:460px;background:var(--paper-0);border:2px solid var(--ink-900);box-shadow:4px 4px 0 #000;" @onclick:stopPropagation="true">
            <div style="background:var(--ink-900);color:#fff;display:flex;justify-content:space-between;align-items:center;padding:0.6rem 0.9rem;font-family:var(--font-mono);font-weight:700;text-transform:uppercase;letter-spacing:1px;">
                <span>Registrar movimiento</span>
                <span style="cursor:pointer;font-size:1.2rem;line-height:1;" @onclick="CloseEntry">×</span>
            </div>
            <div style="background:var(--bg-surface-inset);padding:1.1rem;display:flex;flex-direction:column;gap:14px;">
                <div>
                    <label style="font-family:var(--font-mono);font-weight:700;font-size:0.72rem;text-transform:uppercase;letter-spacing:0.5px;">1. Tipo de operación</label>
                    <div style="display:flex;border:2px solid var(--ink-900);margin-top:6px;">
                        <button @onclick='() => SetTipo("GASTO")' style="flex:1;font-family:var(--font-mono);font-weight:700;font-size:0.78rem;text-transform:uppercase;padding:0.5rem 0.2rem;cursor:pointer;border:none;border-radius:0;background:@(Nuevo.Tipo == "GASTO" ? "var(--signal-danger)" : "var(--paper-0)");color:@(Nuevo.Tipo == "GASTO" ? "#fff" : "var(--ink-900)");">Gasto</button>
                        <button @onclick='() => SetTipo("APORTE")' style="flex:1;font-family:var(--font-mono);font-weight:700;font-size:0.78rem;text-transform:uppercase;padding:0.5rem 0.2rem;cursor:pointer;border:none;border-left:2px solid var(--ink-900);border-radius:0;background:@(Nuevo.Tipo == "APORTE" ? "var(--ink-900)" : "var(--paper-0)");color:@(Nuevo.Tipo == "APORTE" ? "#fff" : "var(--ink-900)");">Aporte</button>
                        <button @onclick='() => SetTipo("RETIRO")' style="flex:1;font-family:var(--font-mono);font-weight:700;font-size:0.78rem;text-transform:uppercase;padding:0.5rem 0.2rem;cursor:pointer;border:none;border-left:2px solid var(--ink-900);border-radius:0;background:@(Nuevo.Tipo == "RETIRO" ? "var(--signal-warning)" : "var(--paper-0)");color:var(--ink-900);">Retiro</button>
                    </div>
                </div>
                <div>
                    <label style="font-family:var(--font-mono);font-weight:700;font-size:0.72rem;text-transform:uppercase;letter-spacing:0.5px;">2. Monto</label>
                    <div style="display:flex;margin-top:6px;">
                        <span style="background:var(--ink-900);color:#fff;font-family:var(--font-mono);font-weight:700;padding:0.5rem 0.95rem;display:flex;align-items:center;">$</span>
                        <input placeholder="0" @bind="MontoString" style="flex:1;border:2px solid var(--ink-900);border-left:none;border-radius:0;padding:0.5rem 0.75rem;font-family:var(--font-sans);font-weight:700;font-size:1.3rem;outline:none;width:100%;" />
                    </div>
                </div>
                <div>
                    <label style="font-family:var(--font-mono);font-weight:700;font-size:0.72rem;text-transform:uppercase;letter-spacing:0.5px;">3. Categoría</label>
                    <select @bind="Nuevo.Categoria" style="width:100%;margin-top:6px;border:2px solid var(--ink-900);border-radius:0;background:var(--paper-0);font-family:var(--font-mono);font-weight:700;font-size:0.82rem;text-transform:uppercase;padding:0.5rem 0.6rem;cursor:pointer;outline:none;">
                        @foreach (var opt in CategoriaOptions)
                        {
                            <option value="@opt.Value">@opt.Label</option>
                        }
                    </select>
                </div>
                <div>
                    <label style="font-family:var(--font-mono);font-weight:700;font-size:0.72rem;text-transform:uppercase;letter-spacing:0.5px;">4. Descripción</label>
                    <input placeholder="Ej: COPEC, LIDER…" @bind="Nuevo.Descripcion" style="width:100%;margin-top:6px;border:2px solid var(--ink-900);border-radius:0;background:var(--paper-0);font-family:var(--font-sans);font-size:0.9rem;padding:0.5rem 0.6rem;outline:none;" />
                </div>
                <div>
                    <label style="font-family:var(--font-mono);font-weight:700;font-size:0.72rem;text-transform:uppercase;letter-spacing:0.5px;">5. Fecha de registro</label>
                    <input type="date" @bind="FechaRegistro" @bind:format="yyyy-MM-dd" style="width:100%;margin-top:6px;border:2px solid var(--ink-900);border-radius:0;background:var(--paper-0);font-family:var(--font-mono);font-weight:700;font-size:0.85rem;padding:0.45rem 0.6rem;outline:none;" />
                </div>
                <div>
                    <label style="font-family:var(--font-mono);font-weight:700;font-size:0.72rem;text-transform:uppercase;letter-spacing:0.5px;">6. Comprobante (opcional)</label>
                    <InputFile OnChange="LoadFile" accept=".jpg,.jpeg,.png,.pdf" style="width:100%;margin-top:6px;border:2px solid var(--ink-900);border-radius:0;background:var(--paper-0);font-family:var(--font-mono);font-size:0.78rem;padding:0.4rem 0.5rem;outline:none;" />
                    @if (_fileToUpload != null)
                    {
                        <small style="font-family:var(--font-mono);font-size:0.7rem;color:var(--signal-success);">@_fileToUpload.Name</small>
                    }
                </div>
                <div style="display:flex;gap:10px;">
                    <VmButton Variant="outline" Block="true" OnClick="CloseEntry">Cancelar</VmButton>
                    <VmButton Variant="dark" Block="true" OnClick="Registrar" Disabled="@(_isUploading || Resumen?.IsLocked == true)">@(_isUploading ? "Subiendo…" : "Registrar")</VmButton>
                </div>
                @if (!string.IsNullOrEmpty(Mensaje))
                {
                    <div style="text-align:center;font-family:var(--font-mono);font-weight:700;font-size:0.8rem;color:var(--signal-success);">@Mensaje</div>
                }
            </div>
        </div>
    </div>
}

<!-- ===== MODAL: Detalle de movimiento ===== -->
@if (_detail is not null)
{
    var d = _detail!;
    <div class="caja-back" style="position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:2000;display:flex;align-items:flex-start;justify-content:center;padding:6vh 16px;overflow:auto;" @onclick="() => _detail = null">
        <div class="caja-modal" style="width:100%;max-width:420px;background:var(--paper-0);border:2px solid var(--ink-900);box-shadow:4px 4px 0 #000;" @onclick:stopPropagation="true">
            <div style="background:var(--ink-900);color:#fff;display:flex;justify-content:space-between;align-items:center;padding:0.6rem 0.9rem;font-family:var(--font-mono);font-weight:700;text-transform:uppercase;letter-spacing:1px;">
                <span>Detalle de movimiento</span>
                <span style="cursor:pointer;font-size:1.2rem;line-height:1;" @onclick="() => _detail = null">×</span>
            </div>
            <div style="padding:1.2rem;">
                <div style="text-align:center;margin-bottom:1rem;">
                    <div style="font-family:var(--font-sans);font-weight:700;font-size:2.2rem;letter-spacing:-1px;color:@(d.Monto > 0 ? "var(--signal-success)" : "var(--signal-danger)");">@MoneySigned(d.Monto)</div>
                </div>
                <div style="display:grid;grid-template-columns:auto 1fr;gap:8px 16px;font-family:var(--font-mono);font-size:0.8rem;align-items:baseline;">
                    <span style="color:var(--text-muted);font-weight:700;text-transform:uppercase;font-size:0.66rem;">Fecha</span><span style="font-weight:600;">@d.Fecha.ToString("dd/MM/yyyy") · @d.Fecha.ToString("HH:mm")</span>
                    <span style="color:var(--text-muted);font-weight:700;text-transform:uppercase;font-size:0.66rem;">Tipo</span><span style="font-weight:600;text-transform:uppercase;">@d.Tipo</span>
                    <span style="color:var(--text-muted);font-weight:700;text-transform:uppercase;font-size:0.66rem;">Categoría</span><span style="font-weight:600;text-transform:uppercase;">@d.Categoria</span>
                    <span style="color:var(--text-muted);font-weight:700;text-transform:uppercase;font-size:0.66rem;">Glosa</span><span style="font-weight:600;text-transform:uppercase;">@d.Descripcion</span>
                </div>
                @if (!string.IsNullOrEmpty(d.ImagenPath))
                {
                    <div style="margin-top:1rem;border:2px dashed var(--line-200);padding:1rem;text-align:center;">
                        <a href="@d.ImagenPath" target="_blank" style="font-family:var(--font-mono);font-size:0.75rem;font-weight:700;text-transform:uppercase;color:var(--ink-900);">
                            <i class="bi @(d.ImagenPath.Contains(".pdf", StringComparison.OrdinalIgnoreCase) ? "bi-file-earmark-pdf" : "bi-image")"></i> Ver comprobante
                        </a>
                    </div>
                }
                else
                {
                    <div style="margin-top:1rem;border:2px dashed var(--line-200);background:repeating-linear-gradient(45deg,#fafafa,#fafafa 8px,#f0f0f0 8px,#f0f0f0 16px);padding:1rem;text-align:center;font-family:var(--font-mono);font-size:0.72rem;color:var(--text-muted);text-transform:uppercase;">
                        <i class="bi bi-paperclip"></i> Sin comprobante adjunto
                    </div>
                }
                <div style="display:flex;gap:10px;margin-top:1.1rem;">
                    <VmButton Variant="outline" Icon="bi-pencil" Block="true" Disabled="true">Editar</VmButton>
                    <VmButton Variant="danger" Icon="bi-trash" Block="true" OnClick="() => _detail = null">Cerrar</VmButton>
                </div>
            </div>
        </div>
    </div>
}

<!-- ===== DRAWER: Gastos fijos ===== -->
@if (_fixedOpen)
{
    <div class="caja-back" style="position:fixed;inset:0;background:rgba(0,0,0,0.45);z-index:2200;" @onclick="() => _fixedOpen = false">
        <div class="caja-panel" style="position:absolute;top:0;right:0;height:100%;width:min(560px,94vw);background:var(--paper-0);border-left:2px solid var(--ink-900);box-shadow:-6px 0 0 rgba(0,0,0,0.12);display:flex;flex-direction:column;" @onclick:stopPropagation="true">
            <div style="flex-shrink:0;background:var(--ink-900);color:#fff;display:flex;justify-content:space-between;align-items:center;padding:0.75rem 1rem;font-family:var(--font-mono);font-weight:700;text-transform:uppercase;letter-spacing:1px;">
                <span style="display:flex;align-items:center;gap:9px;"><i class="bi bi-gear"></i>Gastos fijos mensuales</span>
                <span style="cursor:pointer;font-size:1.4rem;line-height:1;" @onclick="() => _fixedOpen = false">×</span>
            </div>

            <div style="flex:1;min-height:0;overflow:auto;padding:1.1rem;">
                @if (Pendientes.Any())
                {
                    <div style="border:2px solid var(--signal-warning);background:var(--tint-pending);padding:0.8rem 0.9rem;margin-bottom:1.1rem;">
                        <div style="display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap;">
                            <div style="display:flex;align-items:center;gap:9px;">
                                <span style="background:var(--signal-warning);color:var(--ink-900);font-family:var(--font-mono);font-weight:700;font-size:0.62rem;text-transform:uppercase;letter-spacing:0.5px;padding:3px 8px;"><i class="bi bi-lightning-charge-fill"></i> Pendientes</span>
                                <span style="font-family:var(--font-mono);font-weight:700;font-size:0.78rem;text-transform:uppercase;">@Pendientes.Count gasto(s) fijo(s) sin registrar este mes</span>
                            </div>
                            <button @onclick="AplicarPendientes" disabled="@_aplicando" style="display:flex;align-items:center;gap:6px;background:var(--ink-900);color:#fff;border:2px solid var(--ink-900);font-family:var(--font-mono);font-weight:700;font-size:0.68rem;text-transform:uppercase;letter-spacing:0.5px;padding:6px 10px;cursor:pointer;border-radius:0;"><i class="bi bi-check2-all"></i>@(_aplicando ? "Aplicando…" : "Revisar y aplicar")</button>
                        </div>
                        <div style="display:flex;gap:6px;flex-wrap:wrap;margin-top:9px;">
                            @foreach (var p in Pendientes)
                            {
                                <span style="background:var(--ink-900);color:#fff;font-family:var(--font-mono);font-size:0.66rem;font-weight:700;padding:3px 8px;">@p.Descripcion — @Money(p.MontoEstimado)</span>
                            }
                        </div>
                    </div>
                }

                @if (_showGastoForm)
                {
                    <div style="border:2px solid var(--ink-900);padding:0.9rem;margin-bottom:1.1rem;display:flex;flex-direction:column;gap:10px;">
                        <span style="font-family:var(--font-mono);font-weight:700;font-size:0.72rem;text-transform:uppercase;">@(GastoEditando.Id > 0 ? "Editar" : "Nuevo") gasto fijo</span>
                        <input placeholder="Descripción" @bind="GastoEditando.Descripcion" style="border:2px solid var(--ink-900);border-radius:0;padding:0.45rem 0.6rem;font-family:var(--font-sans);font-size:0.85rem;outline:none;" />
                        <input placeholder="Monto estimado" @bind="GastoMontoString" style="border:2px solid var(--ink-900);border-radius:0;padding:0.45rem 0.6rem;font-family:var(--font-sans);font-weight:700;font-size:0.9rem;outline:none;" />
                        <select @bind="GastoEditando.Categoria" style="border:2px solid var(--ink-900);border-radius:0;padding:0.45rem 0.6rem;font-family:var(--font-mono);font-weight:700;font-size:0.8rem;text-transform:uppercase;outline:none;">
                            @foreach (var opt in GastoCategoriaOptions)
                            {
                                <option value="@opt.Value">@opt.Label</option>
                            }
                        </select>
                        <div style="display:flex;gap:8px;">
                            <VmButton Variant="outline" Size="sm" Block="true" OnClick="CancelarGastoForm">Cancelar</VmButton>
                            <VmButton Variant="dark" Size="sm" Block="true" OnClick="GuardarGasto">Guardar</VmButton>
                        </div>
                    </div>
                }

                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:9px;">
                    <span style="font-family:var(--font-mono);font-weight:700;font-size:0.72rem;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Configuración mensual</span>
                    <span style="font-family:var(--font-mono);font-size:0.66rem;border:1px solid var(--ink-900);padding:2px 8px;text-transform:uppercase;">@GastosFijos.Count activos</span>
                </div>

                <table class="vm-accordion-table" style="width:100%;border-collapse:collapse;">
                    <thead>
                        <tr style="border-bottom:2px solid var(--ink-900);">
                            <th style="text-align:left;padding:7px 4px;font-family:var(--font-mono);font-weight:700;font-size:0.6rem;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Descripción</th>
                            <th style="text-align:left;padding:7px 4px;font-family:var(--font-mono);font-weight:700;font-size:0.6rem;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Categoría</th>
                            <th style="text-align:right;padding:7px 4px;font-family:var(--font-mono);font-weight:700;font-size:0.6rem;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Monto</th>
                            <th style="text-align:right;padding:7px 4px;font-family:var(--font-mono);font-weight:700;font-size:0.6rem;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var g in GastosFijos)
                        {
                            <tr style="border-bottom:1px solid var(--line-200);">
                                <td style="padding:10px 4px;">
                                    <span style="display:block;font-family:var(--font-sans);font-weight:600;text-transform:uppercase;font-size:0.84rem;">@g.Descripcion</span>
                                    <small style="font-family:var(--font-mono);color:var(--text-muted);text-transform:uppercase;font-size:0.62rem;">@(g.MaquinaId.HasValue ? $"M-{g.MaquinaId}" : "General")</small>
                                </td>
                                <td style="padding:10px 4px;"><span style="font-family:var(--font-mono);font-size:0.6rem;font-weight:700;text-transform:uppercase;border:1px solid var(--ink-900);padding:2px 6px;display:inline-block;">@g.Categoria</span></td>
                                <td style="padding:10px 4px;text-align:right;font-family:var(--font-mono);font-weight:700;color:var(--signal-danger);">@Money(g.MontoEstimado)</td>
                                <td style="padding:10px 4px;text-align:right;white-space:nowrap;">
                                    <button @onclick="() => EditarGasto(g)" aria-label="Editar" style="width:30px;height:30px;border:1px solid var(--ink-900);background:var(--paper-0);cursor:pointer;border-radius:0;margin-right:5px;"><i class="bi bi-pencil"></i></button>
                                    <button @onclick="() => DesactivarGasto(g.Id)" aria-label="Eliminar" style="width:30px;height:30px;border:1px solid var(--signal-danger);background:var(--paper-0);color:var(--signal-danger);cursor:pointer;border-radius:0;"><i class="bi bi-x-lg"></i></button>
                                </td>
                            </tr>
                        }
                        <tr style="border-top:2px solid var(--ink-900);">
                            <td colspan="2" style="padding:11px 4px;font-family:var(--font-mono);font-weight:700;text-transform:uppercase;">Total mensual</td>
                            <td colspan="2" style="padding:11px 4px;text-align:right;font-family:var(--font-sans);font-weight:700;font-size:1.15rem;">@Money(GastosFijos.Sum(g => g.MontoEstimado))</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div style="flex-shrink:0;border-top:2px solid var(--ink-900);padding:0.9rem 1.1rem;">
                <VmButton Variant="dark" Icon="bi-plus-lg" Block="true" OnClick="NuevoGastoForm">Nuevo gasto fijo</VmButton>
            </div>
        </div>
    </div>
}

<!-- ===== DRAWER: Estado de resultados ===== -->
@if (_pnlOpen && Resumen is not null)
{
    <div class="caja-back" style="position:fixed;inset:0;background:rgba(0,0,0,0.45);z-index:2200;" @onclick="() => _pnlOpen = false">
        <div class="caja-panel" style="position:absolute;top:0;right:0;height:100%;width:min(640px,96vw);background:var(--bg-surface-inset);border-left:2px solid var(--ink-900);box-shadow:-6px 0 0 rgba(0,0,0,0.12);display:flex;flex-direction:column;" @onclick:stopPropagation="true">
            <div style="flex-shrink:0;background:var(--ink-900);color:#fff;display:flex;justify-content:space-between;align-items:center;padding:0.75rem 1rem;font-family:var(--font-mono);font-weight:700;text-transform:uppercase;letter-spacing:1px;">
                <span style="display:flex;align-items:center;gap:9px;"><i class="bi bi-graph-up-arrow"></i>Estado de Resultados · @MesLabel</span>
                <span style="cursor:pointer;font-size:1.4rem;line-height:1;" @onclick="() => _pnlOpen = false">×</span>
            </div>

            <div style="flex:1;min-height:0;overflow:auto;padding:1.1rem;display:flex;flex-direction:column;gap:1rem;">

                <!-- Indicadores de capital -->
                @if (Valorizacion is not null)
                {
                    <div style="border:2px solid var(--ink-900);background:var(--paper-0);">
                        <div style="background:var(--ink-900);color:#fff;padding:0.5rem 0.8rem;font-family:var(--font-mono);font-weight:700;font-size:0.72rem;text-transform:uppercase;letter-spacing:0.5px;"><i class="bi bi-box-seam"></i> Indicadores de capital (snapshot)</div>
                        <div style="display:grid;grid-template-columns:repeat(3,1fr);">
                            <div style="padding:0.8rem;border-right:1px solid var(--line-200);">
                                <small style="display:block;font-family:var(--font-mono);font-weight:700;font-size:0.6rem;text-transform:uppercase;color:var(--text-muted);margin-bottom:4px;">Stock en máquinas</small>
                                <span style="font-family:var(--font-sans);font-weight:700;font-size:1.05rem;">@Money(Valorizacion.ValorMaquinas)</span>
                            </div>
                            <div style="padding:0.8rem;border-right:1px solid var(--line-200);">
                                <small style="display:block;font-family:var(--font-mono);font-weight:700;font-size:0.6rem;text-transform:uppercase;color:var(--text-muted);margin-bottom:4px;">Stock en bodega</small>
                                <span style="font-family:var(--font-sans);font-weight:700;font-size:1.05rem;">@Money(Valorizacion.ValorBodega)</span>
                            </div>
                            <div style="padding:0.8rem;background:#eaf6ef;">
                                <small style="display:block;font-family:var(--font-mono);font-weight:700;font-size:0.6rem;text-transform:uppercase;color:var(--signal-success);margin-bottom:4px;">Capital mercadería</small>
                                <span style="font-family:var(--font-sans);font-weight:700;font-size:1.05rem;color:var(--signal-success);">@Money(Valorizacion.ValorTotal)</span>
                            </div>
                        </div>
                    </div>
                }

                <!-- Niveles -->
                <div style="display:flex;flex-direction:column;gap:8px;">

                    <!-- 01 Ventas netas -->
                    <div style="border:2px solid var(--ink-900);">
                        <button @onclick="() => _ventasExp = !_ventasExp" style="width:100%;display:flex;justify-content:space-between;align-items:center;gap:10px;padding:0.7rem 0.85rem;background:#1a56db;color:#fff;border:none;cursor:pointer;text-align:left;">
                            <span style="display:flex;align-items:center;gap:10px;">
                                <span style="background:#fff;color:#1a56db;font-family:var(--font-mono);font-weight:700;font-size:0.66rem;padding:2px 6px;">01</span>
                                <span style="font-family:var(--font-mono);font-weight:700;text-transform:uppercase;letter-spacing:0.5px;font-size:0.84rem;">Ventas netas</span>
                            </span>
                            <span style="display:flex;align-items:center;gap:10px;">
                                <span style="font-family:var(--font-sans);font-weight:700;font-size:1.05rem;">@Money(Resumen.IngresosVentas - Resumen.Mermas)</span>
                                <i class="bi @(_ventasExp ? "bi-chevron-up" : "bi-chevron-down")"></i>
                            </span>
                        </button>
                        @if (_ventasExp)
                        {
                            <div style="background:var(--paper-0);">
                                <div style="display:flex;justify-content:space-between;align-items:center;padding:0.55rem 0.85rem;border-bottom:1px solid var(--line-200);">
                                    <span style="font-family:var(--font-sans);font-size:0.82rem;text-transform:uppercase;">Ventas brutas</span>
                                    <span style="font-family:var(--font-mono);font-weight:700;color:var(--signal-success);">@MoneySigned(Resumen.IngresosVentas)</span>
                                </div>
                                <div style="display:flex;justify-content:space-between;align-items:center;padding:0.55rem 0.85rem;border-bottom:1px solid var(--line-200);">
                                    <span style="font-family:var(--font-sans);font-size:0.82rem;text-transform:uppercase;">(-) Mermas / pérdidas</span>
                                    <span style="font-family:var(--font-mono);font-weight:700;color:var(--signal-danger);">@MoneyNeg(Resumen.Mermas)</span>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- 02 Margen bruto -->
                    <div style="border:2px solid var(--ink-900);">
                        <button @onclick="() => _margenExp = !_margenExp" style="width:100%;display:flex;justify-content:space-between;align-items:center;gap:10px;padding:0.7rem 0.85rem;background:var(--signal-warning);color:#111;border:none;cursor:pointer;text-align:left;">
                            <span style="display:flex;align-items:center;gap:10px;">
                                <span style="background:var(--ink-900);color:#fff;font-family:var(--font-mono);font-weight:700;font-size:0.66rem;padding:2px 6px;">02</span>
                                <span style="font-family:var(--font-mono);font-weight:700;text-transform:uppercase;letter-spacing:0.5px;font-size:0.84rem;">Margen bruto</span>
                            </span>
                            <span style="display:flex;align-items:center;gap:10px;">
                                <span style="background:rgba(0,0,0,0.18);font-family:var(--font-mono);font-weight:700;font-size:0.68rem;padding:2px 7px;">@MargenPct</span>
                                <span style="font-family:var(--font-sans);font-weight:700;font-size:1.05rem;">@Money(Resumen.UtilidadTotal)</span>
                                <i class="bi @(_margenExp ? "bi-chevron-up" : "bi-chevron-down")"></i>
                            </span>
                        </button>
                        @if (_margenExp)
                        {
                            <div style="background:var(--paper-0);">
                                <div style="display:flex;justify-content:space-between;align-items:center;padding:0.55rem 0.85rem;border-bottom:1px solid var(--line-200);">
                                    <span style="font-family:var(--font-sans);font-size:0.82rem;text-transform:uppercase;">(-) Costo de venta</span>
                                    <span style="font-family:var(--font-mono);font-weight:700;color:var(--signal-danger);">@MoneyNeg(Resumen.TotalCostoVenta)</span>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- 03 Gastos operación -->
                    <div style="border:2px solid var(--ink-900);">
                        <button @onclick="() => _gastosExp = !_gastosExp" style="width:100%;display:flex;justify-content:space-between;align-items:center;gap:10px;padding:0.7rem 0.85rem;background:var(--signal-danger);color:#fff;border:none;cursor:pointer;text-align:left;">
                            <span style="display:flex;align-items:center;gap:10px;">
                                <span style="background:#fff;color:var(--signal-danger);font-family:var(--font-mono);font-weight:700;font-size:0.66rem;padding:2px 6px;">03</span>
                                <span style="font-family:var(--font-mono);font-weight:700;text-transform:uppercase;letter-spacing:0.5px;font-size:0.84rem;">Gastos operación</span>
                            </span>
                            <span style="display:flex;align-items:center;gap:10px;">
                                <span style="font-family:var(--font-sans);font-weight:700;font-size:1.05rem;">@MoneyNeg(Resumen.GastosVariables + Resumen.GastosFijos)</span>
                                <i class="bi @(_gastosExp ? "bi-chevron-up" : "bi-chevron-down")"></i>
                            </span>
                        </button>
                        @if (_gastosExp)
                        {
                            <div style="background:var(--paper-0);">
                                <div style="display:flex;justify-content:space-between;align-items:center;padding:0.55rem 0.85rem;border-bottom:1px solid var(--line-200);">
                                    <span style="font-family:var(--font-sans);font-size:0.82rem;text-transform:uppercase;">Gastos variables</span>
                                    <span style="font-family:var(--font-mono);font-weight:700;color:var(--signal-danger);">@MoneyNeg(Resumen.GastosVariables)</span>
                                </div>
                                <div style="display:flex;justify-content:space-between;align-items:center;padding:0.55rem 0.85rem;border-bottom:1px solid var(--line-200);">
                                    <span style="font-family:var(--font-sans);font-size:0.82rem;text-transform:uppercase;">Gastos fijos</span>
                                    <span style="font-family:var(--font-mono);font-weight:700;color:var(--signal-danger);">@MoneyNeg(Resumen.GastosFijos)</span>
                                </div>
                                @foreach (var g in MovimientosGastos)
                                {
                                    <div style="display:flex;justify-content:space-between;align-items:center;padding:0.4rem 0.85rem;border-bottom:1px solid var(--line-200);">
                                        <span style="font-family:var(--font-sans);font-size:0.76rem;text-transform:uppercase;">@g.Fecha.ToString("dd/MM") · @g.Descripcion</span>
                                        <span style="font-family:var(--font-mono);font-weight:700;font-size:0.78rem;color:var(--signal-danger);">@MoneyNeg(Math.Abs(g.Monto))</span>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>

                <!-- Utilidad operacional -->
                <div style="background:var(--ink-900);color:#fff;padding:1rem 1.1rem;display:flex;justify-content:space-between;align-items:flex-end;gap:12px;">
                    <div>
                        <small style="display:block;font-family:var(--font-mono);font-weight:700;font-size:0.6rem;text-transform:uppercase;letter-spacing:1px;color:rgba(255,255,255,0.55);">Resultado operacional (EBITDA)</small>
                        <span style="font-family:var(--font-mono);font-weight:700;text-transform:uppercase;letter-spacing:0.5px;font-size:1.05rem;">(=) Utilidad operacional</span>
                    </div>
                    <span style="font-family:var(--font-sans);font-weight:700;font-size:1.7rem;letter-spacing:-1px;color:var(--signal-success);">@Money(Resumen.UtilidadOperacional)</span>
                </div>

                <!-- Transbank toggle -->
                <div style="display:flex;justify-content:flex-end;align-items:center;gap:10px;">
                    <button @onclick="() => _descontar = !_descontar" role="switch" aria-checked="@(_descontar ? "true" : "false")" style="position:relative;width:46px;height:24px;border-radius:999px;border:2px solid var(--ink-900);cursor:pointer;background:@(_descontar ? "var(--signal-success)" : "#fff");padding:0;flex-shrink:0;">
                        <span style="position:absolute;top:1px;left:@(_descontar ? "23px" : "1px");width:16px;height:16px;border-radius:50%;background:#fff;border:1px solid var(--ink-900);transition:left .15s;"></span>
                    </button>
                    <span style="font-family:var(--font-mono);font-weight:700;font-size:0.74rem;text-transform:uppercase;">Descontar comisión Transbank (@Resumen.CantidadVentasTransbank tx ≈ @Money(Resumen.CostoTransbank))</span>
                </div>

                <!-- Resultado neto -->
                <div style="background:@(UtilidadNetaFinal >= 0 ? "var(--signal-success)" : "var(--signal-danger)");color:#fff;padding:1.3rem 1.1rem;text-align:center;border:2px solid var(--ink-900);">
                    <small style="display:block;font-family:var(--font-mono);font-weight:700;font-size:0.66rem;text-transform:uppercase;letter-spacing:1px;opacity:0.8;">Resultado neto final</small>
                    <span style="font-family:var(--font-sans);font-weight:700;font-size:2.6rem;letter-spacing:-2px;line-height:1.1;">@Money(UtilidadNetaFinal)</span>
                </div>
            </div>
        </div>
    </div>
}

@code {
    // ── Estado de UI ──────────────────────────────────────────────────────────
