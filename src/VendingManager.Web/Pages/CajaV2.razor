    // ── Modal de alta ──────────────────────────────────────────────────────────
    private void AbrirRegistro()
    {
        Nuevo = new() { Tipo = "GASTO", Categoria = "MERCADERIA" };
        _fileToUpload = null;
        Mensaje = "";
        _entryOpen = true;
    }

    private void CloseEntry() { _entryOpen = false; Mensaje = ""; }

    private void SetTipo(string tipo)
    {
        Nuevo.Tipo = tipo;
        Nuevo.Categoria = tipo switch
        {
            "APORTE" => "APORTE_CAPITAL",
            "RETIRO" => "RETIRO_UTILIDAD",
            _ => "MERCADERIA",
        };
    }

    private void LoadFile(InputFileChangeEventArgs e) => _fileToUpload = e.File;

    private async Task Registrar()
    {
        if (Nuevo.Monto <= 0 || string.IsNullOrWhiteSpace(Nuevo.Descripcion))
        {
            Mensaje = "❌ Completá monto y descripción.";
            return;
        }

        _isUploading = true;
        try
        {
            if (_fileToUpload != null)
            {
                if (_fileToUpload.Size > 5_120_000)
                {
                    Mensaje = "❌ Comprobante muy grande (>5MB).";
                    return;
                }

                using var content = new MultipartFormDataContent();
                using var fileContent = new StreamContent(_fileToUpload.OpenReadStream(5_120_000));
                fileContent.Headers.ContentType = new MediaTypeHeaderValue(_fileToUpload.ContentType);
                content.Add(fileContent, "file", _fileToUpload.Name);
                content.Add(new StringContent(Nuevo.Categoria), "category");

                var upload = await Http.PostAsync("api/caja/upload", content);
                if (!upload.IsSuccessStatusCode)
                {
                    Mensaje = "❌ Error al subir comprobante.";
                    return;
                }
                var result = await upload.Content.ReadFromJsonAsync<UploadResult>();
                Nuevo.ImagenPath = result?.Path;
            }

            Nuevo.Fecha = FechaRegistro;
            var response = await Http.PostAsJsonAsync("api/caja/registrar", Nuevo);
            if (response.IsSuccessStatusCode)
            {
                _entryOpen = false;
                await CargarDatos();
            }
            else
            {
                Mensaje = $"❌ {await response.Content.ReadAsStringAsync()}";
            }
        }
        catch (Exception ex)
        {
            Mensaje = $"❌ {ex.Message}";
        }
        finally
        {
            _isUploading = false;
        }
    }

    // ── Drawer gastos fijos ─────────────────────────────────────────────────────
    private async Task AbrirGastosFijos()
    {
        _fixedOpen = true;
        _showGastoForm = false;
        await CargarGastosRecurrentes();
    }

    private void NuevoGastoForm()
    {
        GastoEditando = new() { Categoria = "INTERNET" };
        _showGastoForm = true;
    }

    private void EditarGasto(GastoRecurrenteDto g)
    {
        GastoEditando = new()
        {
            Id = g.Id,
            Descripcion = g.Descripcion,
            MontoEstimado = g.MontoEstimado,
            Categoria = g.Categoria,
            MaquinaId = g.MaquinaId,
            Activo = g.Activo,
        };
        _showGastoForm = true;
    }

    private void CancelarGastoForm()
    {
        _showGastoForm = false;
        GastoEditando = new() { Categoria = "INTERNET" };
    }

    private async Task GuardarGasto()
    {
        if (string.IsNullOrWhiteSpace(GastoEditando.Descripcion) || GastoEditando.MontoEstimado <= 0) return;

        GastoEditando.Tipo = "GASTO";
        GastoEditando.Activo = true;
        try
        {
            if (GastoEditando.Id > 0)
                await Http.PutAsJsonAsync($"api/GastoRecurrente/{GastoEditando.Id}", GastoEditando);
            else
                await Http.PostAsJsonAsync("api/GastoRecurrente", GastoEditando);

            _showGastoForm = false;
            await CargarGastosRecurrentes();
            await CargarPendientes();
        }
        catch { }
    }

    private async Task DesactivarGasto(int id)
    {
        try
        {
            await Http.DeleteAsync($"api/GastoRecurrente/{id}");
            await CargarGastosRecurrentes();
            await CargarPendientes();
        }
        catch { }
    }

    private async Task AplicarPendientes()
    {
        _aplicando = true;
        try
        {
            var request = new AplicarTodosRequest { Month = SelectedDate.Month, Year = SelectedDate.Year };
            await Http.PostAsJsonAsync("api/GastoRecurrente/aplicar-todos", request);
            await CargarDatos();
        }
        catch { }
        finally { _aplicando = false; }
    }

    // ── Drawer estado de resultados ───────────────────────────────────────────
    private async Task AbrirResultados()
    {
        _pnlOpen = true;
        await CargarDatosResultados();
    }

