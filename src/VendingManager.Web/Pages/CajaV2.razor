@code {
    // ── Estado de UI ──────────────────────────────────────────────────────────
    private int _monthIdx = 5; // Junio
    private string _type = "GASTO";
    private bool _entryOpen;
    private Mov? _detail;
    private bool _fixedOpen;
    private bool _pnlOpen;
    private string _filter = "TODOS";
    private string _search = "";
    private bool _flash;
    private bool _ventasExp;
    private bool _margenExp;
    private bool _gastosExp;
    private bool _descontar;

    // ── Modelos ───────────────────────────────────────────────────────────────
    private record Mov(string Fecha, string Dia, string Hora, string Tipo, string CatLabel, string Descripcion, int Monto);
    private record GrupoVm(string Mes, string Dia, string Titulo, bool Orden, int Count, string TotalDisplay, bool TotalPos, IReadOnlyList<Mov> Items);
    private record GastoFijo(string Nombre, string Categoria, string Maquina, string MontoFmt);
    private record Pendiente(string Nombre, string MontoFmt);

    private static readonly string[] Meses =
    [
        "Enero", "Febrero", "Marzo", "Abril", "Mayo", "Junio",
        "Julio", "Agosto", "Septiembre", "Octubre", "Noviembre", "Diciembre",
    ];

    private string MesLabel => Meses[_monthIdx] + " 2026";

    // ── Datos del libro (idénticos al template) ───────────────────────────────
    private static readonly Mov[] AllMovs =
    [
        new("2026-06-18", "18", "10:05", "GASTO",  "PEAJES",     "Autopista Central",        -4000),
        new("2026-06-18", "18", "09:40", "GASTO",  "LOGÍSTICA",  "Copec — Bencina",          -18500),
        new("2026-06-18", "18", "09:12", "GASTO",  "MERCADERÍA", "Reposición CCU",           -62000),
        new("2026-06-16", "16", "14:20", "GASTO",  "MANTENCIÓN", "Repuesto compresor M0047", -38000),
        new("2026-06-15", "15", "11:30", "APORTE", "CAPITAL",    "Inyección socio",          250000),
        new("2026-06-12", "12", "18:30", "GASTO",  "LOGÍSTICA",  "Bencina ruta sur",         -16000),
        new("2026-06-12", "12", "18:05", "GASTO",  "MERCADERÍA", "Líder — Snacks",           -54200),
        new("2026-06-10", "10", "09:00", "GASTO",  "INFRA",      "Cuenta luz bodega",        -42000),
        new("2026-06-08", "08", "16:20", "GASTO",  "SUELDOS",    "Adelanto operador",        -45000),
        new("2026-06-05", "05", "12:11", "GASTO",  "MANTENCIÓN", "Servicio técnico M0012",   -28000),
        new("2026-06-05", "05", "12:10", "RETIRO", "RETIRO",     "Retiro utilidad socio",    -120000),
    ];

    // Días con metadata especial (orden de carga, título propio).
    private static readonly Dictionary<string, (bool Orden, string Titulo)> DayMeta = new()
    {
        ["2026-06-18"] = (true, "Carga Máquina 0012"),
    };

    private static readonly GastoFijo[] GastosFijos =
    [
        new("Arriendo bodega",    "INFRA",     "Mensual fijo", "$320.000"),
        new("Sueldos operadores", "SUELDOS",   "Planilla",     "$1.200.000"),
        new("Plan datos máquinas", "INTERNET",  "12 SIM",       "$48.000"),
        new("Contador",           "SERVICIOS", "Honorarios",   "$90.000"),
        new("Software / OurVend", "SOFTWARE",  "Licencia",     "$35.000"),
    ];

    private static readonly Pendiente[] Pendientes =
    [
        new("Telefono maquinas WOM", "$30.000"),
    ];

    private static readonly (string Label, string Val)[] GastosOp =
    [
        ("Logística (bencina/fletes)", "-$420.500"),
        ("Mantención / repuestos",     "-$120.000"),
        ("Sueldos",                    "-$1.200.000"),
        ("Otros gastos",               "-$80.000"),
    ];

    // ── Estado de resultados ──────────────────────────────────────────────────
    private const int Utilidad = 1979500;
    private const int Comision = 57358;
    private int Neto => _descontar ? Utilidad - Comision : Utilidad;
    private string NetoFmt => "$" + Neto.ToString("N0", Nfi);
    private string MargenPct => (int)Math.Round((double)Neto / 4820000 * 100) + "%";

    // ── Formato de moneda (es-CL: punto como separador de miles) ──────────────
    private static readonly NumberFormatInfo Nfi = new() { NumberGroupSeparator = ".", NumberDecimalDigits = 0 };
    private static string Sign(int n) => (n > 0 ? "+$" : "-$") + Math.Abs(n).ToString("N0", Nfi);

    // ── Derivados ─────────────────────────────────────────────────────────────
    private IReadOnlyList<Mov> FilteredMovs
    {
        get
        {
            var q = _search.Trim().ToLowerInvariant();
            return AllMovs
                .Where(m => (_filter == "TODOS" || m.Tipo == _filter)
                            && (q == "" || m.Descripcion.ToLowerInvariant().Contains(q)
                                || m.CatLabel.ToLowerInvariant().Contains(q)))
                .ToList();
        }
    }

    private List<GrupoVm> BuildGrupos()
    {
        var filtered = FilteredMovs;
        var grupos = new List<GrupoVm>();
        foreach (var fecha in filtered.Select(m => m.Fecha).Distinct())
        {
            var items = filtered.Where(m => m.Fecha == fecha).ToList();
            var total = items.Sum(m => m.Monto);
            var meta = DayMeta.TryGetValue(fecha, out var dm) ? dm : (Orden: false, Titulo: "");
            var titulo = string.IsNullOrEmpty(meta.Titulo) ? $"Movimientos del {items[0].Dia}/06" : meta.Titulo;
            grupos.Add(new GrupoVm("JUN", items[0].Dia, titulo, meta.Orden, items.Count, Sign(total), total > 0, items));
        }
        return grupos;
    }

    // ── Acciones ──────────────────────────────────────────────────────────────
    private void PrevMonth() => _monthIdx = Math.Max(0, _monthIdx - 1);
    private void NextMonth() => _monthIdx = Math.Min(11, _monthIdx + 1);
    private void Today() => _monthIdx = 5;

    private void CloseEntry()
    {
        _entryOpen = false;
        _flash = false;
    }

    private async Task Register()
    {
        _flash = true;
        StateHasChanged();
        await Task.Delay(1100);
        CloseEntry();
    }
}
