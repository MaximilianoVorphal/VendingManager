    private bool _isUploading;
    private bool _aplicando;
    private bool _showGastoForm;
    private string ErrorCarga = "";
    private string Mensaje = "";

    // ── Datos ──────────────────────────────────────────────────────────────────
    private CajaResumenDto? Resumen;
    private List<MovimientoCaja> Movimientos = new();
    private List<OrdenCargaDto> OrdenesMensuales = new();
    private List<GastoRecurrenteDto> GastosFijos = new();
    private List<GastoPendienteDto> Pendientes = new();
    private List<MovimientoCaja> MovimientosGastos = new();
    private ValorizacionStockData? Valorizacion;

