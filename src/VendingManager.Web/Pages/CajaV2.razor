    // ── Gasto fijo en edición ─────────────────────────────────────────────────
    private GastoRecurrenteDto GastoEditando = new() { Categoria = "INTERNET" };

    private readonly string[] _targetCategories =
    {
        "LOGISTICA", "PEAJES", "INSUMOS", "MANTENCION",
        "INFRA", "ARRIENDO_POS", "INTERNET", "COMISIONES", "SUELDOS", "OTROS",
        "GASTOS GENERALES",
    };

    // ── Formato de moneda (es-CL: punto como separador de miles) ──────────────
    private static readonly NumberFormatInfo Nfi = new() { NumberGroupSeparator = ".", NumberDecimalDigits = 0 };
    private static readonly CultureInfo EsCl = new("es-CL");
    private static string Money(decimal n) => "$" + n.ToString("N0", Nfi);
    private static string MoneyNeg(decimal n) => n == 0 ? "$0" : "-$" + Math.Abs(n).ToString("N0", Nfi);
    private static string MoneySigned(decimal n) => (n >= 0 ? "+$" : "-$") + Math.Abs(n).ToString("N0", Nfi);

    private string MesLabel => Capitalize(SelectedDate.ToString("MMMM yyyy", EsCl));
    private static string Capitalize(string s) => string.IsNullOrEmpty(s) ? s : char.ToUpper(s[0]) + s[1..];

    private decimal ResultadoMes => (Resumen?.IngresosVentas ?? 0) - (Resumen?.GastosOperativos ?? 0);

    private string MargenPct
    {
        get
        {
            if (Resumen == null || Resumen.IngresosVentas == 0) return "0%";
            return Math.Round((double)Resumen.UtilidadTotal / (double)Resumen.IngresosVentas * 100) + "%";
        }
    }

    private decimal UtilidadNetaFinal
    {
        get
        {
            if (Resumen == null) return 0;
            var neta = Resumen.UtilidadNeta;
            if (_descontar) neta -= Resumen.CostoTransbank;
            return neta;
        }
    }

    // ── Bindings de formulario ──────────────────────────────────────────────────
    private string MontoString
    {
        get => Nuevo.Monto == 0 ? "" : Nuevo.Monto.ToString("#,##0", Nfi);
        set
        {
            if (string.IsNullOrWhiteSpace(value)) { Nuevo.Monto = 0; return; }
            if (decimal.TryParse(value.Replace(".", ""), out var m)) Nuevo.Monto = m;
        }
    }

    private string GastoMontoString
    {
        get => GastoEditando.MontoEstimado == 0 ? "" : GastoEditando.MontoEstimado.ToString("#,##0", Nfi);
        set
        {
            if (string.IsNullOrWhiteSpace(value)) { GastoEditando.MontoEstimado = 0; return; }
            if (decimal.TryParse(value.Replace(".", ""), out var m)) GastoEditando.MontoEstimado = m;
        }
    }

    private record Opt(string Value, string Label);

    private IEnumerable<Opt> CategoriaOptions => Nuevo.Tipo switch
    {
        "GASTO" => new[]
        {
            new Opt("MERCADERIA", "Mercadería (reposición)"),
            new Opt("LOGISTICA", "Logística (bencina/fletes)"),
            new Opt("PEAJES", "Peajes / estacionamiento"),
            new Opt("INSUMOS", "Insumos (limpieza/bolsas)"),
            new Opt("MANTENCION", "Mantención / repuestos"),
            new Opt("INFRA", "Infraestructura (luz/agua/arriendo)"),
            new Opt("ARRIENDO_POS", "Arriendo POS (Transbank)"),
            new Opt("INTERNET", "Internet (planes/chips)"),
            new Opt("COMISIONES", "Comisiones bancarias"),
            new Opt("SUELDOS", "Sueldos personal"),
            new Opt("OTROS", "Otros gastos"),
        },
        "APORTE" => new[]
        {
            new Opt("APORTE_CAPITAL", "Inyección de capital"),
            new Opt("DEVOLUCION", "Devolución proveedor"),
        },
        "RETIRO" => new[] { new Opt("RETIRO_UTILIDAD", "Retiro utilidad") },
        _ => Array.Empty<Opt>(),
    };

    private static readonly Opt[] GastoCategoriaOptions =
    {
        new("LOGISTICA", "Logística"),
        new("PEAJES", "Peajes"),
        new("INSUMOS", "Insumos"),
        new("MANTENCION", "Mantención"),
        new("INFRA", "Infraestructura"),
        new("ARRIENDO_POS", "Arriendo POS"),
        new("INTERNET", "Internet"),
        new("COMISIONES", "Comisiones"),
        new("SUELDOS", "Sueldos"),
        new("OTROS", "Otros"),
    };

    // ── Grupo visual (por orden de carga o por día) ───────────────────────────
    private record GrupoVm(string Mes, string Dia, string Titulo, bool Orden, decimal Total, bool TotalPos, List<MovimientoCaja> Items);

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
        await CargarGastosRecurrentes();
    }

    // ── Carga de datos ──────────────────────────────────────────────────────────
    private async Task CargarDatos()
    {
        ErrorCarga = "";
        var query = $"?month={SelectedDate.Month}&year={SelectedDate.Year}";
        try
        {
            Resumen = await Http.GetFromJsonAsync<CajaResumenDto>($"api/caja/resumen{query}");
            Movimientos = await Http.GetFromJsonAsync<List<MovimientoCaja>>($"api/caja/movimientos{query}") ?? new();

            try
            {
                var historial = await Http.GetFromJsonAsync<List<OrdenCargaDto>>("api/OrdenCarga/historial?maquinaId=0");
                if (historial != null) OrdenesMensuales = historial;
            }
            catch { }

            await CargarPendientes();
        }
        catch (Exception ex)
        {
            ErrorCarga = $"Error al cargar datos: {ex.Message}";
        }

        FechaRegistro = (SelectedDate.Month == DateTime.Now.Month && SelectedDate.Year == DateTime.Now.Year)
            ? DateTime.Now
            : new DateTime(SelectedDate.Year, SelectedDate.Month, DateTime.DaysInMonth(SelectedDate.Year, SelectedDate.Month));
    }

    private async Task CargarGastosRecurrentes()
    {
        try { GastosFijos = await Http.GetFromJsonAsync<List<GastoRecurrenteDto>>("api/GastoRecurrente") ?? new(); }
        catch { GastosFijos = new(); }
    }

    private async Task CargarPendientes()
    {
        try
        {
            Pendientes = await Http.GetFromJsonAsync<List<GastoPendienteDto>>(
                $"api/GastoRecurrente/pendientes?month={SelectedDate.Month}&year={SelectedDate.Year}") ?? new();
        }
        catch { Pendientes = new(); }
    }

    private async Task CargarDatosResultados()
    {
        try
        {
            var query = $"?month={SelectedDate.Month}&year={SelectedDate.Year}";
            var all = await Http.GetFromJsonAsync<List<MovimientoCaja>>($"api/caja/movimientos{query}");
            MovimientosGastos = all?
                .Where(m => _targetCategories.Contains(m.Categoria) && m.Monto < 0)
                .OrderBy(m => m.Fecha)
                .ToList() ?? new();
            Valorizacion = await Http.GetFromJsonAsync<ValorizacionStockData>("api/caja/valorizacion");
        }
        catch { }
    }

    // ── Filtro y agrupación ─────────────────────────────────────────────────────
    private List<MovimientoCaja> FilteredMovs
    {
        get
        {
            var q = _search.Trim().ToLowerInvariant();
            return Movimientos
                .Where(m => m.Categoria != "LOTES"
                            && (_filter == "TODOS" || m.Tipo == _filter)
                            && (q == "" || m.Descripcion.ToLowerInvariant().Contains(q) || m.Categoria.ToLowerInvariant().Contains(q)))
                .ToList();
        }
    }

    private List<GrupoVm> BuildGrupos()
    {
        var lista = FilteredMovs;
        var grupos = new List<(DateTime Fecha, GrupoVm Vm)>();

        // Vinculados a orden de carga
        foreach (var g in lista.Where(m => m.OrdenCargaId.HasValue).GroupBy(m => m.OrdenCargaId!.Value))
        {
            var orden = OrdenesMensuales.FirstOrDefault(o => o.Id == g.Key);
            var fecha = orden?.FechaCreacion ?? g.First().Fecha;
            var titulo = orden != null ? $"Carga {orden.MaquinaNombre}" : $"Orden de carga #{g.Key}";
            var total = g.Sum(m => m.Monto);
            var items = g.OrderByDescending(m => m.Fecha).ToList();
            grupos.Add((fecha, new GrupoVm(Mes(fecha), fecha.Day.ToString(), titulo, true, total, total > 0, items)));
        }

        // Generales por día
        foreach (var g in lista.Where(m => !m.OrdenCargaId.HasValue).GroupBy(m => m.Fecha.Date))
        {
            var total = g.Sum(m => m.Monto);
            var items = g.OrderByDescending(m => m.Fecha).ToList();
            var titulo = Capitalize(g.Key.ToString("dddd, dd MMMM", EsCl));
            grupos.Add((g.Key, new GrupoVm(Mes(g.Key), g.Key.Day.ToString(), titulo, false, total, total > 0, items)));
        }

        return grupos.OrderByDescending(x => x.Fecha).Select(x => x.Vm).ToList();
    }

    private static string Mes(DateTime d) => d.ToString("MMM", EsCl).ToUpper();

    // ── Navegación de mes ─────────────────────────────────────────────────────
    private async Task PrevMonth() { SelectedDate = SelectedDate.AddMonths(-1); await CargarDatos(); }
    private async Task NextMonth() { SelectedDate = SelectedDate.AddMonths(1); await CargarDatos(); }
    private async Task Today() { SelectedDate = DateTime.Now; await CargarDatos(); }

