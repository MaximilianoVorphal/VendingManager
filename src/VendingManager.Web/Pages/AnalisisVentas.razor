@page "/analisis-ventas"
@inject HttpClient Http
@inject Microsoft.Extensions.Logging.ILogger<AnalisisVentas> Logger
@inject NavigationManager NavManager
@using Microsoft.AspNetCore.WebUtilities
@using System.Globalization
@using VendingManager.Shared.DTOs

    <div class="industrial-wrapper container-fluid px-4 mt-4">
    
    <!-- HEADER -->
    <div class="row align-items-center mb-4 border-bottom border-3 border-dark pb-3">
        <div class="col-12">
            <h2 class="m-0 fw-bold text-uppercase" style="letter-spacing: -1px;">ANÁLISIS DE PRODUCTOS</h2>
            <small class="text-muted fw-bold">DETALLE ESTRATÉGICO DE VENTAS Y RENDIMIENTO</small>
        </div>
    </div>

    <!-- FILTROS -->
    <div class="card border-2 border-dark rounded-0 shadow-sm mb-4">
        <div class="card-body bg-light p-3">
             <div class="row align-items-end g-3">
                <div class="col-md-3 col-12">
                     <label class="fw-bold small text-uppercase mb-1">UNIDAD:</label>
                     <select class="form-select border-dark rounded-0 fw-bold py-2" @bind="MaquinaSeleccionada">
                         <option value="0">:: TODAS LAS UNIDADES ::</option>
                         @if (ListaMaquinas != null)
                         {
                             @foreach (var m in ListaMaquinas)
                             {
                                 <option value="@m.Id">@m.Nombre.ToUpper()</option>
                             }
                         }
                     </select>
                </div>
                 <div class="col-6 col-md-3">
                     <label class="fw-bold small text-uppercase mb-1">DESDE:</label>
                     <input type="date" @bind="FechaInicio" class="form-control border-dark rounded-0 fw-bold" />
                 </div>
                 <div class="col-6 col-md-3">
                     <label class="fw-bold small text-uppercase mb-1">HASTA:</label>
                     <input type="date" @bind="FechaFin" class="form-control border-dark rounded-0 fw-bold" />
                 </div>
                  <div class="col-12 col-md-3">
                      <button class="btn btn-dark w-100 rounded-0 fw-bold py-2" @onclick="CargarDatos" disabled="@Cargando">
                          @(Cargando ? "PROCESANDO..." : "ANALIZAR")
                      </button>
                  </div>
              </div>
              <div class="row mt-2 align-items-center">
                  <div class="col-12">
                      <div class="form-check">
                          <input class="form-check-input border-dark" type="checkbox" id="incluirPendientes" @bind="IncludePendientes" />
                          <label class="form-check-label fw-bold small text-uppercase" for="incluirPendientes">
                              <i class="bi bi-question-circle me-1"></i> Incluir Pendientes / Desconocidos (ventas sin producto asignado)
                          </label>
                      </div>
                  </div>
              </div>
         </div>
     </div>

    @if (!string.IsNullOrEmpty(MensajeError))
    {
        <div class="alert alert-danger border-2 border-dark rounded-0 mb-4 shadow-sm fw-bold">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @MensajeError
        </div>
    }

    @if (Cargando)
    {
        <div class="text-center py-5 border border-dark border-2 bg-light">
            <div class="spinner-grow text-dark" role="status"></div>
            <p class="mt-2 fw-bold text-uppercase" style="letter-spacing: 2px;">Calculando Métricas...</p>
        </div>
    }
    else if (Productos != null)
    {
        <div class="card border-2 border-dark rounded-0 shadow-sm mb-4">
              <div class="card-header bg-dark text-white rounded-0 fw-bold border-bottom border-dark text-uppercase d-flex justify-content-between align-items-center">
                  <span><i class="bi bi-list-stars me-2"></i>Ranking de Productos</span>
                  <span class="badge bg-white text-dark border border-white">@Productos.Count items</span>
              </div>
              <div class="bg-light border-bottom border-dark px-3 py-2 small">
                  <div class="row g-2">
                      <div class="col-md-6">
                          <strong>ABC</strong> — Clasificación Pareto (regla 80/20):
                          <span class="badge bg-success ms-1">A</span> = generan el 80% del revenue acumulado &nbsp;
                          <span class="badge bg-warning text-dark">B</span> = siguiente 15% &nbsp;
                          <span class="badge bg-danger">C</span> = resto.
                      </div>
                      <div class="col-md-6">
                          <strong>TENDENCIA</strong> — vs período anterior de igual duración:
                          <span class="text-success fw-bold">▲ +X%</span> = mejoró &nbsp;
                          <span class="text-danger fw-bold">▼ -X%</span> = empeoró &nbsp;
                          <span class="text-muted">→</span> = igual &nbsp;
                          <span class="text-muted">—</span> = sin datos previos.
                      </div>
                  </div>
              </div>
             <div class="table-responsive industrial-stack-table" style="max-height: 600px; overflow-y: auto;">
                 <table class="table table-hover table-bordered border-dark m-0 table-sm align-middle">
                     <thead class="bg-secondary text-white text-uppercase small sticky-top">
                         <tr>
                              <th role="button" @onclick='() => OrdenarPor("Nombre")'>PRODUCTO @RenderIcono("Nombre")</th>
                               <th>ABC</th>
                               <th>TENDENCIA</th>
                              @* Removed Rotacion/Dia *@
                             <th role="button" class="text-center" @onclick='() => OrdenarPor("Cantidad")'>TOTAL UNID. @RenderIcono("Cantidad")</th>
                             <th role="button" class="text-end" @onclick='() => OrdenarPor("Ventas")'>INGRESOS @RenderIcono("Ventas")</th>
                             <th role="button" class="text-end" @onclick='() => OrdenarPor("Ganancia")'>GANANCIA @RenderIcono("Ganancia")</th>
                             <th role="button" class="text-center" @onclick='() => OrdenarPor("Margen")'>MARGEN % @RenderIcono("Margen")</th>
                         </tr>
                     </thead>
                     <tbody class="bg-white">
                         @foreach(var p in Productos)
                         {
                             <tr class="@(p.CantidadVendida == 0 ? "bg-light text-muted" : "")">
                                  <td class="fw-bold text-uppercase" data-label="PRODUCTO">@p.Nombre</td>
                                   <td class="text-center" data-label="ABC">
                                      @if (!string.IsNullOrEmpty(p.ClasificacionABC))
                                      {
                                          var abcClass = p.ClasificacionABC == "A" ? "bg-success"
                                              : p.ClasificacionABC == "B" ? "bg-warning text-dark"
                                              : "bg-danger";
                                          <span class="badge @abcClass">@p.ClasificacionABC</span>
                                          @if (p.PorcentajeAcumulado.HasValue)
                                          {
                                              <small class="text-muted ms-1">@p.PorcentajeAcumulado.Value.ToString("F1")%</small>
                                          }
                                      }
                                  </td>
                                  <td class="text-center" data-label="TENDENCIA">
                                      @if (p.Tendencia == "▲")
                                      {
                                          <span class="text-success fw-bold">▲ @p.CambioPorcentual?.ToString("+0.0;-0.0")%</span>
                                      }
                                      else if (p.Tendencia == "▼")
                                      {
                                          <span class="text-danger fw-bold">▼ @p.CambioPorcentual?.ToString("+0.0;-0.0")%</span>
                                      }
                                      else if (p.Tendencia == "→")
                                      {
                                          <span class="text-muted">→ @p.CambioPorcentual?.ToString("F1")%</span>
                                      }
                                      else
                                      {
                                          <span class="text-muted">—</span>
                                      }
                                  </td>
                                 @* Removed Rotacion Cell *@
                                 <td class="text-center font-monospace @(p.CantidadVendida == 0 ? "text-danger fw-bold" : "fw-bold")" style="font-size: 1.1em;" data-label="TOTAL UNID.">
                                     @p.CantidadVendida
                                 </td>
                                 <td class="text-end font-monospace" data-label="INGRESOS">$@p.TotalVentas.ToString("N0")</td>
                                 <td class="text-end font-monospace text-success fw-bold" data-label="GANANCIA">$@p.TotalGanancia.ToString("N0")</td>
                                 <td class="text-center small" data-label="MARGEN %">
                                     @if(p.TotalVentas > 0) {
                                         <span class="badge rounded-pill @(p.MargenPromedio > 40 ? "bg-success" : p.MargenPromedio > 20 ? "bg-warning text-dark" : "bg-danger")">
                                             @p.MargenPromedio.ToString("F1")%
                                         </span>
                                     }
                                     else {
                                         <span>-</span>
                                     }
                                 </td>
                             </tr>
                         }
                     </tbody>
                 </table>
             </div>
        </div>
    }

    <div class="mb-3">
        <button class="btn btn-outline-primary btn-sm" @onclick="ToggleCategorias">
            @(mostrarCategorias ? "Ocultar" : "Mostrar") Análisis por Categoría
        </button>
    </div>

    @if (mostrarCategorias && categorias != null && categorias.Any())
    {
        <div class="card mb-4">
            <div class="card-body">
                <table class="table table-sm table-hover">
                    <thead>
                        <tr>
                            <th>Categoría</th>
                            <th class="text-end">Unidades</th>
                            <th class="text-end">Ingresos</th>
                            <th class="text-end">Ganancia</th>
                            <th>% del Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cat in categorias)
                        {
                            <tr>
                                <td>@cat.Nombre</td>
                                <td class="text-end">@cat.CantidadVendida</td>
                                <td class="text-end">@cat.TotalVentas.ToString("C")</td>
                                <td class="text-end">@cat.TotalGanancia.ToString("C")</td>
                                <td>
                                    <div class="progress" style="height: 20px;">
                                        <div class="progress-bar" role="progressbar"
                                             style="width: @cat.PorcentajeDelTotal.ToString("F1", CultureInfo.InvariantCulture)%">
                                            @cat.PorcentajeDelTotal.ToString("F1")%
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

</div>

@code {
    private bool Cargando = false;
    private string MensajeError = "";
    private DateTime FechaInicio = DateTime.Today.AddDays(-30);
    private DateTime FechaFin = DateTime.Today;
    private int MaquinaSeleccionada = 0;
    private bool IncludePendientes = false;

    private List<MaquinaSimpleDto>? ListaMaquinas;
    private List<AnalisisProductoDto>? Productos;
    private bool mostrarCategorias = false;
    private List<CategoriaAnalisisDto>? categorias;

    // Sorting
    private string ColumnaOrden = "Cantidad";
    private bool Ascendente = false;

    protected override async Task OnInitializedAsync()
    {
        await CargarMaquinas();
        await CargarDatos();
    }

    private async Task CargarMaquinas()
    {
        try {
            ListaMaquinas = await Http.GetFromJsonAsync<List<MaquinaSimpleDto>>("api/Ventas/lista-maquinas");
        } catch {}
    }

    private async Task CargarDatos()
    {
        Cargando = true;
        MensajeError = "";
        Productos = null;
        StateHasChanged();

        try
        {
            string inicio = FechaInicio.ToString("yyyy-MM-dd");
            string fin = FechaFin.ToString("yyyy-MM-dd");
            string url = $"api/Ventas/analisis-productos?inicio={inicio}&fin={fin}&maquinaId={MaquinaSeleccionada}&includePendientes={IncludePendientes}";

            Productos = await Http.GetFromJsonAsync<List<AnalisisProductoDto>>(url);
            AplicarOrdenamiento();
        }
        catch (Exception ex)
        {
            MensajeError = "Error al cargar análisis: " + ex.Message;
        }
        finally
        {
            Cargando = false;
        }
    }

    private void OrdenarPor(string col)
    {
        if (ColumnaOrden == col) Ascendente = !Ascendente;
        else { ColumnaOrden = col; Ascendente = true; } // Default Asc for text? Custom logic below.

        // Default desc for numbers usually better
        if (col == "Cantidad" || col == "Ventas" || col == "Ganancia" || col == "Margen")
        {
             if (ColumnaOrden != col) Ascendente = false; // Reset to desc
        }
        
        AplicarOrdenamiento();
    }

    private void AplicarOrdenamiento()
    {
        if (Productos == null) return;

        switch (ColumnaOrden)
        {
            case "Nombre":
                Productos = Ascendente ? Productos.OrderBy(x => x.Nombre).ToList() : Productos.OrderByDescending(x => x.Nombre).ToList();
                break;
            case "Rotacion":
                Productos = Ascendente ? Productos.OrderBy(x => x.RotacionDiaria).ToList() : Productos.OrderByDescending(x => x.RotacionDiaria).ToList();
                break;
            case "Cantidad":
                Productos = Ascendente ? Productos.OrderBy(x => x.CantidadVendida).ToList() : Productos.OrderByDescending(x => x.CantidadVendida).ToList();
                break;
            case "Ventas":
                Productos = Ascendente ? Productos.OrderBy(x => x.TotalVentas).ToList() : Productos.OrderByDescending(x => x.TotalVentas).ToList();
                break;
            case "Ganancia":
                Productos = Ascendente ? Productos.OrderBy(x => x.TotalGanancia).ToList() : Productos.OrderByDescending(x => x.TotalGanancia).ToList();
                break;
            case "Margen":
                Productos = Ascendente ? Productos.OrderBy(x => x.MargenPromedio).ToList() : Productos.OrderByDescending(x => x.MargenPromedio).ToList();
                break;
        }
    }

    private string RenderIcono(string col)
    {
        if (ColumnaOrden != col) return "";
        return Ascendente ? "▲" : "▼";
    }

    async Task ToggleCategorias()
    {
        mostrarCategorias = !mostrarCategorias;
        if (mostrarCategorias && categorias == null)
        {
            string inicio = FechaInicio.ToString("yyyy-MM-dd");
            string fin = FechaFin.ToString("yyyy-MM-dd");
            categorias = await Http.GetFromJsonAsync<List<CategoriaAnalisisDto>>(
                $"api/Ventas/categoria-analisis?inicio={inicio}&fin={fin}&maquinaId={MaquinaSeleccionada}");
        }
    }

    // DTOs Locales
    public class MaquinaSimpleDto
    {
        public int Id { get; set; }
        public string Nombre { get; set; } = string.Empty;
    }

    public class AnalisisProductoDto
    {
        public int ProductoId { get; set; }
        public string Nombre { get; set; } = string.Empty;
        public string Codigo { get; set; } = string.Empty;
        public string Categoria { get; set; } = string.Empty;
        public int CantidadVendida { get; set; }
        public decimal TotalVentas { get; set; }
        public decimal TotalGanancia { get; set; }

        public decimal RotacionDiaria { get; set; }
        public string Clasificacion { get; set; } = "Normal";

        public decimal PrecioPromedio => CantidadVendida > 0 ? TotalVentas / CantidadVendida : 0;
        public decimal MargenPromedio => TotalVentas > 0 ? (TotalGanancia / TotalVentas) * 100 : 0;

        // ABC + Tendencias
        public string? ClasificacionABC { get; set; }
        public decimal? PorcentajeAcumulado { get; set; }
        public string? Tendencia { get; set; }
        public decimal? CambioPorcentual { get; set; }

        // Helper UI Color
        public string ColorClasificacion => Clasificacion switch
        {
            "Estrella" => "bg-warning text-dark",
            "Joya" => "bg-info text-dark",
            "Cacho" => "bg-danger text-white",
            _ => "bg-light text-muted border"
        };
    }
}
