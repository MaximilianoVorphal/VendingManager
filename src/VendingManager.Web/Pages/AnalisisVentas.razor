@page "/analisis-ventas"
@inject HttpClient Http
@inject Microsoft.Extensions.Logging.ILogger<AnalisisVentas> Logger
@inject NavigationManager NavManager
@inject IPlantillaService PlantillaService
@using Microsoft.AspNetCore.WebUtilities
@using System.Globalization
@using VendingManager.Shared.DTOs

    <div class="industrial-wrapper container-fluid px-4 mt-4">

    <!-- HEADER -->
    <div class="row align-items-center mb-4 border-bottom border-3 border-dark pb-3">
        <div class="col-12">
            <h2 class="m-0 fw-bold text-uppercase" style="letter-spacing: -1px;">ANÁLISIS DE PRODUCTOS</h2>
            <small class="text-muted fw-bold">DETALLE ESTRATÉGICO DE VENTAS Y RENDIMIENTO</small>
        </div>
    </div>

    <!-- FILTROS -->
    <VmCard Header="FILTROS" HeaderVariant="dark" Style="margin-bottom:1.5rem;">
        <div class="row align-items-end g-3">
            <div class="col-md-3 col-12">
                <VmSelect Label="UNIDAD"
                          Value="@MaquinaSeleccionada.ToString()"
                          ValueChanged="OnMaquinaChanged"
                          Options="@MaquinaOptions" />
            </div>
            <div class="col-md-3 col-12">
                <VmSelect Label="PLANTILLA"
                          Value="@PlantillaSeleccionada.ToString()"
                          ValueChanged="OnPlantillaChanged"
                          Options="@PlantillaOptions" />
            </div>
            <div class="col-6 col-md-2">
                <VmInput Type="date" Label="DESDE" @bind-Value="FechaInicioString" />
            </div>
            <div class="col-6 col-md-2">
                <VmInput Type="date" Label="HASTA" @bind-Value="FechaFinString" />
            </div>
            <div class="col-12 col-md-2">
                <VmButton Variant="dark" Block="true" OnClick="CargarDatos" Disabled="Cargando" Icon="bi-bar-chart-line-fill">
                    @(Cargando ? "PROCESANDO..." : "ANALIZAR")
                </VmButton>
            </div>
        </div>
        <div class="row mt-3 align-items-center">
            <div class="col-12">
                <div class="form-check">
                    <input class="form-check-input border-dark" type="checkbox" id="incluirPendientes" @bind="IncludePendientes" />
                    <label class="form-check-label fw-bold small text-uppercase" for="incluirPendientes">
                        <i class="bi bi-question-circle me-1"></i> Incluir Pendientes / Desconocidos (ventas sin producto asignado)
                    </label>
                </div>
            </div>
        </div>
    </VmCard>

    @if (!string.IsNullOrEmpty(MensajeError))
    {
        <div class="alert alert-danger border-2 border-dark rounded-0 mb-4 shadow-sm fw-bold">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @MensajeError
        </div>
    }

    @if (Cargando)
    {
        <div class="text-center py-5 border border-dark border-2 bg-light">
            <div class="spinner-grow text-dark" role="status"></div>
            <p class="mt-2 fw-bold text-uppercase" style="letter-spacing: 2px;">Calculando Métricas...</p>
        </div>
    }
    else if (Productos != null)
    {
        <VmCard Header="Ranking de Productos" HeaderVariant="dark" Style="margin-bottom:1.5rem;">
            <div style="background:var(--paper-50);border-bottom:2px solid var(--ink-900);padding:0.7rem 0.85rem;font-family:var(--font-mono);font-size:var(--fs-2xs);line-height:1.55;">
                <div class="row g-2">
                    <div class="col-md-6">
                        <strong style="letter-spacing:0.3px;">ABC</strong> — Clasificación Pareto (regla 80/20):
                        <VmBadge Variant="success">A</VmBadge> = generan el 80% del revenue acumulado &nbsp;
                        <VmBadge Variant="warning">B</VmBadge> = siguiente 15% &nbsp;
                        <VmBadge Variant="danger">C</VmBadge> = resto.
                    </div>
                    <div class="col-md-6">
                        <strong style="letter-spacing:0.3px;">TENDENCIA</strong> — vs período anterior de igual duración:
                        <span style="color:var(--signal-success);font-weight:700;">▲ +X%</span> = mejoró &nbsp;
                        <span style="color:var(--signal-danger);font-weight:700;">▼ -X%</span> = empeoró &nbsp;
                        <span style="color:var(--text-muted);font-weight:700;">→</span> = igual &nbsp;
                        <span style="color:var(--text-muted);font-weight:700;">—</span> = sin datos previos.
                    </div>
                </div>
            </div>
            <div style="max-height:600px;overflow-y:auto;">
                <table style="width:100%;border-collapse:collapse;border:2px solid var(--ink-900);font-family:var(--font-sans);">
                    <thead style="position:sticky;top:0;z-index:2;background:var(--ink-900);color:var(--paper-0);font-family:var(--font-mono);text-transform:uppercase;font-size:var(--fs-2xs);letter-spacing:0.5px;">
                        <tr>
                            <th role="button" @onclick='() => OrdenarPor("Nombre")' style="text-align:left;padding:8px 12px;font-weight:700;background:var(--ink-900);">PRODUCTO @RenderIcono("Nombre")</th>
                            <th style="text-align:left;padding:8px 12px;font-weight:700;background:var(--ink-900);">ABC</th>
                            <th style="text-align:left;padding:8px 12px;font-weight:700;background:var(--ink-900);">TENDENCIA</th>
                            <th role="button" class="text-center" @onclick='() => OrdenarPor("Cantidad")' style="text-align:right;padding:8px 12px;font-weight:700;background:var(--ink-900);">TOTAL UNID. @RenderIcono("Cantidad")</th>
                            <th role="button" class="text-end" @onclick='() => OrdenarPor("Ventas")' style="text-align:right;padding:8px 12px;font-weight:700;background:var(--ink-900);">INGRESOS @RenderIcono("Ventas")</th>
                            <th role="button" class="text-end" @onclick='() => OrdenarPor("Ganancia")' style="text-align:right;padding:8px 12px;font-weight:700;background:var(--ink-900);">GANANCIA @RenderIcono("Ganancia")</th>
                            <th role="button" class="text-center" @onclick='() => OrdenarPor("Margen")' style="text-align:right;padding:8px 12px;font-weight:700;background:var(--ink-900);">MARGEN % @RenderIcono("Margen")</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var p in Productos)
                        {
                            <tr style="border-bottom:1px solid var(--line-200);@(p.CantidadVendida == 0 ? "background:var(--tint-danger);" : "")">
                                <td style="font-family:var(--font-sans);font-weight:600;font-size:0.84rem;text-transform:uppercase;letter-spacing:-0.2px;padding:8px 12px;" data-label="PRODUCTO">@p.Nombre</td>
                                <td style="text-align:center;padding:8px 12px;" data-label="ABC">
                                    @if (!string.IsNullOrEmpty(p.ClasificacionABC))
                                    {
                                        var abcVariant = p.ClasificacionABC == "A" ? "success"
                                            : p.ClasificacionABC == "B" ? "warning"
                                            : "danger";
                                        <VmBadge Variant="@abcVariant">@p.ClasificacionABC</VmBadge>
                                        @if (p.PorcentajeAcumulado.HasValue)
                                        {
                                            <small style="color:var(--text-muted);margin-left:0.25rem;">@p.PorcentajeAcumulado.Value.ToString("F1")%</small>
                                        }
                                    }
                                </td>
                                <td style="white-space:nowrap;font-family:var(--font-mono);font-weight:700;font-size:0.78rem;text-align:center;padding:8px 12px;" data-label="TENDENCIA">
                                    @if (p.Tendencia == "▲")
                                    {
                                        <span style="color:var(--signal-success);">▲ @p.CambioPorcentual?.ToString("+0.0;-0.0")%</span>
                                    }
                                    else if (p.Tendencia == "▼")
                                    {
                                        <span style="color:var(--signal-danger);">▼ @p.CambioPorcentual?.ToString("+0.0;-0.0")%</span>
                                    }
                                    else if (p.Tendencia == "→")
                                    {
                                        <span style="color:var(--text-muted);">→ @p.CambioPorcentual?.ToString("F1")%</span>
                                    }
                                    else
                                    {
                                        <span style="color:var(--text-muted);">—</span>
                                    }
                                </td>
                                <td style="text-align:right;font-family:var(--font-mono);font-weight:700;font-size:0.82rem;padding:8px 12px;@(p.CantidadVendida == 0 ? "color:var(--signal-danger);" : "")" data-label="TOTAL UNID.">
                                    @p.CantidadVendida
                                </td>
                                <td style="text-align:right;font-family:var(--font-mono);font-weight:700;font-size:0.8rem;padding:8px 12px;" data-label="INGRESOS">$@p.TotalVentas.ToString("N0")</td>
                                <td style="text-align:right;font-family:var(--font-mono);font-weight:700;font-size:0.8rem;color:var(--signal-success);padding:8px 12px;" data-label="GANANCIA">$@p.TotalGanancia.ToString("N0")</td>
                                <td style="text-align:right;padding:8px 12px;" data-label="MARGEN %">
                                    @if(p.TotalVentas > 0) {
                                        var margenVariant = p.MargenPromedio > 40 ? "success"
                                            : p.MargenPromedio > 20 ? "warning"
                                            : "danger";
                                        <VmBadge Variant="@margenVariant">@p.MargenPromedio.ToString("F1")%</VmBadge>
                                    }
                                    else {
                                        <span>-</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </VmCard>
    }

    <div class="mb-3">
        <button class="btn btn-outline-primary btn-sm" @onclick="ToggleCategorias">
            @(mostrarCategorias ? "Ocultar" : "Mostrar") Análisis por Categoría
        </button>
    </div>

    @if (mostrarCategorias && categorias != null && categorias.Any())
    {
        <div class="card mb-4">
            <div class="card-body">
                <table class="table table-sm table-hover">
                    <thead>
                        <tr>
                            <th>Categoría</th>
                            <th class="text-end">Unidades</th>
                            <th class="text-end">Ingresos</th>
                            <th class="text-end">Ganancia</th>
                            <th>% del Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cat in categorias)
                        {
                            <tr>
                                <td>@cat.Nombre</td>
                                <td class="text-end">@cat.CantidadVendida</td>
                                <td class="text-end">@cat.TotalVentas.ToString("C")</td>
                                <td class="text-end">@cat.TotalGanancia.ToString("C")</td>
                                <td>
                                    <div class="progress" style="height: 20px;">
                                        <div class="progress-bar" role="progressbar"
                                             style="width: @cat.PorcentajeDelTotal.ToString("F1", CultureInfo.InvariantCulture)%">
                                            @cat.PorcentajeDelTotal.ToString("F1")%
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

</div>

@code {
    private bool Cargando = false;
    private string MensajeError = "";
    private DateTime FechaInicio = DateTime.Today.AddDays(-30);
    private DateTime FechaFin = DateTime.Today;
    private int MaquinaSeleccionada = 0;
    private int PlantillaSeleccionada = 0;
    private bool IncludePendientes = false;

    private List<MaquinaSimpleDto>? ListaMaquinas;
    private List<Plantilla>? ListaPlantillas;
    private List<AnalisisProductoDto>? Productos;
    private bool mostrarCategorias = false;
    private List<CategoriaAnalisisDto>? categorias;

    // Sorting
    private string ColumnaOrden = "Ventas";  // ABC se entiende ordenado por ingresos
    private bool Ascendente = false;

    private string FechaInicioString
    {
        get => FechaInicio.ToString("yyyy-MM-dd");
        set { if (DateTime.TryParse(value, out var d)) FechaInicio = d; }
    }

    private string FechaFinString
    {
        get => FechaFin.ToString("yyyy-MM-dd");
        set { if (DateTime.TryParse(value, out var d)) FechaFin = d; }
    }

    private IEnumerable<VmSelect.VmSelectOption> MaquinaOptions =>
        new[] { new VmSelect.VmSelectOption("0", ":: TODAS LAS UNIDADES ::") }
        .Concat(MaquinasFiltradas.Select(m => new VmSelect.VmSelectOption(m.Id.ToString(), m.Nombre.ToUpper())));

    private IEnumerable<VmSelect.VmSelectOption> PlantillaOptions =>
        new[] { new VmSelect.VmSelectOption("0", ":: TODAS LAS PLANTILLAS ::") }
        .Concat(ListaPlantillas?.Select(p => new VmSelect.VmSelectOption(p.Id.ToString(), p.Nombre)) ?? []);

    private IEnumerable<MaquinaSimpleDto> MaquinasFiltradas
    {
        get
        {
            if (ListaMaquinas == null) return [];
            if (PlantillaSeleccionada == 0) return ListaMaquinas;

            var plantilla = ListaPlantillas?.FirstOrDefault(p => p.Id == PlantillaSeleccionada);
            if (plantilla == null) return ListaMaquinas;

            var termino = plantilla.Nombre.Replace("PLANTILLA ", "", StringComparison.OrdinalIgnoreCase);
            return ListaMaquinas.Where(m => m.Nombre.Contains(termino, StringComparison.OrdinalIgnoreCase));
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await CargarMaquinas();
        await CargarPlantillas();
        await CargarDatos();
    }

    private async Task CargarMaquinas()
    {
        try {
            ListaMaquinas = await Http.GetFromJsonAsync<List<MaquinaSimpleDto>>("api/Ventas/lista-maquinas");
        } catch {}
    }

    private async Task CargarPlantillas()
    {
        try {
            ListaPlantillas = (await PlantillaService.GetPlantillasAsync()).ToList();
        } catch {}
    }

    private async Task OnMaquinaChanged(string? value)
    {
        if (int.TryParse(value, out int id))
        {
            MaquinaSeleccionada = id;
            await CargarDatos();
        }
    }

    private async Task OnPlantillaChanged(string? value)
    {
        if (int.TryParse(value, out int id))
        {
            PlantillaSeleccionada = id;
            MaquinaSeleccionada = 0;
            await CargarDatos();
        }
    }

    private async Task CargarDatos()
    {
        Cargando = true;
        MensajeError = "";
        Productos = null;
        StateHasChanged();

        try
        {
            string inicio = FechaInicio.ToString("yyyy-MM-dd");
            string fin = FechaFin.ToString("yyyy-MM-dd");
            string url = $"api/Ventas/analisis-productos?inicio={inicio}&fin={fin}&maquinaId={MaquinaSeleccionada}&plantillaId={PlantillaSeleccionada}&includePendientes={IncludePendientes}";

            Productos = await Http.GetFromJsonAsync<List<AnalisisProductoDto>>(url);
            AplicarOrdenamiento();
        }
        catch (Exception ex)
        {
            MensajeError = "Error al cargar análisis: " + ex.Message;
        }
        finally
        {
            Cargando = false;
        }
    }

    private void OrdenarPor(string col)
    {
        if (ColumnaOrden == col) Ascendente = !Ascendente;
        else { ColumnaOrden = col; Ascendente = true; } // Default Asc for text? Custom logic below.

        // Default desc for numbers usually better
        if (col == "Cantidad" || col == "Ventas" || col == "Ganancia" || col == "Margen")
        {
             if (ColumnaOrden != col) Ascendente = false; // Reset to desc
        }
        
        AplicarOrdenamiento();
    }

    private void AplicarOrdenamiento()
    {
        if (Productos == null) return;

        switch (ColumnaOrden)
        {
            case "Nombre":
                Productos = Ascendente ? Productos.OrderBy(x => x.Nombre).ToList() : Productos.OrderByDescending(x => x.Nombre).ToList();
                break;
            case "Rotacion":
                Productos = Ascendente ? Productos.OrderBy(x => x.RotacionDiaria).ToList() : Productos.OrderByDescending(x => x.RotacionDiaria).ToList();
                break;
            case "Cantidad":
                Productos = Ascendente ? Productos.OrderBy(x => x.CantidadVendida).ToList() : Productos.OrderByDescending(x => x.CantidadVendida).ToList();
                break;
            case "Ventas":
                Productos = Ascendente ? Productos.OrderBy(x => x.TotalVentas).ToList() : Productos.OrderByDescending(x => x.TotalVentas).ToList();
                break;
            case "Ganancia":
                Productos = Ascendente ? Productos.OrderBy(x => x.TotalGanancia).ToList() : Productos.OrderByDescending(x => x.TotalGanancia).ToList();
                break;
            case "Margen":
                Productos = Ascendente ? Productos.OrderBy(x => x.MargenPromedio).ToList() : Productos.OrderByDescending(x => x.MargenPromedio).ToList();
                break;
        }
    }

    private string RenderIcono(string col)
    {
        if (ColumnaOrden != col) return "";
        return Ascendente ? "▲" : "▼";
    }

    async Task ToggleCategorias()
    {
        mostrarCategorias = !mostrarCategorias;
        if (mostrarCategorias && categorias == null)
        {
            string inicio = FechaInicio.ToString("yyyy-MM-dd");
            string fin = FechaFin.ToString("yyyy-MM-dd");
            categorias = await Http.GetFromJsonAsync<List<CategoriaAnalisisDto>>(
                $"api/Ventas/categoria-analisis?inicio={inicio}&fin={fin}&maquinaId={MaquinaSeleccionada}");
        }
    }

    // DTOs Locales
    public class MaquinaSimpleDto
    {
        public int Id { get; set; }
        public string Nombre { get; set; } = string.Empty;
    }

    public class AnalisisProductoDto
    {
        public int ProductoId { get; set; }
        public string Nombre { get; set; } = string.Empty;
        public string Codigo { get; set; } = string.Empty;
        public string Categoria { get; set; } = string.Empty;
        public int CantidadVendida { get; set; }
        public decimal TotalVentas { get; set; }
        public decimal TotalGanancia { get; set; }

        public decimal RotacionDiaria { get; set; }
        public string Clasificacion { get; set; } = "Normal";

        public decimal PrecioPromedio => CantidadVendida > 0 ? TotalVentas / CantidadVendida : 0;
        public decimal MargenPromedio => TotalVentas > 0 ? (TotalGanancia / TotalVentas) * 100 : 0;

        // ABC + Tendencias
        public string? ClasificacionABC { get; set; }
        public decimal? PorcentajeAcumulado { get; set; }
        public string? Tendencia { get; set; }
        public decimal? CambioPorcentual { get; set; }

        // Helper UI Color
        public string ColorClasificacion => Clasificacion switch
        {
            "Estrella" => "bg-warning text-dark",
            "Joya" => "bg-info text-dark",
            "Cacho" => "bg-danger text-white",
            _ => "bg-light text-muted border"
        };
    }
}
