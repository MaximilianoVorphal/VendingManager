@page "/cargas"
@using System.Text.Json.Serialization
@using Microsoft.AspNetCore.Components
@using VendingManager.Web.Components.Mobile

<PageTitle>GESTIÓN DE CARGAS</PageTitle>

<MobileShell>
    <div class="industrial-wrapper container-fluid px-4 mt-4">
      <div class="row align-items-center mb-4 border-bottom border-3 border-dark pb-3">
        <div class="col-md-6">
            <h2 class="m-0 fw-bold text-uppercase" style="letter-spacing: -1px;">
                <i class="bi bi-truck me-2"></i>Centro de Cargas
            </h2>
            <small class="text-muted fw-bold">PLANIFICACIÓN Y LOGÍSTICA DE REPOSICIÓN</small>
        </div>
        <div class="col-md-6 text-end">
             <div class="d-flex justify-content-end gap-2 flex-wrap" style="position: relative; z-index: 1030;">
                 <button class="btn btn-outline-dark rounded-0 fw-bold" @onclick="ExportarReporte">
                     <i class="bi bi-file-earmark-excel me-2"></i>
                     @(MaquinaActualId > 0 ? "EXPORTAR MÁQUINA" : "EXPORTAR TODO")
                 </button>

                 <!-- MÁQUINA SELECTOR -->
                 <div class="input-group" style="max-width: 400px; position: relative;">
                    <span class="input-group-text bg-dark text-white fw-bold rounded-0">MÁQUINA</span>
                    <select class="form-select border-dark rounded-0 fw-bold" @onchange="CambiarMaquina" value="@MaquinaActualId">
                        <option value="0">:: SELECCIONE UNIDAD ::</option>
                        @if (ListaMaquinas != null)
                        {
                            @foreach (var m in ListaMaquinas)
                            {
                                <option value="@m.Id">@m.Nombre.ToUpper()</option>
                            }
                        }
                    </select>
                </div>
            </div>
        </div>
    </div>
    
    @if (!string.IsNullOrEmpty(Mensaje))
    {
        <div class="alert @AlertClass border-dark rounded-0 fw-bold shadow-sm mb-4">
            @Mensaje
        </div>
    }

    @if (MaquinaActualId == 0)
    {
        <!-- VISTA HISTORIAL GLOBAL -->
        <h4 class="mt-4 mb-3 fw-bold text-uppercase small"><i class="bi bi-clock-history me-2"></i>Historial Global de Órdenes</h4>
        
        <div class="list-group shadow">
            @if (HistorialGlobal == null)
            {
                <div class="list-group-item">Cargando...</div>
            }
            else if (!HistorialGlobal.Any())
            {
                <div class="list-group-item">No hay órdenes registradas.</div>
            }
            else
            {
                @foreach(var ord in HistorialGlobal)
                {
                    <div class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                        <div>
                            <span class="badge @(ord.Estado == "FINALIZADA" ? "bg-success" : "bg-warning text-dark") me-2 rounded-0">
                                @ord.Estado
                            </span>
                            <strong>ORDEN #@ord.Id</strong> 
                            @if(!string.IsNullOrEmpty(ord.Nombre))
                            {
                                <span class="badge bg-secondary ms-2 rounded-0">@ord.Nombre.ToUpper()</span>
                            }
                            <br/>
                            <small class="text-muted text-uppercase">
                                <i class="bi bi-box-seam me-1"></i> @ord.MaquinaNombre | 
                                <i class="bi bi-calendar me-1"></i> @ord.FechaCreacion.ToString("dd/MM/yyyy HH:mm") | 
                                @ord.Detalles.Count items
                                @if (ord.CostoTotal > 0)
                                {
                                    <span class="ms-1">| <strong class="text-danger">$@ord.CostoTotal.ToString("N0")</strong></span>
                                }
                            </small>
                        </div>
                        <div>
                            @if(ord.Estado == "PENDIENTE")
                            {
                                <button class="btn btn-sm btn-primary rounded-0 fw-bold px-3" @onclick="() => AbrirFinalizar(ord)">
                                    FINALIZAR
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-outline-dark rounded-0 fw-bold px-3" @onclick="() => AbrirDetalle(ord)">
                                    VER DETALLE
                                </button>
                            }
                        </div>
                    </div>
                }
            }
        </div>
    }
    else
    {
        <div class="row g-4">
            <!-- LEFT COLUMN: GENERAR NUEVA ORDEN -->
            <div class="col-lg-7">
                <div class="card border-2 border-dark rounded-0 shadow h-100">
                    <div class="card-header bg-dark text-white fw-bold text-uppercase rounded-0 d-flex justify-content-between align-items-center">
                        <span><i class="bi bi-cart-plus me-2"></i>Nueva Orden de Carga</span>
                        <span class="badge bg-white text-dark rounded-0">SUGERENCIA AUTOMÁTICA</span>
                    </div>
                    <div class="card-body p-0">
                         @if (CargandoSugerencia)
                         {
                             <div class="text-center py-5"><div class="spinner-border" role="status"></div></div>
                         }
                         else if (SugerenciaItems == null || SugerenciaItems.Count == 0)
                         {
                             <div class="text-center py-5">
                                 <i class="bi bi-check-circle fs-1 text-success"></i>
                                 <p class="fw-bold mt-2">No hay sugerencias de carga (Stock Llena).</p>
                             </div>
                         }
                         else
                         {
                             <div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
                                 <table class="table table-hover table-striped m-0 align-middle small vm-accordion-table">
                                    <thead class="bg-light sticky-top">
                                        <tr class="text-uppercase">
                                            <th class="text-center">Slot</th>
                                            <th>Producto</th>
                                            <th class="text-center">Stock/Cap</th>
                                            <th class="text-center" style="width: 120px;">Cargar</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach(var item in SugerenciaItems)
                                        {
                                            <tr>
                                                <td class="text-center font-monospace fw-bold">@item.NumeroSlot</td>
                                                <td>@item.Producto</td>
                                                <td class="text-center text-muted">
                                                    @item.StockActual / @item.CapacidadMaxima
                                                </td>
                                                <td>
                                                    <input type="number" class="form-control form-control-sm border-dark rounded-0 text-center fw-bold @(item.CantidadSolicitada > 0 ? "bg-warning-subtle" : "")" 
                                                           @bind="item.CantidadSolicitada" min="0" />
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                 </table>
                             </div>
                         }
                    </div>
                    <div class="card-footer bg-white border-top border-dark p-3 text-end">
                        @{ var totalItems = SugerenciaItems?.Sum(x => x.CantidadSolicitada) ?? 0; }
                        
                        <button class="btn btn-success rounded-0 fw-bold px-4 shadow-sm"
                                disabled="@(totalItems == 0)"
                                @onclick="GenerarOrden">
                            <i class="bi bi-check-lg me-2"></i>GENERAR ORDEN (@totalItems UNID.)
                        </button>
                    </div>
                </div>
            </div>

            <!-- RIGHT COLUMN: HISTORIAL Y ACTIVAS -->
            <div class="col-lg-5">
                <div class="card border-2 border-dark rounded-0 shadow h-100">
                    <div class="card-header bg-secondary text-white fw-bold text-uppercase rounded-0 d-flex justify-content-between align-items-center">
                        <span><i class="bi bi-clock-history me-2"></i>Órdenes Recientes</span>
                        <button class="btn btn-sm btn-light text-dark fw-bold rounded-0" @onclick="AbrirModalManual">
                            <i class="bi bi-plus-circle me-1"></i>CREAR MANUAL
                        </button>
                    </div>
                    <div class="list-group list-group-flush rounded-0">
                        @if (HistorialOrdenes == null)
                        {
                             <div class="text-center py-3"><div class="spinner-border spinner-border-sm" role="status"></div></div>
                        }
                        else if (HistorialOrdenes.Count == 0)
                        {
                            <div class="text-center py-3 text-muted fw-bold small">Sin historial</div>
                        }
                        else
                        {
                            @foreach(var ord in HistorialOrdenes)
                            {
                                <div class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="fw-bold">
                                            ORDEN #@ord.Id 
                                            @if(!string.IsNullOrEmpty(ord.Nombre))
                                            {
                                                <span class="badge bg-secondary ms-2 rounded-0">@ord.Nombre.ToUpper()</span>
                                            }
                                            <small class="text-muted fw-normal">| @ord.FechaCreacion.ToString("dd/MM HH:mm")</small>
                                        </div>
                                        <small class="text-muted">@ord.Detalles.Count Items
                                            @if (ord.CostoTotal > 0)
                                            {
                                                <span class="ms-1 text-danger fw-bold">$@ord.CostoTotal.ToString("N0")</span>
                                            }
                                        </small>
                                    </div>
                                    <div>
                                        @if(ord.Estado == "PENDIENTE")
                                        {
                                            <button class="btn btn-sm btn-primary rounded-0 fw-bold" @onclick="() => AbrirFinalizar(ord)">
                                                FINALIZAR
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-outline-dark rounded-0 fw-bold" @onclick="() => AbrirDetalle(ord)">
                                                VER DETALLE
                                            </button>
                                        }
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>
</MobileShell>

<!-- MODAL CREAR MANUAL -->
@if (MostrarModalManual)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-0 border-2 border-dark shadow-lg">
                <div class="modal-header bg-dark text-white rounded-0">
                    <h5 class="modal-title fw-bold">CREAR ORDEN MANUAL</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarModalManual"></button>
                </div>
                <div class="modal-body">
                    <p class="small text-muted mb-3">
                        Esto creará una Orden de Carga vacía para la máquina seleccionada. 
                        Úsala para vincular gastos (bencina, peajes) a esta ruta específica.
                    </p>
                    
                    <label class="fw-bold small text-uppercase mb-1">FECHA DE ORDEN:</label>
                    <input type="date" class="form-control border-dark rounded-0 mb-3 fw-bold" @bind="FechaManual" />

                    <label class="fw-bold small text-uppercase mb-1">NOMBRE (OPCIONAL):</label>
                    <input type="text" class="form-control border-dark rounded-0 mb-3" placeholder="Ej: Ruta Norte, Carga Especial..." @bind="NombreManual" />

                    <label class="fw-bold small text-uppercase mb-1">SELECCIONAR MÁQUINA:</label>
                    <select class="form-select border-dark rounded-0 mb-3" @bind="MaquinaManualId">
                        <option value="0">-- SELECCIONE MÁQUINA --</option>
                        <option value="-1" class="fw-bold bg-light">:: TODAS LAS MÁQUINAS ::</option>
                        @if (ListaMaquinas != null)
                        {
                            @foreach (var m in ListaMaquinas)
                            {
                                <option value="@m.Id">@m.Nombre</option>
                            }
                        }
                    </select>

                    <div class="form-check">
                        <input class="form-check-input border-dark rounded-0" type="checkbox" id="checkSugerencia" @bind="CargarSugerenciaManual">
                        <label class="form-check-label small" for="checkSugerencia">
                            <strong>Cargar Sugerencia (Ignorar Stock)</strong><br />
                            <span class="text-muted">Si no tienes stock registrado, marca esto para forzar la creación con items.</span>
                        </label>
                    </div>
                </div>
                <div class="modal-footer bg-light rounded-0">
                    <button class="btn btn-outline-dark rounded-0 fw-bold" @onclick="CerrarModalManual">CANCELAR</button>
                    <button class="btn btn-success rounded-0 fw-bold px-4" @onclick="CrearOrdenManual" disabled="@(MaquinaManualId == 0)">
                        CREAR ORDEN@(MaquinaManualId == -1 ? "ES (TODAS)" : "")
                    </button>
                </div>
            </div>
        </div>
    </div>
}


<!-- MODAL FINALIZAR / DETALLE -->
@if (MostrarModalFinalizar && OrdenSeleccionada != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content rounded-0 border-2 border-dark shadow-lg">
                <div class="modal-header @(EsModoLectura ? "bg-secondary" : "bg-primary") text-white rounded-0">
                    <h5 class="modal-title fw-bold">
                        <i class="bi @(EsModoLectura ? "bi-eye" : "bi-clipboard-check") me-2"></i>
                        @(EsModoLectura ? "DETALLE ORDEN" : "FINALIZAR CARGA") #@OrdenSeleccionada.Id
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarModal"></button>
                </div>
                <div class="modal-body p-0">
                    <div class="p-3 bg-light border-bottom border-dark">
                        <div class="row g-3">
                            <div class="col-md-7">
                                <label class="fw-bold small text-uppercase mb-1">Nombre de la Orden / Ruta:</label>
                                <input type="text" class="form-control border-dark rounded-0" placeholder="Sin nombre..." @bind="OrdenSeleccionada.Nombre" />
                            </div>
                            <div class="col-md-5">
                                <label class="fw-bold small text-uppercase mb-1">Fecha Creación:</label>
                                <input type="datetime-local" class="form-control border-dark rounded-0" @bind="OrdenSeleccionada.FechaCreacion" />
                            </div>
                        </div>
                        <div class="mt-3 text-end">
                            <button class="btn btn-dark rounded-0 fw-bold" @onclick="GuardarEdicionOrden">
                                <i class="bi bi-save me-1"></i> GUARDAR CAMBIOS
                            </button>
                        </div>
                    </div>

                    @if (!EsModoLectura)
                    {
                        <div class="alert alert-info rounded-0 m-3 small border-info">
                            <i class="bi bi-info-circle-fill me-2"></i>Ingrese la cantidad de productos que <strong>SOBRARON</strong> (no fueron cargados) para devolverlos a bodega.
                        </div>
                    }
                    <div class="table-responsive">
                        <table class="table table-striped m-0 align-middle vm-accordion-table">
                            <thead class="bg-light small text-uppercase">
                                <tr>
                                    @if(OrdenSeleccionada != null && (OrdenSeleccionada.MaquinaId == null || OrdenSeleccionada.MaquinaId == 0))
                                    {
                                        <th class="text-muted">Máquina</th>
                                    }
                                    <th class="px-3">Producto</th>
                                    <th class="text-center">Q. Llevada</th>
                                    @if (EsModoLectura)
                                    {
                                        <th class="text-center">Q. Cargada</th>
                                    }
                                    <th class="text-center" style="width: 150px;">Q. Sobrante (Retorno)</th>
                                    @if (EsModoLectura)
                                    {
                                        <th class="text-end">Costo</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach(var det in OrdenSeleccionada!.Detalles)
                                {
                                    <tr>
                                        @if(OrdenSeleccionada.MaquinaId == null || OrdenSeleccionada.MaquinaId == 0)
                                        {
                                            <td class="text-muted small">@det.MaquinaNombre</td>
                                        }
                                        <td class="px-3">@det.ProductoNombre</td>
                                        <td class="text-center fw-bold">@det.CantidadSolicitada</td>
                                        @if (EsModoLectura)
                                        {
                                            <td class="text-center">
                                                <span class="badge bg-success rounded-0 fs-6">@(det.CantidadSolicitada - det.CantidadRetornada)</span>
                                            </td>
                                        }
                                        <td class="text-center">
                                            @if (EsModoLectura)
                                            {
                                                <span class="badge bg-secondary rounded-0 fs-6">@det.CantidadRetornada</span>
                                            }
                                            else
                                            {
                                                <input type="number" class="form-control form-control-sm border-dark rounded-0 text-center"
                                                       @bind="det.CantidadRetornada" min="0" max="@det.CantidadSolicitada" />
                                            }
                                        </td>
                                        @if (EsModoLectura && det.CostoUnitario > 0)
                                        {
                                            var costoLinea = (det.CantidadSolicitada - det.CantidadRetornada) * det.CostoUnitario;
                                            <td class="text-end text-danger fw-bold font-monospace small">$@costoLinea.ToString("N0")</td>
                                        }
                                        else if (EsModoLectura)
                                        {
                                            <td class="text-end text-muted">—</td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="modal-footer bg-light rounded-0 d-flex justify-content-between align-items-center">
                    <div>
                        @if (EsModoLectura && OrdenSeleccionada.CostoTotal > 0)
                        {
                            <span class="fw-bold text-uppercase small text-muted me-2">COSTO TOTAL:</span>
                            <span class="fw-bold fs-5 text-danger font-monospace">$@OrdenSeleccionada.CostoTotal.ToString("N0")</span>
                        }
                    </div>
                    <div class="d-flex gap-2">
                    <button type="button" class="btn btn-outline-dark rounded-0 fw-bold" @onclick="CerrarModal">CERRAR</button>
                    @if (!EsModoLectura)
                    {
                        <button type="button" class="btn btn-primary rounded-0 fw-bold px-4" @onclick="ConfirmarFinalizacion">
                            CONFIRMAR Y CERRAR
                        </button>
                    }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

