@page "/informe-compras"
@using VendingManager.Shared.DTOs
@using System.Net.Http.Json
@inject HttpClient Http
@inject IJSRuntime JS
@attribute [Authorize]

<PageTitle>Informe de Compras</PageTitle>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Informe de Compras Sugeridas</h1>
        <div class="d-flex flex-wrap gap-3 align-items-center">
            
            <div class="input-group" style="max-width: 350px;">
                <span class="input-group-text bg-dark text-white fw-bold border-dark">
                    <i class="bi bi-vending-machine me-2"></i> MÁQUINA
                </span>
                <select class="form-select border-dark shadow-sm" @bind="MaquinaActualId" @bind:after="LoadData">
                    <option value="0">:: CONSOLIDADO GLOBAL ::</option>
                    @foreach (var m in Maquinas)
                    {
                        <option value="@m.Id">@m.Nombre</option>
                    }
                </select>
            </div>

            <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" id="filterInMachine" @bind="showOnlyInMachine" />
                <label class="form-check-label" for="filterInMachine">Solo en Máquinas</label>
            </div>

            <div class="d-flex align-items-center gap-2">
                <label class="text-nowrap">Días de análisis:</label>
                <input type="number" class="form-control" style="width: 80px;" @bind="days" min="1" max="365" />
            </div>

            <button class="btn btn-primary" @onclick="LoadData">Calcular</button>
            <button class="btn btn-success" @onclick="DownloadExcel">
                 <i class="bi bi-file-earmark-excel"></i> Exportar Excel
            </button>
        </div>
    </div>

    @if (suggestions == null)
    {
        <p><em>Cargando...</em></p>
    }
    else if (!FilteredSuggestions.Any())
    {
        <div class="alert alert-info">No hay sugerencias de compra para el periodo seleccionado (o filtro aplicado).</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th class="text-center">En Máq.</th>
                        <th>Producto</th>
                        <th class="text-center">Ventas (@days días)</th>
                        <th class="text-center">Stock en Máquinas</th>
                        <th class="text-center">Stock Bodega</th>
                        <th class="text-center">Sugerido Compra</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in FilteredSuggestions)
                    {
                        <tr class="@(item.CantidadSugerida > 0 ? "table-warning" : "")">
                            <td class="text-center">
                                @if (item.EnMaquina)
                                {
                                    <span class="badge bg-success">Sí</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">No</span>
                                }
                            </td>
                            <td>
                                <strong>@item.NombreProducto</strong>
                            </td>
                            <td class="text-center">@item.VentasUltimos30Dias</td>
                            <td class="text-center">@item.StockActualMaquinas</td>
                            <td class="text-center">@item.StockBodega</td>
                            <td class="text-center fw-bold text-danger">
                                @if(item.CantidadSugerida > 0)
                                {
                                    <span>@item.CantidadSugerida</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<PurchaseSuggestionDto>? suggestions;
    private List<MaquinaSimpleDto> Maquinas = new();
    private int days = 30;
    private bool showOnlyInMachine = false;
    private int MaquinaActualId = 0;

    private IEnumerable<PurchaseSuggestionDto> FilteredSuggestions
    {
        get
        {
            if (suggestions == null) return Enumerable.Empty<PurchaseSuggestionDto>();
            if (showOnlyInMachine)
            {
                return suggestions.Where(s => s.EnMaquina);
            }
            return suggestions;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        Maquinas = await Http.GetFromJsonAsync<List<MaquinaSimpleDto>>("api/Ventas/lista-maquinas") ?? new();
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            suggestions = null;
            suggestions = await Http.GetFromJsonAsync<List<PurchaseSuggestionDto>>($"api/Ventas/purchase-suggestion?days={days}&maquinaId={MaquinaActualId}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading purchase suggestions: {ex.Message}");
            // Handle error appropriately
        }
    }

    private async Task DownloadExcel()
    {
        try
        {
            var response = await Http.GetAsync($"api/Ventas/purchase-suggestion/export?days={days}&maquinaId={MaquinaActualId}");
            if (response.IsSuccessStatusCode)
            {
                var fileContent = await response.Content.ReadAsByteArrayAsync();
                if (fileContent.Length == 0)
                {
                    await JS.InvokeVoidAsync("alert", "El archivo generado está vacío.");
                    return;
                }
                
                var fileName = MaquinaActualId > 0 
                    ? $"Sugerencia_Compra_M{MaquinaActualId}_{DateTime.Now:ddMMyy}.xlsx" 
                    : $"Sugerencia_Compra_{DateTime.Now:ddMMyy}.xlsx";
                
                try 
                {
                    await JS.InvokeVoidAsync("descargarArchivo", fileContent, fileName);
                }
                catch (Exception ex)
                {
                    await JS.InvokeVoidAsync("alert", $"Error JS: {ex.Message}");
                }
            }
            else
            {
                var msg = await response.Content.ReadAsStringAsync();
                await JS.InvokeVoidAsync("alert", $"Error al exportar: {msg}");
            }
        }
        catch (Exception ex)
        {
             await JS.InvokeVoidAsync("alert", $"Error inesperado: {ex.Message}");
             Console.WriteLine($"Error exporting: {ex.Message}");
        }
    }
}
