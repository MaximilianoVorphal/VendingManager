        </div>

        <!-- Administración dropdown -->
        <div style="position:relative;">
            <button @onclick='() => ToggleDropdown("administracion-mobile")'
                    style="font-family:var(--font-mono);font-weight:var(--fw-bold);
                           font-size:1rem;text-transform:uppercase;letter-spacing:0.5px;
                           cursor:pointer;padding:10px 24px;border-radius:0;text-align:left;
                           width:100%;background:var(--paper-0);color:var(--ink-900);border:none;">
                [ Administración ▾ ]
            </button>
            @if (_openDropdown == "administracion-mobile")
            {
                <div style="padding:0 24px;display:flex;flex-direction:column;gap:0.25rem;">
                    @foreach (var item in Administracion)
                    {
                        var disabled = item.Key == null && item.Href == null;
                        <button @onclick="() => Navigate(item)"
                                disabled="@disabled"
                                style="display:block;width:100%;text-align:left;
                                       font-family:var(--font-mono);font-weight:var(--fw-bold);
                                       font-size:0.9rem;text-transform:uppercase;
                                       letter-spacing:0.5px;padding:8px 16px;
                                       border:none;border-left:4px solid @(IsItemActive(item)?"var(--ink-900)":"transparent");
                                       background:@(IsItemActive(item)?"var(--line-200)":"var(--paper-0)");
                                       color:@(disabled?"var(--ink-500)":"var(--ink-900)");
                                       cursor:@(disabled?"not-allowed":"pointer");
                                       opacity:@(disabled?"0.55":"1");">
                            @item.Label@(disabled?" ·":"")
                        </button>
                    }
                </div>
            }
        </div>

        <!-- Cerrar Sesión -->
        <button @onclick="Logout"
                style="font-family:var(--font-mono);font-weight:var(--fw-bold);
                       font-size:1rem;text-transform:uppercase;letter-spacing:0.5px;
                       cursor:pointer;padding:10px 24px;border-radius:0;text-align:left;
                       background:transparent;color:var(--signal-danger);border:none;">
            [ Cerrar Sesión ]
        </button>
    </nav>
</div>

<style>
    /* Base: position la define la CSS para que el @@media móvil pueda
       override sin que un inline style le gane por specificity. */
    .vm-navbar {
        position: relative;
    }

    .vm-hamburger {
        display: none;
        background: transparent;
        border: 2px solid var(--ink-900);
        border-radius: 0;
        width: 45px;
        height: 45px;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: var(--ink-900);
    }

    .vm-mobile-drawer {
        display: none;
        position: fixed;
        top: 0;
        right: 0;
        width: min(320px, 85vw);
        /* 100dvh (not 100vh) so the drawer stops at the home indicator instead
           of spilling behind it. padding clears the notch top and bottom. */
        height: 100dvh;
        padding-top: env(safe-area-inset-top, 0px);
        padding-bottom: env(safe-area-inset-bottom, 0px);
        box-sizing: border-box;
        background: var(--paper-0);
        border-left: 2px solid var(--ink-900);
        z-index: var(--z-modal);
        transform: translateX(100%);
        transition: transform var(--dur-base);
    }

    .vm-mobile-drawer.show {
        transform: translateX(0);
    }

    @@media (max-width: 760px) {
        .vm-hamburger {
            display: flex;
        }

        .vm-desktop-nav {
            display: none !important;
        }

        .vm-mobile-drawer {
            display: block;
        }

        /* En móvil la barra se mantiene fija arriba para que no se vaya
           con el scroll y tape la URL bar / status bar de iOS. */
        .vm-navbar {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            /* Push the bar's own content below the notch / status bar.
               The background fills the inset because padding is inside the
               background box. Its total height becomes 72px + inset — the
               wrapper reservation in MainLayout.razor.css must match. */
            padding-top: env(safe-area-inset-top, 0px);
        }

        /* Prevent drawer flash: when closed, the drawer is translated
           offscreen but display:block can briefly show it before Blazor
           hydrates the .show class. visibility + pointer-events are a
           belt-and-suspenders guard that does not break the transition. */
        .vm-mobile-drawer:not(.show) {
            visibility: hidden;
            pointer-events: none;
        }
    }
</style>
