@* =========================================================================
   VmNavbar — Barra de navegación industrial (equivale a NavMenu.razor)
   Desktop: wordmark VENDING + links con dropdowns.
   Mobile (<760px): hamburger + panel deslizante derecho.

   Props:
   - Active:      key de la sección activa (legacy). Si está vacío, el estado
                  activo se deriva de la URI actual (Nav.Uri).
   - OnNavigate:  EventCallback<string> — recibe el key al navegar.
                  Si no se provee, navega con NavigationManager al Href real.
   - Collapsed:   cuando es true oculta toda la navbar (API heredada de MainLayout).

   Cada NavItem define Key (para highlight) y Href (ruta real a la que navegar).
   El estado activo se calcula comparando el path actual con el Href del item.

   Uso en MainLayout.razor:
   <VmNavbar Active="@_currentSection" OnNavigate="HandleNav" Collapsed="@_navbarCollapsed" />
   ========================================================================= *@

@inject NavigationManager Nav
@inject IJSRuntime JSRuntime

@code {
    [Parameter] public string Active { get; set; } = "";
    [Parameter] public EventCallback<string> OnNavigate { get; set; }
    [Parameter] public bool Collapsed { get; set; }

    private string? _openDropdown = null;
    private bool _mobileOpen = false;
    private bool _isMobile = false;
    private string _currentPath = "";

    // Items de navegación. Key se usa para el resaltado activo; Href para navegar.
    // IsPending: true → label en rojo (signal-danger). Indica que la página aún
    //            no fue migrada al diseño industrial v3 (ver docs/design-v3/ARCHIVE.md).
    record NavItem(string Label, string? Key = null, string? Href = null, bool IsPending = false, string? BadgeText = null);

    private static readonly NavItem[] Gestion = [
        new("Informe Ventas", "informe-ventas", "/informe-ventas"),
        new("Análisis Productos", "analisis-productos", "/analisis-productos"),
        new("Quiebres de Stock", "stockout", "/stockout-dashboard"),
        new("Templates Recarga", "recarga", "/templates-recarga"),
        new("Informe Compras", "informe-compras", "/informe-compras"),
        new("Caja", "caja", "/caja"),
        new("Conciliación", "contabilidad", "/contabilidad"),
    ];
    private static readonly NavItem[] Operaciones = [
        new("Máquinas", "maquinas", "/maquinas", IsPending: true),
        new("Compras", "compras", "/compras"),
        new("Bodega", "bodega", "/inventario", IsPending: true),
        new("Centro de Cargas", "cargas", "/cargas", IsPending: true),
        new("Optimizador de Rutas", "optimizador-rutas", "/optimizador-rutas"),
    ];
    private static readonly NavItem[] Administracion = [
        new("Auditoría", "auditoria", "/admin/auditoria", IsPending: true),
        new("Gestión de Usuarios", "gestion-usuarios", "/admin/usuarios", IsPending: true),
        new("Integridad de Datos", "integridad", "/admin/integridad-datos", IsPending: true),
        new("Proveedores", "proveedores", "/admin/proveedores", IsPending: true),
        new("Zonas Logísticas", "zonas", "/admin/zonas"),
    ];

    protected override async Task OnInitializedAsync()
    {
        _currentPath = new Uri(Nav.Uri).AbsolutePath.Trim('/').ToLowerInvariant();
        await RefreshMobileAsync();
    }

    private bool IsItemActive(NavItem item)
    {
        if (string.IsNullOrWhiteSpace(item.Href)) return false;
        var itemPath = item.Href.Trim('/').ToLowerInvariant();
        if (itemPath == "") return _currentPath == "";

        // "Templates Recarga" highlights for both desktop and mobile routes
        if (item.Key == "recarga")
            return _currentPath == itemPath || _currentPath == "recarga-movil";

        // "Conciliación" highlights for both desktop and mobile routes
        if (item.Key == "contabilidad")
            return _currentPath == itemPath || _currentPath == "conciliacion-movil";

        return _currentPath == itemPath;
    }

    private bool IsDashboardActive() => _currentPath == "";

    private async Task RefreshMobileAsync()
    {
        try
        {
            var width = await JSRuntime.InvokeAsync<int>("eval", "window.innerWidth");
            _isMobile = width < 760;
        }
        catch
        {
            _isMobile = false;
        }
    }

    private async Task Navigate(NavItem item)
    {
        _openDropdown = null;
        if (_isMobile)
            _mobileOpen = false;

        // Mobile-friendly versions on small screens
        var href = _isMobile switch
        {
            true when item.Key == "recarga" => "/recarga-movil",
            true when item.Key == "contabilidad" => "/conciliacion-movil",
            _ => item.Href
        };

        if (item.Key != null && OnNavigate.HasDelegate)
            await OnNavigate.InvokeAsync(item.Key);
        else if (!string.IsNullOrWhiteSpace(href))
            Nav.NavigateTo(href);
    }

    private void ToggleDropdown(string name) =>
        _openDropdown = _openDropdown == name ? null : name;

    private void ToggleMobile() =>
        _mobileOpen = !_mobileOpen;

    // Logout: Blazor WASM no puede borrar la cookie server-side por sí mismo.
    // forceLoad:true fuerza una recarga completa de página → el server ejecuta
    // AccountController.Logout (SignOutAsync) → App.razor detecta que no hay
    // sesión y <RedirectToLogin> manda a /login.
    private void Logout() => Nav.NavigateTo("logout", true);
}

<!-- Barra superior -->
<div class="vm-navbar" style="flex-shrink:0;background:var(--paper-0);
            border-bottom:2px solid var(--ink-900);
            z-index:var(--z-nav);
            @(Collapsed ? "display:none;" : "")">
    <div style="display:flex;justify-content:space-between;align-items:center;
                gap:16px;padding:12px 24px;">

        <!-- Wordmark -->
        <button @onclick='() => Navigate(new NavItem("Panel de Control","dashboard","/"))'
                style="font-family:var(--font-mono);font-weight:800;font-size:1.5rem;
                       letter-spacing:-1px;text-transform:uppercase;cursor:pointer;
                       border:2px solid var(--ink-900);padding:5px 10px;
                       background:var(--ink-900);color:var(--paper-0);border-radius:0;">
            VENDING
        </button>

        <!-- Hamburger (mobile) -->
        <button class="vm-hamburger" @onclick="ToggleMobile" aria-label="Abrir menú" type="button">
            <i class="bi bi-list" style="font-size:1.5rem;"></i>
        </button>

        <!-- Links desktop -->
        <nav class="vm-desktop-nav"
             style="display:flex;gap:0.6rem;flex-wrap:wrap;
                    justify-content:flex-end;align-items:center;">

<!-- Panel de Control (link directo) -->
            <button @onclick='() => Navigate(new NavItem("Panel de Control","dashboard","/"))'
                    style="font-family:var(--font-mono);font-weight:var(--fw-bold);
                           font-size:1rem;text-transform:uppercase;letter-spacing:0.5px;
                           cursor:pointer;padding:5px 10px;border-radius:0;
                           background:@(IsDashboardActive()?"var(--ink-900)":"transparent");
                            color:@(IsDashboardActive()?"var(--paper-0)":"var(--ink-900)");
                            border:@(IsDashboardActive()?"1px solid var(--ink-900)":"1px solid transparent");">
                [ Panel de Control ]
            </button>

            <!-- Gestión dropdown -->
            <div style="position:relative;">
                <button @onclick='() => ToggleDropdown("gestion")'
                        style="font-family:var(--font-mono);font-weight:var(--fw-bold);
                               font-size:1rem;text-transform:uppercase;letter-spacing:0.5px;
                               cursor:pointer;padding:5px 10px;border-radius:0;
                               background:@(_openDropdown=="gestion"?"var(--line-200)":"transparent");
                               color:var(--ink-900);
                               border:@(_openDropdown=="gestion"?"1px solid var(--ink-900)":"1px solid transparent");">
                    [ Gestión ▾ ]
                </button>
                @if (_openDropdown == "gestion")
                {
                    <div style="position:absolute;top:100%;left:0;margin-top:5px;
                                min-width:230px;background:var(--paper-0);
                                border:2px solid var(--ink-900);
                                box-shadow:var(--shadow-pop);padding:10px 0;
                                z-index:var(--z-dropdown);">
                        @foreach (var item in Gestion)
                        {
                            var disabled = item.Key == null && item.Href == null;
                            <button @onclick="() => Navigate(item)"
                                    disabled="@disabled"
                                    style="display:block;width:100%;text-align:left;
                                           font-family:var(--font-mono);font-weight:var(--fw-bold);
                                           font-size:0.9rem;text-transform:uppercase;
                                           letter-spacing:0.5px;padding:10px 15px;
                                           border:none;border-left:4px solid @(IsItemActive(item)?"var(--ink-900)":"transparent");
                                           background:@(IsItemActive(item)?"var(--line-200)":"var(--paper-0)");
                                           color:@(disabled ? "var(--ink-500)" : (item.IsPending && !IsItemActive(item) ? "var(--signal-danger)" : "var(--ink-900)"));
                                           cursor:@(disabled?"not-allowed":"pointer");
                                           opacity:@(disabled?"0.55":"1");">
                                @item.Label@(disabled?" ·":"")@if (item.BadgeText != null) { <span class="rm-badge-mobile">@item.BadgeText</span> }
                            </button>
                        }
                    </div>
                }
            </div>

            <!-- Operaciones dropdown (mismo patrón) -->
            <div style="position:relative;">
                <button @onclick='() => ToggleDropdown("operaciones")'
                        style="font-family:var(--font-mono);font-weight:var(--fw-bold);
                               font-size:1rem;text-transform:uppercase;letter-spacing:0.5px;
                               cursor:pointer;padding:5px 10px;border-radius:0;
                               background:@(_openDropdown=="operaciones"?"var(--line-200)":"transparent");
                               color:var(--ink-900);
                               border:@(_openDropdown=="operaciones"?"1px solid var(--ink-900)":"1px solid transparent");">
                    [ Operaciones ▾ ]
                </button>
                @if (_openDropdown == "operaciones")
                {
                    <div style="position:absolute;top:100%;left:0;margin-top:5px;
                                min-width:210px;background:var(--paper-0);
                                border:2px solid var(--ink-900);
                                box-shadow:var(--shadow-pop);padding:10px 0;
                                z-index:var(--z-dropdown);">
                        @foreach (var item in Operaciones)
                        {
                            var disabled = item.Key == null && item.Href == null;
                            <button @onclick="() => Navigate(item)"
                                    disabled="@disabled"
                                    style="display:block;width:100%;text-align:left;
                                           font-family:var(--font-mono);font-weight:var(--fw-bold);
                                           font-size:0.9rem;text-transform:uppercase;
                                           letter-spacing:0.5px;padding:10px 15px;
                                           border:none;border-left:4px solid @(IsItemActive(item)?"var(--ink-900)":"transparent");
                                           background:@(IsItemActive(item)?"var(--line-200)":"var(--paper-0)");
                                           color:@(disabled ? "var(--ink-500)" : (item.IsPending && !IsItemActive(item) ? "var(--signal-danger)" : "var(--ink-900)"));
                                           cursor:@(disabled?"not-allowed":"pointer");
                                           opacity:@(disabled?"0.55":"1");">
                                @item.Label@(disabled?" ·":"")
                            </button>
                        }
                    </div>
                }
            </div>

            <!-- Administración dropdown (mismo patrón) -->
            <div style="position:relative;">
                <button @onclick='() => ToggleDropdown("administracion")'
                        style="font-family:var(--font-mono);font-weight:var(--fw-bold);
                               font-size:1rem;text-transform:uppercase;letter-spacing:0.5px;
                               cursor:pointer;padding:5px 10px;border-radius:0;
                               background:@(_openDropdown=="administracion"?"var(--line-200)":"transparent");
                               color:var(--ink-900);
                               border:@(_openDropdown=="administracion"?"1px solid var(--ink-900)":"1px solid transparent");">
                    [ Administración ▾ ]
                </button>
                @if (_openDropdown == "administracion")
                {
                    <div style="position:absolute;top:100%;left:0;margin-top:5px;
                                min-width:210px;background:var(--paper-0);
                                border:2px solid var(--ink-900);
                                box-shadow:var(--shadow-pop);padding:10px 0;
                                z-index:var(--z-dropdown);">
                        @foreach (var item in Administracion)
                        {
                            var disabled = item.Key == null && item.Href == null;
                            <button @onclick="() => Navigate(item)"
                                    disabled="@disabled"
                                    style="display:block;width:100%;text-align:left;
                                           font-family:var(--font-mono);font-weight:var(--fw-bold);
                                           font-size:0.9rem;text-transform:uppercase;
                                           letter-spacing:0.5px;padding:10px 15px;
                                           border:none;border-left:4px solid @(IsItemActive(item)?"var(--ink-900)":"transparent");
                                           background:@(IsItemActive(item)?"var(--line-200)":"var(--paper-0)");
                                           color:@(disabled ? "var(--ink-500)" : (item.IsPending && !IsItemActive(item) ? "var(--signal-danger)" : "var(--ink-900)"));
                                           cursor:@(disabled?"not-allowed":"pointer");
                                           opacity:@(disabled?"0.55":"1");">
                                @item.Label@(disabled?" ·":"")
                            </button>
                        }
                    </div>
                }
            </div>

            <!-- Cerrar Sesión -->
            <button @onclick="Logout"
                    style="font-family:var(--font-mono);font-weight:var(--fw-bold);
                           font-size:1rem;text-transform:uppercase;letter-spacing:0.5px;
                           cursor:pointer;padding:5px 10px;border-radius:0;
                           background:transparent;color:var(--signal-danger);
                           border:1px solid transparent;">
                [ Cerrar Sesión ]
            </button>
        </nav>
    </div>
</div>

<!-- Mobile drawer -->
