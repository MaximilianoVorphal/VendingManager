                        </button>
                    }
                </div>
            }
        </div>

        <!-- Operaciones dropdown -->
        <div style="position:relative;">
            <button @onclick='() => ToggleDropdown("operaciones-mobile")'
                    style="font-family:var(--font-mono);font-weight:var(--fw-bold);
                           font-size:1rem;text-transform:uppercase;letter-spacing:0.5px;
                           cursor:pointer;padding:10px 24px;border-radius:0;text-align:left;
                           width:100%;background:var(--paper-0);color:var(--ink-900);border:none;">
                [ Operaciones ▾ ]
            </button>
            @if (_openDropdown == "operaciones-mobile")
            {
                <div style="padding:0 24px;display:flex;flex-direction:column;gap:0.25rem;">
                    @foreach (var item in Operaciones)
                    {
                        var disabled = item.Key == null && item.Href == null;
                        <button @onclick="() => Navigate(item)"
                                disabled="@disabled"
                                style="display:block;width:100%;text-align:left;
                                       font-family:var(--font-mono);font-weight:var(--fw-bold);
                                       font-size:0.9rem;text-transform:uppercase;
                                       letter-spacing:0.5px;padding:8px 16px;
                                       border:none;border-left:4px solid @(IsItemActive(item)?"var(--ink-900)":"transparent");
                                       background:@(IsItemActive(item)?"var(--line-200)":"var(--paper-0)");
                                       color:@(disabled?"var(--ink-500)":"var(--ink-900)");
                                       cursor:@(disabled?"not-allowed":"pointer");
                                       opacity:@(disabled?"0.55":"1");">
                            @item.Label@(disabled?" ·":"")
