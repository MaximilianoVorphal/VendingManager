@* =========================================================================
   VmNavbar — Barra de navegación industrial (equivale a NavMenu.razor)
   Desktop: wordmark VENDING + links con dropdowns.
   Mobile (<760px): hamburger + panel deslizante derecho.

   Props:
   - Active:      key de la sección activa, ej. "dashboard" | "recarga" | "caja"
   - OnNavigate:  EventCallback<string> — recibe el key al navegar
                  Si no se provee, navega con NavigationManager a la ruta real.
   - Collapsed:   cuando es true oculta toda la navbar (API heredada de MainLayout).

   Claves disponibles: "dashboard", "recarga", "caja"
   (el resto de ítems están como placeholders deshabilitados)

   Uso en MainLayout.razor:
   <VmNavbar Active="@_currentSection" OnNavigate="HandleNav" Collapsed="@_navbarCollapsed" />
   ========================================================================= *@

@inject NavigationManager Nav
@inject IJSRuntime JSRuntime

@code {
    [Parameter] public string Active { get; set; } = "";
    [Parameter] public EventCallback<string> OnNavigate { get; set; }
    [Parameter] public bool Collapsed { get; set; }

    private string? _openDropdown = null;
    private bool _mobileOpen = false;
    private bool _isMobile = false;

    // Items de navegación
    record NavItem(string Label, string? Key = null, string? Href = null);

    private static readonly NavItem[] Gestion = [
        new("Informe Ventas"),
        new("Análisis Productos"),
        new("Quiebres de Stock"),
        new("Templates Recarga", "recarga"),
        new("Informe Compras"),
        new("Caja", "caja"),
        new("Conciliación"),
    ];
    private static readonly NavItem[] Operaciones = [
        new("Máquinas"), new("Compras"), new("Bodega"), new("Centro de Cargas"),
    ];

    protected override async Task OnInitializedAsync()
    {
        await RefreshMobileAsync();
    }

    private async Task RefreshMobileAsync()
    {
        try
        {
            var width = await JSRuntime.InvokeAsync<int>("eval", "window.innerWidth");
            _isMobile = width < 760;
        }
        catch
        {
            _isMobile = false;
        }
    }

    private async Task Navigate(NavItem item)
    {
        _openDropdown = null;
        if (_isMobile)
            _mobileOpen = false;

        if (item.Key != null && OnNavigate.HasDelegate)
            await OnNavigate.InvokeAsync(item.Key);
        else if (item.Href != null)
            Nav.NavigateTo(item.Href);
    }

    private void ToggleDropdown(string name) =>
        _openDropdown = _openDropdown == name ? null : name;

    private void ToggleMobile() =>
        _mobileOpen = !_mobileOpen;
}

<!-- Barra superior -->
<div style="flex-shrink:0;background:var(--paper-0);
            border-bottom:2px solid var(--ink-900);
            position:relative;z-index:var(--z-nav);
            @(Collapsed ? "display:none;" : "")">
    <div style="display:flex;justify-content:space-between;align-items:center;
                gap:16px;padding:12px 24px;">

        <!-- Wordmark -->
        <button @onclick='() => Navigate(new NavItem("Panel de Control","dashboard"))'
                style="font-family:var(--font-mono);font-weight:800;font-size:1.5rem;
                       letter-spacing:-1px;text-transform:uppercase;cursor:pointer;
                       border:2px solid var(--ink-900);padding:5px 10px;
                       background:var(--ink-900);color:var(--paper-0);border-radius:0;">
            VENDING
        </button>

        <!-- Hamburger (mobile) -->
        <button class="vm-hamburger" @onclick="ToggleMobile" aria-label="Abrir menú" type="button">
            <i class="bi bi-list" style="font-size:1.5rem;"></i>
        </button>

        <!-- Links desktop -->
        <nav class="vm-desktop-nav"
             style="display:flex;gap:0.6rem;flex-wrap:wrap;
                    justify-content:flex-end;align-items:center;">

            <!-- Panel de Control (link directo) -->
            <button @onclick='() => Navigate(new NavItem("Panel de Control","dashboard"))'
                    style="font-family:var(--font-mono);font-weight:var(--fw-bold);
                           font-size:1rem;text-transform:uppercase;letter-spacing:0.5px;
                           cursor:pointer;padding:5px 10px;border-radius:0;
                           background:@(Active=="dashboard"?"var(--ink-900)":"transparent");
                           color:@(Active=="dashboard"?"var(--paper-0)":"var(--ink-900)");
                           border:@(Active=="dashboard"?"1px solid var(--ink-900)":"1px solid transparent");">
                [ Panel de Control ]
            </button>

            <!-- Gestión dropdown -->
            <div style="position:relative;">
                <button @onclick='() => ToggleDropdown("gestion")'
                        style="font-family:var(--font-mono);font-weight:var(--fw-bold);
                               font-size:1rem;text-transform:uppercase;letter-spacing:0.5px;
                               cursor:pointer;padding:5px 10px;border-radius:0;
                               background:@(_openDropdown=="gestion"?"var(--line-200)":"transparent");
                               color:var(--ink-900);
                               border:@(_openDropdown=="gestion"?"1px solid var(--ink-900)":"1px solid transparent");">
                    [ Gestión ▾ ]
                </button>
                @if (_openDropdown == "gestion")
                {
                    <div style="position:absolute;top:100%;left:0;margin-top:5px;
                                min-width:230px;background:var(--paper-0);
                                border:2px solid var(--ink-900);
                                box-shadow:var(--shadow-pop);padding:10px 0;
                                z-index:var(--z-dropdown);">
                        @foreach (var item in Gestion)
                        {
                            var disabled = item.Key == null && item.Href == null;
                            <button @onclick="() => Navigate(item)"
                                    disabled="@disabled"
                                    style="display:block;width:100%;text-align:left;
                                           font-family:var(--font-mono);font-weight:var(--fw-bold);
                                           font-size:0.9rem;text-transform:uppercase;
                                           letter-spacing:0.5px;padding:10px 15px;
                                           border:none;border-left:4px solid transparent;
                                           background:var(--paper-0);
                                           color:@(disabled?"var(--ink-500)":"var(--ink-900)");
                                           cursor:@(disabled?"not-allowed":"pointer");
                                           opacity:@(disabled?"0.55":"1");">
                                @item.Label@(disabled?" ·":"")
                            </button>
                        }
                    </div>
                }
            </div>

            <!-- Operaciones dropdown (mismo patrón) -->
            <div style="position:relative;">
                <button @onclick='() => ToggleDropdown("operaciones")'
                        style="font-family:var(--font-mono);font-weight:var(--fw-bold);
                               font-size:1rem;text-transform:uppercase;letter-spacing:0.5px;
                               cursor:pointer;padding:5px 10px;border-radius:0;
                               background:transparent;color:var(--ink-900);
                               border:1px solid transparent;">
                    [ Operaciones ▾ ]
                </button>
                @if (_openDropdown == "operaciones")
                {
                    <div style="position:absolute;top:100%;left:0;margin-top:5px;
                                min-width:210px;background:var(--paper-0);
                                border:2px solid var(--ink-900);
                                box-shadow:var(--shadow-pop);padding:10px 0;
                                z-index:var(--z-dropdown);">
                        @foreach (var item in Operaciones)
                        {
                            <button disabled="true"
                                    style="display:block;width:100%;text-align:left;
                                           font-family:var(--font-mono);font-weight:var(--fw-bold);
                                           font-size:0.9rem;text-transform:uppercase;
                                           letter-spacing:0.5px;padding:10px 15px;
                                           border:none;background:var(--paper-0);
                                           color:var(--ink-500);cursor:not-allowed;opacity:0.55;">
                                @item.Label ·
                            </button>
                        }
                    </div>
                }
            </div>

            <!-- Cerrar Sesión -->
            <button style="font-family:var(--font-mono);font-weight:var(--fw-bold);
                           font-size:1rem;text-transform:uppercase;letter-spacing:0.5px;
                           cursor:pointer;padding:5px 10px;border-radius:0;
                           background:transparent;color:var(--signal-danger);
                           border:1px solid transparent;">
                [ Cerrar Sesión ]
            </button>
        </nav>
    </div>
</div>

<!-- Mobile drawer -->
<div class="vm-mobile-drawer @(_mobileOpen ? "show" : "")"
     aria-hidden="@(!_mobileOpen)"
     role="dialog"
     aria-label="Menú de navegación">
    <div style="display:flex;justify-content:space-between;align-items:center;
                gap:16px;padding:12px 24px;border-bottom:2px solid var(--ink-900);">
        <span style="font-family:var(--font-mono);font-weight:800;font-size:1.5rem;
                     letter-spacing:-1px;text-transform:uppercase;
                     border:2px solid var(--ink-900);padding:5px 10px;
                     background:var(--ink-900);color:var(--paper-0);">
            VENDING
        </span>
        <button @onclick="ToggleMobile"
                aria-label="Cerrar menú"
                type="button"
                style="background:transparent;border:2px solid var(--ink-900);
                       width:45px;height:45px;display:flex;align-items:center;
                       justify-content:center;cursor:pointer;border-radius:0;">
            <i class="bi bi-x-lg" style="font-size:1.5rem;"></i>
        </button>
    </div>

    <nav style="display:flex;flex-direction:column;padding:1rem 0;gap:0.25rem;">
        <!-- Panel de Control -->
        <button @onclick='() => Navigate(new NavItem("Panel de Control","dashboard"))'
                style="font-family:var(--font-mono);font-weight:var(--fw-bold);
                       font-size:1rem;text-transform:uppercase;letter-spacing:0.5px;
                       cursor:pointer;padding:10px 24px;border-radius:0;text-align:left;
                       background:@(Active=="dashboard"?"var(--ink-900)":"transparent");
                       color:@(Active=="dashboard"?"var(--paper-0)":"var(--ink-900)");
                       border:none;">
            [ Panel de Control ]
        </button>

        <!-- Gestión dropdown -->
        <div style="position:relative;">
            <button @onclick='() => ToggleDropdown("gestion-mobile")'
                    style="font-family:var(--font-mono);font-weight:var(--fw-bold);
                           font-size:1rem;text-transform:uppercase;letter-spacing:0.5px;
                           cursor:pointer;padding:10px 24px;border-radius:0;text-align:left;
                           width:100%;background:var(--paper-0);color:var(--ink-900);border:none;">
                [ Gestión ▾ ]
            </button>
            @if (_openDropdown == "gestion-mobile")
            {
                <div style="padding:0 24px;display:flex;flex-direction:column;gap:0.25rem;">
                    @foreach (var item in Gestion)
                    {
                        var disabled = item.Key == null && item.Href == null;
                        <button @onclick="() => Navigate(item)"
                                disabled="@disabled"
                                style="display:block;width:100%;text-align:left;
                                       font-family:var(--font-mono);font-weight:var(--fw-bold);
                                       font-size:0.9rem;text-transform:uppercase;
                                       letter-spacing:0.5px;padding:8px 16px;
                                       border:none;background:var(--paper-0);
                                       color:@(disabled?"var(--ink-500)":"var(--ink-900)");
                                       cursor:@(disabled?"not-allowed":"pointer");
                                       opacity:@(disabled?"0.55":"1");">
                            @item.Label@(disabled?" ·":"")
                        </button>
                    }
                </div>
            }
        </div>

        <!-- Operaciones dropdown -->
        <div style="position:relative;">
            <button @onclick='() => ToggleDropdown("operaciones-mobile")'
                    style="font-family:var(--font-mono);font-weight:var(--fw-bold);
                           font-size:1rem;text-transform:uppercase;letter-spacing:0.5px;
                           cursor:pointer;padding:10px 24px;border-radius:0;text-align:left;
                           width:100%;background:var(--paper-0);color:var(--ink-900);border:none;">
                [ Operaciones ▾ ]
            </button>
            @if (_openDropdown == "operaciones-mobile")
            {
                <div style="padding:0 24px;display:flex;flex-direction:column;gap:0.25rem;">
                    @foreach (var item in Operaciones)
                    {
                        <button disabled="true"
                                style="display:block;width:100%;text-align:left;
                                       font-family:var(--font-mono);font-weight:var(--fw-bold);
                                       font-size:0.9rem;text-transform:uppercase;
                                       letter-spacing:0.5px;padding:8px 16px;
                                       border:none;background:var(--paper-0);
                                       color:var(--ink-500);cursor:not-allowed;opacity:0.55;">
                            @item.Label ·
                        </button>
                    }
                </div>
            }
        </div>

        <!-- Cerrar Sesión -->
        <button style="font-family:var(--font-mono);font-weight:var(--fw-bold);
                       font-size:1rem;text-transform:uppercase;letter-spacing:0.5px;
                       cursor:pointer;padding:10px 24px;border-radius:0;text-align:left;
                       background:transparent;color:var(--signal-danger);border:none;">
            [ Cerrar Sesión ]
        </button>
    </nav>
</div>

<style>
    .vm-hamburger {
        display: none;
        background: transparent;
        border: 2px solid var(--ink-900);
        border-radius: 0;
        width: 45px;
        height: 45px;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: var(--ink-900);
    }

    .vm-mobile-drawer {
        display: none;
        position: fixed;
        top: 0;
        right: 0;
        width: min(320px, 85vw);
        height: 100vh;
        background: var(--paper-0);
        border-left: 2px solid var(--ink-900);
        z-index: var(--z-modal);
        transform: translateX(100%);
        transition: transform var(--dur-base);
    }

    .vm-mobile-drawer.show {
        transform: translateX(0);
    }

    @@media (max-width: 760px) {
        .vm-hamburger {
            display: flex;
        }

        .vm-desktop-nav {
            display: none !important;
        }

        .vm-mobile-drawer {
            display: block;
        }
    }
</style>
