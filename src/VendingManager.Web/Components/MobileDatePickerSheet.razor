@* =========================================================================
   MobileDatePickerSheet.razor — Bottom sheet for editing carga date
   Opens from Resumen header calendar icon.
   ========================================================================= *@

@namespace VendingManager.Web.Components

@if (Visible)
{
    <div class="rm-sheet__backdrop" @onclick="HandleCancel">
        <div class="rm-sheet__panel" @onclick:stopPropagation="true"
             style="padding-bottom:calc(8px + env(safe-area-inset-bottom));">
            <div class="rm-sheet__handle"></div>
            <div class="rm-sheet__head">Editar fecha</div>

            <div style="padding:12px 16px;">
                <input class="rm-search" type="date"
                       value="@_selectedDate.ToString("yyyy-MM-dd")"
                       @onchange="HandleDateChanged" />
            </div>

            <div style="padding:0 16px 12px;display:flex;gap:8px;">
                <button class="rm-cta rm-cta--dashed" style="flex:1;"
                        type="button"
                        aria-label="Cancelar"
                        @onclick="HandleCancel">
                    Cancelar
                </button>
                <button class="rm-cta rm-cta--primary" style="flex:1;"
                        type="button"
                        @onclick="HandleSave">
                    Guardar
                </button>
            </div>
        </div>
    </div>
}
