@namespace VendingManager.Web.Components

@* IndustrialHeader — Header de página con estilo industrial *@
@* Parámetros: Title (string, requerido), Subtitle (string, opcional), ChildContent (RenderFragment, opcional) *@

<div class="industrial-wrapper container-fluid px-4 mt-4">
    <div class="row align-items-center mb-4 border-bottom border-3 border-dark pb-3">
        <div class="col-12 d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <h2 class="m-0 fw-bold text-uppercase" style="letter-spacing: -1px;">
                    @Title
                </h2>
                @if (!string.IsNullOrEmpty(Subtitle))
                {
                    <small class="text-muted fw-bold">@Subtitle</small>
                }
            </div>
            @if (ChildContent != null)
            {
                <div class="d-flex align-items-center gap-2">
                    @ChildContent
                </div>
            }
        </div>
    </div>
</div>

@code {
    /// <summary>
    /// Título principal del header.
    /// </summary>
    [Parameter] public string Title { get; set; } = "";

    /// <summary>
    /// Subtítulo descriptivo.
    /// </summary>
    [Parameter] public string? Subtitle { get; set; }

    /// <summary>
    /// Contenido adicional para botones de acción.
    /// </summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }
}