@namespace VendingManager.Web.Components

<div class="slot-card @(Slot.ProductoId.HasValue ? "" : "is-empty") @(_isHighlighted ? "is-highlighted" : "")">
    <div class="slot-header">
        <span class="slot-id">SLOT @Slot.NumeroSlot</span>
        @if (!IsReadOnly)
        {
            <button class="btn-menu" type="button"
                    @onclick="ToggleMenu" @onclick:stopPropagation="true"
                    title="Opciones">⋮</button>
        }
    </div>
    <div class="slot-body">
        <div class="product-area" @onclick="OnProductNameTapped">
            <span class="product-name">
                @(Slot.ProductoId.HasValue && !string.IsNullOrEmpty(Slot.ProductoNombre)
                    ? Slot.ProductoNombre
                    : "-- SELECCIONAR --")
            </span>
        </div>
        @if (!IsReadOnly)
        {
            <div class="stepper">
                <button class="btn-step" @onclick="OnDecrement" disabled="@(_localQuantity <= 0)">−</button>
                <span class="step-number">@_localQuantity</span>
                <button class="btn-step" @onclick="OnIncrement" disabled="@(_localQuantity >= Slot.CapacidadSlot)">+</button>
            </div>
        }
        else
        {
            <span class="step-number">@_localQuantity</span>
        }
    </div>
    <div class="slot-footer">
        <div class="progress-track">
            <div class="progress-fill @GetColorClass()" style="width: @GetPercentage()%;"></div>
        </div>
        <span class="capacity-text">@_localQuantity / @Slot.CapacidadSlot</span>
    </div>

    @if (_menuOpen)
    {
        <div class="dropdown-menu">
            <button class="dropdown-item" @onclick="OnChangeProductClicked">
                Cambiar Producto
            </button>
            <button class="dropdown-item dropdown-item--danger" @onclick="OnEmptySlotClicked">
                Vaciar Slot
            </button>
        </div>
    }
</div>

@code {
    [Parameter] public TemplatesRecarga.SnapshotSlotFormModel Slot { get; set; } = new();
    [Parameter] public bool IsOcrHighlighted { get; set; }
    [Parameter] public bool IsReadOnly { get; set; }

    [Parameter] public EventCallback<int> OnQuantityChanged { get; set; }
    [Parameter] public EventCallback OnChangeProductRequested { get; set; }
    [Parameter] public EventCallback OnEmptySlotRequested { get; set; }

    private int _localQuantity;
    private System.Threading.Timer? _debounceTimer;
    private bool _disposed;
    private bool _menuOpen;

    private bool _isHighlighted => IsOcrHighlighted;

    protected override void OnInitialized()
    {
        _localQuantity = Slot.CantidadInicial;
    }

    protected override void OnParametersSet()
    {
        if (!_debounceTimerIsActive())
        {
            _localQuantity = Slot.CantidadInicial;
        }
    }

    private bool _debounceTimerIsActive() => _debounceTimer != null;

    private void OnIncrement()
    {
        if (_localQuantity < Slot.CapacidadSlot)
        {
            _localQuantity++;
            DebounceAndFireQuantityChanged();
        }
    }

    private void OnDecrement()
    {
        if (_localQuantity > 0)
        {
            _localQuantity--;
            DebounceAndFireQuantityChanged();
        }
    }

    private void DebounceAndFireQuantityChanged()
    {
        _debounceTimer?.Dispose();
        _debounceTimer = new System.Threading.Timer(
            _ =>
            {
                InvokeAsync(async () =>
                {
                    if (!_disposed)
                    {
                        await OnQuantityChanged.InvokeAsync(_localQuantity);
                    }
                });
            },
            null,
            200,
            System.Threading.Timeout.Infinite);
    }

    private void ToggleMenu()
    {
        _menuOpen = !_menuOpen;
    }

    private void OnProductNameTapped()
    {
        if (!IsReadOnly)
        {
            _ = OnChangeProductRequested.InvokeAsync();
        }
    }

    private void OnChangeProductClicked()
    {
        _menuOpen = false;
        if (!IsReadOnly)
        {
            _ = OnChangeProductRequested.InvokeAsync();
        }
    }

    private void OnEmptySlotClicked()
    {
        _menuOpen = false;
        if (!IsReadOnly)
        {
            _ = OnEmptySlotRequested.InvokeAsync();
        }
    }

    private double GetPercentage()
    {
        if (Slot.CapacidadSlot <= 0) return 0;
        return ((double)_localQuantity / Slot.CapacidadSlot) * 100;
    }

    private string GetColorClass()
    {
        var pct = GetPercentage();
        if (pct >= 80) return "fill-good";
        if (pct >= 30) return "fill-warning";
        return "fill-danger";
    }

    public void Dispose()
    {
        _disposed = true;
        _debounceTimer?.Dispose();
    }
}
