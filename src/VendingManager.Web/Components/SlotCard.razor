@namespace VendingManager.Web.Components

<div class="slot-card border border-2 border-dark shadow-sm @(_isHighlighted ? "slot-ocr-highlight" : "") @GetProductBgClass()"
     style="min-height: 160px; transition: all 0.2s;">
    <!-- TOP ROW: Slot number + context menu -->
    <div class="d-flex justify-content-between align-items-center mb-2 pb-2 border-bottom border-secondary">
        <div class="d-flex align-items-center">
            <span class="text-muted fw-bold" style="font-size: 0.7rem;">SLOT</span>
            <span class="font-monospace fw-bold ms-1" style="font-size: 0.9rem;">@Slot.NumeroSlot</span>
        </div>
        @if (!IsReadOnly)
        {
            <div class="position-relative" style="display: inline-block;">
                <button class="btn btn-sm p-0 m-0 lh-1" type="button"
                        @onclick="ToggleMenu" @onclick:stopPropagation="true"
                        title="Opciones">
                    <i class="bi bi-three-dots-vertical fs-5"></i>
                </button>
                @if (_menuOpen)
                {
                    <div class="dropdown-menu dropdown-menu-end rounded-0 border-dark show"
                         style="position: absolute; right: 0; top: 100%; z-index: 1050; min-width: 180px; display: block;">
                        <button class="dropdown-item fw-bold" @onclick="OnChangeProductClicked">
                            <i class="bi bi-arrow-left-right me-1"></i> Cambiar Producto
                        </button>
                        <button class="dropdown-item fw-bold text-danger" @onclick="OnEmptySlotClicked">
                            <i class="bi bi-trash me-1"></i> Vaciar Slot
                        </button>
                    </div>
                }
            </div>
        }
    </div>

    <!-- MIDDLE ROW: Product name (tappable) + stepper -->
    <div class="mb-2 flex-grow-1 d-flex align-items-center">
        @if (Slot.ProductoId.HasValue && !string.IsNullOrEmpty(Slot.ProductoNombre))
        {
            <button class="btn btn-outline-dark fw-bold text-start w-60 text-truncate shadow-none rounded-0"
                    style="height: 44px; white-space: normal; cursor: pointer;"
                    title="@Slot.ProductoNombre"
                    @onclick="OnProductNameTapped"
                    disabled="@IsReadOnly">
                @Slot.ProductoNombre
            </button>
        }
        else
        {
            <button class="btn btn-outline-secondary fw-bold w-60 text-truncate shadow-none rounded-0"
                    style="height: 44px; white-space: normal; cursor: pointer;"
                    title="Sin producto asignado"
                    @onclick="OnChangeProductClicked"
                    disabled="@IsReadOnly">
                <i class="bi bi-plus-lg me-1"></i> SELECCIONAR
            </button>
        }

        <!-- Stepper: right side -->
        @if (!IsReadOnly)
        {
            <div class="d-flex align-items-center gap-1 ms-auto">
                <button class="btn btn-dark rounded-0 fw-bold px-2"
                        style="min-width: 44px; min-height: 44px;"
                        @onclick="OnDecrement"
                        disabled="@(_localQuantity <= 0)"
                        title="Reducir cantidad">
                    <i class="bi bi-dash-lg"></i>
                </button>
                <span class="fs-3 fw-bold text-center" style="min-width: 40px;">@_localQuantity</span>
                <button class="btn btn-dark rounded-0 fw-bold px-2"
                        style="min-width: 44px; min-height: 44px;"
                        @onclick="OnIncrement"
                        disabled="@(_localQuantity >= Slot.CapacidadSlot)"
                        title="Aumentar cantidad">
                    <i class="bi bi-plus-lg"></i>
                </button>
            </div>
        }
        else
        {
            <span class="fs-3 fw-bold text-center ms-auto me-auto">@_localQuantity</span>
        }
    </div>

    <!-- BOTTOM ROW: Capacity text + progress bar -->
    <div class="mt-auto d-flex align-items-center justify-content-between border-top border-secondary pt-2">
        <div class="d-flex flex-column w-50 pe-1 border-end border-secondary">
            <span class="text-muted" style="font-size: 0.6rem; font-weight: 800;">CANT.</span>
            <span class="fw-bold text-dark text-center d-block" style="height: 22px; font-size: 0.9rem; line-height: 22px;">@_localQuantity</span>
        </div>
        <div class="d-flex flex-column w-50 ps-1">
            <span class="text-muted" style="font-size: 0.6rem; font-weight: 800;">CAPAC.</span>
            <span class="fw-bold text-dark text-center d-block border bg-light"
                  style="height: 22px; font-size: 0.9rem; line-height: 22px;">@Slot.CapacidadSlot</span>
        </div>
    </div>

    <!-- Progress bar -->
    <div class="mt-2">
        <div class="progress rounded-0 border border-dark" style="height: 8px;">
            <div class="progress-bar @GetProgressBarClass()"
                 role="progressbar"
                 style="width: @GetProgressPercent()%;"
                 aria-valuenow="@_localQuantity"
                 aria-valuemin="0"
                 aria-valuemax="@Slot.CapacidadSlot">
            </div>
        </div>
        <small class="text-muted fw-bold d-block text-center mt-1" style="font-size: 0.65rem;">
            @_localQuantity / @Slot.CapacidadSlot
        </small>
    </div>
</div>

@code {
    [Parameter] public TemplatesRecarga.SnapshotSlotFormModel Slot { get; set; } = new();
    [Parameter] public bool IsOcrHighlighted { get; set; }
    [Parameter] public bool IsReadOnly { get; set; }

    [Parameter] public EventCallback<int> OnQuantityChanged { get; set; }
    [Parameter] public EventCallback OnChangeProductRequested { get; set; }
    [Parameter] public EventCallback OnEmptySlotRequested { get; set; }

    private int _localQuantity;
    private System.Threading.Timer? _debounceTimer;
    private bool _disposed;
    private bool _menuOpen;

    private bool _isHighlighted => IsOcrHighlighted;

    protected override void OnInitialized()
    {
        _localQuantity = Slot.CantidadInicial;
    }

    protected override void OnParametersSet()
    {
        // Sync from parent if not actively editing
        if (!_debounceTimerIsActive())
        {
            _localQuantity = Slot.CantidadInicial;
        }
    }

    private bool _debounceTimerIsActive() => _debounceTimer != null;

    private void OnIncrement()
    {
        if (_localQuantity < Slot.CapacidadSlot)
        {
            _localQuantity++;
            DebounceAndFireQuantityChanged();
        }
    }

    private void OnDecrement()
    {
        if (_localQuantity > 0)
        {
            _localQuantity--;
            DebounceAndFireQuantityChanged();
        }
    }

    private void DebounceAndFireQuantityChanged()
    {
        _debounceTimer?.Dispose();
        _debounceTimer = new System.Threading.Timer(
            _ =>
            {
                InvokeAsync(async () =>
                {
                    if (!_disposed)
                    {
                        await OnQuantityChanged.InvokeAsync(_localQuantity);
                    }
                });
            },
            null,
            200,
            System.Threading.Timeout.Infinite);
    }

    private void ToggleMenu()
    {
        _menuOpen = !_menuOpen;
    }

    private void OnProductNameTapped()
    {
        if (!IsReadOnly)
        {
            _ = OnChangeProductRequested.InvokeAsync();
        }
    }

    private void OnChangeProductClicked()
    {
        _menuOpen = false;
        if (!IsReadOnly)
        {
            _ = OnChangeProductRequested.InvokeAsync();
        }
    }

    private void OnEmptySlotClicked()
    {
        _menuOpen = false;
        if (!IsReadOnly)
        {
            _ = OnEmptySlotRequested.InvokeAsync();
        }
    }

    private string GetProgressPercent()
    {
        if (Slot.CapacidadSlot <= 0) return "0";
        var pct = (double)_localQuantity / Slot.CapacidadSlot * 100;
        return Math.Round(pct, 0).ToString(System.Globalization.CultureInfo.InvariantCulture);
    }

    private string GetProgressBarClass()
    {
        if (_localQuantity <= 0) return "bg-danger";
        var pct = (double)_localQuantity / Slot.CapacidadSlot * 100;
        return pct > 50 ? "bg-success" : "bg-warning";
    }

    private string GetProductBgClass()
    {
        return Slot.ProductoId.HasValue ? "bg-white" : "bg-warning bg-opacity-25";
    }

    public void Dispose()
    {
        _disposed = true;
        _debounceTimer?.Dispose();
    }
}