@namespace VendingManager.Web.Components

<article class="slot-card @(_isHighlighted ? "slot-card--highlighted" : "") @(Slot.ProductoId.HasValue ? "" : "slot-card--empty")">
    <!-- TOP ROW: Slot number + context menu -->
    <header class="slot-card__header">
        <div class="slot-card__slot-info">
            <span class="slot-card__slot-label">SLOT</span>
            <span class="slot-card__slot-number">@Slot.NumeroSlot</span>
        </div>
        @if (!IsReadOnly)
        {
            <div class="slot-card__menu-wrapper">
                <button class="slot-card__menu-btn" type="button"
                        @onclick="ToggleMenu" @onclick:stopPropagation="true"
                        title="Opciones">
                    <i class="bi bi-three-dots-vertical fs-5"></i>
                </button>
                @if (_menuOpen)
                {
                    <div class="slot-card__dropdown show">
                        <button class="slot-card__dropdown-item" @onclick="OnChangeProductClicked">
                            <i class="bi bi-arrow-left-right"></i> Cambiar Producto
                        </button>
                        <button class="slot-card__dropdown-item slot-card__dropdown-item--danger" @onclick="OnEmptySlotClicked">
                            <i class="bi bi-trash"></i> Vaciar Slot
                        </button>
                    </div>
                }
            </div>
        }
    </header>

    <!-- MIDDLE ROW: Product name (tappable) + stepper -->
    <section class="slot-card__body">
        @if (Slot.ProductoId.HasValue && !string.IsNullOrEmpty(Slot.ProductoNombre))
        {
            <div class="slot-card__product-btn"
                 title="@Slot.ProductoNombre"
                 @onclick="OnProductNameTapped"
                 @onclick:stopPropagation="true">
                <span>@Slot.ProductoNombre</span>
            </div>
        }
        else
        {
            <div class="slot-card__product-btn slot-card__product-btn--empty"
                 title="Sin producto asignado"
                 @onclick="OnChangeProductClicked"
                 @onclick:stopPropagation="true">
                <i class="bi bi-plus-lg slot-card__product-icon"></i>
                <span>SELECCIONAR</span>
            </div>
        }

        <!-- Stepper: right side -->
        @if (!IsReadOnly)
        {
            <div class="slot-card__stepper">
                <button class="stepper-btn"
                        @onclick="OnDecrement"
                        disabled="@(_localQuantity <= 0)"
                        title="Reducir cantidad">
                    <i class="bi bi-dash-lg"></i>
                </button>
                <span class="stepper-qty">@_localQuantity</span>
                <button class="stepper-btn"
                        @onclick="OnIncrement"
                        disabled="@(_localQuantity >= Slot.CapacidadSlot)"
                        title="Aumentar cantidad">
                    <i class="bi bi-plus-lg"></i>
                </button>
            </div>
        }
        else
        {
            <span class="slot-card__qty-readonly">@_localQuantity</span>
        }
    </section>

    <!-- BOTTOM ROW: Capacity text + progress bar -->
    <footer class="slot-card__footer">
        <div class="slot-card__capacity-group">
            <div class="slot-card__capacity-item slot-card__capacity-item--cant">
                <span class="slot-card__capacity-label">CANT.</span>
                <span class="slot-card__capacity-value">@_localQuantity</span>
            </div>
            <div class="slot-card__capacity-item slot-card__capacity-item--capac">
                <span class="slot-card__capacity-label">CAPAC.</span>
                <span class="slot-card__capacity-value">@Slot.CapacidadSlot</span>
            </div>
        </div>
    </footer>

    <!-- Progress bar -->
    <div class="slot-card__progress-container">
        <div class="slot-card__progress-track">
            <div class="slot-card__progress-fill @GetProgressBarClass()"
                 style="width: @GetProgressPercent()%;"
                 role="progressbar"
                 aria-valuenow="@_localQuantity"
                 aria-valuemin="0"
                 aria-valuemax="@Slot.CapacidadSlot">
            </div>
        </div>
        <small class="slot-card__progress-text">
            @_localQuantity / @Slot.CapacidadSlot
        </small>
    </div>
</article>

@code {
    [Parameter] public TemplatesRecarga.SnapshotSlotFormModel Slot { get; set; } = new();
    [Parameter] public bool IsOcrHighlighted { get; set; }
    [Parameter] public bool IsReadOnly { get; set; }

    [Parameter] public EventCallback<int> OnQuantityChanged { get; set; }
    [Parameter] public EventCallback OnChangeProductRequested { get; set; }
    [Parameter] public EventCallback OnEmptySlotRequested { get; set; }

    private int _localQuantity;
    private System.Threading.Timer? _debounceTimer;
    private bool _disposed;
    private bool _menuOpen;

    private bool _isHighlighted => IsOcrHighlighted;

    protected override void OnInitialized()
    {
        _localQuantity = Slot.CantidadInicial;
    }

    protected override void OnParametersSet()
    {
        // Sync from parent if not actively editing
        if (!_debounceTimerIsActive())
        {
            _localQuantity = Slot.CantidadInicial;
        }
    }

    private bool _debounceTimerIsActive() => _debounceTimer != null;

    private void OnIncrement()
    {
        if (_localQuantity < Slot.CapacidadSlot)
        {
            _localQuantity++;
            DebounceAndFireQuantityChanged();
        }
    }

    private void OnDecrement()
    {
        if (_localQuantity > 0)
        {
            _localQuantity--;
            DebounceAndFireQuantityChanged();
        }
    }

    private void DebounceAndFireQuantityChanged()
    {
        _debounceTimer?.Dispose();
        _debounceTimer = new System.Threading.Timer(
            _ =>
            {
                InvokeAsync(async () =>
                {
                    if (!_disposed)
                    {
                        await OnQuantityChanged.InvokeAsync(_localQuantity);
                    }
                });
            },
            null,
            200,
            System.Threading.Timeout.Infinite);
    }

    private void ToggleMenu()
    {
        _menuOpen = !_menuOpen;
    }

    private void OnProductNameTapped()
    {
        if (!IsReadOnly)
        {
            _ = OnChangeProductRequested.InvokeAsync();
        }
    }

    private void OnChangeProductClicked()
    {
        _menuOpen = false;
        if (!IsReadOnly)
        {
            _ = OnChangeProductRequested.InvokeAsync();
        }
    }

    private void OnEmptySlotClicked()
    {
        _menuOpen = false;
        if (!IsReadOnly)
        {
            _ = OnEmptySlotRequested.InvokeAsync();
        }
    }

    private string GetProgressPercent()
    {
        if (Slot.CapacidadSlot <= 0) return "0";
        var pct = (double)_localQuantity / Slot.CapacidadSlot * 100;
        return Math.Round(pct, 0).ToString(System.Globalization.CultureInfo.InvariantCulture);
    }

    private string GetProgressBarClass()
    {
        if (_localQuantity <= 0) return "slot-card__progress-fill--red";
        var pct = (double)_localQuantity / Slot.CapacidadSlot * 100;
        return pct > 50 ? "slot-card__progress-fill--green" : "slot-card__progress-fill--orange";
    }

    public void Dispose()
    {
        _disposed = true;
        _debounceTimer?.Dispose();
    }
}