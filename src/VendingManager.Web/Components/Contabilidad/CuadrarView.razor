@using VendingManager.Shared.DTOs
@using VendingManager.Shared.Enums
@inject HttpClient Http
@inject IJSRuntime JS

<div class="p-3">
    <h4 class="fw-bold text-uppercase mb-4 text-center" style="letter-spacing: -1px;">
        <i class="bi bi-check2-square me-2"></i>CUADRE DE RENDICIÓN
    </h4>

    @* ====== TRANSFERENCIAS SECTION ====== *@
    <div class="card border-2 border-dark rounded-0 shadow mb-3">
        <div class="card-header bg-dark text-white rounded-0 fw-bold d-flex justify-content-between align-items-center p-2">
            <span><i class="bi bi-bank me-2"></i>💰 TRANSFERENCIAS</span>
            <div class="d-flex gap-2">
                <span class="badge bg-light text-dark rounded-0">@Transferencias.Count</span>
                <span class="badge @(GetTransferenciasTotal() >= 0 ? "bg-success" : "bg-danger") rounded-0">
                    Total: $@GetTransferenciasTotal().ToString("N0")
                </span>
            </div>
        </div>
        <div class="card-body p-0">
            @if (EditingTransferenciaId > 0)
            {
                @* Inline edit row *@
                <div class="row g-2 p-2 bg-warning-subtle border-bottom border-dark align-items-center">
                    <div class="col-md-4">
                        <span class="fw-bold small">EDITANDO TRANSFERENCIA #@EditingTransferenciaId</span>
                    </div>
                    <div class="col-md-4">
                        <div class="input-group input-group-sm">
                            <span class="input-group-text bg-dark text-white border-dark rounded-0">$</span>
                            <input type="number" class="form-control border-dark rounded-0 font-monospace text-end"
                                   @bind="EditingMonto" min="0" />
                        </div>
                    </div>
                    <div class="col-md-2">
                        <button class="btn btn-success btn-sm rounded-0 fw-bold" @onclick="GuardarEdicionMonto">
                            <i class="bi bi-check-lg"></i> GUARDAR
                        </button>
                    </div>
                    <div class="col-md-2">
                        <button class="btn btn-outline-dark btn-sm rounded-0 fw-bold" @onclick="CancelarEdicion">
                            CANCELAR
                        </button>
                    </div>
                    @if (!string.IsNullOrEmpty(ErrorEditando))
                    {
                        <div class="col-12 text-danger fw-bold small">@ErrorEditando</div>
                    }
                </div>
            }

            @if (Transferencias.Any())
            {
                <table class="table table-hover table-bordered border-dark m-0 align-middle">
                    <thead class="bg-secondary text-white text-uppercase small fw-bold text-center">
                        <tr>
                            <th>FECHA</th>
                            <th>DESCRIPCIÓN</th>
                            <th style="width: 130px;">MONTO</th>
                            <th style="width: 100px;">ESTADO</th>
                            <th style="width: 100px;">ACCIÓN</th>
                        </tr>
                    </thead>
                    <tbody class="fw-bold" style="font-size: 0.85rem;">
                        @foreach (var t in Transferencias)
                        {
                            <tr>
                                <td>@t.Fecha.ToString("dd/MM/yyyy")</td>
                                <td>@(string.IsNullOrEmpty(t.Descripcion) ? "—" : t.Descripcion)</td>
                                <td class="text-end font-monospace text-success fw-bold">$@t.Monto.ToString("N0")</td>
                                <td class="text-center">
                                    @if (t.Estado == TransferenciaEstado.Conciliado)
                                    {
                                        <span class="badge bg-success rounded-0">CONCILIADO</span>
                                    }
                                    else if (t.Estado == TransferenciaEstado.EnUso)
                                    {
                                        <span class="badge bg-primary rounded-0">EN USO</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark rounded-0">PENDIENTE</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="d-flex gap-1 justify-content-center">
                                        <button class="btn btn-sm btn-outline-dark rounded-0 fw-bold"
                                                title="Editar monto"
                                                @onclick="() => IniciarEdicionMonto(t)"
                                                disabled="@(t.Estado == TransferenciaEstado.Conciliado)">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger rounded-0 fw-bold"
                                                title="Desvincular transferencia"
                                                @onclick="() => DesvincularTransferenciaClick(t.Id)">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="text-center text-muted p-4">No hay transferencias registradas.</div>
            }
        </div>
    </div>

    @* ====== COMPRAS SECTION ====== *@
    <div class="card border-2 border-dark rounded-0 shadow mb-3">
        <div class="card-header bg-dark text-white rounded-0 fw-bold d-flex justify-content-between align-items-center p-2">
            <span><i class="bi bi-cart4 me-2"></i>📦 COMPRAS</span>
            <div class="d-flex gap-2">
                <span class="badge bg-light text-dark rounded-0">@Compras.Count(c => c.TipoFactura == "MERCADERIA")</span>
                <span class="badge bg-danger rounded-0">Total: -$@GetComprasTotal().ToString("N0")</span>
            </div>
        </div>
        <div class="card-body p-0">
            @if (EditingCompraId > 0)
            {
                @* Inline edit row for compra *@
                var compra = Compras.FirstOrDefault(c => c.Id == EditingCompraId);
                if (compra != null)
                {
                    <div class="row g-2 p-2 bg-warning-subtle border-bottom border-dark align-items-center">
                        <div class="col-md-12 mb-2">
                            <span class="fw-bold small">EDITANDO COMPRA #@EditingCompraId — @compra.Proveedor</span>
                        </div>
                        <div class="col-md-3">
                            <label class="fw-bold small text-muted">PROVEEDOR</label>
                            <input type="text" class="form-control form-control-sm border-dark rounded-0" @bind="EditCompraProveedor" />
                        </div>
                        <div class="col-md-2">
                            <label class="fw-bold small text-muted">Nº DOCUMENTO</label>
                            <input type="text" class="form-control form-control-sm border-dark rounded-0" @bind="EditCompraNumeroDocumento" />
                        </div>
                        <div class="col-md-2">
                            <label class="fw-bold small text-muted">FECHA</label>
                            <input type="date" class="form-control form-control-sm border-dark rounded-0" @bind="EditCompraFecha" />
                        </div>
                        <div class="col-md-2">
                            <label class="fw-bold small text-muted">TIPO</label>
                            <select class="form-select form-select-sm border-dark rounded-0" @bind="EditCompraTipo">
                                <option value="MERCADERIA">MERCADERIA</option>
                                <option value="GASTO_GENERAL">GASTO GENERAL</option>
                            </select>
                        </div>
                        <div class="col-md-3 d-flex align-items-end gap-1">
                            <button class="btn btn-success btn-sm rounded-0 fw-bold" @onclick="GuardarEdicionCompra" disabled="@EditCompraGuardando">
                                @if (EditCompraGuardando)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                }
                                <i class="bi bi-check-lg"></i> GUARDAR
                            </button>
                            <button class="btn btn-outline-dark btn-sm rounded-0 fw-bold" @onclick="CancelarEdicionCompra">
                                CANCELAR
                            </button>
                        </div>
                        @if (!string.IsNullOrEmpty(ErrorEditCompra))
                        {
                            <div class="col-12 text-danger fw-bold small">@ErrorEditCompra</div>
                        }
                    </div>
                }
            }

            @if (Compras.Any(c => c.TipoFactura == "MERCADERIA"))
            {
                <table class="table table-hover table-bordered border-dark m-0 align-middle">
                    <thead class="bg-secondary text-white text-uppercase small fw-bold text-center">
                        <tr>
                            <th style="width: 60px;">FACTURA</th>
                            <th>FECHA</th>
                            <th>Nº DOCUMENTO</th>
                            <th>PROVEEDOR</th>
                            <th>TIPO</th>
                            <th style="width: 130px;">TOTAL</th>
                            <th style="width: 120px;">ACCIÓN</th>
                        </tr>
                    </thead>
                    <tbody class="fw-bold" style="font-size: 0.85rem;">
                        @foreach (var c in Compras.Where(c => c.TipoFactura == "MERCADERIA"))
                        {
                            <tr class="@(EditingCompraId == c.Id ? "table-warning" : "")">
                                <td class="text-center">
                                    @if (!string.IsNullOrEmpty(c.FacturaImagenPath))
                                    {
                                        <a href="api/compras/@c.Id/factura" target="_blank">
                                            <img src="api/compras/@c.Id/factura" class="img-thumbnail border-dark"
                                                 style="max-height: 40px; max-width: 40px; object-fit: cover;"
                                                 alt="Factura" title="Ver factura" />
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted" title="Sin factura"><i class="bi bi-file-earmark-x"></i></span>
                                    }
                                </td>
                                <td>@c.FechaCompra.ToString("dd/MM/yyyy")</td>
                                <td class="font-monospace">@(string.IsNullOrEmpty(c.NumeroDocumento) ? "S/N" : c.NumeroDocumento)</td>
                                <td>@c.Proveedor</td>
                                <td><span class="badge bg-secondary rounded-0 small">@c.TipoFactura</span></td>
                                <td class="text-end font-monospace text-danger">-$@c.MontoTotal.ToString("N0")</td>
                                <td class="text-center">
                                    <div class="d-flex gap-1 justify-content-center">
                                        <button class="btn btn-sm btn-outline-warning rounded-0 fw-bold border-dark"
                                                title="Editar compra"
                                                @onclick="() => IniciarEdicionCompra(c)">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger rounded-0 fw-bold"
                                                title="Desvincular compra"
                                                @onclick="() => DesvincularCompraClick(c.Id)">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="text-center text-muted p-4">No hay compras de mercadería registradas.</div>
            }
        </div>
    </div>

    @* ====== GASTOS SECTION ====== *@
    <div class="card border-2 border-dark rounded-0 shadow mb-4">
        <div class="card-header bg-dark text-white rounded-0 fw-bold d-flex justify-content-between align-items-center p-2">
            <span><i class="bi bi-fuel-pump me-2"></i>⛽ GASTOS</span>
            <div class="d-flex gap-2">
                <span class="badge bg-light text-dark rounded-0">@(Compras.Count(c => c.TipoFactura != "MERCADERIA") + Gastos.Count)</span>
                <span class="badge bg-danger rounded-0">Total: -$@GetGastosTotalCombinado().ToString("N0")</span>
            </div>
        </div>
        <div class="card-body p-0">
            @if (EditingGastoId > 0)
            {
                @* Inline edit row for gasto *@
                var gasto = Gastos.FirstOrDefault(g => g.Id == EditingGastoId);
                if (gasto != null)
                {
                    <div class="row g-2 p-2 bg-warning-subtle border-bottom border-dark align-items-center">
                        <div class="col-md-12 mb-2">
                            <span class="fw-bold small">EDITANDO GASTO #@EditingGastoId — @gasto.Descripcion</span>
                        </div>
                        <div class="col-md-4">
                            <label class="fw-bold small text-muted">DESCRIPCIÓN</label>
                            <input type="text" class="form-control form-control-sm border-dark rounded-0" @bind="EditGastoDescripcion" />
                        </div>
                        <div class="col-md-2">
                            <label class="fw-bold small text-muted">MONTO</label>
                            <div class="input-group input-group-sm">
                                <span class="input-group-text bg-dark text-white border-dark rounded-0">$</span>
                                <input type="number" class="form-control border-dark rounded-0 font-monospace text-end"
                                       @bind="EditGastoMonto" min="0" />
                            </div>
                        </div>
                        <div class="col-md-2">
                            <label class="fw-bold small text-muted">CATEGORÍA</label>
                            <select class="form-select form-select-sm border-dark rounded-0" @bind="EditGastoCategoria">
                                <option value="MERCADERIA">MERCADERIA</option>
                                <option value="GASTOS GENERALES">GASTOS GENERALES</option>
                                <option value="LOGISTICA">LOGISTICA</option>
                                <option value="SUELDOS">SUELDOS</option>
                                <option value="MANTENIMIENTO">MANTENIMIENTO</option>
                                <option value="GENERAL">GENERAL</option>
                            </select>
                        </div>
                        <div class="col-md-4 d-flex align-items-end gap-1">
                            <button class="btn btn-success btn-sm rounded-0 fw-bold" @onclick="GuardarEdicionGasto" disabled="@EditGastoGuardando">
                                @if (EditGastoGuardando)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                }
                                <i class="bi bi-check-lg"></i> GUARDAR
                            </button>
                            <button class="btn btn-outline-dark btn-sm rounded-0 fw-bold" @onclick="CancelarEdicionGasto">
                                CANCELAR
                            </button>
                        </div>
                        @if (!string.IsNullOrEmpty(ErrorEditGasto))
                        {
                            <div class="col-12 text-danger fw-bold small">@ErrorEditGasto</div>
                        }
                    </div>
                }
            }

            @{
                var gastoGeneralCompras = Compras.Where(c => c.TipoFactura != "MERCADERIA").ToList();
                var hasGastoGeneral = gastoGeneralCompras.Any();
                var hasCajaGastos = Gastos.Any();
            }

            @if (hasGastoGeneral)
            {
                <table class="table table-hover table-bordered border-dark m-0 align-middle">
                    <thead class="bg-secondary text-white text-uppercase small fw-bold text-center">
                        <tr>
                            <th style="width: 60px;">FACTURA</th>
                            <th>FECHA</th>
                            <th>Nº DOCUMENTO</th>
                            <th>PROVEEDOR</th>
                            <th>TIPO</th>
                            <th style="width: 130px;">TOTAL</th>
                            <th style="width: 120px;">ACCIÓN</th>
                        </tr>
                    </thead>
                    <tbody class="fw-bold" style="font-size: 0.85rem;">
                        @foreach (var c in gastoGeneralCompras)
                        {
                            <tr class="@(EditingCompraId == c.Id ? "table-warning" : "")">
                                <td class="text-center p-1">
                                    @if (!string.IsNullOrEmpty(c.FacturaImagenPath))
                                    {
                                        <a href="api/compras/@c.Id/factura" target="_blank">
                                            <img src="api/compras/@c.Id/factura"
                                                 style="width: 40px; height: 40px; object-fit: cover;"
                                                 class="border border-dark rounded-0" alt="Factura" />
                                        </a>
                                    }
                                    else
                                    {
                                        <i class="bi bi-file-earmark-x text-secondary fs-5"></i>
                                    }
                                </td>
                                <td>@c.FechaCompra.ToString("dd/MM/yyyy")</td>
                                <td class="font-monospace small">@c.NumeroDocumento</td>
                                <td>@c.Proveedor</td>
                                <td class="text-center">
                                    <span class="badge bg-secondary rounded-0">@c.TipoFactura</span>
                                </td>
                                <td class="text-end font-monospace text-danger">-$@c.MontoTotal.ToString("N0")</td>
                                <td class="text-center">
                                    <div class="d-flex gap-1 justify-content-center">
                                        <button class="btn btn-sm btn-outline-warning rounded-0 fw-bold border-dark"
                                                title="Editar compra"
                                                @onclick="() => IniciarEdicionCompra(c)">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger rounded-0 fw-bold"
                                                title="Desvincular compra"
                                                @onclick="() => DesvincularCompraClick(c.Id)">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }

            @if (hasCajaGastos)
            {
                @if (hasGastoGeneral)
                {
                    <div class="px-2 py-1 bg-light border-top border-dark small text-muted fw-bold text-uppercase">
                        <i class="bi bi-cash-coin me-1"></i>Gastos de caja
                    </div>
                }
                <table class="table table-hover table-bordered border-dark m-0 align-middle">
                    <thead class="bg-secondary text-white text-uppercase small fw-bold text-center">
                        <tr>
                            <th>FECHA</th>
                            <th>CATEGORÍA</th>
                            <th>DESCRIPCIÓN</th>
                            <th style="width: 130px;">MONTO</th>
                            <th style="width: 120px;">ACCIÓN</th>
                        </tr>
                    </thead>
                    <tbody class="fw-bold" style="font-size: 0.85rem;">
                        @foreach (var g in Gastos)
                        {
                            <tr class="@(EditingGastoId == g.Id ? "table-warning" : "")">
                                <td>@g.Fecha.ToString("dd/MM/yyyy")</td>
                                <td><span class="badge bg-secondary rounded-0">@g.Categoria</span></td>
                                <td>@g.Descripcion</td>
                                <td class="text-end font-monospace text-danger">-$@Math.Abs(g.Monto).ToString("N0")</td>
                                <td class="text-center">
                                    <div class="d-flex gap-1 justify-content-center">
                                        <button class="btn btn-sm btn-outline-warning rounded-0 fw-bold border-dark"
                                                title="Editar gasto"
                                                @onclick="() => IniciarEdicionGasto(g)">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger rounded-0 fw-bold"
                                                title="Desvincular gasto"
                                                @onclick="() => DesvincularGastoClick(g.Id)">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }

            @if (!hasGastoGeneral && !hasCajaGastos)
            {
                <div class="text-center text-muted p-4">No hay gastos registrados.</div>
            }
        </div>
    </div>

    @* Navigation buttons *@
    <div class="d-flex gap-3 justify-content-between">
        @* Placeholder for future batch actions *@
    </div>
</div>

@code {
    [Parameter] public List<TransferenciaDto> Transferencias { get; set; } = new();
    [Parameter] public List<CompraDto> Compras { get; set; } = new();
    [Parameter] public List<MovimientoCajaDto> Gastos { get; set; } = new();
    [Parameter] public int RendicionId { get; set; }
    [Parameter] public EventCallback OnItemUpdated { get; set; }
    [Parameter] public EventCallback OnAvanzar { get; set; }

    // ===== Transferencia (monto) edit state =====
    private int EditingTransferenciaId { get; set; }
    private decimal EditingMonto { get; set; }
    private string? ErrorEditando { get; set; }

    // ===== Compra edit state =====
    private int EditingCompraId { get; set; }
    private string EditCompraProveedor { get; set; } = string.Empty;
    private string EditCompraNumeroDocumento { get; set; } = string.Empty;
    private DateTime EditCompraFecha { get; set; } = DateTime.Today;
    private string EditCompraTipo { get; set; } = "MERCADERIA";
    private bool EditCompraGuardando { get; set; }
    private string? ErrorEditCompra { get; set; }

    // ===== Gasto edit state =====
    private int EditingGastoId { get; set; }
    private string EditGastoDescripcion { get; set; } = string.Empty;
    private decimal EditGastoMonto { get; set; }
    private string EditGastoCategoria { get; set; } = "GENERAL";
    private bool EditGastoGuardando { get; set; }
    private string? ErrorEditGasto { get; set; }

    private decimal GetTransferenciasTotal() => Transferencias.Sum(t => t.Monto);
    private decimal GetComprasTotal() => Compras.Where(c => c.TipoFactura == "MERCADERIA").Sum(c => c.MontoTotal);
    private decimal GetGastosTotal() => Gastos.Sum(g => Math.Abs(g.Monto));
    private decimal GetGastosTotalCombinado() =>
        Compras.Where(c => c.TipoFactura != "MERCADERIA").Sum(c => c.MontoTotal) + GetGastosTotal();

    private void IniciarEdicionMonto(TransferenciaDto t)
    {
        EditingTransferenciaId = t.Id;
        EditingMonto = t.Monto;
        ErrorEditando = null;
    }

    private async Task GuardarEdicionMonto()
    {
        if (EditingTransferenciaId <= 0) return;

        try
        {
            ErrorEditando = null;
            var response = await Http.PutAsJsonAsync(
                $"api/contabilidad/transferencia/{EditingTransferenciaId}/monto",
                new { monto = EditingMonto });

            if (response.IsSuccessStatusCode)
            {
                EditingTransferenciaId = 0;
                EditingMonto = 0;
                await OnItemUpdated.InvokeAsync();
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Conflict)
            {
                ErrorEditando = "Otro usuario modificó esta transferencia. Recargá la página.";
            }
            else
            {
                ErrorEditando = await response.Content.ReadAsStringAsync();
            }
        }
        catch (Exception ex)
        {
            ErrorEditando = $"Error: {ex.Message}";
        }
    }

    private void CancelarEdicion()
    {
        EditingTransferenciaId = 0;
        EditingMonto = 0;
        ErrorEditando = null;
    }

    // ===== Compra inline edit =====

    private void IniciarEdicionCompra(CompraDto c)
    {
        EditingCompraId = c.Id;
        EditCompraProveedor = c.Proveedor;
        EditCompraNumeroDocumento = c.NumeroDocumento ?? string.Empty;
        EditCompraFecha = c.FechaCompra;
        EditCompraTipo = c.TipoFactura;
        ErrorEditCompra = null;
        EditCompraGuardando = false;
    }

    private async Task GuardarEdicionCompra()
    {
        if (EditingCompraId <= 0) return;

        try
        {
            EditCompraGuardando = true;
            ErrorEditCompra = null;

            var request = new UpdateCompraRequest
            {
                Proveedor = EditCompraProveedor,
                NumeroDocumento = EditCompraNumeroDocumento,
                Fecha = EditCompraFecha,
                Tipo = EditCompraTipo
            };

            var response = await Http.PutAsJsonAsync($"api/contabilidad/compra/{EditingCompraId}", request);

            if (response.IsSuccessStatusCode)
            {
                var updated = await response.Content.ReadFromJsonAsync<CompraDto>();
                if (updated != null)
                {
                    var idx = Compras.FindIndex(c => c.Id == EditingCompraId);
                    if (idx >= 0)
                        Compras[idx] = updated;
                }

                EditingCompraId = 0;
                EditCompraGuardando = false;
                StateHasChanged();
                await OnItemUpdated.InvokeAsync();
            }
            else
            {
                ErrorEditCompra = await response.Content.ReadAsStringAsync();
                EditCompraGuardando = false;
            }
        }
        catch (Exception ex)
        {
            ErrorEditCompra = $"Error: {ex.Message}";
            EditCompraGuardando = false;
        }
    }

    private void CancelarEdicionCompra()
    {
        EditingCompraId = 0;
        EditCompraProveedor = string.Empty;
        EditCompraNumeroDocumento = string.Empty;
        EditCompraFecha = DateTime.Today;
        EditCompraTipo = "MERCADERIA";
        ErrorEditCompra = null;
        EditCompraGuardando = false;
    }

    // ===== Gasto inline edit =====

    private void IniciarEdicionGasto(MovimientoCajaDto g)
    {
        EditingGastoId = g.Id;
        EditGastoDescripcion = g.Descripcion;
        EditGastoMonto = Math.Abs(g.Monto);
        EditGastoCategoria = g.Categoria;
        ErrorEditGasto = null;
        EditGastoGuardando = false;
    }

    private async Task GuardarEdicionGasto()
    {
        if (EditingGastoId <= 0) return;

        try
        {
            EditGastoGuardando = true;
            ErrorEditGasto = null;

            var request = new UpdateGastoRequest
            {
                Descripcion = EditGastoDescripcion,
                Monto = EditGastoMonto,
                Categoria = EditGastoCategoria
            };

            var response = await Http.PutAsJsonAsync($"api/contabilidad/gasto/{EditingGastoId}", request);

            if (response.IsSuccessStatusCode)
            {
                var updated = await response.Content.ReadFromJsonAsync<MovimientoCajaDto>();
                if (updated != null)
                {
                    var idx = Gastos.FindIndex(g => g.Id == EditingGastoId);
                    if (idx >= 0)
                        Gastos[idx] = updated;
                }

                EditingGastoId = 0;
                EditGastoGuardando = false;
                StateHasChanged();
                await OnItemUpdated.InvokeAsync();
            }
            else
            {
                ErrorEditGasto = await response.Content.ReadAsStringAsync();
                EditGastoGuardando = false;
            }
        }
        catch (Exception ex)
        {
            ErrorEditGasto = $"Error: {ex.Message}";
            EditGastoGuardando = false;
        }
    }

    private void CancelarEdicionGasto()
    {
        EditingGastoId = 0;
        EditGastoDescripcion = string.Empty;
        EditGastoMonto = 0;
        EditGastoCategoria = "GENERAL";
        ErrorEditGasto = null;
        EditGastoGuardando = false;
    }

    private async Task DesvincularTransferenciaClick(int transferenciaId)
    {
        try
        {
            var response = await Http.PostAsync(
                $"api/contabilidad/transferencia/{transferenciaId}/desvincular", null);

            if (response.IsSuccessStatusCode)
            {
                Transferencias.RemoveAll(t => t.Id == transferenciaId);
                StateHasChanged();
                await OnItemUpdated.InvokeAsync();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                await JS.InvokeVoidAsync("alert", $"Error al desvincular: {error}");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Error al desvincular: {ex.Message}");
        }
    }

