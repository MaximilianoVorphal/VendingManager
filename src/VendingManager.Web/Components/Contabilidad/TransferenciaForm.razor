@using VendingManager.Shared.DTOs
@using Microsoft.AspNetCore.Components.Forms
@inject HttpClient Http
@inject IJSRuntime JS

<div class="p-3">
    @if (!string.IsNullOrEmpty(Error))
    {
        <div class="alert alert-danger border-dark rounded-0 fw-bold py-2 mb-3">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @Error
        </div>
    }

    <div class="row g-3">
        <div class="col-12">
            <label class="fw-bold small text-uppercase mb-1 text-muted">TRABAJADOR (opcional)</label>
            <input type="text" class="form-control border-dark rounded-0 fw-bold" @bind="_trabajadorLocal" placeholder="Ej: Juan Pérez" />
        </div>
        <div class="col-12">
            <label class="fw-bold small text-uppercase mb-1 text-muted">MONTO *</label>
            <div class="input-group">
                <span class="input-group-text bg-dark text-white border-dark rounded-0 fw-bold">$</span>
                <input type="text" inputmode="numeric" class="form-control border-dark rounded-0 fw-bold font-monospace text-end fs-5"
                       @oninput="OnMontoChanged"
                       placeholder="0" value="@_montoDisplay" />
            </div>
        </div>
        <div class="col-12">
            <label class="fw-bold small text-uppercase mb-1 text-muted">DESCRIPCIÓN</label>
            <textarea class="form-control border-dark rounded-0 fw-bold" rows="2"
                      @bind="Form.Descripcion" placeholder="Ej: Efectivo para recarga máquina #3"></textarea>
        </div>
        <div class="col-md-6">
            <label class="fw-bold small text-uppercase mb-1 text-muted">FECHA *</label>
            <input type="date" class="form-control border-dark rounded-0 fw-bold"
                   @bind="Form.Fecha" />
        </div>
        <div class="col-12">
            <label class="fw-bold small text-uppercase mb-1 text-muted">COMPROBANTE (opcional)</label>
            @if (_pendingFile != null)
            {
                <div class="d-flex align-items-center gap-2 p-2 border border-dark rounded-0 bg-white mb-1">
                    <i class="bi bi-paperclip text-success"></i>
                    <span class="small fw-bold text-truncate flex-grow-1">@_pendingFile.Name</span>
                    <button type="button" class="btn btn-sm btn-outline-danger rounded-0 p-1 lh-1 border-0"
                            @onclick="() => _pendingFile = null" title="Quitar archivo">
                        <i class="bi bi-x-lg" style="font-size: 0.75rem;"></i>
                    </button>
                </div>
            }
            <InputFile OnChange="OnFileSelected"
                       accept=".jpg,.jpeg,.png,.pdf"
                       class="form-control form-control-sm border-dark rounded-0" />
            <small class="text-muted">JPG, PNG o PDF — máx. 5MB</small>
        </div>
        <div class="col-12 mt-3">
            <button class="btn btn-dark rounded-0 fw-bold w-100 py-2"
                    @onclick="RegistrarTransferencia"
                    disabled="@(Enviando || Form.Monto <= 0)">
                @if (Enviando)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                    @(_uploadingComprobante ? "Subiendo comprobante..." : "Registrando...")
                }
                else
                {
                    <i class="bi bi-check-lg me-2"></i>
                    @("REGISTRAR TRANSFERENCIA")
                }
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter] public string Trabajador { get; set; } = string.Empty;
    [Parameter] public int RendicionId { get; set; }
    [Parameter] public int? PeriodoId { get; set; }
    [Parameter] public EventCallback<TransferenciaDto> OnTransferenciaCreated { get; set; }

    private TransferenciaFormData Form { get; set; } = new() { Fecha = DateTime.Today };
    private bool Enviando { get; set; }
    private bool _uploadingComprobante;
    private string? Error { get; set; }
    private string _trabajadorLocal = string.Empty;
    private string _montoDisplay = string.Empty;
    private IBrowserFile? _pendingFile;

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrEmpty(Trabajador) && string.IsNullOrEmpty(_trabajadorLocal))
            _trabajadorLocal = Trabajador;
    }

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        _pendingFile = e.File;
    }

    private void OnMontoChanged(ChangeEventArgs e)
    {
        var raw = e.Value?.ToString() ?? "";
        var digits = new string(raw.Where(char.IsDigit).ToArray());

        if (string.IsNullOrEmpty(digits))
        {
            Form.Monto = 0;
            _montoDisplay = string.Empty;
            return;
        }

        if (long.TryParse(digits, out var value))
        {
            Form.Monto = value;
            _montoDisplay = value.ToString("N0", new System.Globalization.CultureInfo("es-AR"));
        }
    }

    private async Task RegistrarTransferencia()
    {
        if (Form.Monto <= 0)
        {
            Error = "El monto debe ser mayor a cero.";
            return;
        }

        try
        {
            Enviando = true;
            Error = null;

            var request = new TransferenciaConMovimientoRequest
            {
                RendicionId = RendicionId,
                PeriodoId = PeriodoId,
                Trabajador = _trabajadorLocal,
                Fecha = Form.Fecha,
                Monto = Form.Monto,
                Descripcion = Form.Descripcion
            };

            var response = await Http.PostAsJsonAsync("api/contabilidad/transferencia-con-movimiento", request);

            if (!response.IsSuccessStatusCode)
            {
                Error = await response.Content.ReadAsStringAsync();
                return;
            }

            var body = await response.Content.ReadAsStringAsync();
            var dto = System.Text.Json.JsonSerializer.Deserialize<TransferenciaDto>(body,
                new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });

            if (dto == null)
            {
                Error = "Error al procesar la respuesta del servidor.";
                return;
            }

            if (_pendingFile != null)
            {
                _uploadingComprobante = true;
                await UploadComprobante(dto.Id);
                _uploadingComprobante = false;
            }

            Form = new() { Fecha = DateTime.Today };
            _montoDisplay = string.Empty;
            _pendingFile = null;
            await OnTransferenciaCreated.InvokeAsync(dto);
        }
        catch (Exception ex)
        {
            Error = $"Error: {ex.Message}";
        }
        finally
        {
            Enviando = false;
            _uploadingComprobante = false;
        }
    }

    private async Task UploadComprobante(int transferenciaId)
    {
        if (_pendingFile == null) return;
        try
        {
            using var content = new MultipartFormDataContent();
            var stream = _pendingFile.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            content.Add(new StreamContent(stream), "file", _pendingFile.Name);
            var uploadResponse = await Http.PostAsync(
                $"api/contabilidad/transferencia/{transferenciaId}/comprobante", content);
            if (!uploadResponse.IsSuccessStatusCode)
            {
                var uploadError = await uploadResponse.Content.ReadAsStringAsync();
                Error = $"Transferencia registrada, pero el comprobante no se pudo subir: {uploadError}";
            }
        }
        catch (Exception ex)
        {
            Error = $"Transferencia registrada, pero error al subir comprobante: {ex.Message}";
        }
    }

    private class TransferenciaFormData
    {
        public DateTime Fecha { get; set; } = DateTime.Today;
        public decimal Monto { get; set; }
        public string? Descripcion { get; set; }
    }
}
