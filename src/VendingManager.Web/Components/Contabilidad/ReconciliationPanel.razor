@using VendingManager.Web.Pages.Contabilidad.State
@using VendingManager.Shared.DTOs
@using VendingManager.Shared.Enums

<div class="card border-2 border-dark rounded-0 shadow mb-3">
    <div class="card-body bg-light p-0">
        @if (RendicionActiva != null)
        {
            <div class="d-flex flex-wrap align-items-stretch">

                @* Rendicion info *@
                <div class="p-3 border-end border-dark d-flex flex-column justify-content-center" style="min-width: 180px;">
                    <div class="fw-bold text-uppercase small">@RendicionActiva.Trabajador</div>
                    <div class="small fw-bold font-monospace text-muted mt-1">
                        @RendicionActiva.FechaInicio.ToString("dd/MM/yyyy")
                    </div>
                    <div class="mt-1">
                        <span class="badge @(RendicionActiva.Estado == RendicionEstado.Abierta ? "bg-success" : "bg-secondary") rounded-0">
                            @(RendicionActiva.Estado == RendicionEstado.Abierta ? "ABIERTA" : "CERRADA")
                        </span>
                    </div>
                </div>

                @* Transferido *@
                <div class="flex-fill p-3 border-end border-dark text-center d-flex flex-column justify-content-center" style="min-width: 110px;">
                    <small class="text-muted fw-bold text-uppercase" style="font-size: 0.65rem;">TRANSFERIDO</small>
                    <span class="text-success fw-bold font-monospace fs-6 mt-1">+$@TotalTransferido.ToString("N0")</span>
                </div>

                @* Compras *@
                <div class="flex-fill p-3 border-end border-dark text-center d-flex flex-column justify-content-center" style="min-width: 110px;">
                    <small class="text-muted fw-bold text-uppercase" style="font-size: 0.65rem;">COMPRAS</small>
                    <span class="text-danger fw-bold font-monospace fs-6 mt-1">-$@TotalCompras.ToString("N0")</span>
                </div>

                @* Gastos *@
                <div class="flex-fill p-3 border-end border-dark text-center d-flex flex-column justify-content-center" style="min-width: 110px;">
                    <small class="text-muted fw-bold text-uppercase" style="font-size: 0.65rem;">GASTOS</small>
                    <span class="text-danger fw-bold font-monospace fs-6 mt-1">-$@TotalGastos.ToString("N0")</span>
                </div>

                @* Devuelto (only if any) *@
                @if (Devuelto > 0)
                {
                    <div class="flex-fill p-3 border-end border-dark text-center d-flex flex-column justify-content-center" style="min-width: 110px;">
                        <small class="text-muted fw-bold text-uppercase" style="font-size: 0.65rem;">DEVUELTO</small>
                        <span class="text-info fw-bold font-monospace fs-6 mt-1">-$@Devuelto.ToString("N0")</span>
                    </div>
                }

                @* Diferencia + status badge *@
                <div class="@DiferenciaClass p-3 border-end border-dark text-center d-flex flex-column justify-content-center" style="min-width: 150px;">
                    <small class="text-uppercase fw-bold" style="font-size: 0.65rem;">DIFERENCIA</small>
                    <span class="fw-bold font-monospace fs-5">$@Diferencia.ToString("N0")</span>
                    <div class="mt-1">
                        @if (Diferencia == 0)
                        {
                            <span class="badge bg-white text-dark rounded-0 fw-bold"><i class="bi bi-check-circle-fill me-1"></i>CUADRADO</span>
                        }
                        else if (Diferencia > 0)
                        {
                            <span class="badge bg-dark text-white rounded-0 fw-bold">POSITIVA</span>
                        }
                        else
                        {
                            <span class="badge bg-dark text-white rounded-0 fw-bold">NEGATIVA</span>
                        }
                    </div>
                </div>

                @* Cerrar rendición *@
                @if (MostrarCerrar)
                {
                    <div class="p-3 d-flex flex-column justify-content-center" style="min-width: 200px;">
                        <button class="btn btn-warning rounded-0 fw-bold py-2"
                                @onclick="() => OnCerrar.InvokeAsync()"
                                disabled="@(Cerrando || !CanCuadrar)"
                                title="@(CanCuadrar ? "Cerrar rendición" : "Verificá todos los comprobantes y devolvé el saldo antes de cerrar")">
                            @if (Cerrando)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                            }
                            else
                            {
                                <i class="bi bi-lock-fill me-2"></i>
                            }
                            CERRAR
                        </button>
                        @if (!CanCuadrar)
                        {
                            <div class="small text-muted fw-bold text-center mt-2" style="font-size: 0.65rem;">
                                @if (SaldoADevolver > 0)
                                {
                                    <span><i class="bi bi-exclamation-triangle-fill me-1 text-warning"></i>Saldo pendiente a devolver</span>
                                }
                                else
                                {
                                    <span><i class="bi bi-exclamation-triangle-fill me-1 text-warning"></i>Comprobantes sin verificar</span>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center text-muted p-3">
                <i class="bi bi-inbox me-2"></i>
                <span class="fw-bold small">Seleccioná una transferencia para ver el resumen.</span>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public ContabilidadPageState? State { get; set; }
    [Parameter] public EventCallback OnCerrar { get; set; }

    private RendicionDto? RendicionActiva => State?.RendicionActiva;
    private decimal TotalTransferido => State?.TotalTransferido ?? 0;
    private decimal TotalCompras => State?.TotalCompras ?? 0;
    private decimal TotalGastos => State?.TotalGastos ?? 0;
    private decimal Diferencia => State?.Diferencia ?? 0;
    private decimal Devuelto => State?.Devuelto ?? 0;
    private decimal SaldoADevolver => State?.SaldoADevolver ?? 0;
    private bool CanCuadrar => State?.CanCuadrar ?? false;

    private bool MostrarCerrar => RendicionActiva?.Estado == RendicionEstado.Abierta;
    private bool Cerrando { get; set; }

    private string DiferenciaClass
    {
        get
        {
            if (Diferencia == 0) return "bg-success text-white";
            if (Diferencia > 0) return "bg-warning text-dark";
            return "bg-danger text-white";
        }
    }
}
