@using VendingManager.Shared.DTOs
@using VendingManager.Shared.Enums
@inject HttpClient Http

<div class="p-3">
    @if (!string.IsNullOrEmpty(Error))
    {
        <div class="alert alert-danger border-dark rounded-0 fw-bold py-2 mb-3">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @Error
        </div>
    }

    <div class="row g-3">
        @* Proveedor y Numero Documento *@
        <div class="col-md-6">
            <label class="fw-bold small text-uppercase mb-1 text-muted">PROVEEDOR *</label>
            <input type="text" class="form-control border-dark rounded-0 fw-bold"
                   @bind="Form.Proveedor" placeholder="Nombre del proveedor..." />
        </div>
        <div class="col-md-3">
            <label class="fw-bold small text-uppercase mb-1 text-muted">Nº DOCUMENTO</label>
            <input type="text" class="form-control border-dark rounded-0 fw-bold font-monospace"
                   @bind="Form.NumeroDocumento" placeholder="F-123456" />
        </div>
        <div class="col-md-3">
            <label class="fw-bold small text-uppercase mb-1 text-muted">FECHA</label>
            <input type="date" class="form-control border-dark rounded-0 fw-bold"
                   @bind="Form.Fecha" />
        </div>

        @* Tipo Factura *@
        <div class="col-md-6">
            <label class="fw-bold small text-uppercase mb-1 text-muted">TIPO DOCUMENTO</label>
            <select class="form-select border-dark rounded-0 fw-bold" @bind="Form.TipoFactura">
                <option value="MERCADERIA">🛒 MERCADERÍA</option>
                <option value="GASTO_GENERAL">⛽ GASTO GENERAL</option>
            </select>
        </div>
        <div class="col-md-6 d-flex align-items-end">
            <div class="form-check form-switch w-100">
                <input class="form-check-input border-dark" type="checkbox" id="pagadaCaja" @bind="Form.PagadaCaja" />
                <label class="form-check-label fw-bold small" for="pagadaCaja">PAGADA EN EFECTIVO DE LA TRANSFERENCIA</label>
            </div>
        </div>

        @* Transferencia selector *@
        <div class="col-12">
            <label class="fw-bold small text-uppercase mb-1 text-muted">TRANSFERENCIA A UTILIZAR *</label>
            <select class="form-select border-dark rounded-0 fw-bold" @bind="Form.TransferenciaId">
                <option value="0">-- SELECCIONAR TRANSFERENCIA --</option>
                @foreach (var t in Transferencias.Where(t => t.Estado != TransferenciaEstado.Conciliado))
                {
                    <option value="@t.Id">
                        @t.Fecha.ToString("dd/MM") - $@t.Monto.ToString("N0")
                        @(t.Estado == TransferenciaEstado.EnUso ? " [EN USO]" : " [PENDIENTE]")
                    </option>
                }
            </select>
        </div>
    </div>

    @* Product Search / Detail Table for MERCADERIA *@
    @if (Form.TipoFactura == "MERCADERIA")
    {
        <hr class="border-dark mt-4" />
        <div class="bg-white border border-dark p-3 mb-3">
            <div class="row g-2 align-items-end">
                <div class="col-md-6">
                    <label class="fw-bold small text-uppercase mb-1 text-muted">BUSCAR PRODUCTO</label>
                    <select class="form-select border-dark rounded-0" @bind="ProductoSeleccionadoId">
                        <option value="0">-- SELECCIONE PRODUCTO --</option>
                        @foreach (var p in Productos)
                        {
                            <option value="@p.Id">@p.Nombre (Stock: @p.StockBodega | CPP: $@p.CostoPromedio.ToString("N0"))</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="fw-bold small text-uppercase mb-1 text-muted">CANTIDAD</label>
                    <input type="number" class="form-control border-dark rounded-0 fw-bold text-center"
                           @bind="CantidadAgregar" @bind:event="oninput" min="1" />
                </div>
                <div class="col-md-3">
                    <label class="fw-bold small text-uppercase mb-1 text-muted">COSTO UNITARIO</label>
                    <div class="input-group">
                        <span class="input-group-text bg-dark text-white border-dark rounded-0">$</span>
                        <input type="number" class="form-control border-dark rounded-0 font-monospace text-end"
                               @bind="CostoUnitarioAgregar" min="0" />
                    </div>
                </div>
                <div class="col-md-1 d-grid">
                    <button class="btn btn-outline-dark rounded-0 fw-bold"
                            @onclick="AgregarDetalle"
                            disabled="@(ProductoSeleccionadoId == 0)">
                        <i class="bi bi-plus-lg"></i>
                    </button>
                </div>
            </div>
        </div>

        @* Detail Table *@
        @if (Form.Detalles.Any())
        {
            <div class="table-responsive">
                <table class="table table-bordered border-dark table-hover align-middle mb-0">
                    <thead class="bg-secondary text-white text-uppercase small fw-bold text-center">
                        <tr>
                            <th class="text-start">PRODUCTO</th>
                            <th style="width: 80px;">CANT</th>
                            <th style="width: 130px;">COSTO UNIT.</th>
                            <th style="width: 130px;">SUBTOTAL</th>
                            <th style="width: 50px;"></th>
                        </tr>
                    </thead>
                    <tbody class="fw-bold" style="font-size: 0.85rem;">
                        @foreach (var d in Form.Detalles)
                        {
                            <tr>
                                <td>@d.ProductoNombre</td>
                                <td class="text-center font-monospace">@d.Cantidad</td>
                                <td class="text-end font-monospace">$@d.CostoUnitario.ToString("N0")</td>
                                <td class="text-end text-success font-monospace">$@((d.Cantidad * d.CostoUnitario).ToString("N0"))</td>
                                <td class="text-center">
                                    <button class="btn btn-sm btn-outline-danger border-dark rounded-0"
                                            @onclick="() => EliminarDetalle(d)">
                                        <i class="bi bi-trash-fill"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="bg-light">
                        <tr>
                            <td colspan="3" class="text-end fw-bold text-uppercase">TOTAL:</td>
                            <td class="text-end fw-bold font-monospace text-success fs-5">$@Total.ToString("N0")</td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        }
    }
    else
    {
        @* Simple expense mode *@
        <hr class="border-dark mt-4" />
        <div class="row g-3">
            <div class="col-md-8">
                <label class="fw-bold small text-uppercase mb-1 text-muted">DESCRIPCIÓN DEL GASTO</label>
                <input type="text" class="form-control border-dark rounded-0 fw-bold"
                       @bind="Form.DescripcionGasto" placeholder="Ej: Bencina Camioneta" />
            </div>
            <div class="col-md-4">
                <label class="fw-bold small text-uppercase mb-1 text-muted">MONTO $</label>
                <div class="input-group">
                    <span class="input-group-text bg-dark text-white border-dark rounded-0">$</span>
                    <input type="number" class="form-control border-dark rounded-0 font-monospace text-end fs-5"
                           @bind="GastoMonto" min="0" />
                </div>
            </div>
        </div>
    }

    @* Submit button *@
    <div class="mt-4">
        <button class="btn btn-dark rounded-0 fw-bold w-100 py-2"
                @onclick="RegistrarCompra"
                disabled="@(Enviando || !PuedeRegistrar)">
            @if (Enviando)
            {
                <span class="spinner-border spinner-border-sm me-2"></span>
            }
            else
            {
                <i class="bi bi-check-lg me-2"></i>
            }
            REGISTRAR COMPRA
        </button>
    </div>
</div>

@code {
    [Parameter] public string Trabajador { get; set; } = string.Empty;
    [Parameter] public int RendicionId { get; set; }
    [Parameter] public List<TransferenciaDto> Transferencias { get; set; } = new();
    [Parameter] public EventCallback<CompraDto> OnCompraCreated { get; set; }

    private CompraFormData Form { get; set; } = new() { Fecha = DateTime.Today, TipoFactura = "MERCADERIA", PagadaCaja = true };
    private List<ProductoSimpleDto> Productos { get; set; } = new();
    private int ProductoSeleccionadoId { get; set; }
    private int CantidadAgregar { get; set; } = 1;
    private decimal CostoUnitarioAgregar { get; set; }
    private decimal GastoMonto { get; set; }
    private bool Enviando { get; set; }
    private string? Error { get; set; }

    private decimal Total => Form.TipoFactura == "MERCADERIA"
        ? Form.Detalles.Sum(d => d.Cantidad * d.CostoUnitario)
        : GastoMonto;

    private bool PuedeRegistrar
    {
        get
        {
            if (Form.TipoFactura == "MERCADERIA")
                return Form.Proveedor.Length > 0 && Form.Detalles.Count > 0 && Form.TransferenciaId > 0;
            return !string.IsNullOrWhiteSpace(Form.DescripcionGasto) && GastoMonto > 0 && Form.TransferenciaId > 0;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await CargarProductos();
    }

    private async Task CargarProductos()
    {
        try
        {
            Productos = await Http.GetFromJsonAsync<List<ProductoSimpleDto>>("api/productos/simple") ?? new();
            // Auto-prefill first product's CPP if available
            if (Productos.Any())
            {
                CostoUnitarioAgregar = Productos.First().CostoPromedio;
            }
        }
        catch
        {
            // Products might not be available
        }
    }

    private void AgregarDetalle()
    {
        var producto = Productos.FirstOrDefault(p => p.Id == ProductoSeleccionadoId);
        if (producto == null) return;

        // Pre-fill from product's CPP if not set
        if (CostoUnitarioAgregar == 0)
            CostoUnitarioAgregar = producto.CostoPromedio;

        Form.Detalles.Add(new DetalleItem
        {
            ProductoId = producto.Id,
            ProductoNombre = producto.Nombre,
            Cantidad = CantidadAgregar,
            CostoUnitario = CostoUnitarioAgregar
        });

        ProductoSeleccionadoId = 0;
        CantidadAgregar = 1;
        // Keep last CostoUnitario for convenience
    }

    private void EliminarDetalle(DetalleItem d)
    {
        Form.Detalles.Remove(d);
    }

    private async Task RegistrarCompra()
    {
        if (!PuedeRegistrar)
        {
            Error = "Completá todos los campos requeridos.";
            return;
        }

        try
        {
            Enviando = true;
            Error = null;

            if (Form.TipoFactura == "MERCADERIA")
            {
                var request = new CompraVinculadaRequest
                {
                    TransferenciaId = Form.TransferenciaId,
                    RendicionId = RendicionId,
                    Trabajador = Trabajador,
                    FechaCompra = Form.Fecha,
                    Proveedor = Form.Proveedor,
                    NumeroDocumento = Form.NumeroDocumento,
                    TipoFactura = Form.TipoFactura,
                    PagadaCaja = Form.PagadaCaja,
                    Detalles = Form.Detalles.Select(d => new RegistrarDetalleCompraRequestDto
                    {
                        ProductoId = d.ProductoId,
                        DescripcionItem = d.ProductoNombre,
                        Cantidad = d.Cantidad,
                        CostoUnitario = d.CostoUnitario
                    }).ToList()
                };

                var response = await Http.PostAsJsonAsync("api/contabilidad/compra-vinculada", request);
                if (response.IsSuccessStatusCode)
                {
                    var dto = await response.Content.ReadFromJsonAsync<CompraDto>();
                    if (dto != null)
                    {
                        ResetForm();
                        await OnCompraCreated.InvokeAsync(dto);
                    }
                }
                else
                {
                    Error = await response.Content.ReadAsStringAsync();
                }
            }
            else
            {
                // GASTO_GENERAL: create a compra with a single item
                var request = new CompraVinculadaRequest
                {
                    TransferenciaId = Form.TransferenciaId,
                    RendicionId = RendicionId,
                    Trabajador = Trabajador,
                    FechaCompra = Form.Fecha,
                    Proveedor = Form.Proveedor,
                    NumeroDocumento = Form.NumeroDocumento,
                    TipoFactura = "GASTO_GENERAL",
                    PagadaCaja = Form.PagadaCaja,
                    Detalles = new List<RegistrarDetalleCompraRequestDto>
                    {
                        new() { DescripcionItem = Form.DescripcionGasto, Cantidad = 1, CostoUnitario = GastoMonto }
                    }
                };

                var response = await Http.PostAsJsonAsync("api/contabilidad/compra-vinculada", request);
                if (response.IsSuccessStatusCode)
                {
                    var dto = await response.Content.ReadFromJsonAsync<CompraDto>();
                    if (dto != null)
                    {
                        ResetForm();
                        await OnCompraCreated.InvokeAsync(dto);
                    }
                }
                else
                {
                    Error = await response.Content.ReadAsStringAsync();
                }
            }
        }
        catch (Exception ex)
        {
            Error = $"Error: {ex.Message}";
        }
        finally
        {
            Enviando = false;
        }
    }

    private void ResetForm()
    {
        Form = new() { Fecha = DateTime.Today, TipoFactura = "MERCADERIA", PagadaCaja = true };
        GastoMonto = 0;
        Error = null;
    }

    private class CompraFormData
    {
        public DateTime Fecha { get; set; } = DateTime.Today;
        public string Proveedor { get; set; } = string.Empty;
        public string? NumeroDocumento { get; set; }
        public string TipoFactura { get; set; } = "MERCADERIA";
        public bool PagadaCaja { get; set; } = true;
        public int TransferenciaId { get; set; }
        public List<DetalleItem> Detalles { get; set; } = new();
        public string? DescripcionGasto { get; set; }
    }

    private class DetalleItem
    {
        public int? ProductoId { get; set; }
        public string ProductoNombre { get; set; } = string.Empty;
        public int Cantidad { get; set; }
        public decimal CostoUnitario { get; set; }
    }
}