@using VendingManager.Shared.DTOs
@using VendingManager.Shared.Enums
@inject HttpClient Http
@inject IJSRuntime JS

<div class="p-3">
    @if (!string.IsNullOrEmpty(Error))
    {
        <div class="alert alert-danger border-dark rounded-0 fw-bold py-2 mb-3">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @Error
        </div>
    }

    @* Toggle: Crear nueva vs Vincular existente *@
    <div class="btn-group w-100 mb-3" role="group">
        <button class="btn btn-@(!VincularExistente ? "dark" : "outline-dark") rounded-0 fw-bold"
                @onclick="() => { VincularExistente = false; Error = null; }">
            <i class="bi bi-plus-lg me-1"></i>CREAR NUEVA
        </button>
        <button class="btn btn-@(VincularExistente ? "dark" : "outline-dark") rounded-0 fw-bold"
                @onclick="() => { VincularExistente = true; Error = null; }">
            <i class="bi bi-link me-1"></i>VINCULAR EXISTENTE
        </button>
    </div>

    @if (!VincularExistente)
    {
        <div class="row g-3">
            @* Proveedor y Numero Documento *@
            <div class="col-md-6">
                <label class="fw-bold small text-uppercase mb-1 text-muted">PROVEEDOR *</label>
                <input type="text" class="form-control border-dark rounded-0 fw-bold"
                       @bind="Form.Proveedor" placeholder="Nombre del proveedor..." />
            </div>
            <div class="col-md-3">
                <label class="fw-bold small text-uppercase mb-1 text-muted">Nº DOCUMENTO</label>
                <input type="text" class="form-control border-dark rounded-0 fw-bold font-monospace"
                       @bind="Form.NumeroDocumento" placeholder="F-123456" />
            </div>
            <div class="col-md-3">
                <label class="fw-bold small text-uppercase mb-1 text-muted">FECHA</label>
                <input type="date" class="form-control border-dark rounded-0 fw-bold"
                       @bind="Form.Fecha" />
            </div>

            @* Tipo Factura *@
            <div class="col-md-6">
                <label class="fw-bold small text-uppercase mb-1 text-muted">TIPO DOCUMENTO</label>
                <select class="form-select border-dark rounded-0 fw-bold" @bind="Form.TipoFactura">
                    <option value="MERCADERIA">🛒 MERCADERÍA</option>
                    <option value="GASTO_GENERAL">⛽ GASTO GENERAL</option>
                </select>
            </div>
            <div class="col-md-6 d-flex align-items-end">
                <div class="form-check form-switch w-100">
                    <input class="form-check-input border-dark" type="checkbox" id="pagadaCaja" @bind="Form.PagadaCaja" />
                    <label class="form-check-label fw-bold small" for="pagadaCaja">PAGADA EN EFECTIVO DE LA TRANSFERENCIA</label>
                </div>
            </div>

            @* Transferencia selector *@
            <div class="col-12">
                <label class="fw-bold small text-uppercase mb-1 text-muted">TRANSFERENCIA A UTILIZAR *</label>
                <select class="form-select border-dark rounded-0 fw-bold" @bind="Form.TransferenciaId">
                    <option value="0">-- SELECCIONAR TRANSFERENCIA --</option>
                    @foreach (var t in Transferencias.Where(t => t.Estado != TransferenciaEstado.Conciliado))
                    {
                        <option value="@t.Id">
                            @t.Fecha.ToString("dd/MM") - $@t.Monto.ToString("N0")
                            @(t.Estado == TransferenciaEstado.EnUso ? " [EN USO]" : " [PENDIENTE]")
                        </option>
                    }
                </select>
            </div>
        </div>

        @* Product Search / Detail Table for MERCADERIA *@
        @if (Form.TipoFactura == "MERCADERIA")
        {
            <hr class="border-dark mt-4" />
            <div class="bg-white border border-dark p-3 mb-3">
                <div class="row g-2 align-items-end">
                    <div class="col-md-6">
                        <label class="fw-bold small text-uppercase mb-1 text-muted">BUSCAR PRODUCTO</label>
                        <select class="form-select border-dark rounded-0" @bind="ProductoSeleccionadoId">
                            <option value="0">-- SELECCIONE PRODUCTO --</option>
                            @foreach (var p in Productos)
                            {
                                <option value="@p.Id">@p.Nombre (Stock: @p.StockBodega | CPP: $@p.CostoPromedio.ToString("N0"))</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="fw-bold small text-uppercase mb-1 text-muted">CANTIDAD</label>
                        <input type="number" class="form-control border-dark rounded-0 fw-bold text-center"
                               @bind="CantidadAgregar" @bind:event="oninput" min="1" />
                    </div>
                    <div class="col-md-3">
                        <label class="fw-bold small text-uppercase mb-1 text-muted">COSTO UNITARIO</label>
                        <div class="input-group">
                            <span class="input-group-text bg-dark text-white border-dark rounded-0">$</span>
                            <input type="number" class="form-control border-dark rounded-0 font-monospace text-end"
                                   @bind="CostoUnitarioAgregar" min="0" />
                        </div>
                    </div>
                    <div class="col-md-1 d-grid">
                        <button class="btn btn-outline-dark rounded-0 fw-bold"
                                @onclick="AgregarDetalle"
                                disabled="@(ProductoSeleccionadoId == 0)">
                            <i class="bi bi-plus-lg"></i>
                        </button>
                    </div>
                </div>
            </div>

            @* Detail Table *@
            @if (Form.Detalles.Any())
            {
                <div class="table-responsive">
                    <table class="table table-bordered border-dark table-hover align-middle mb-0">
                        <thead class="bg-secondary text-white text-uppercase small fw-bold text-center">
                            <tr>
                                <th class="text-start">PRODUCTO</th>
                                <th style="width: 80px;">CANT</th>
                                <th style="width: 130px;">COSTO UNIT.</th>
                                <th style="width: 130px;">SUBTOTAL</th>
                                <th style="width: 50px;"></th>
                            </tr>
                        </thead>
                        <tbody class="fw-bold" style="font-size: 0.85rem;">
                            @foreach (var d in Form.Detalles)
                            {
                                <tr>
                                    <td>@d.ProductoNombre</td>
                                    <td class="text-center font-monospace">@d.Cantidad</td>
                                    <td class="text-end font-monospace">$@d.CostoUnitario.ToString("N0")</td>
                                    <td class="text-end text-success font-monospace">$@((d.Cantidad * d.CostoUnitario).ToString("N0"))</td>
                                    <td class="text-center">
                                        <button class="btn btn-sm btn-outline-danger border-dark rounded-0"
                                                @onclick="() => EliminarDetalle(d)">
                                            <i class="bi bi-trash-fill"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="bg-light">
                            <tr>
                                <td colspan="3" class="text-end fw-bold text-uppercase">TOTAL:</td>
                                <td class="text-end fw-bold font-monospace text-success fs-5">$@Total.ToString("N0")</td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            }
        }
        else
        {
            @* Simple expense mode *@
            <hr class="border-dark mt-4" />
            <div class="row g-3">
                <div class="col-md-8">
                    <label class="fw-bold small text-uppercase mb-1 text-muted">DESCRIPCIÓN DEL GASTO</label>
                    <input type="text" class="form-control border-dark rounded-0 fw-bold"
                           @bind="Form.DescripcionGasto" placeholder="Ej: Bencina Camioneta" />
                </div>
                <div class="col-md-4">
                    <label class="fw-bold small text-uppercase mb-1 text-muted">MONTO $</label>
                    <div class="input-group">
                        <span class="input-group-text bg-dark text-white border-dark rounded-0">$</span>
                        <input type="number" class="form-control border-dark rounded-0 font-monospace text-end fs-5"
                               @bind="GastoMonto" min="0" />
                    </div>
                </div>
            </div>
        }

        @* Invoice upload section *@
        <div class="mt-4 p-3 border border-dark rounded-0 bg-light">
            <label class="fw-bold small text-uppercase mb-1 text-muted">📎 FACTURA (OPCIONAL)</label>
            <div class="d-flex gap-2 align-items-center flex-wrap">
                <label class="btn btn-outline-dark rounded-0 fw-bold mb-0" style="cursor:pointer;">
                    <i class="bi bi-paperclip me-1"></i>
                    @if (string.IsNullOrEmpty(FacturaFileName))
                    {
                        <span>SELECCIONAR ARCHIVO</span>
                    }
                    else
                    {
                        <span>CAMBIAR ARCHIVO</span>
                    }
                    <InputFile OnChange="HandleFileSelected" accept=".jpg,.jpeg,.png,.pdf" style="display: none;" />
                </label>
                @if (!string.IsNullOrEmpty(FacturaFileName))
                {
                    <span class="fw-bold small text-muted"><i class="bi bi-file-earmark me-1"></i>@FacturaFileName</span>
                    <button class="btn btn-sm btn-outline-danger rounded-0" @onclick="ClearFactura" title="Quitar archivo">
                        <i class="bi bi-x-lg"></i>
                    </button>
                }
            </div>
            @if (!string.IsNullOrEmpty(FacturaPreviewUrl))
            {
                <div class="mt-2">
                    @if (FacturaFileName?.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase) == true)
                    {
                        <a href="@FacturaPreviewUrl" target="_blank" class="btn btn-sm btn-outline-dark rounded-0">
                            <i class="bi bi-file-earmark-pdf-fill text-danger me-1"></i> Ver PDF seleccionado
                        </a>
                    }
                    else
                    {
                        <img src="@FacturaPreviewUrl" class="img-thumbnail border-dark" style="max-height: 80px; object-fit: cover;" />
                    }
                </div>
            }
            @if (FacturaUploadError != null)
            {
                <div class="text-warning fw-bold small mt-1">
                    <i class="bi bi-exclamation-triangle me-1"></i>@FacturaUploadError
                </div>
            }
        </div>

        @* Submit button *@
        <div class="mt-4">
            <button class="btn btn-dark rounded-0 fw-bold w-100 py-2"
                    @onclick="RegistrarCompra"
                    disabled="@(Enviando || !PuedeRegistrar)">
                @if (Enviando)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                }
                else
                {
                    <i class="bi bi-check-lg me-2"></i>
                }
                REGISTRAR COMPRA
            </button>
        </div>
    }
    else
    {
        @* ===== VINCULAR EXISTENTE: SEARCH & LINK ===== *@
        <div class="bg-white border border-dark p-3 mb-3">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="fw-bold small text-uppercase mb-1 text-muted">PROVEEDOR</label>
                    <input type="text" class="form-control border-dark rounded-0" @bind="LinkSearch.Proveedor" placeholder="Buscar proveedor..." />
                </div>
                <div class="col-md-3">
                    <label class="fw-bold small text-uppercase mb-1 text-muted">Nº DOCUMENTO</label>
                    <input type="text" class="form-control border-dark rounded-0" @bind="LinkSearch.NumeroDocumento" placeholder="N° documento..." />
                </div>
                <div class="col-md-2">
                    <label class="fw-bold small text-uppercase mb-1 text-muted">DESDE</label>
                    <input type="date" class="form-control border-dark rounded-0" @bind="LinkSearch.Desde" />
                </div>
                <div class="col-md-2">
                    <label class="fw-bold small text-uppercase mb-1 text-muted">HASTA</label>
                    <input type="date" class="form-control border-dark rounded-0" @bind="LinkSearch.Hasta" />
                </div>
                <div class="col-md-2 d-grid">
                    <button class="btn btn-outline-dark rounded-0 fw-bold" @onclick="BuscarComprasNoVinculadas" disabled="@LinkBuscando">
                        @if (LinkBuscando)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        else
                        {
                            <i class="bi bi-search me-1"></i>
                        }
                        BUSCAR
                    </button>
                </div>
            </div>
        </div>

        @if (LinkError != null)
        {
            <div class="alert alert-danger border-dark rounded-0 fw-bold small py-2 mb-3">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>@LinkError
            </div>
        }

        @if (ComprasNoVinculadas != null)
        {
            @if (!ComprasNoVinculadas.Any())
            {
                <div class="text-center text-muted p-4 border border-dark bg-white">
                    No se encontraron compras sin vincular.
                </div>
            }
            else
            {
                @* Shared transferencia + batch link action bar *@
                <div class="bg-white border border-dark p-3 mb-3">
                    <div class="row g-2 align-items-end">
                        <div class="col-md-7">
                            <label class="fw-bold small text-uppercase mb-1 text-muted">TRANSFERENCIA A UTILIZAR *</label>
                            <select class="form-select border-dark rounded-0 fw-bold" @bind="compraLinkTransferenciaId">
                                <option value="0">-- SELECCIONAR TRANSFERENCIA --</option>
                                @foreach (var t in Transferencias.Where(t => t.Estado != TransferenciaEstado.Conciliado))
                                {
                                    <option value="@t.Id">@t.Fecha.ToString("dd/MM") - $@t.Monto.ToString("N0")</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-5 d-grid">
                            <button class="btn btn-success rounded-0 fw-bold border-dark"
                                    @onclick="VincularSeleccionadas"
                                    disabled="@(compraLinkTransferenciaId == 0 || !SelectedCompraIds.Any() || LinkEnviando)">
                                @if (LinkEnviando)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                }
                                else
                                {
                                    <i class="bi bi-link me-1"></i>
                                }
                                VINCULAR SELECCIONADAS (@SelectedCompraIds.Count)
                            </button>
                        </div>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-bordered border-dark table-hover align-middle mb-0">
                        <thead class="bg-secondary text-white text-uppercase small fw-bold text-center">
                            <tr>
                                <th style="width: 44px;">
                                    <input type="checkbox" class="form-check-input border-dark"
                                           checked="@AllSeleccionadas" @onchange="ToggleSeleccionarTodas" title="Seleccionar todas" />
                                </th>
                                <th>FECHA</th>
                                <th>Nº FACTURA</th>
                                <th>PROVEEDOR</th>
                                <th class="text-end">MONTO</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white fw-bold" style="font-size: 0.85rem;">
                            @foreach (var c in ComprasNoVinculadas)
                            {
                                <tr class="@(SelectedCompraIds.Contains(c.Id) ? "table-active" : "")">
                                    <td class="text-center">
                                        <input type="checkbox" class="form-check-input border-dark"
                                               checked="@SelectedCompraIds.Contains(c.Id)"
                                               @onchange="(e) => ToggleSeleccion(c.Id, e)" />
                                    </td>
                                    <td>@c.FechaCompra.ToString("dd/MM/yyyy")</td>
                                    <td><span class="font-monospace">@(string.IsNullOrEmpty(c.NumeroDocumento) ? "S/N" : c.NumeroDocumento)</span></td>
                                    <td>@c.Proveedor</td>
                                    <td class="text-end text-danger font-monospace">$@c.MontoTotal.ToString("N0")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        }
    }
</div>

@code {
    [Parameter] public string Trabajador { get; set; } = string.Empty;
    [Parameter] public int RendicionId { get; set; }
    [Parameter] public List<TransferenciaDto> Transferencias { get; set; } = new();
    [Parameter] public EventCallback<CompraDto> OnCompraCreated { get; set; }

    private CompraFormData Form { get; set; } = new() { Fecha = DateTime.Today, TipoFactura = "MERCADERIA", PagadaCaja = true };
    private List<ProductoSimpleDto> Productos { get; set; } = new();
    private int ProductoSeleccionadoId { get; set; }
    private int CantidadAgregar { get; set; } = 1;
    private decimal CostoUnitarioAgregar { get; set; }
    private decimal GastoMonto { get; set; }
    private bool Enviando { get; set; }
    private string? Error { get; set; }

    // File upload state
    private IBrowserFile? FacturaFile;
    private string? FacturaPreviewUrl;
    private byte[]? FacturaPreviewBytes;
    private string? FacturaFileName;
    private string? FacturaUploadError;

    // Linking state
    private bool VincularExistente { get; set; }
    private LinkCompraSearch LinkSearch { get; set; } = new();
    private List<CompraDto>? ComprasNoVinculadas { get; set; }
    private HashSet<int> SelectedCompraIds { get; set; } = new();
    private int compraLinkTransferenciaId { get; set; }
    private bool LinkBuscando { get; set; }
    private bool LinkEnviando { get; set; }
    private string? LinkError { get; set; }

    private decimal Total => Form.TipoFactura == "MERCADERIA"
        ? Form.Detalles.Sum(d => d.Cantidad * d.CostoUnitario)
        : GastoMonto;

    private bool PuedeRegistrar
    {
        get
        {
            if (Form.TipoFactura == "MERCADERIA")
                return Form.Proveedor.Length > 0 && Form.Detalles.Count > 0 && Form.TransferenciaId > 0;
            return !string.IsNullOrWhiteSpace(Form.DescripcionGasto) && GastoMonto > 0 && Form.TransferenciaId > 0;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await CargarProductos();
    }

    private async Task CargarProductos()
    {
        try
        {
            Productos = await Http.GetFromJsonAsync<List<ProductoSimpleDto>>("api/productos/simple") ?? new();
            // Auto-prefill first product's CPP if available
            if (Productos.Any())
            {
                CostoUnitarioAgregar = Productos.First().CostoPromedio;
            }
        }
        catch
        {
            // Products might not be available
        }
    }

    private void AgregarDetalle()
    {
        var producto = Productos.FirstOrDefault(p => p.Id == ProductoSeleccionadoId);
        if (producto == null) return;

        // Pre-fill from product's CPP if not set
        if (CostoUnitarioAgregar == 0)
            CostoUnitarioAgregar = producto.CostoPromedio;

        Form.Detalles.Add(new DetalleItem
        {
            ProductoId = producto.Id,
            ProductoNombre = producto.Nombre,
            Cantidad = CantidadAgregar,
            CostoUnitario = CostoUnitarioAgregar
        });

        ProductoSeleccionadoId = 0;
        CantidadAgregar = 1;
        // Keep last CostoUnitario for convenience
    }

    private void EliminarDetalle(DetalleItem d)
    {
        Form.Detalles.Remove(d);
    }

    private async Task RegistrarCompra()
    {
        if (!PuedeRegistrar)
        {
            Error = "Completá todos los campos requeridos.";
            return;
        }

        try
        {
            Enviando = true;
            Error = null;

            if (Form.TipoFactura == "MERCADERIA")
            {
                var request = new CompraVinculadaRequest
                {
                    TransferenciaId = Form.TransferenciaId,
                    RendicionId = RendicionId,
                    Trabajador = Trabajador,
                    FechaCompra = Form.Fecha,
                    Proveedor = Form.Proveedor,
                    NumeroDocumento = Form.NumeroDocumento,
                    TipoFactura = Form.TipoFactura,
                    PagadaCaja = Form.PagadaCaja,
                    Detalles = Form.Detalles.Select(d => new RegistrarDetalleCompraRequestDto
                    {
                        ProductoId = d.ProductoId,
                        DescripcionItem = d.ProductoNombre,
                        Cantidad = d.Cantidad,
                        CostoUnitario = d.CostoUnitario
                    }).ToList()
                };

                var response = await Http.PostAsJsonAsync("api/contabilidad/compra-vinculada", request);
                if (response.IsSuccessStatusCode)
                {
                    var dto = await response.Content.ReadFromJsonAsync<CompraDto>();
                    if (dto != null)
                    {
                        // Upload invoice if file selected
                        if (FacturaPreviewBytes != null && FacturaFile != null)
                        {
                            await UploadFacturaImagen(dto.Id);
                        }

                        ResetForm();
                        await OnCompraCreated.InvokeAsync(dto);
                    }
                }
                else
                {
                    Error = await response.Content.ReadAsStringAsync();
                }
            }
            else
            {
                // GASTO_GENERAL: create a compra with a single item
                var request = new CompraVinculadaRequest
                {
                    TransferenciaId = Form.TransferenciaId,
                    RendicionId = RendicionId,
                    Trabajador = Trabajador,
                    FechaCompra = Form.Fecha,
                    Proveedor = Form.Proveedor,
                    NumeroDocumento = Form.NumeroDocumento,
                    TipoFactura = "GASTO_GENERAL",
                    PagadaCaja = Form.PagadaCaja,
                    Detalles = new List<RegistrarDetalleCompraRequestDto>
                    {
                        new() { DescripcionItem = Form.DescripcionGasto, Cantidad = 1, CostoUnitario = GastoMonto }
                    }
                };

                var response = await Http.PostAsJsonAsync("api/contabilidad/compra-vinculada", request);
                if (response.IsSuccessStatusCode)
                {
                    var dto = await response.Content.ReadFromJsonAsync<CompraDto>();
                    if (dto != null)
                    {
                        // Upload invoice if file selected
                        if (FacturaPreviewBytes != null && FacturaFile != null)
                        {
                            await UploadFacturaImagen(dto.Id);
                        }

                        ResetForm();
                        await OnCompraCreated.InvokeAsync(dto);
                    }
                }
                else
                {
                    Error = await response.Content.ReadAsStringAsync();
                }
            }
        }
        catch (Exception ex)
        {
            Error = $"Error: {ex.Message}";
        }
        finally
        {
            Enviando = false;
        }
    }

    // ====== VINCULAR EXISTENTE METHODS ======
    private async Task BuscarComprasNoVinculadas()
    {
        try
        {
            LinkBuscando = true;
            LinkError = null;
            SelectedCompraIds.Clear();

            var qs = new List<string>();
            if (!string.IsNullOrWhiteSpace(LinkSearch.Proveedor))
                qs.Add($"proveedor={Uri.EscapeDataString(LinkSearch.Proveedor)}");
            if (!string.IsNullOrWhiteSpace(LinkSearch.NumeroDocumento))
                qs.Add($"numeroDocumento={Uri.EscapeDataString(LinkSearch.NumeroDocumento)}");
            if (LinkSearch.Desde.HasValue)
                qs.Add($"desde={LinkSearch.Desde.Value:yyyy-MM-dd}");
            if (LinkSearch.Hasta.HasValue)
                qs.Add($"hasta={LinkSearch.Hasta.Value:yyyy-MM-dd}");

            var url = "api/rendicion/compras-no-vinculadas" + (qs.Any() ? "?" + string.Join("&", qs) : "");
            ComprasNoVinculadas = await Http.GetFromJsonAsync<List<CompraDto>>(url) ?? new();
        }
        catch (Exception ex)
        {
            LinkError = $"Error al buscar compras: {ex.Message}";
        }
        finally
        {
            LinkBuscando = false;
        }
    }

    private void ToggleSeleccion(int compraId, ChangeEventArgs e)
    {
        if (e.Value is bool b && b)
            SelectedCompraIds.Add(compraId);
        else
            SelectedCompraIds.Remove(compraId);
    }

    private bool AllSeleccionadas =>
        ComprasNoVinculadas is { Count: > 0 }
        && ComprasNoVinculadas.All(c => SelectedCompraIds.Contains(c.Id));

    private void ToggleSeleccionarTodas(ChangeEventArgs e)
    {
        if (ComprasNoVinculadas == null) return;
        if (e.Value is bool b && b)
        {
            foreach (var c in ComprasNoVinculadas)
                SelectedCompraIds.Add(c.Id);
        }
        else
        {
            SelectedCompraIds.Clear();
        }
    }

    private async Task VincularSeleccionadas()
    {
        if (compraLinkTransferenciaId == 0)
        {
            LinkError = "Seleccioná una transferencia.";
            return;
        }
        if (!SelectedCompraIds.Any())
        {
            LinkError = "Seleccioná al menos una compra.";
            return;
        }

        try
        {
            LinkEnviando = true;
            LinkError = null;

            var ids = SelectedCompraIds.ToList();
            var fallidas = new List<int>();
            CompraDto? ultimaVinculada = null;

            foreach (var id in ids)
            {
                var request = new LinkCompraRequest { CompraId = id, TransferenciaId = compraLinkTransferenciaId };
                var response = await Http.PostAsJsonAsync($"api/rendicion/{RendicionId}/link-compra", request);
                if (response.IsSuccessStatusCode)
                {
                    var linked = ComprasNoVinculadas?.FirstOrDefault(c => c.Id == id);
                    if (linked != null)
                    {
                        linked.TransferenciaId = compraLinkTransferenciaId;
                        ultimaVinculada = linked;
                    }
                }
                else
                {
                    fallidas.Add(id);
                }
            }

            var exitos = ids.Count - fallidas.Count;
            if (exitos == 0)
            {
                LinkError = "No se pudo vincular ninguna compra. Verificá la transferencia seleccionada.";
                return;
            }

            if (fallidas.Any())
            {
                await JS.InvokeVoidAsync("alert",
                    $"Se vincularon {exitos} de {ids.Count} compras. {fallidas.Count} fallaron y siguen sin vincular.");
            }

            // Reset & close (parent reloads the cuadre with everything linked)
            ComprasNoVinculadas = null;
            SelectedCompraIds.Clear();
            compraLinkTransferenciaId = 0;
            LinkSearch = new();
            VincularExistente = false;
            Error = null;
            await OnCompraCreated.InvokeAsync(ultimaVinculada!);
        }
        catch (Exception ex)
        {
            LinkError = $"Error: {ex.Message}";
        }
        finally
        {
            LinkEnviando = false;
        }
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        Error = null;
        FacturaUploadError = null;
        var file = e.File;
        if (file == null) return;

        const long maxSize = 10 * 1024 * 1024; // 10MB
        if (file.Size > maxSize)
        {
            Error = "El archivo supera los 10MB permitidos.";
            FacturaFile = null;
            FacturaPreviewUrl = null;
            FacturaPreviewBytes = null;
            FacturaFileName = null;
            return;
        }

        var ext = Path.GetExtension(file.Name).ToLowerInvariant();
        var allowedExt = new[] { ".jpg", ".jpeg", ".png", ".pdf" };
        if (!allowedExt.Contains(ext))
        {
            Error = "Formato no permitido. Solo JPG, PNG o PDF.";
            FacturaFile = null;
            FacturaPreviewUrl = null;
            FacturaPreviewBytes = null;
            FacturaFileName = null;
            return;
        }

        FacturaFile = file;
        FacturaFileName = file.Name;

        // Read file into memory for upload
        using var stream = file.OpenReadStream(maxSize);
        using var memoryStream = new MemoryStream();
        await stream.CopyToAsync(memoryStream);
        FacturaPreviewBytes = memoryStream.ToArray();

        // Generate inline preview for images
        if (ext != ".pdf")
        {
            FacturaPreviewUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(FacturaPreviewBytes)}";
        }
        else
        {
            FacturaPreviewUrl = "#"; // Placeholder — PDF shows a link instead
        }
    }

    private async Task UploadFacturaImagen(int compraId)
    {
        if (FacturaPreviewBytes == null || FacturaFile == null) return;

        try
        {
            using var content = new MultipartFormDataContent();
            var byteContent = new ByteArrayContent(FacturaPreviewBytes);
            byteContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(FacturaFile.ContentType);
            content.Add(byteContent, "file", FacturaFile.Name);

            var response = await Http.PostAsync($"api/compras/{compraId}/factura", content);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<System.Text.Json.JsonElement>();
                var path = result.GetProperty("Path").GetString();
                FacturaPreviewUrl = $"api/compras/{compraId}/factura";
                FacturaUploadError = null;
            }
            else
            {
                var errorBody = await response.Content.ReadAsStringAsync();
                FacturaUploadError = $"Compra registrada, pero falló la carga de la factura: {errorBody}";
            }
        }
        catch (Exception ex)
        {
            FacturaUploadError = $"Compra registrada, pero falló la carga de la factura: {ex.Message}";
        }
    }

    private void ClearFactura()
    {
        FacturaFile = null;
        FacturaPreviewUrl = null;
        FacturaPreviewBytes = null;
        FacturaFileName = null;
        FacturaUploadError = null;
    }

    private void ResetForm()
    {
        Form = new() { Fecha = DateTime.Today, TipoFactura = "MERCADERIA", PagadaCaja = true };
        GastoMonto = 0;
        Error = null;
        ClearFactura();
    }

