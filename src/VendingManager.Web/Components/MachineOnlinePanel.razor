@inject IMachineOnlineService MachineService

<VmCard Header="MÁQUINAS ONLINE" HeaderVariant="dark" Style="min-width:260px;">
    @if (_machines == null)
    {
        <p style="font-family:var(--font-mono);font-size:var(--fs-sm);color:var(--ink-500);margin:0;">
            CARGANDO ESTADO_
        </p>
    }
    else if (_machines.Count == 0)
    {
        <p style="font-family:var(--font-mono);font-size:var(--fs-sm);color:var(--ink-500);margin:0;">
            Sin máquinas configuradas.
        </p>
    }
    else
    {
        <div style="display:flex;flex-direction:column;gap:0.75rem;"
             role="list"
             aria-label="Máquinas online">
            @foreach (var machine in _machines)
            {
                <div style="display:flex;align-items:center;justify-content:space-between;gap:0.5rem;"
                     role="listitem">
                    <div style="display:flex;align-items:center;gap:0.5rem;">
                        <VmBadge Variant="@(machine.IsOnline ? "success" : "danger")">
                            <span style="width:6px;height:6px;border-radius:50%;background:currentColor;display:inline-block;"></span>
                        </VmBadge>
                        <span style="font-family:var(--font-mono);font-size:var(--fs-sm);font-weight:var(--fw-bold);text-transform:uppercase;">
                            @machine.Name
                        </span>
                    </div>
                    <span style="font-family:var(--font-mono);font-size:var(--fs-xs);color:var(--ink-500);white-space:nowrap;">
                        @machine.LastSeen.ToString("dd/MM/yyyy HH:mm:ss")
                    </span>
                </div>
            }
        </div>
    }
</VmCard>

@code {
    private IReadOnlyList<MachineOnlineStatus>? _machines;

    protected override async Task OnInitializedAsync()
    {
        _machines = await MachineService.GetOnlineMachinesAsync();
    }
}
