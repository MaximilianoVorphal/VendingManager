@using System.Linq
@using System.Net.Http.Json
@using System.Text.Json
@using VendingManager.Shared.DTOs
@using VendingManager.Web.Services
@implements IDisposable

<aside class="pdc-sidebar" aria-label="Unidades">
    <div class="pdc-sidebar__head">UNIDADES</div>
    <ul class="pdc-sidebar__list" role="list">
        @foreach (var row in _rows)
        {
            var active = row.Id == ActiveUnitId;
            var secondaryText = ResolveSecondaryText(row);
            <li class="pdc-unit-item @(active ? "pdc-unit-item--active" : "")">
                <button type="button" @onclick="() => OnUnitSelected.InvokeAsync(row.Id)">
                    @if (row.Status == PdcUnitStatus.All)
                    {
                        <span class="pdc-unit-item__glyph" aria-hidden="true">◈</span>
                    }
                    else if (row.Status == PdcUnitStatus.Online)
                    {
                        <span class="pdc-dot pdc-dot--ok" aria-hidden="true"></span>
                    }
                    else if (row.Status == PdcUnitStatus.StockLow)
                    {
                        <span class="pdc-dot pdc-dot--err" aria-hidden="true"></span>
                    }
                    else if (row.Status == PdcUnitStatus.Offline)
                    {
                        <span class="pdc-dot pdc-dot--err" aria-hidden="true"></span>
                    }
                    <span class="pdc-unit-item__text">
                        <span class="pdc-unit-item__label">@row.Label</span>
                        @if (secondaryText != null)
                        {
                            var secClass = row.Status switch
                            {
                                PdcUnitStatus.Offline => "pdc-unit-item__secondary--err",
                                PdcUnitStatus.StockLow => "pdc-unit-item__secondary--err",
                                _ => ""
                            };
                            <span class="pdc-unit-item__secondary @secClass">@secondaryText</span>
                        }
                    </span>
                </button>
            </li>
        }
    </ul>
    <div class="pdc-sidebar__foot">@activeCount unidades activas</div>
</aside>

@code {
    /// <summary>Currently selected unit id (matches the id emitted in <see cref="OnUnitSelected"/>).</summary>
    [Parameter] public int ActiveUnitId { get; set; } = 0;

    /// <summary>Fired when the user clicks a unit row. The int is the row's id (0 for "Todas", 1..N for machines).</summary>
    [Parameter] public EventCallback<int> OnUnitSelected { get; set; }

    /// <summary>
    /// How often the sidebar refreshes machine online status from the backend.
    /// Defaults to 6 hours to match the scraper's own polling cadence. Set to
    /// <see cref="TimeSpan.Zero"/> to disable the timer (the initial fetch on
    /// <see cref="OnInitializedAsync"/> still runs).
    /// </summary>
    [Parameter] public TimeSpan RefreshInterval { get; set; } = TimeSpan.FromHours(6);

    [Inject] private HttpClient? Http { get; set; }
    [Inject] private ILogger<PanelDeControlSidebar>? Logger { get; set; }

    private IReadOnlyList<Row> _rows = Array.Empty<Row>();
    private Timer? _refreshTimer;
    private CancellationTokenSource? _cts;

    private static readonly JsonSerializerOptions _jsonOptions = new()
    {
        PropertyNamingPolicy = JsonNamingPolicy.SnakeCaseLower,
    };

    /// <summary>Internal row model: an id, a display label, the OURVEND machine id (for the secondary text), and the resolved status.</summary>
    private record Row(int Id, string Label, string? MachineId, PdcUnitStatus Status);

    private int activeCount => _rows.Count(r => r.Id != 0);

    protected override async Task OnInitializedAsync()
    {
        await FetchAsync();

        if (RefreshInterval > TimeSpan.Zero)
        {
            _cts = new CancellationTokenSource();
            var token = _cts.Token;
            _refreshTimer = new Timer(async _ =>
            {
                if (token.IsCancellationRequested) return;
                try
                {
                    await InvokeAsync(async () =>
                    {
                        await FetchAsync();
                        StateHasChanged();
                    });
                }
                catch (Exception ex)
                {
                    Logger?.LogWarning(ex, "Sidebar status refresh failed");
                }
            }, null, RefreshInterval, RefreshInterval);
        }
    }

    private async Task FetchAsync()
    {
        if (Http == null) return;
        var machines = new List<MachineStatusDto>();
        try
        {
            var response = await Http.GetAsync("api/Ventas/machine-status");
            if (response.IsSuccessStatusCode)
            {
                var payload = await response.Content.ReadFromJsonAsync<MachineStatusResponse>(_jsonOptions);
                if (payload?.Machines != null) machines = payload.Machines;
            }
            else
            {
                Logger?.LogWarning("machine-status returned {Status}", response.StatusCode);
            }
        }
        catch (Exception ex)
        {
            Logger?.LogWarning(ex, "Failed to fetch machine status for sidebar");
        }

        ApplyMachines(machines);
    }

    private void ApplyMachines(List<MachineStatusDto> machines)
    {
        // "Todas" is always shown — even if the API failed, the operator still needs a way to clear the unit filter.
        var list = new List<Row>(capacity: machines.Count + 1)
        {
            new(0, "Todas", null, PdcUnitStatus.All),
        };
        int id = 1;
        foreach (var m in machines)
        {
            list.Add(new Row(
                Id: id++,
                Label: string.IsNullOrWhiteSpace(m.Name) ? m.MachineId : m.Name,
                MachineId: string.IsNullOrWhiteSpace(m.MachineId) ? null : m.MachineId,
                Status: MapStatus(m.Status)));
        }
        _rows = list;
    }

    private static PdcUnitStatus MapStatus(string? status) => status switch
    {
        "online" => PdcUnitStatus.Online,
        "warning" => PdcUnitStatus.StockLow,
        "offline" => PdcUnitStatus.Offline,
        _ => PdcUnitStatus.Online, // default for unknown / loading
    };

    private static string? ResolveSecondaryText(Row row)
    {
        if (row.Status == PdcUnitStatus.All) return null;
        if (string.IsNullOrEmpty(row.MachineId)) return null;
        var statusText = row.Status switch
        {
            PdcUnitStatus.Online => "Online",
            PdcUnitStatus.StockLow => "Stock bajo",
            PdcUnitStatus.Offline => "Sin conexión",
            _ => "—",
        };
        return $"{row.MachineId} · {statusText}";
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _refreshTimer?.Dispose();
        _cts?.Dispose();
    }
}
