@inherits ErrorBoundary

@if (CurrentException is null)
{
    @ChildContent
}
else
{
    <div class="alert alert-danger border-3 border-danger shadow-lg p-4 mt-4 bg-white text-danger font-monospace">
        <h4 class="alert-heading fw-bold text-uppercase">⛔ CRITICAL SYSTEM FAILURE</h4>
        <hr class="border-danger opacity-100">
        <p class="fw-bold">@CurrentException.Message</p>

        <details class="mt-3">
            <summary class="fw-bold cursor-pointer mb-2">VER STACK TRACE COMPLETO</summary>
            <pre class="bg-light p-3 border border-danger text-dark small" style="max-height: 300px; overflow-y: auto;">
                @CurrentException.StackTrace
                </pre>
        </details>

        <button class="btn btn-outline-danger btn-sm mt-3 fw-bold text-uppercase" @onclick="Recover">
            ↻ REINICIAR SISTEMA
        </button>
    </div>
}
