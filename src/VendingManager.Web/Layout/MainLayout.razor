@inherits LayoutComponentBase
@inject IJSRuntime JSRuntime
@inject NavigationManager NavManager
@using VendingManager.Web.Services

<CascadingValue Value="this">
    <div class="industrial-wrapper @(IsFullscreenRoute ? "industrial-wrapper--fullscreen" : "") @(_navbarCollapsed ? "industrial-wrapper--navbar-collapsed" : "")">
        <AuthorizeView>
            <Authorized>
                <VmNavbar Active="dashboard" Collapsed="@_navbarCollapsed" />
            </Authorized>
        </AuthorizeView>

        <main class="@(IsFullscreenRoute ? "container-fluid p-0" : "container-fluid px-3 px-lg-5")">
            <div class="vm-shell">
                @if (ShowLeftPanel)
                {
                    <aside class="vm-shell__left" role="complementary" aria-label="Unidades">
                        <PanelDeControlSidebar />
                    </aside>
                }
                <div class="vm-shell__main">
                    <CustomErrorBoundary>
                        @Body
                    </CustomErrorBoundary>
                </div>
            </div>
        </main>
    </div>
</CascadingValue>

@code {
    private bool _navbarCollapsed;

    private bool ShowLeftPanel
    {
        get
        {
            var path = new Uri(NavManager.Uri).AbsolutePath.Trim('/').ToLowerInvariant();
            return path == "";
        }
    }

    /// <summary>
    /// Rutas que ocupan toda la altura del viewport (100vh, sin scroll de página).
    /// El scroll vive dentro de tablas/paneles. La home la activa por su sidebar.
    /// </summary>
    private static readonly string[] FullscreenRoutes = ["", "informe-ventas", "contabilidad", "caja", "caja-v2", "analisis-productos", "compras", "templates-recarga", "recarga-movil", "conciliacion-movil", "stockout-dashboard", "informe-compras"];

    private bool IsFullscreenRoute
    {
        get
        {
            var path = new Uri(NavManager.Uri).AbsolutePath.Trim('/').ToLowerInvariant();
            return FullscreenRoutes.Contains(path);
        }
    }

    /// <summary>
    /// Permite a páginas hijas colapsar la navbar para ganar espacio (ej: editor visual de slots).
    /// </summary>
    public void CollapseNavbar()
    {
        if (!_navbarCollapsed)
        {
            _navbarCollapsed = true;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Restaura la navbar a su estado normal.
    /// </summary>
    public void ExpandNavbar()
    {
        if (_navbarCollapsed)
        {
            _navbarCollapsed = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Alterna el estado colapsado/expandido (usado por el botón toggle en la navbar).
    /// </summary>
    public void ToggleNavbarCollapse()
    {
        _navbarCollapsed = !_navbarCollapsed;
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("hideLoader");
        }
    }
}