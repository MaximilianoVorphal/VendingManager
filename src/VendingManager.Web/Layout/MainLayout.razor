@inherits LayoutComponentBase
@inject IJSRuntime JSRuntime
@inject NavigationManager NavManager

<CascadingValue Value="this">
    <div class="industrial-wrapper">
        <AuthorizeView>
            <Authorized>
                <VmNavbar Active="dashboard" Collapsed="@_navbarCollapsed" />
            </Authorized>
        </AuthorizeView>

        <main class="container-fluid px-3 px-lg-5">
            <div style="display:flex;gap:1.5rem;align-items:flex-start;flex-wrap:wrap;">
                <div style="flex:1;min-width:0;">
                    <CustomErrorBoundary>
                        @Body
                    </CustomErrorBoundary>
                </div>
                <AuthorizeView>
                    <Authorized>
                        @if (ShowMachineOnlinePanel)
                        {
                            <aside style="flex:0 0 280px;max-width:100%;" role="complementary" aria-label="Máquinas online">
                                <MachineOnlinePanel />
                            </aside>
                        }
                    </Authorized>
                </AuthorizeView>
            </div>
        </main>
    </div>
</CascadingValue>

@code {
    private bool _navbarCollapsed;

    private bool ShowMachineOnlinePanel
    {
        get
        {
            var path = new Uri(NavManager.Uri).AbsolutePath.Trim('/').ToLowerInvariant();
            return path switch
            {
                "" or "informe-ventas" or "analisis-ventas" => true,
                _ => false
            };
        }
    }

    /// <summary>
    /// Permite a páginas hijas colapsar la navbar para ganar espacio (ej: editor visual de slots).
    /// </summary>
    public void CollapseNavbar()
    {
        if (!_navbarCollapsed)
        {
            _navbarCollapsed = true;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Restaura la navbar a su estado normal.
    /// </summary>
    public void ExpandNavbar()
    {
        if (_navbarCollapsed)
        {
            _navbarCollapsed = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Alterna el estado colapsado/expandido (usado por el botón toggle en la navbar).
    /// </summary>
    public void ToggleNavbarCollapse()
    {
        _navbarCollapsed = !_navbarCollapsed;
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("hideLoader");
        }
    }
}