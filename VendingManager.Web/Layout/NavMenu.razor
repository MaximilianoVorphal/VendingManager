<div class="industrial-navbar">
    <div class="container-fluid px-4 d-flex justify-content-between align-items-center position-relative">

        <div class="brand-logo">
            VENDING
        </div>

        <!-- Botón Hamburger (Visible solo en móvil) -->
        <button class="hamburger-btn" @onclick="ToggleNavMenu">
            <i class="bi bi-list"
                style="visibility: visible; float: none; bottom: 1px; left: 5px; width: 26px; height: 28px"></i>
        </button>

        <nav class="nav-links-container @NavMenuCssClass">
            <NavLink class="industrial-link" href="" Match="NavLinkMatch.All" @onclick="CloseNavMenu">
                [ PANEL DE CONTROL ]
            </NavLink>

            <!-- Dropdown GESTIÓN -->
            <div class="industrial-dropdown">
                <button class="industrial-dropdown-toggle" @onclick="ToggleGestionMenu">
                    [ GESTIÓN ▾ ]
                </button>
                <div class="industrial-dropdown-content @(showGestionMenu ? "show" : "")">
                    <NavLink class="industrial-link" href="reportes" @onclick="CloseNavMenu">
                        VENTAS
                    </NavLink>
                    <NavLink class="industrial-link" href="analisis-ventas" @onclick="CloseNavMenu">
                        ANÁLISIS PRODUCTOS
                    </NavLink>
                    <NavLink class="industrial-link" href="stockout-dashboard" @onclick="CloseNavMenu">
                        QUIEBRES DE STOCK
                    </NavLink>
                    <AuthorizeView Roles="Admin">
                        <NavLink class="industrial-link" href="templates-recarga" @onclick="CloseNavMenu">
                            TEMPLATES RECARGA
                        </NavLink>
                        <NavLink class="industrial-link" href="finanzas" @onclick="CloseNavMenu">
                            FINANZAS
                        </NavLink>
                    </AuthorizeView>
                    <NavLink class="industrial-link" href="informe-compras" @onclick="CloseNavMenu">
                        INFORME COMPRAS
                    </NavLink>
                    <NavLink class="industrial-link" href="caja" @onclick="CloseNavMenu">
                        CAJA
                    </NavLink>
                </div>
            </div>

            <!-- Dropdown OPERACIONES -->
            <div class="industrial-dropdown">
                <button class="industrial-dropdown-toggle" @onclick="ToggleOperacionesMenu">
                    [ OPERACIONES ▾ ]
                </button>
                <div class="industrial-dropdown-content @(showOperacionesMenu ? "show" : "")">
                    <AuthorizeView Roles="Admin">
                        <NavLink class="industrial-link" href="maquinas" @onclick="CloseNavMenu">
                            MÁQUINAS
                        </NavLink>
                    </AuthorizeView>
                    <NavLink class="industrial-link" href="compras" @onclick="CloseNavMenu">
                        COMPRAS
                    </NavLink>
                    <NavLink class="industrial-link" href="inventario" @onclick="CloseNavMenu">
                        BODEGA
                    </NavLink>
                    <NavLink class="industrial-link" href="reposicion" @onclick="CloseNavMenu">
                        INVENTARIO MAQUINAS
                    </NavLink>
                    <NavLink class="industrial-link" href="cargas" @onclick="CloseNavMenu">
                        CENTRO DE CARGAS
                    </NavLink>
                </div>
            </div>

            <AuthorizeView Roles="Admin">
                <NavLink class="industrial-link" href="documentos" @onclick="CloseNavMenu">
                    [ DOCUMENTOS ]
                </NavLink>
            </AuthorizeView>

            <AuthorizeView Roles="Admin">
                <div class="industrial-dropdown">
                    <button class="industrial-dropdown-toggle" @onclick="ToggleAdminMenu">
                        [ ADMINISTRACIÓN ▾ ]
                    </button>
                    <div class="industrial-dropdown-content @(showAdminMenu ? "show" : "")">
                        <NavLink class="industrial-link" href="admin/auditoria" @onclick="CloseNavMenu">
                            AUDITORÍA
                        </NavLink>
                        <NavLink class="industrial-link" href="admin/usuarios" @onclick="CloseNavMenu">
                            USUARIOS
                        </NavLink>
                    </div>
                </div>
            </AuthorizeView>
            
            <AuthorizeView>
                <a class="industrial-link text-danger" href="logout" @onclick="CloseNavMenu">
                    [ CERRAR SESIÓN ]
                </a>
            </AuthorizeView>
        </nav>

    </div>
</div>

@code {
    private bool collapseNavMenu = true;
    private bool showGestionMenu = false;
    private bool showOperacionesMenu = false;
    private bool showAdminMenu = false;

    private string? NavMenuCssClass => collapseNavMenu ? null : "show";

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private void CloseNavMenu()
    {
        collapseNavMenu = true;
        showGestionMenu = false;
        showOperacionesMenu = false;
        showAdminMenu = false;
    }

    private void ToggleGestionMenu()
    {
        showGestionMenu = !showGestionMenu;
        if (showGestionMenu) 
        {
            showOperacionesMenu = false;
            showAdminMenu = false;
        }
    }

    private void ToggleOperacionesMenu()
    {
        showOperacionesMenu = !showOperacionesMenu;
        if (showOperacionesMenu) 
        {
            showGestionMenu = false;
            showAdminMenu = false;
        }
    }

    private void ToggleAdminMenu()
    {
        showAdminMenu = !showAdminMenu;
        if (showAdminMenu)
        {
            showGestionMenu = false;
            showOperacionesMenu = false;
        }
    }
}
