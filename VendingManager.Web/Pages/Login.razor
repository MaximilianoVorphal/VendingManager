@page "/login"
@using VendingManager.Core.DTOs
@using VendingManager.Web.Auth
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@inject HttpClient Http
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@layout Layout.LoginLayout

<h3>Iniciar Sesión</h3>

<div class="row">
    <div class="col-md-4 offset-md-4">
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger">@errorMessage</div>
        }

        <div class="card">
            <div class="card-body">
                <EditForm Model="@loginDto" OnValidSubmit="HandleLogin" FormName="loginForm">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="mb-3">
                        <label for="username" class="form-label">Usuario</label>
                        <InputText id="username" class="form-control" @bind-Value="loginDto.Username" />
                    </div>

                    <div class="mb-3">
                        <label for="password" class="form-label">Contraseña</label>
                        <InputText id="password" type="password" class="form-control" @bind-Value="loginDto.Password" />
                    </div>

                    <button type="submit" class="btn btn-primary w-100">Ingresar</button>
                </EditForm>
            </div>
        </div>
    </div>
</div>

@code {
    private LoginDto loginDto = new LoginDto();
    private string errorMessage;

    private async Task HandleLogin()
    {
        errorMessage = null;
        try
        {
            var response = await Http.PostAsJsonAsync("api/account/login", loginDto);
            if (response.IsSuccessStatusCode)
            {
                // Force a reload or notify state provider
                // Reloading is safer for cookies to "stick" in some WASM scenarios, 
                // but notifying is better SPA experience if possible. 
                // Since this is WASM hosted, we need the cookie to be sent on subsequent requests.
                // Re-checking auth state is enough.
                
                if (AuthStateProvider is CookieAuthenticationStateProvider customAuthProvider)
                {
                    customAuthProvider.NotifyAuthenticationStateChanged();
                }
                
                // Navigate to home
                Navigation.NavigateTo("/", true); // Force load to ensure cookies are sent? Usually not needed if Http client handles it, but refreshing ensures everything is clean.
            }
            else
            {
                errorMessage = "Usuario o contraseña incorrectos.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Error al iniciar sesión: " + ex.Message;
        }
    }
}
