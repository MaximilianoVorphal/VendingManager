@page "/inventario-maquina"
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>INVENTARIO MÁQUINA</PageTitle>

<div class="container-fluid px-4 mt-4" style="font-family: 'Segoe UI', Consolas, monospace;">

    <div class="row align-items-center mb-4 border-bottom border-3 border-dark pb-3 g-3">
        <div class="col-md-5 col-12">
            <h2 class="m-0 fw-bold text-uppercase" style="letter-spacing: -1px; color: #333;">
                <i class="bi bi-hdd-rack me-2"></i>INVENTARIO DE MÁQUINA
            </h2>
            <small class="text-muted fw-bold">MAPEO DE SLOTS Y REPOSICIÓN</small>
        </div>

        <div class="col-md-7 col-12">
            <div class="d-flex flex-wrap gap-2 justify-content-md-end align-items-center">
                <label class="fw-bold me-2">SELECCIONAR UNIDAD:</label>
                <select class="form-select border-dark rounded-0 fw-bold shadow-sm" style="max-width: 300px;" 
                        @onchange="CargarSlotsMaquina">
                    <option value="0">:: SELECCIONE MÁQUINA ::</option>
                    @if (Maquinas != null)
                    {
                        @foreach (var m in Maquinas)
                        {
                            <option value="@m.Id">@m.Nombre.ToUpper()</option>
                        }
                    }
                </select>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Mensaje))
    {
        <div class="alert @AlertClass border-dark rounded-0 fw-bold mb-4 shadow-sm fade show">
            @Mensaje
        </div>
    }

    @if (MaquinaIdSeleccionada > 0)
    {
        <div class="card border-2 border-dark rounded-0 shadow my-4">
            <div class="card-header bg-dark text-white rounded-0 fw-bold d-flex justify-content-between align-items-center flex-wrap">
                <span>CONFIGURACIÓN DE SLOTS</span>
                <button class="btn btn-sm btn-light rounded-0 fw-bold text-dark border-secondary" @onclick="NuevoSlot">
                    <i class="bi bi-plus-lg me-1"></i>AGREGAR SLOT
                </button>
            </div>
            <div class="table-responsive">
                <table class="table table-hover table-bordered border-dark m-0 align-middle">
                    <thead class="bg-secondary text-white text-uppercase small">
                        <tr>
                            <th class="text-center" width="80">SLOT</th>
                            <th>PRODUCTO ASIGNADO</th>
                            <th class="text-end" width="120">PRECIO</th>
                            <th class="text-center" width="120">STOCK</th>
                            <th class="text-center" width="120">CAPACIDAD</th>
                            <th class="text-center" width="150">ACCIONES</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white fw-bold small">
                        @if (Slots.Count == 0)
                        {
                            <tr>
                                <td colspan="6" class="text-center p-4 text-muted">No hay slots configurados para esta máquina.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var s in Slots.OrderBy(x => x.NumeroSlot))
                            {
                                <tr class="@(s.ProductoId == 0 ? "table-warning" : "")">
                                    <td class="text-center font-monospace bg-light fs-5">@s.NumeroSlot</td>
                                    <td>
                                        @if (s.Producto != null)
                                        {
                                            <div class="d-flex flex-column">
                                                <span class="text-uppercase">@s.Producto.Nombre</span>
                                                <span class="text-muted small font-monospace">@s.Producto.CodigoBarras</span>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-danger fst-italic">SIN ASIGNAR</span>
                                        }
                                    </td>
                                    <td class="text-end font-monospace text-success">$@s.PrecioVenta.ToString("N0")</td>
                                    
                                    <td class="text-center">
                                        <div class="d-flex align-items-center justify-content-center gap-1">
                                            <span class="fs-6 @(s.StockActual < 3 ? "text-danger" : "text-dark")">@s.StockActual</span>
                                        </div>
                                    </td>
                                    <td class="text-center text-muted">@s.CapacidadMaxima</td>

                                    <td class="text-center">
                                        <div class="d-flex justify-content-center gap-2">
                                            <button class="btn btn-sm btn-outline-warning rounded-0 border-dark text-dark"
                                                    title="Editar Configuración" @onclick="() => EditarSlot(s)">
                                                <i class="bi bi-gear-fill"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-primary rounded-0 border-dark text-dark"
                                                    title="Reponer Stock" @onclick="() => AbrirModalReposicion(s)">
                                                <i class="bi bi-box-arrow-in-up"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5 text-muted border border-2 border-dark border-dashed my-4 bg-light">
            <h4 class="fw-bold">SELECCIONE UNA MÁQUINA PARA COMENZAR</h4>
            <p class="mb-0">Use el selector superior para cargar la configuración.</p>
        </div>
    }
</div>

<!-- MODAL EDICIÓN SLOT -->
@if (MostrarModalEditar && SlotEnEdicion != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-0 border-2 border-dark shadow-lg">
                <div class="modal-header bg-warning text-dark rounded-0 border-bottom border-dark">
                    <h5 class="modal-title fw-bold"><i class="bi bi-gear-fill me-2"></i>CONFIGURAR SLOT @SlotEnEdicion.NumeroSlot</h5>
                    <button type="button" class="btn-close" @onclick="CerrarModal"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold small">NUMERO DE SLOT (ID)</label>
                        <input type="text" class="form-control rounded-0 border-dark font-monospace text-uppercase" 
                               @bind="SlotEnEdicion.NumeroSlot" placeholder="EJ: A1, 10, B5" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold small">PRODUCTO ASIGNADO</label>
                        <select class="form-select rounded-0 border-dark" @bind="SlotEnEdicion.ProductoId">
                            <option value="0">-- SIN PRODUCTO --</option>
                            @if (ProductosDisponibles != null)
                            {
                                @foreach (var p in ProductosDisponibles.OrderBy(x => x.Nombre))
                                {
                                    <option value="@p.Id">@p.Nombre (@p.StockBodega en Bodega)</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="row g-3">
                        <div class="col-6">
                            <label class="form-label fw-bold small text-success">PRECIO VENTA</label>
                            <input type="number" class="form-control rounded-0 border-dark fw-bold text-success" 
                                   @bind="SlotEnEdicion.PrecioVenta" />
                        </div>
                        <div class="col-6">
                            <label class="form-label fw-bold small text-muted">CAPACIDAD MAX</label>
                            <input type="number" class="form-control rounded-0 border-dark fw-bold" 
                                   @bind="SlotEnEdicion.CapacidadMaxima" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light rounded-0">
                    <button type="button" class="btn btn-outline-dark rounded-0 fw-bold" @onclick="CerrarModal">CANCELAR</button>
                    <button type="button" class="btn btn-warning rounded-0 border-dark fw-bold px-4" @onclick="GuardarSlot">
                        <i class="bi bi-save me-2"></i>GUARDAR
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- MODAL REPOSICIÓN -->
@if (MostrarModalRepo && SlotEnEdicion != null)
{
    var prod = ProductosDisponibles?.FirstOrDefault(p => p.Id == SlotEnEdicion.ProductoId);
    int maxReponer = prod != null ? prod.StockBodega : 0;
    int espacioLibre = SlotEnEdicion.CapacidadMaxima - SlotEnEdicion.StockActual;
    int sugerido = Math.Min(maxReponer, espacioLibre);
    if(CantidadReposicion == 0) CantidadReposicion = sugerido > 0 ? sugerido : 1;

    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-0 border-2 border-dark shadow-lg">
                <div class="modal-header bg-primary text-white rounded-0 border-bottom border-dark">
                    <h5 class="modal-title fw-bold"><i class="bi bi-box-arrow-in-up me-2"></i>REPONER SLOT @SlotEnEdicion.NumeroSlot</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarModal"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="alert alert-info rounded-0 border-dark mb-4">
                        <h6 class="fw-bold mb-1">Producto: @(prod?.Nombre ?? "DESCONOCIDO")</h6>
                        <div class="d-flex justify-content-between small font-monospace">
                            <span>Bodega: @(prod?.StockBodega ?? 0)</span>
                            <span>Máquina: @SlotEnEdicion.StockActual / @SlotEnEdicion.CapacidadMaxima</span>
                        </div>
                    </div>

                    <label class="form-label fw-bold small">CANTIDAD A TRASLADAR (BODEGA -> MÁQUINA)</label>
                    <input type="number" class="form-control form-control-lg rounded-0 border-dark fw-bold text-center"
                           @bind="CantidadReposicion" min="1" max="@maxReponer" />
                    
                    @if (CantidadReposicion > maxReponer)
                    {
                        <div class="text-danger small mt-2 fw-bold">No hay suficiente stock en bodega.</div>
                    }
                </div>
                <div class="modal-footer bg-light rounded-0">
                     <button type="button" class="btn btn-outline-dark rounded-0 fw-bold" @onclick="CerrarModal">CANCELAR</button>
                    <button type="button" class="btn btn-primary rounded-0 border-dark fw-bold px-4" 
                            @onclick="ConfirmarReposicion" disabled="@(CantidadReposicion > maxReponer || CantidadReposicion <= 0)">
                        <i class="bi bi-check-lg me-2"></i>CONFIRMAR
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    // DATA
    private List<MaquinaSimpleDto> Maquinas;
    private List<ConfiguracionSlotDto> Slots = new();
    private List<ProductoSimpleDto> ProductosDisponibles;
    
    // STATE
    private int MaquinaIdSeleccionada = 0;
    private string Mensaje = "";
    private string AlertClass = "alert-info";
    
    // MODALS
    private bool MostrarModalEditar = false;
    private bool MostrarModalRepo = false;
    private ConfiguracionSlotDto? SlotEnEdicion;
    private int CantidadReposicion = 0;

    protected override async Task OnInitializedAsync()
    {
        await CargarMaquinas();
        await CargarProductos();
    }

    private async Task CargarMaquinas()
    {
        try { Maquinas = await Http.GetFromJsonAsync<List<MaquinaSimpleDto>>("api/Maquinas") ?? new(); }
        catch { }
    }

    private async Task CargarProductos()
    {
         try { ProductosDisponibles = await Http.GetFromJsonAsync<List<ProductoSimpleDto>>("api/Inventario/lista") ?? new(); }
        catch { }
    }

    private async Task CargarSlotsMaquina(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id) && id > 0)
        {
            MaquinaIdSeleccionada = id;
            Slots = await Http.GetFromJsonAsync<List<ConfiguracionSlotDto>>($"api/Maquinas/{id}/slots") ?? new();
        }
        else
        {
            MaquinaIdSeleccionada = 0;
            Slots.Clear();
        }
    }

    // --- ACCIONES SLOT ---
    private void NuevoSlot()
    {
        SlotEnEdicion = new ConfiguracionSlotDto { MaquinaId = MaquinaIdSeleccionada, CapacidadMaxima = 10, StockActual = 0 };
        MostrarModalEditar = true;
    }

    private void EditarSlot(ConfiguracionSlotDto slot)
    {
        // Clone simple
        SlotEnEdicion = new ConfiguracionSlotDto 
        { 
            Id = slot.Id,
            MaquinaId = slot.MaquinaId, 
            NumeroSlot = slot.NumeroSlot, 
            ProductoId = slot.ProductoId,
            PrecioVenta = slot.PrecioVenta,
            StockActual = slot.StockActual,
            CapacidadMaxima = slot.CapacidadMaxima
        };
        MostrarModalEditar = true;
    }

    private async Task GuardarSlot()
    {
        if (SlotEnEdicion == null) return;
        try
        {
            var response = await Http.PostAsJsonAsync($"api/Maquinas/{MaquinaIdSeleccionada}/slots", SlotEnEdicion);
            if (response.IsSuccessStatusCode)
            {
                Mensaje = "✅ Slot guardado correctamente.";
                AlertClass = "alert-success";
                MostrarModalEditar = false;
                // Reload list to get IDs and updates
                Slots = await Http.GetFromJsonAsync<List<ConfiguracionSlotDto>>($"api/Maquinas/{MaquinaIdSeleccionada}/slots") ?? new();
            }
            else
            {
                Mensaje = "❌ Error al guardar slot.";
                AlertClass = "alert-danger";
            }
        }
        catch (Exception ex)
        {
             Mensaje = $"❌ Error: {ex.Message}";
             AlertClass = "alert-danger";
        }
    }

    // --- ACCIONES REPOSICION ---
    private void AbrirModalReposicion(ConfiguracionSlotDto slot)
    {
        if(slot.ProductoId == 0) 
        {
            Mensaje = "⚠️ Debes asignar un producto antes de reponer.";
            AlertClass = "alert-warning";
            return;
        }
        SlotEnEdicion = slot; // Reference is okay here as we only update stock locally then sync
        MostrarModalRepo = true;
        CantidadReposicion = 0; 
    }

    private async Task ConfirmarReposicion()
    {
        if (SlotEnEdicion == null) return;
        
        // 1. Decrement Bodega (Reuse existing API logic or create new combined one?)
        // Ideally we need a transactional move. For now we will do client-orchestrated or better yet, new endpoint.
        // Let's us the AjustarStock endpoint for Bodega decrement, then update Slot.
        
        try
        {
            var prod = ProductosDisponibles.FirstOrDefault(p => p.Id == SlotEnEdicion.ProductoId);
            if (prod == null) return;

            // A. Decrement Bodega
            int nuevoStockBodega = prod.StockBodega - CantidadReposicion;
            var dto = new { ProductoId = prod.Id, NuevoStock = nuevoStockBodega };
            var resp1 = await Http.PostAsJsonAsync("api/productos/ajustar-stock", dto); // Using existing endpoint assumed from prev files

             if (!resp1.IsSuccessStatusCode) throw new Exception("Fallo al descontar de bodega.");

            // B. Increment Machine
            SlotEnEdicion.StockActual += CantidadReposicion;
             var resp2 = await Http.PostAsJsonAsync($"api/Maquinas/{MaquinaIdSeleccionada}/slots", SlotEnEdicion);
             
             if (!resp2.IsSuccessStatusCode) throw new Exception("Fallo al actualizar stock máquina.");

             // Success
             prod.StockBodega = nuevoStockBodega; // Update local view
             Mensaje = $"✅ Reposición exitosa: +{CantidadReposicion} unidades.";
             AlertClass = "alert-success";
             MostrarModalRepo = false;
             
             // Reload slots
             Slots = await Http.GetFromJsonAsync<List<ConfiguracionSlotDto>>($"api/Maquinas/{MaquinaIdSeleccionada}/slots") ?? new();
        }
        catch (Exception ex)
        {
             Mensaje = $"❌ Error en reposición: {ex.Message}";
             AlertClass = "alert-danger";
        }
    }
    
    private void CerrarModal()
    {
        MostrarModalEditar = false;
        MostrarModalRepo = false;
        SlotEnEdicion = null;
    }

    // DTOs Helpers
    class MaquinaSimpleDto { public int Id { get; set; } public string Nombre { get; set; } = ""; }
    class ProductoSimpleDto { public int Id { get; set; } public string Nombre { get; set; } = ""; public string CodigoBarras { get; set; } = ""; public int StockBodega { get; set;} }
    
    // Use Local DTO to avoid namespace issues
    class ConfiguracionSlotDto
    {
        public int Id { get; set; }
        public int MaquinaId { get; set; }
        public string NumeroSlot { get; set; } = "";
        public int ProductoId { get; set; }
        public ProductoSimpleDto? Producto { get; set; }
        public int StockActual { get; set; }
        public int CapacidadMaxima { get; set; }
        public decimal PrecioVenta { get; set; }
    }
}
