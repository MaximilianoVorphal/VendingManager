@page "/admin/auditoria"
@using Microsoft.AspNetCore.Authorization
@using VendingManager.Web.DTOs
@attribute [Authorize(Roles = "Admin")]
@inject HttpClient Http

<PageTitle>Auditoría</PageTitle>

<h1>Registro de Auditoría</h1>



<div class="row mb-3">
    <div class="col-md-3">
        <label class="form-label">Usuario:</label>
        <input type="text" class="form-control" @bind="filtroUsuario" placeholder="Ej: admin" />
    </div>
    <div class="col-md-3">
        <label class="form-label">Acción:</label>
        <input type="text" class="form-control" @bind="filtroAccion" placeholder="Ej: Login" />
    </div>
    <div class="col-md-2 d-flex align-items-end">
        <button class="btn btn-primary w-100" @onclick="CargarLogs">
            <i class="bi bi-search me-2"></i>Filtrar
        </button>
    </div>
</div>

@if (logs == null)
{
    <p><em>Cargando...</em></p>
}
else if (!logs.Any())
{
    <div class="alert alert-info">No se encontraron registros.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Fecha</th>
                    <th>Usuario</th>
                    <th>Acción</th>
                    <th>Detalle</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in logs)
                {
                    <tr>
                        <td>@log.Fecha.ToString("g")</td>
                        <td>@log.Usuario</td>
                        <td>@log.Accion</td>
                        <td>@log.Detalle</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<AuditoriaDto>? logs;
    private string filtroUsuario = "";
    private string filtroAccion = "";

    protected override async Task OnInitializedAsync()
    {
        await CargarLogs();
    }

    private async Task CargarLogs()
    {
        try
        {
            var url = "api/auditoria";
            if (!string.IsNullOrWhiteSpace(filtroUsuario))
            {
                url += $"?usuario={filtroUsuario}";
            }
            if (!string.IsNullOrWhiteSpace(filtroAccion))
            {
                url += string.IsNullOrWhiteSpace(filtroUsuario) ? "?" : "&";
                url += $"accion={filtroAccion}";
            }
            logs = await Http.GetFromJsonAsync<List<AuditoriaDto>>(url);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando auditoría: {ex.Message}");
            logs = new List<AuditoriaDto>();
        }
    }
}
