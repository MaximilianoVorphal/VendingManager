@page "/finanzas"
@inject HttpClient Http

<PageTitle>FINANZAS</PageTitle>

<div class="container-fluid px-4 mt-4" style="font-family: 'Segoe UI', Consolas, monospace;">

    <div class="row align-items-center mb-4 border-bottom border-3 border-dark pb-3">
        <div class="col-12 d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <h2 class="m-0 fw-bold text-uppercase" style="letter-spacing: -1px;">DASHBOARD FINANCIERO</h2>
                <small class="text-muted fw-bold">ANÁLISIS DE RENTABILIDAD Y FLUJO</small>
            </div>

            <!-- MONTH SELECTOR -->
            <div class="d-flex align-items-center gap-2 flex-wrap justify-content-end">
                <button class="btn btn-dark rounded-0 btn-sm" @onclick="() => ChangeMonth(-1)">◀</button>
                <div class="bg-dark text-white px-3 py-2 fw-bold rounded-0 text-uppercase text-center" style="min-width: 180px;">
                    @SelectedDate.ToString("MMMM yyyy")
                </div>
                <button class="btn btn-dark rounded-0 btn-sm" @onclick="() => ChangeMonth(1)">▶</button>
                <button class="btn btn-outline-dark rounded-0 btn-sm" @onclick="GoToToday" title="Ir a Hoy">Hoy</button>
            </div>
        </div>
    </div>

    @if (Resumen != null)
    {
        <!-- KPI CARDS HERO SECTION -->
        <div class="row g-4 mb-5">
            
            <!-- 1. UTILIDAD REAL (PROFIT) -->
            <div class="col-md-3">
                <div class="card h-100 border-0 shadow-lg position-relative overflow-hidden" 
                     style="background: linear-gradient(135deg, #0f2027, #203a43, #2c5364); color: white;">
                    <div class="card-body p-4 position-relative z-1">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div>
                                <h6 class="text-uppercase fw-bold text-success mb-1" style="letter-spacing: 1px; font-size: 0.8rem;">UTILIDAD NETA</h6>
                                <small class="text-white-50" style="font-size: 0.7rem;">(Ventas - Costo - Gastos)</small>
                            </div>
                            <i class="fs-1 text-success opacity-50 bi bi-cash-coin"></i>
                        </div>
                        <!-- Formula de utilidad neta aproximada: Utilidad Bruta (Venta-Costo) - Gastos Operativos -->
                        <h2 class="display-6 fw-bold mb-0 text-success">$@((Resumen.UtilidadTotal - Resumen.GastosOperativos).ToString("N0"))</h2>
                        <div class="mt-3 pt-3 border-top border-secondary">
                             <small class="text-info fw-bold">Margen Bruto (Venta-Costo): $@Resumen.UtilidadTotal.ToString("N0")</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- 2. VENTAS TOTALES -->
            <div class="col-md-3">
                <div class="p-4 bg-white border border-2 border-primary h-100 shadow-sm position-relative">
                    <div class="position-absolute top-0 end-0 bg-primary text-white px-3 py-1 fw-bold small">INGRESOS</div>
                    <small class="text-primary fw-bold text-uppercase d-block mb-1">VENTAS TOTALES</small>
                    <h3 class="fw-bold text-dark display-6 mb-0">$@Resumen.IngresosVentas.ToString("N0")</h3>
                    <small class="text-muted mt-2 d-block">Facturación bruta del periodo</small>
                </div>
            </div>

            <!-- 3. COMPRA MERCADERÍA -->
            <div class="col-md-3">
                <div class="p-4 bg-white border border-2 border-warning h-100 shadow-sm position-relative">
                    <div class="position-absolute top-0 end-0 bg-warning text-dark px-3 py-1 fw-bold small">STOCK</div>
                    <small class="text-warning fw-bold text-uppercase d-block mb-1 text-dark">COMPRA MERCADERÍA</small>
                    <h3 class="fw-bold text-dark display-6 mb-0">-$@Resumen.GastosMercaderia.ToString("N0")</h3>
                    <small class="text-muted mt-2 d-block">Re-inversión en productos</small>
                </div>
            </div>

            <!-- 4. GASTOS TOTALES -->
            <div class="col-md-3">
                <div class="p-4 bg-white border border-2 border-danger h-100 shadow-sm position-relative">
                    <div class="position-absolute top-0 end-0 bg-danger text-white px-3 py-1 fw-bold small">EGR</div>
                    <small class="text-danger fw-bold text-uppercase d-block mb-1">GASTOS TOTALES</small>
                    <h3 class="fw-bold text-danger display-6 mb-0">-$@Resumen.GastosOperativos.ToString("N0")</h3>
                    <small class="text-muted mt-2 d-block">Operativos + Mercadería</small>
                </div>
            </div>
        </div>

        <!-- DETALLE Y GRÁFICOS (Placeholder text visual) -->
        <div class="row">
            <div class="col-md-6 mb-4">
                <div class="card border-dark rounded-0 h-100">
                    <div class="card-header bg-dark text-white fw-bold rounded-0">
                        RESUMEN DE FLUJO
                    </div>
                    <div class="card-body">
                         <div class="d-flex justify-content-between align-items-center border-bottom py-2">
                             <span class="text-muted">Ingresos por Ventas</span>
                             <span class="fw-bold text-success">$@Resumen.IngresosVentas.ToString("N0")</span>
                         </div>
                         <div class="d-flex justify-content-between align-items-center border-bottom py-2">
                             <span class="text-muted">(-) Costo de Ventas (Histórico)</span>
                             <span class="fw-bold text-danger">-$@((Resumen.IngresosVentas - Resumen.UtilidadTotal).ToString("N0"))</span>
                         </div>
                         <div class="d-flex justify-content-between align-items-center border-bottom py-2 bg-light">
                             <span class="fw-bold text-dark">Utilidad Bruta</span>
                             <span class="fw-bold text-primary">$@Resumen.UtilidadTotal.ToString("N0")</span>
                         </div>
                         <div class="d-flex justify-content-between align-items-center border-bottom py-2">
                             <span class="text-muted">(-) Gastos Operativos Totales</span>
                             <span class="fw-bold text-danger">-$@Resumen.GastosOperativos.ToString("N0")</span>
                         </div>
                         <div class="alert alert-info mt-3 mb-0 rounded-0 text-center fw-bold">
                             SALDO FINAL EN CAJA: $@Resumen.SaldoFinal.ToString("N0")
                             <br/>
                             <small class="fw-normal">(Dinero real disponible)</small>
                         </div>
                    </div>
                </div>
            </div>
            
             <div class="col-md-6 mb-4">
                <div class="card border-dark rounded-0 h-100">
                    <div class="card-header bg-secondary text-white fw-bold rounded-0">
                        DESGLOSE RAPIDO
                    </div>
                    <div class="card-body d-flex flex-column justify-content-center align-items-center text-center">
                        <h4 class="text-uppercase text-muted fw-bold">RENTABILIDAD OPERATIVA</h4>
                        @if (Resumen.IngresosVentas > 0)
                        {
                             var margenPorcentaje = (Resumen.UtilidadTotal / Resumen.IngresosVentas) * 100;
                             <h1 class="display-1 fw-bold @(margenPorcentaje > 30 ? "text-success" : "text-warning")">  
                                 @margenPorcentaje.ToString("F1")%
                             </h1>
                             <small class="text-muted">MARGEN BRUTO SOBRE VENTAS</small>
                        }
                        else
                        {
                            <h2 class="text-muted">SIN DATOS</h2>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="d-flex justify-content-center align-items-center" style="height: 300px;">
            <div class="spinner-border text-dark" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }

</div>

@code {
    private DateTime SelectedDate = DateTime.Now;
    private CajaResumenDto? Resumen;

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task ChangeMonth(int months)
    {
        SelectedDate = SelectedDate.AddMonths(months);
        await CargarDatos();
    }

    private async Task GoToToday()
    {
        SelectedDate = DateTime.Now;
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        try
        {
            string query = $"?month={SelectedDate.Month}&year={SelectedDate.Year}";
            Resumen = await Http.GetFromJsonAsync<CajaResumenDto>($"api/caja/resumen{query}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
    }

    // --- DTOs Locales (Copia de Estructura Backend) ---
    public class CajaResumenDto
    {
        public decimal SaldoAnterior { get; set; }
        public decimal IngresosVentas { get; set; }
        public decimal GastosOperativos { get; set; }
        public decimal AportesExtra { get; set; }
        public decimal SaldoFinal { get; set; }
        public decimal UtilidadTotal { get; set; }
        public decimal GastosMercaderia { get; set; }
        public bool IsLocked { get; set; }
    }
}
