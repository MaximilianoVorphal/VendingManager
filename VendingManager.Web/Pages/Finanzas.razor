@page "/finanzas"
@inject HttpClient Http

<PageTitle>FINANZAS</PageTitle>

<div class="container-fluid px-4 mt-4" style="font-family: 'Segoe UI', Consolas, monospace;">

    <div class="row align-items-center mb-4 border-bottom border-3 border-dark pb-3">
        <div class="col-12 d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <h2 class="m-0 fw-bold text-uppercase" style="letter-spacing: -1px;">ESTADO DE RESULTADOS</h2>
                <small class="text-muted fw-bold">ANÁLISIS DE RENTABILIDAD</small>
            </div>

            <div class="d-flex align-items-center gap-2 flex-wrap justify-content-end">
                <button class="btn btn-dark rounded-0 btn-sm" @onclick="() => ChangeMonth(-1)">◀</button>
                <div class="bg-dark text-white px-3 py-2 fw-bold rounded-0 text-uppercase text-center" style="min-width: 180px;">
                    @SelectedDate.ToString("MMMM yyyy")
                </div>
                <button class="btn btn-dark rounded-0 btn-sm" @onclick="() => ChangeMonth(1)">▶</button>
                <button class="btn btn-outline-dark rounded-0 btn-sm" @onclick="GoToToday" title="Ir a Hoy">Hoy</button>
            </div>
        </div>
    </div>

    @if (Resumen != null)
    {
        <!-- 1. BLOQUE DE VENTAS (INGRESOS) -->
        <h5 class="fw-bold text-uppercase mb-2 text-primary border-bottom border-dark pb-1">1. BLOQUE DE VENTAS (Ingresos)</h5>
        <div class="row mb-4">
            <div class="col-md-6 mb-3">
                 <div class="card h-100 border-0 shadow-sm bg-light">
                    <div class="card-body">
                         <div class="d-flex justify-content-between align-items-center mb-2">
                             <span class="text-muted fw-bold">(+) Ventas Brutas</span>
                             <span class="fw-bold fs-5 text-dark">$@Resumen.IngresosVentas.ToString("N0")</span>
                         </div>
                         <div class="d-flex justify-content-between align-items-center">
                             <span class="text-danger fw-bold">(-) Mermas / Pérdidas</span>
                             <span class="fw-bold fs-5 text-danger">-$@Resumen.Mermas.ToString("N0")</span>
                         </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6 mb-3">
                <div class="card h-100 border-0 shadow bg-primary text-white">
                     <div class="card-body d-flex flex-column justify-content-center align-items-center text-center">
                         <small class="text-uppercase fw-bold opacity-75">VENTAS NETAS</small>
                         <h2 class="fw-bold m-0">$@((Resumen.IngresosVentas - Resumen.Mermas).ToString("N0"))</h2>
                     </div>
                </div>
            </div>
        </div>

        <!-- 2. BLOQUE DE COSTO DIRECTO -->
        <h5 class="fw-bold text-uppercase mb-2 text-warning border-bottom border-dark pb-1">2. BLOQUE DE COSTO DIRECTO</h5>
        <div class="row mb-4">
            <div class="col-md-6 mb-3">
                 <div class="card h-100 border-0 shadow-sm bg-light">
                    <div class="card-body">
                         <div class="d-flex justify-content-between align-items-center">
                             <div>
                                <span class="text-muted fw-bold">(-) Costo de Venta</span>
                             </div>
                             <span class="fw-bold fs-5 text-danger">-$@Resumen.TotalCostoVenta.ToString("N0")</span>
                         </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6 mb-3">
                <div class="card h-100 border-0 shadow bg-warning text-dark">
                     <div class="card-body d-flex flex-column justify-content-center align-items-center text-center">
                         <small class="text-uppercase fw-bold opacity-75">MARGEN BRUTO</small>
                         <h2 class="fw-bold m-0">$@Resumen.UtilidadTotal.ToString("N0")</h2>
                         <small class="fw-bold mt-1">@GetMarginPercentage()% Margen</small>
                     </div>
                </div>
            </div>
        </div>

        <!-- 3. BLOQUE DE GASTOS DE OPERACIÓN -->
        <h5 class="fw-bold text-uppercase mb-2 text-danger border-bottom border-dark pb-1">3. BLOQUE DE GASTOS DE OPERACIÓN</h5>
        <div class="row mb-4">
             <!-- A. GASTOS VARIABLES -->
             <div class="col-md-6 mb-3">
                 <div class="card h-100 border-start border-4 border-danger shadow-sm rounded-0">
                     <div class="card-header bg-white fw-bold">A. Gastos Variables (Logística)</div>
                     <div class="card-body">
                         <div class="d-flex justify-content-between align-items-center mb-2">
                             <span>Bencina, Peajes, Insumos</span>
                             <span class="fw-bold text-danger">-$@Resumen.GastosVariables.ToString("N0")</span>
                         </div>
                     </div>
                 </div>
             </div>

             <!-- B. GASTOS FIJOS -->
             <div class="col-md-6 mb-3">
                 <div class="card h-100 border-start border-4 border-danger shadow-sm rounded-0">
                     <div class="card-header bg-white fw-bold">B. Gastos Fijos (Estructurales)</div>
                     <div class="card-body">
                         <div class="d-flex justify-content-between align-items-center mb-2">
                             <span>WOM, Transbank, Comisión Tarjeta</span>
                             <span class="fw-bold text-danger">-$@Resumen.GastosFijos.ToString("N0")</span>
                         </div>
                     </div>
                 </div>
             </div>
        </div>

        <!-- 4. RESULTADO FINAL -->
        <h5 class="fw-bold text-uppercase mb-2 text-success border-bottom border-dark pb-1">4. RESULTADO FINAL</h5>
        <div class="row mb-2">
            <div class="col-12">
                 <div class="card border-0 shadow rounded-0 bg-dark text-white mb-2">
                     <div class="card-body d-flex justify-content-between align-items-center px-4 py-3">
                        <div>
                             <h4 class="m-0 fw-bold">(=) UTILIDAD OPERACIONAL</h4>
                        </div>
                        <h2 class="m-0 fw-bold text-white">$@Resumen.UtilidadOperacional.ToString("N0")</h2>
                     </div>
                 </div>
            </div>
        </div>

        <div class="row mb-4">
             <div class="col-md-6">
                 <div class="card border-dark border-dashed h-100 bg-transparent text-muted">
                     <div class="card-body d-flex justify-content-between align-items-center">
                         <span class="fw-bold">(-) Meta de Sueldo / Retiro</span>
                         <span class="fs-5">-$@Resumen.SueldoEsperado.ToString("N0")</span>
                     </div>
                 </div>
             </div>
             <div class="col-md-6">
                 <div class="card border-0 shadow-lg h-100" style="background: linear-gradient(135deg, #11998e, #38ef7d);">
                     <div class="card-body d-flex flex-column justify-content-center align-items-center text-center text-white py-4">
                          <small class="text-uppercase fw-bold text-white-50">UTILIDAD NETA REAL</small>
                          <h1 class="display-4 fw-bold m-0">$@Resumen.UtilidadNeta.ToString("N0")</h1>
                     </div>
                 </div>
             </div>
        </div>

    }
    else
    {
        <div class="d-flex justify-content-center align-items-center" style="height: 300px;">
            <div class="spinner-border text-dark" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }

</div>

@code {
    private DateTime SelectedDate = DateTime.Now;
    private CajaResumenDto? Resumen;

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task ChangeMonth(int months)
    {
        SelectedDate = SelectedDate.AddMonths(months);
        await CargarDatos();
    }

    private async Task GoToToday()
    {
        SelectedDate = DateTime.Now;
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        try
        {
            string query = $"?month={SelectedDate.Month}&year={SelectedDate.Year}";
            Resumen = await Http.GetFromJsonAsync<CajaResumenDto>($"api/caja/resumen{query}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
    }

    private string GetMarginPercentage()
    {
        if (Resumen == null || Resumen.IngresosVentas == 0) return "0.0";
        double margin = (double)Resumen.UtilidadTotal / (double)Resumen.IngresosVentas;
        return (margin * 100).ToString("F1");
    }

    // --- DTO Local (Updated) ---
    public class CajaResumenDto
    {
        public decimal SaldoAnterior { get; set; }
        public decimal IngresosVentas { get; set; }
        public decimal GastosOperativos { get; set; }
        public decimal AportesExtra { get; set; }
        public decimal SaldoFinal { get; set; }
        public decimal UtilidadTotal { get; set; }
        public decimal GastosMercaderia { get; set; }
        public decimal TotalCostoVenta { get; set; } 
        public decimal Mermas { get; set; }          
        public decimal GastosVariables { get; set; } 
        public decimal GastosFijos { get; set; }     
        public decimal UtilidadOperacional { get; set; } 
        public decimal SueldoEsperado { get; set; }  
        public decimal UtilidadNeta { get; set; }    
        public bool IsLocked { get; set; }
    }
}
