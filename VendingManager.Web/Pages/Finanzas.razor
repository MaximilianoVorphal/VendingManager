@page "/finanzas"
@inject HttpClient Http

<PageTitle>FINANZAS</PageTitle>

<div class="container-fluid px-4 mt-4" style="font-family: 'Segoe UI', Consolas, monospace;">

    <!-- HEADER SECCION -->
    <div class="row align-items-center mb-4 border-bottom border-3 border-dark pb-3">
        <div class="col-12 d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <h2 class="m-0 fw-bold text-uppercase" style="letter-spacing: -1px;">ESTADO DE RESULTADOS</h2>
                <small class="text-muted fw-bold">ANÁLISIS DE RENTABILIDAD MENSUAL</small>
            </div>

            <div class="d-flex align-items-center gap-2 flex-wrap justify-content-end">
                <button class="btn btn-dark rounded-0 btn-sm" @onclick="() => ChangeMonth(-1)">◀</button>
                <div class="bg-dark text-white px-3 py-2 fw-bold rounded-0 text-uppercase text-center" style="min-width: 180px;">
                    @SelectedDate.ToString("MMMM yyyy")
                </div>
                <button class="btn btn-dark rounded-0 btn-sm" @onclick="() => ChangeMonth(1)">▶</button>
                <button class="btn btn-outline-dark rounded-0 btn-sm" @onclick="GoToToday" title="Ir a Hoy">Hoy</button>
            </div>
        </div>
    </div>

    @if (Resumen != null)
    {
        <!-- 1. BLOQUE DE VENTAS (INGRESOS) -->
        <div class="row mb-4">
            <div class="col-12 mb-2">
                <h5 class="fw-bold text-uppercase border-bottom border-2 border-dark pb-2 mb-0 d-flex align-items-center gap-2">
                     <span class="bg-primary text-white px-2 py-1 rounded-0" style="font-size: 0.8rem;">01</span>
                     BLOQUE DE VENTAS (INGRESOS)
                </h5>
            </div>
            
            <div class="col-md-4 mb-3">
                 <div class="card h-100 border-2 border-dark rounded-0 shadow-sm">
                    <div class="card-body bg-light">
                         <div class="d-flex justify-content-between align-items-center mb-2">
                             <span class="text-muted fw-bold text-uppercase small">Ventas Brutas</span>
                             <span class="fw-bold fs-5 text-dark font-monospace">$@Resumen.IngresosVentas.ToString("N0")</span>
                         </div>
                         <div class="d-flex justify-content-between align-items-center">
                             <span class="text-danger fw-bold text-uppercase small">(-) Mermas / Pérdidas</span>
                             <span class="fw-bold fs-5 text-danger font-monospace">-$@Resumen.Mermas.ToString("N0")</span>
                         </div>
                    </div>
                </div>
            </div>
            <div class="col-md-8 mb-3">
                <div class="card h-100 border-2 border-dark rounded-0 shadow bg-primary text-white">
                     <div class="card-body d-flex flex-row justify-content-between align-items-center px-5">
                         <div class="text-start">
                              <small class="text-uppercase fw-bold opacity-75 d-block">Resultado Bloque 1</small>
                              <h2 class="fw-bold m-0 text-uppercase">VENTAS NETAS</h2>
                         </div>
                         <h1 class="display-5 fw-bold m-0 font-monospace">$@((Resumen.IngresosVentas - Resumen.Mermas).ToString("N0"))</h1>
                     </div>
                </div>
            </div>
        </div>

        <!-- 2. BLOQUE DE COSTO DIRECTO -->
        <div class="row mb-4">
            <div class="col-12 mb-2">
                <h5 class="fw-bold text-uppercase border-bottom border-2 border-dark pb-2 mb-0 d-flex align-items-center gap-2">
                     <span class="bg-warning text-dark px-2 py-1 rounded-0" style="font-size: 0.8rem;">02</span>
                     BLOQUE COSTO DIRECTO
                </h5>
            </div>

            <div class="col-md-4 mb-3">
                 <div class="card h-100 border-2 border-dark rounded-0 shadow-sm">
                    <div class="card-body bg-light d-flex align-items-center justify-content-between">
                         <div>
                            <span class="text-muted fw-bold text-uppercase small d-block">(-) Costo de Venta</span>
                            <small class="text-muted">Reposición de Mercadería</small>
                         </div>
                         <span class="fw-bold fs-4 text-danger font-monospace">-$@Resumen.TotalCostoVenta.ToString("N0")</span>
                    </div>
                </div>
            </div>
            <div class="col-md-8 mb-3">
                <div class="card h-100 border-2 border-dark rounded-0 shadow bg-warning text-dark">
                     <div class="card-body d-flex flex-row justify-content-between align-items-center px-5">
                         <div class="text-start">
                             <small class="text-uppercase fw-bold opacity-75 d-block">Resultado Bloque 2</small>
                             <h2 class="fw-bold m-0 text-uppercase">MARGEN BRUTO</h2>
                         </div>
                         <div class="text-end">
                             <h1 class="display-5 fw-bold m-0 font-monospace">$@Resumen.UtilidadTotal.ToString("N0")</h1>
                             <span class="badge bg-dark text-white rounded-0 fs-6">@GetMarginPercentage()% DE MARGEN</span>
                         </div>
                     </div>
                </div>
            </div>
        </div>

        <!-- 3. BLOQUE DE GASTOS DE OPERACIÓN -->
        <div class="row mb-4">
             <div class="col-12 mb-2">
                <h5 class="fw-bold text-uppercase border-bottom border-2 border-dark pb-2 mb-0 d-flex align-items-center gap-2">
                     <span class="bg-danger text-white px-2 py-1 rounded-0" style="font-size: 0.8rem;">03</span>
                     GASTOS DE OPERACIÓN
                </h5>
            </div>

             <!-- A. GASTOS VARIABLES -->
             <div class="col-md-6 mb-3">
                 <div class="card h-100 border-2 border-danger rounded-0 shadow-sm">
                     <div class="card-header bg-danger text-white fw-bold rounded-0 text-uppercase d-flex justify-content-between">
                         <span>A. Gastos Variables</span>
                         <i class="bi bi-truck"></i>
                     </div>
                     <div class="card-body">
                         <div class="d-flex justify-content-between align-items-center mb-2">
                             <span class="fw-bold small text-muted text-uppercase">Logística, Bencina, Insumos</span>
                             <span class="fw-bold text-danger fs-5 font-monospace">-$@Resumen.GastosVariables.ToString("N0")</span>
                         </div>
                     </div>
                 </div>
             </div>

             <!-- B. GASTOS FIJOS -->
             <div class="col-md-6 mb-3">
                 <div class="card h-100 border-2 border-danger rounded-0 shadow-sm">
                     <div class="card-header bg-danger text-white fw-bold rounded-0 text-uppercase d-flex justify-content-between">
                         <span>B. Gastos Fijos</span>
                         <i class="bi bi-building"></i>
                     </div>
                     <div class="card-body">
                         <div class="d-flex justify-content-between align-items-center mb-2">
                             <span class="fw-bold small text-muted text-uppercase">Estructurales, Servicios</span>
                             <span class="fw-bold text-danger fs-5 font-monospace">-$@Resumen.GastosFijos.ToString("N0")</span>
                         </div>
                     </div>
                 </div>
             </div>
        </div>

        <!-- 4. RESULTADO FINAL -->
        <div class="row mb-2">
             <div class="col-12">
                 <h5 class="fw-bold text-uppercase border-bottom border-2 border-dark pb-2 mb-3 d-flex align-items-center gap-2 text-success">
                     <span class="bg-dark text-white px-2 py-1 rounded-0" style="font-size: 0.8rem;">04</span>
                     RESULTADO FINAL
                </h5>
            </div>

            <div class="col-12 mb-3">
                 <div class="card border-2 border-dark shadow rounded-0 bg-dark text-white">
                     <div class="card-body d-flex justify-content-between align-items-center px-4 py-4">
                        <div>
                             <small class="text-white-50 fw-bold text-uppercase d-block mb-1">Resultado Operacional (EBITDA)</small>
                             <h2 class="m-0 fw-bold text-uppercase">(=) UTILIDAD OPERACIONAL</h2>
                        </div>
                        <h1 class="m-0 fw-bold text-white display-4 font-monospace">$@Resumen.UtilidadOperacional.ToString("N0")</h1>
                     </div>
                 </div>
            </div>
        </div>

        <div class="row mb-5">
             <div class="col-md-6">
                 <div class="card border-2 border-dashed border-dark h-100 bg-transparent text-muted rounded-0">
                     <div class="card-body d-flex justify-content-between align-items-center px-4">
                         <span class="fw-bold text-uppercase">(-) Meta de Sueldo / Retiro</span>
                         <span class="fs-4 font-monospace text-dark fw-bold">-$@Resumen.SueldoEsperado.ToString("N0")</span>
                     </div>
                 </div>
             </div>
             <div class="col-md-6">
                 <div class="card border-2 border-dark shadow-lg h-100 rounded-0 bg-success text-white">
                     <div class="card-body d-flex flex-column justify-content-center align-items-center text-center text-white py-4">
                          <small class="text-uppercase fw-bold text-white opacity-75 mb-2">RESULTADO NETO FINAL</small>
                          <h1 class="display-3 fw-bold m-0 font-monospace">$@Resumen.UtilidadNeta.ToString("N0")</h1>
                     </div>
                 </div>
             </div>
        </div>

    }
    else
    {
        <div class="d-flex justify-content-center align-items-center border-2 border-dark border bg-light" style="height: 300px;">
            <div class="text-center">
                 <div class="spinner-border text-dark mb-3" role="status"></div>
                 <h5 class="fw-bold text-uppercase">Calculando Finanzas...</h5>
            </div>
        </div>
    }

</div>

@code {
    private DateTime SelectedDate = DateTime.Now;
    private CajaResumenDto? Resumen;

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task ChangeMonth(int months)
    {
        SelectedDate = SelectedDate.AddMonths(months);
        await CargarDatos();
    }

    private async Task GoToToday()
    {
        SelectedDate = DateTime.Now;
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        try
        {
            string query = $"?month={SelectedDate.Month}&year={SelectedDate.Year}";
            Resumen = await Http.GetFromJsonAsync<CajaResumenDto>($"api/caja/resumen{query}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
    }

    private string GetMarginPercentage()
    {
        if (Resumen == null || Resumen.IngresosVentas == 0) return "0.0";
        double margin = (double)Resumen.UtilidadTotal / (double)Resumen.IngresosVentas;
        return (margin * 100).ToString("F1");
    }

    // --- DTO Local (Updated) ---
    public class CajaResumenDto
    {
        public decimal SaldoAnterior { get; set; }
        public decimal IngresosVentas { get; set; }
        public decimal GastosOperativos { get; set; }
        public decimal AportesExtra { get; set; }
        public decimal SaldoFinal { get; set; }
        public decimal UtilidadTotal { get; set; }
        public decimal GastosMercaderia { get; set; }
        public decimal TotalCostoVenta { get; set; } 
        public decimal Mermas { get; set; }          
        public decimal GastosVariables { get; set; } 
        public decimal GastosFijos { get; set; }     
        public decimal UtilidadOperacional { get; set; } 
        public decimal SueldoEsperado { get; set; }  
        public decimal UtilidadNeta { get; set; }    
        public bool IsLocked { get; set; }
    }
}
