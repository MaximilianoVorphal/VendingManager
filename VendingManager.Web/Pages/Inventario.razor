@page "/inventario"
@inject HttpClient Http
@inject IJSRuntime JS
@using System.Net.Http.Headers

<PageTitle>INVENTARIO</PageTitle>

<div class="container-fluid px-4 mt-4" style="font-family: 'Segoe UI', Consolas, monospace;">

    <div class="row align-items-center mb-4 border-bottom border-3 border-dark pb-3 g-3">
        <div class="col-md-5 col-12">
            <h2 class="m-0 fw-bold text-uppercase" style="letter-spacing: -1px; color: #333;">
                <i class="bi bi-box-seam me-2"></i>MAESTRO DE PRODUCTOS
            </h2>
            <small class="text-muted fw-bold">GESTIÓN CENTRALIZADA DE INVENTARIO</small>
        </div>

        <div class="col-md-7 col-12">
            <div class="d-flex flex-wrap gap-2 justify-content-md-end">
                <!-- SEARCH BAR -->
                <div class="input-group" style="max-width: 300px;">
                    <span class="input-group-text bg-white border-dark rounded-0"><i class="bi bi-search"></i></span>
                    <input type="text" class="form-control border-dark rounded-0 shadow-sm" 
                           placeholder="Buscar producto, SKU..." 
                           @bind="SearchTerm" @bind:event="oninput" />
                </div>

                <label class="btn btn-dark rounded-0 fw-bold shadow">
                    <i class="bi bi-file-earmark-excel me-2"></i>IMPORTAR
                    <InputFile OnChange="@SubirCatalogo" style="display: none;" accept=".xls,.xlsx" />
                </label>
            </div>
            
             @if (Cargando)
            {
                <div class="text-end mt-1">
                    <span class="fw-bold text-primary small">Procesando...</span>
                </div>
            }
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Mensaje))
    {
        <div class="alert @AlertClass border-dark rounded-0 fw-bold mb-4 shadow-sm fade show">
            @Mensaje
        </div>
    }

    <div class="card border-2 border-dark rounded-0 shadow my-4">
        <div class="card-header bg-dark text-white rounded-0 fw-bold d-flex justify-content-between align-items-center flex-wrap">
            <span>INVENTARIO: @FilteredProductos.Count() ITEMS (Total: @Productos.Count)</span>
            <span>VALOR: $@FilteredProductos.Sum(x => x.StockBodega * x.CostoPromedio).ToString("N0")</span>
        </div>
        <div class="table-responsive">
            <table class="table table-hover table-bordered border-dark m-0 align-middle">
                <thead class="bg-secondary text-white text-uppercase" style="font-size: 0.85rem;">
                    <tr>
                        <th class="text-center sortable-header" @onclick="@(() => SortBy("Codigo"))">
                            CÓDIGO <i class="@GetSortIcon("Codigo")"></i>
                        </th>
                        <th class="sortable-header" @onclick="@(() => SortBy("Nombre"))">
                            PRODUCTO <i class="@GetSortIcon("Nombre")"></i>
                        </th>
                        <th class="text-center sortable-header" @onclick="@(() => SortBy("Categoria"))">
                            CATEGORÍA <i class="@GetSortIcon("Categoria")"></i>
                        </th>
                        <th class="text-center sortable-header" @onclick="@(() => SortBy("Proveedor"))">
                            PROVEEDOR <i class="@GetSortIcon("Proveedor")"></i>
                        </th>
                        <th class="text-end sortable-header" @onclick="@(() => SortBy("Costo"))">
                            COSTO <i class="@GetSortIcon("Costo")"></i>
                        </th>
                        <th class="text-end sortable-header" @onclick="@(() => SortBy("Precio"))">
                            PRECIO <i class="@GetSortIcon("Precio")"></i>
                        </th>
                        <th class="text-center sortable-header" @onclick="@(() => SortBy("Stock"))">
                            STOCK <i class="@GetSortIcon("Stock")"></i>
                        </th>
                        <th class="text-center" style="min-width: 120px;">ACCIONES</th>
                    </tr>
                </thead>
                <tbody class="bg-white fw-bold" style="font-size: 0.9rem;">
                    @if (Cargando && Productos.Count == 0)
                    {
                        <tr>
                            <td colspan="8" class="text-center p-4">Cargando datos...</td>
                        </tr>
                    }
                    else if (Productos.Count == 0)
                    {
                        <tr>
                            <td colspan="8" class="text-center p-4 text-muted">No hay productos registrados. Importa una plantilla.</td>
                        </tr>
                    }
                    else if (!FilteredProductos.Any())
                    {
                        <tr>
                             <td colspan="8" class="text-center p-4 text-muted">No se encontraron resultados para "@SearchTerm".</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var p in PagedProductos)
                        {
                            <tr class="@(p.StockBodega < 5 ? "table-danger-custom" : "")">
                                <td class="text-center font-monospace bg-light">@p.CodigoBarras</td>
                                <td>@p.Nombre</td>
                                <td class="text-center"><span class="badge bg-light text-dark border border-dark rounded-0">@p.Categoria</span></td>
                                <td class="text-center small text-muted">@p.Proveedor</td>
                                <td class="text-end font-monospace text-muted">$@p.CostoPromedio.ToString("N0")</td>
                                <td class="text-end font-monospace text-success">$@p.PrecioVenta.ToString("N0")</td>

                                <td class="text-center">
                                    <span class="fs-6 fw-bold @(p.StockBodega < 10 ? "text-danger" : "text-dark")">
                                        @p.StockBodega
                                    </span>
                                </td>

                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-2 flex-wrap">
                                        <!-- BOTÓN EDITAR -->
                                        <button class="btn btn-sm btn-outline-warning rounded-0 fw-bold border-dark text-dark"
                                            title="Editar Producto" @onclick="() => AbrirModalEditar(p)">
                                            <i class="bi bi-pencil-square"></i>
                                        </button>

                                        <!-- BOTÓN INGRESO -->
                                        <button class="btn btn-sm btn-outline-success rounded-0 fw-bold border-dark"
                                            title="Ingresar nueva mercadería" @onclick="() => AbrirModal(p, true)">
                                            <i class="bi bi-box-arrow-in-down"></i>
                                        </button>

                                        <!-- BOTÓN REPONER -->
                                        <button class="btn btn-sm btn-outline-primary rounded-0 fw-bold border-dark"
                                            title="Cargar máquina (Salida)" @onclick="() => AbrirModal(p, false)">
                                            <i class="bi bi-box-arrow-up"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        
        <!-- PAGINATION -->
        @if (TotalPages > 1)
        {
            <div class="card-footer bg-light border-top border-dark d-flex justify-content-between align-items-center">
                <span class="text-muted small fw-bold">Página @CurrentPage de @TotalPages</span>
                <nav>
                    <ul class="pagination pagination-sm m-0">
                        <li class="page-item @(CurrentPage == 1 ? "disabled" : "")">
                            <button class="page-link text-dark fw-bold" @onclick="() => ChangePage(CurrentPage - 1)">Anterior</button>
                        </li>
                        <li class="page-item @(CurrentPage == TotalPages ? "disabled" : "")">
                             <button class="page-link text-dark fw-bold" @onclick="() => ChangePage(CurrentPage + 1)">Siguiente</button>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>

<style>
    .sortable-header {
        cursor: pointer;
        user-select: none;
    }
    .sortable-header:hover {
        background-color: #555 !important;
    }
    .table-danger-custom {
        background-color: #fff5f5 !important;
    }
</style>

<!-- MODAL UNIFICADO (INGRESO / SALIDA) -->
@if (MostrarModal && ProductoSeleccionado != null)
{
    var esIngreso = EsIngresoStock; 
    var colorModal = esIngreso ? "bg-success" : "bg-primary";
    var colorBoton = esIngreso ? "btn-success" : "btn-primary";
    var textoAccion = esIngreso ? "INGRESAR A BODEGA" : "CARGAR EN MÁQUINA";
    var titulo = esIngreso ? "INGRESAR MERCADERÍA" : "REPONER PRODUCTO";
    var icono = esIngreso ? "bi-box-arrow-in-down" : "bi-box-arrow-up";

    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-0 border-2 border-dark shadow-lg">
                <div class="modal-header @colorModal text-white rounded-0">
                    <h5 class="modal-title fw-bold"><i class="bi @icono me-2"></i>@titulo</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarModal"></button>
                </div>
                <div class="modal-body p-4 text-center">
                    <h4 class="fw-bold mb-1">@ProductoSeleccionado.Nombre</h4>
                    <p class="text-muted small mb-4">@ProductoSeleccionado.CodigoBarras | STOCK ACTUAL:
                        @ProductoSeleccionado.StockBodega</p>

                    <div class="mb-4 text-start">
                        <label class="form-label fw-bold small">CANTIDAD A @(esIngreso ? "INGRESAR" : "SACAR")</label>
                        <input type="number" class="form-control form-control-lg rounded-0 border-dark fw-bold text-center"
                        @bind="CantidadMovimiento" @bind:event="oninput" min="1" />

                        <div class="form-text mt-2 fw-bold text-muted">
                            Stock final en bodega:
                            <span class="@(StockInsuficiente ? "text-danger" : "text-dark")">
                                @(esIngreso
                            ? ProductoSeleccionado.StockBodega + CantidadMovimiento
                            : ProductoSeleccionado.StockBodega - CantidadMovimiento)
                            </span>
                        </div>
                    </div>

                    @if (!esIngreso && StockInsuficiente)
                    {
                        <div class="alert alert-danger rounded-0 fw-bold small mb-3">
                            <i class="bi bi-exclamation-triangle-fill me-1"></i> No hay suficiente stock disponible para reponer
                            esta cantidad.
                        </div>
                    }
                </div>
                <div class="modal-footer bg-light rounded-0">
                    <button type="button" class="btn btn-outline-secondary rounded-0 border-dark fw-bold"
                    @onclick="CerrarModal">CANCELAR</button>
                    <button type="button" class="btn @colorBoton rounded-0 border-dark fw-bold px-4"
                    @onclick="ConfirmarMovimiento"
                    disabled="@(!esIngreso && StockInsuficiente || CantidadMovimiento <= 0)">
                        CONFIRMAR @(esIngreso ? "INGRESO" : "SALIDA")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- MODAL EDICIÓN PRO -->
@if (MostrarModalEditar && ProductoEditar != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content rounded-0 border-2 border-dark shadow-lg">
                <div class="modal-header bg-warning text-dark rounded-0 border-bottom border-dark">
                    <h5 class="modal-title fw-bold"><i class="bi bi-pencil-square me-2"></i>EDITAR FICHA TÉCNICA</h5>
                    <button type="button" class="btn-close" @onclick="CerrarModalEditar"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold small">NOMBRE DEL PRODUCTO</label>
                            <input type="text" class="form-control rounded-0 border-dark" @bind="ProductoEditar.Nombre" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold small">CÓDIGO DE BARRAS / SKU</label>
                            <input type="text" class="form-control rounded-0 border-dark font-monospace"
                            @bind="ProductoEditar.CodigoBarras" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold small">CATEGORÍA</label>
                            <input type="text" class="form-control rounded-0 border-dark"
                            @bind="ProductoEditar.Categoria" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold small">PROVEEDOR</label>
                            <input type="text" class="form-control rounded-0 border-dark"
                            @bind="ProductoEditar.Proveedor" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-success">PRECIO VENTA ($)</label>
                            <input type="number" class="form-control rounded-0 border-dark fw-bold text-success"
                            @bind="ProductoEditar.PrecioVenta" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-muted">COSTO UNITARIO ($)</label>
                            <input type="number" class="form-control rounded-0 border-dark fw-bold text-muted"
                            @bind="ProductoEditar.CostoPromedio" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light rounded-0">
                    <button type="button" class="btn btn-outline-dark rounded-0 fw-bold"
                    @onclick="CerrarModalEditar">CANCELAR</button>
                    <button type="button" class="btn btn-warning rounded-0 border-dark fw-bold px-4"
                    @onclick="GuardarEdicion">
                        <i class="bi bi-save me-2"></i>GUARDAR CAMBIOS
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<ProductoDTO> Productos = new();
    private string Mensaje = "";
    private string AlertClass = "alert-info";
    private bool Cargando = false;

    // Filter & Sort State
    private string SearchTerm = "";
    private string SortColumn = "Nombre";
    private bool IsAscending = true;
    
    // Pagination State
    private int CurrentPage = 1;
    private int PageSize = 10;

    // Derived Properties
    private IEnumerable<ProductoDTO> FilteredProductos 
    {
        get 
        {
            var query = Productos.AsEnumerable();

            // 1. Search
            if (!string.IsNullOrWhiteSpace(SearchTerm))
            {
                var term = SearchTerm.ToLower();
                query = query.Where(p => 
                    (p.Nombre?.ToLower().Contains(term) ?? false) || 
                    (p.CodigoBarras?.ToLower().Contains(term) ?? false) || 
                    (p.Proveedor?.ToLower().Contains(term) ?? false));
            }

            // 2. Sort
            query = SortColumn switch
            {
                "Codigo" => IsAscending ? query.OrderBy(p => p.CodigoBarras) : query.OrderByDescending(p => p.CodigoBarras),
                "Nombre" => IsAscending ? query.OrderBy(p => p.Nombre) : query.OrderByDescending(p => p.Nombre),
                "Categoria" => IsAscending ? query.OrderBy(p => p.Categoria) : query.OrderByDescending(p => p.Categoria),
                "Proveedor" => IsAscending ? query.OrderBy(p => p.Proveedor) : query.OrderByDescending(p => p.Proveedor),
                "Costo" => IsAscending ? query.OrderBy(p => p.CostoPromedio) : query.OrderByDescending(p => p.CostoPromedio),
                "Precio" => IsAscending ? query.OrderBy(p => p.PrecioVenta) : query.OrderByDescending(p => p.PrecioVenta),
                "Stock" => IsAscending ? query.OrderBy(p => p.StockBodega) : query.OrderByDescending(p => p.StockBodega),
                _ => query
            };

            return query; 
        }
    }

    private IEnumerable<ProductoDTO> PagedProductos => FilteredProductos
        .Skip((CurrentPage - 1) * PageSize)
        .Take(PageSize);

    private int TotalPages => (int)Math.Ceiling(FilteredProductos.Count() / (double)PageSize);

    // Modal Stock State
    private bool MostrarModal = false;
    private bool EsIngresoStock = false;
    private ProductoDTO? ProductoSeleccionado;
    private int CantidadMovimiento = 1;
    private bool StockInsuficiente => !EsIngresoStock && ProductoSeleccionado != null && (ProductoSeleccionado.StockBodega -
    CantidadMovimiento) < 0;

    // Modal Edición State
    private bool MostrarModalEditar = false;
    private ProductoDTO? ProductoEditar;

    protected override async Task OnInitializedAsync()
    {
        await CargarInventario();
    }

    private async Task CargarInventario()
    {
        try { Productos = await Http.GetFromJsonAsync<List<ProductoDTO>>("api/productos") ?? new(); }
        catch (Exception ex) { Mensaje = "Error critico: " + ex.Message; AlertClass = "alert-danger"; }
    }

    private void SortBy(string column)
    {
        if (SortColumn == column)
        {
            IsAscending = !IsAscending;
        }
        else
        {
            SortColumn = column;
            IsAscending = true;
        }
        CurrentPage = 1; // Reset to page 1 on sort
    }

    private string GetSortIcon(string column)
    {
        if (SortColumn != column) return "bi bi-arrow-down-up text-muted opacity-25";
        return IsAscending ? "bi bi-arrow-up-circle-fill" : "bi bi-arrow-down-circle-fill";
    }

    private void ChangePage(int page)
    {
        if (page < 1 || page > TotalPages) return;
        CurrentPage = page;
    }

    // --- ACCIONES STOCK ---
    private void AbrirModal(ProductoDTO producto, bool esIngreso)
    {
        ProductoSeleccionado = producto;
        EsIngresoStock = esIngreso;
        CantidadMovimiento = 1;
        MostrarModal = true;
    }

    private void CerrarModal()
    {
        MostrarModal = false;
        ProductoSeleccionado = null;
    }

    private async Task ConfirmarMovimiento()
    {
        if (ProductoSeleccionado == null || CantidadMovimiento <= 0) return;
        if (!EsIngresoStock && StockInsuficiente) return;

        int nuevoStock = EsIngresoStock
        ? ProductoSeleccionado.StockBodega + CantidadMovimiento
        : ProductoSeleccionado.StockBodega - CantidadMovimiento;

        try
        {
            var dto = new { ProductoId = ProductoSeleccionado.Id, NuevoStock = nuevoStock };
            var response = await Http.PostAsJsonAsync("api/productos/ajustar-stock", dto);

            if (response.IsSuccessStatusCode)
            {
                ProductoSeleccionado.StockBodega = nuevoStock;
                var verbo = EsIngresoStock ? "ingresaron" : "sacaron";
                Mensaje = $"✅ Éxito: Se {verbo} {CantidadMovimiento} unidades de '{ProductoSeleccionado.Nombre}'.";
                AlertClass = "alert-success";
                CerrarModal();
            }
            else { Mensaje = "❌ Fallo al actualizar stock."; AlertClass = "alert-danger"; }
        }
        catch (Exception ex) { Mensaje = "❌ Error de conexión: " + ex.Message; AlertClass = "alert-danger"; }
    }

    // --- ACCIONES EDICIÓN ---
    private void AbrirModalEditar(ProductoDTO producto)
    {
        // Clonar para no modificar la tabla directamente hasta confirmar
        ProductoEditar = new ProductoDTO
        {
            Id = producto.Id,
            Nombre = producto.Nombre,
            CodigoBarras = producto.CodigoBarras,
            SKU = producto.SKU, // Copiar SKU
            Categoria = producto.Categoria,
            Proveedor = producto.Proveedor,
            CostoPromedio = producto.CostoPromedio,
            PrecioVenta = producto.PrecioVenta,
            StockBodega = producto.StockBodega
        };
        MostrarModalEditar = true;
    }

    private void CerrarModalEditar()
    {
        MostrarModalEditar = false;
        ProductoEditar = null;
    }

    private async Task GuardarEdicion()
    {
        if (ProductoEditar == null) return;

        // Asegurar consistencia si SKU está vacío
        if (string.IsNullOrEmpty(ProductoEditar.SKU)) ProductoEditar.SKU = ProductoEditar.CodigoBarras ?? "SIN-SKU";

        try
        {
            var response = await Http.PutAsJsonAsync($"api/productos/{ProductoEditar.Id}", ProductoEditar);
            if (response.IsSuccessStatusCode)
            {
                Mensaje = "✅ Producto actualizado correctamente.";
                AlertClass = "alert-success";
                await CargarInventario(); // Recargar lista completa
                CerrarModalEditar();
            }
            else
            {
                Mensaje = "❌ Error al guardar cambios en el servidor.";
                AlertClass = "alert-danger";
            }
        }
        catch (Exception ex)
        {
            Mensaje = $"❌ Error crítico al editar: {ex.Message}";
            AlertClass = "alert-danger";
        }
    }

    private async Task SubirCatalogo(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;
        Cargando = true;
        try
        {
            var content = new MultipartFormDataContent();
            var fileContent = new StreamContent(file.OpenReadStream(maxAllowedSize: 10485760));
            fileContent.Headers.ContentType = new MediaTypeHeaderValue("application/vnd.ms-excel");
            content.Add(fileContent, "file", file.Name);

            var response = await Http.PostAsync("api/productos/importar-catalogo", content);

            if (response.IsSuccessStatusCode)
            {
                Mensaje = "✅ Catálogo importado correctamente.";
                AlertClass = "alert-success";
                await CargarInventario();
            }
            else
            {
                Mensaje = $"❌ Error: {await response.Content.ReadAsStringAsync()}";
                AlertClass = "alert-danger";
            }
        }
        catch (Exception ex) { Mensaje = $"❌ Error crítico: {ex.Message}"; AlertClass = "alert-danger"; }
        finally { Cargando = false; }
    }

    public class ProductoDTO
    {
        public int Id { get; set; }
        public string Nombre { get; set; } = "";
        public string? CodigoBarras { get; set; }
        public string SKU { get; set; } = "";
        public string? Categoria { get; set; }
        public string? Proveedor { get; set; }
        public decimal CostoPromedio { get; set; }
        public decimal PrecioVenta { get; set; }
        public int StockBodega { get; set; }
    }
}
