@page "/reportes"
@inject HttpClient Http
@inject Microsoft.Extensions.Logging.ILogger<Reportes> Logger
@inject NavigationManager NavManager
@inject IJSRuntime JS
@using Microsoft.AspNetCore.WebUtilities

<div class="container-fluid px-2 px-md-4 mt-4" style="font-family: 'Segoe UI', Consolas, monospace;">

    <!-- HEADER -->
    <div class="row align-items-center mb-4 border-bottom border-3 border-dark pb-3">
        <div class="col-12">
            <h2 class="m-0 fw-bold text-uppercase" style="letter-spacing: -1px;">INFORME DE VENTAS</h2>
            <small class="text-muted fw-bold">ANÁLISIS DE RENDIMIENTO Y TRANSACCIONES</small>
        </div>
    </div>

    <!-- CONTROL PANEL -->
    <div class="card border-2 border-dark rounded-0 shadow-sm mb-4">
        <div class="card-body bg-light p-3">
            <div class="row align-items-end g-3">
                <div class="col-md-3 col-12">
                    <label class="fw-bold small text-uppercase mb-1">UNIDAD:</label>
                    <!-- Added py-2 for better vertical centering of text in select -->
                    <select class="form-select border-dark rounded-0 fw-bold py-2" @bind="MaquinaSeleccionada">
                        <option value="0">:: TODAS LAS UNIDADES ::</option>
                        @if (ListaMaquinas != null)
                        {
                            @foreach (var m in ListaMaquinas)
                            {
                                <option value="@m.Id">@m.Nombre.ToUpper()</option>
                            }
                        }
                    </select>
                </div>
                <!-- Fechas grouped for mobile 2-col layout -->
                <div class="col-6 col-md-3">
                    <label class="fw-bold small text-uppercase mb-1">DESDE:</label>
                    <input type="date" @bind="FechaInicio" class="form-control border-dark rounded-0 fw-bold" />
                </div>
                <div class="col-6 col-md-3">
                    <label class="fw-bold small text-uppercase mb-1">HASTA:</label>
                    <input type="date" @bind="FechaFin" class="form-control border-dark rounded-0 fw-bold" />
                </div>
                <div class="col-12 col-md-3 d-flex gap-2">
                    <button class="btn btn-dark flex-grow-1 rounded-0 fw-bold py-2" @onclick="CargarReporte"
                        disabled="@Cargando">
                        @(Cargando ? "PROCESANDO..." : "EJECUTAR QUERY")
                    </button>
                    <button class="btn btn-success rounded-0 fw-bold border-dark py-2" @onclick="ExportarExcel"
                        title="Exportar a Excel" style="width: 50px;">
                        <i class="bi bi-file-earmark-excel"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(MensajeError))
    {
        <div class="alert alert-danger border-2 border-dark rounded-0 mb-4 shadow-sm fw-bold">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> ERROR DE SISTEMA: @MensajeError
        </div>
    }

    @if (Cargando)
    {
        <div class="text-center py-5 border border-dark border-2 bg-light">
            <div class="spinner-grow text-dark" role="status"></div>
            <p class="mt-2 fw-bold text-uppercase" style="letter-spacing: 2px;">Conectando Base de Datos...</p>
        </div>
    }
    else if (Datos != null)
    {
        <!-- KPI CARDS -->
        <div class="row g-3 mb-4">
            <div class="col-12 col-md-4">
                <div class="border border-2 border-dark bg-white p-3 p-md-4 h-100 shadow-sm position-relative">
                    <div class="text-muted fw-bold text-uppercase small" style="letter-spacing: 1px;">Venta Bruta</div>
                    <h2 class="display-6 fw-bold mt-2 text-dark" style="letter-spacing: -1px;">
                        $@Datos.MontoTotal.ToString("N0")</h2>
                    <!-- Increased size and padding for Transacciones badge -->
                <div class="mt-3 pt-3 border-top border-dark d-flex justify-content-between align-items-center">
                        <span class="small fw-bold text-uppercase">Transacciones</span>
                        <span class="badge bg-dark rounded-0 font-monospace fs-6 p-2">@Datos.TotalVentas</span>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-4">
                <div class="border border-2 border-dark bg-white p-3 p-md-4 h-100 shadow-sm">
                    <div class="text-success fw-bold text-uppercase small" style="letter-spacing: 1px;">Ingreso Confirmado
                    </div>
                    <h3 class="fw-bold mt-2 text-success" style="letter-spacing: -1px;">$@Datos.MontoPagado.ToString("N0")
                    </h3>
                    <div class="mt-2 border-top border-dark pt-2">
                        <small class="text-muted fw-bold text-uppercase" style="font-size: 0.7rem;">Pagado via
                            Transbank</small>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-4">
                <div class="border border-2 border-dark bg-light p-3 p-md-4 h-100 shadow-sm">
                    <div class="text-danger fw-bold text-uppercase small" style="letter-spacing: 1px;">Pendiente / Efectivo
                    </div>
                    <h3 class="fw-bold mt-2 text-dark" style="letter-spacing: -1px;">$@Datos.MontoPendiente.ToString("N0")
                    </h3>
                    <div class="mt-2 border-top border-dark pt-2">
                        <small class="text-muted fw-bold text-uppercase" style="font-size: 0.7rem;">Diferencia
                            Recaudación</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- MAIN DATA TABLE -->
        <div class="card border-2 border-dark rounded-0 shadow-sm mb-4">
            <div class="card-header bg-dark text-white rounded-0 fw-bold border-bottom border-dark text-uppercase">
                <i class="bi bi-table me-2"></i>Detalle de Operaciones
            </div>
            <div class="table-responsive">
                <table class="table table-hover table-bordered border-dark m-0" style="min-width: 600px;">
                    <thead class="bg-secondary text-white text-uppercase small">
                        <tr>
                            <th role="button" class="sortable-header" @onclick='() => OrdenarPor("Fecha")'>
                                FECHA LOCAL @RenderIcono("Fecha")
                            </th>
                            <th role="button" class="sortable-header" @onclick='() => OrdenarPor("Maquina")'>
                                UNIDAD @RenderIcono("Maquina")
                            </th>
                            <th role="button" class="sortable-header text-center" @onclick='() => OrdenarPor("Slot")'>
                                SLOT @RenderIcono("Slot")
                            </th>
                            <th>PRODUCTO</th>
                            <th role="button" class="sortable-header text-end" @onclick='() => OrdenarPor("Monto")'>
                                MONTO @RenderIcono("Monto")
                            </th>
                            <th class="text-end">GANANCIA</th>
                            <th role="button" class="sortable-header text-center" @onclick='() => OrdenarPor("Estado")'>
                                ESTADO @RenderIcono("Estado")
                            </th>
                        </tr>
                    </thead>
                    <tbody class="bg-white">
                        @if (Datos.Detalle != null && Datos.Detalle.Count > 0)
                        {
                            @foreach (var v in Datos.Detalle)
                            {
                                <tr>
                                    <td class="font-monospace small">@v.Fecha</td>
                                    <td class="fw-bold small">@v.Maquina</td>
                                    <td class="text-center font-monospace small">@v.Slot</td>
                                    <td class="fw-bold small text-uppercase">@v.Producto</td>
                                    <td class="text-end font-monospace">$@v.Monto.ToString("N0")</td>
                                    <td class="text-end font-monospace text-success">$@v.Ganancia.ToString("N0")</td>
                                    <td class="text-center">
                                        @if (v.Estado == "Pagado")
                                        {
                                            <span class="badge bg-success rounded-0 border border-dark text-white">OK</span>
                                        }
                                        else
                                        {

                                            <span class="badge bg-warning rounded-0 border border-dark text-dark">PEND</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-4 text-muted fw-bold fst-italic">NO SE ENCONTRARON
                                    REGISTROS EN ESTE RANGO.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- TABLAS AGRUPADAS -->
        <div class="row g-4 mb-4">
            <!-- POR MAQUINA -->
        <div class="col-md-6">
                <div class="card border-2 border-dark rounded-0 h-100 shadow-sm">
                    <div class="card-header bg-dark text-white rounded-0 fw-bold text-uppercase">
                        <i class="bi bi-hdd-rack me-2"></i>Rendimiento por Máquina
                    </div>
                    <div class="table-responsive">
                        <table class="table table-sm table-bordered border-dark m-0 table-hover">
                            <thead class="bg-light text-uppercase small">
                                <tr>
                                    <th>MÁQUINA</th>
                                    <th class="text-end">VTAS</th>
                                    <th class="text-end">TOTAL</th>
                                    <th class="text-end">GANANCIA</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var m in (Datos.Detalle ?? new List<DetalleVentaDto>()).GroupBy(x =>
                               x.Maquina).Select(g => new
                               {
                                   Nombre = g.Key,
                                   Count = g.Count(),
                                   Total = g.Sum(x => x.Monto),
                                   Ganancia = g.Sum(x => x.Ganancia)
                               }).OrderByDescending(x => x.Total))
                                {
                                    <tr>
                                        <td class="small fw-bold">@m.Nombre</td>
                                        <td class="text-end font-monospace">@m.Count</td>
                                        <td class="text-end font-monospace">$@m.Total.ToString("N0")</td>
                                        <td class="text-end font-monospace text-success">$@m.Ganancia.ToString("N0")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- TOP PRODUCTOS -->
        <div class="col-md-6">
                <div class="card border-2 border-dark rounded-0 h-100 shadow-sm">
                    <div class="card-header bg-dark text-white rounded-0 fw-bold text-uppercase">
                        <i class="bi bi-star-fill me-2"></i>Top Productos
                    </div>
                    <div class="table-responsive">
                        <table class="table table-sm table-bordered border-dark m-0 table-hover">
                            <thead class="bg-light text-uppercase small">
                                <tr>
                                    <th>PRODUCTO</th>
                                    <th class="text-end">CANT</th>
                                    <th class="text-end">TOTAL</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var p in (Datos.Detalle ?? new List<DetalleVentaDto>()).GroupBy(x =>
                               x.Producto).Select(g => new
                               {
                                   Nombre = g.Key,
                                   Count = g.Count(),
                                   Total = g.Sum(x => x.Monto)
                               }).OrderByDescending(x => x.Count).Take(10))
                                {
                                    <tr>
                                        <td class="small fw-bold text-uppercase">@p.Nombre</td>
                                        <td class="text-end font-monospace">@p.Count</td>
                                        <td class="text-end font-monospace">$@p.Total.ToString("N0")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .sortable-header {
        cursor: pointer;
        user-select: none;
    }

    .sortable-header:hover {
        background-color: #555 !important;
        color: white;
    }
</style>

@code {
    // --- VARIABLES DE ESTADO ---
    private bool Cargando = false;
    private string MensajeError = "";

    // --- VARIABLES DE DATOS ---
    private DateTime FechaInicio = DateTime.Today.AddDays(-30);
    private DateTime FechaFin = DateTime.Today;
    private int MaquinaSeleccionada = 0;

    private ReporteDto? Datos;
    private List<MaquinaSimpleDto>? ListaMaquinas;

    // --- CONTROL DE ORDEN ---
    private string ColumnaOrden = "Fecha";
    private bool Ascendente = false;

    // --- MÉTODOS ---
    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Solo cargamos la lista de máquinas al iniciar
            ListaMaquinas = await Http.GetFromJsonAsync<List<MaquinaSimpleDto>>("api/Ventas/lista-maquinas");

            // PROCESAR QUERY PARAMS
            var uri = NavManager.ToAbsoluteUri(NavManager.Uri);
            if (QueryHelpers.ParseQuery(uri.Query).TryGetValue("start", out var startParam))
            {
                if (DateTime.TryParse(startParam, out DateTime dtStart)) FechaInicio = dtStart;
            }
            if (QueryHelpers.ParseQuery(uri.Query).TryGetValue("end", out var endParam))
            {
                if (DateTime.TryParse(endParam, out DateTime dtEnd)) FechaFin = dtEnd;
            }
            if (QueryHelpers.ParseQuery(uri.Query).TryGetValue("maquinaId", out var maqParam))
            {
                if (int.TryParse(maqParam, out int mId)) MaquinaSeleccionada = mId;
            }
        }
        catch (Exception ex)
        {
            MensajeError = "ERROR AL CARGAR LISTA DE UNIDADES: " + ex.Message;
            return;
        }

        try
        {
            // Y cargamos el reporte inicial
            await CargarReporte();
        }
        catch (Exception ex)
        {
            MensajeError = "ERROR AL INICIAR REPORTE: " + ex.Message;
        }
    }

    private async Task CargarReporte()
    {
        Cargando = true;
        MensajeError = "";
        Datos = null;
        StateHasChanged();

        try
        {
            string inicio = FechaInicio.ToString("yyyy-MM-dd");
            string fin = FechaFin.ToString("yyyy-MM-dd");
            string url =
            $"api/Ventas/reporte-rango?inicio={inicio}&fin={fin}&maquinaId={MaquinaSeleccionada}";

            Logger.LogDebug("Reportes: CargarReporte inicio. Url={Url}", url);

            Datos = await Http.GetFromJsonAsync<ReporteDto>(url);

            if (Datos == null) // ✅ Validar si llegó null
            {
                MensajeError = "El servidor no retornó datos válidos.";
                Logger.LogWarning("Reportes: respuesta nula del servidor para {Url}", url);
                return;
            }

            Logger.LogDebug("Reportes: datos recibidos. TotalVentas={TotalVentas}, MontoTotal={MontoTotal}", Datos.TotalVentas,
            Datos.MontoTotal);
            AplicarOrdenamiento();
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            MensajeError = $"ERROR: {ex.Message}";
            Logger.LogError(ex, "Reportes: excepción en CargarReporte");
            Console.WriteLine($"[Reportes] Stack: {ex}"); // redundante pero útil en F12 si Logger no aparece
        }
        finally
        {
            Cargando = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void OrdenarPor(string columna)
    {
        try
        {
            if (ColumnaOrden == columna) Ascendente = !Ascendente;
            else
            {
                ColumnaOrden = columna;
                Ascendente = true;
            }
            AplicarOrdenamiento();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Reportes: excepción en OrdenarPor columna={Columna}", columna);
            MensajeError = "ERROR AL ORDENAR: " + ex.Message;
        }
    }

    private void AplicarOrdenamiento()
    {
        if (Datos?.Detalle == null || Datos.Detalle.Count == 0) return;

        switch (ColumnaOrden)
        {
            case "Fecha":
                Datos.Detalle = Ascendente
                ? Datos.Detalle.OrderBy(x => x.FechaRaw).ToList()
                : Datos.Detalle.OrderByDescending(x => x.FechaRaw).ToList();
                break;
            case "Monto":
                Datos.Detalle = Ascendente
                ? Datos.Detalle.OrderBy(x => x.Monto).ToList()
                : Datos.Detalle.OrderByDescending(x => x.Monto).ToList();
                break;
            case "Maquina":
                Datos.Detalle = Ascendente
                ? Datos.Detalle.OrderBy(x => x.Maquina ?? string.Empty).ToList()
                : Datos.Detalle.OrderByDescending(x => x.Maquina ?? string.Empty).ToList();
                break;
            case "Slot":
                Datos.Detalle = Ascendente
                ? Datos.Detalle.OrderBy(x => x.Slot).ToList()
                : Datos.Detalle.OrderByDescending(x => x.Slot).ToList();
                break;
            case "Estado":
                Datos.Detalle = Ascendente
                ? Datos.Detalle.OrderBy(x => x.Estado ?? string.Empty).ToList()
                : Datos.Detalle.OrderByDescending(x => x.Estado ?? string.Empty).ToList();
                break;
        }
        StateHasChanged();
    }

    private string RenderIcono(string columna)
    {
        if (ColumnaOrden != columna) return "";
        return Ascendente ? "▲" : "▼";
    }

    private async Task ExportarExcel()
    {
        try
        {
            string inicio = FechaInicio.ToString("yyyy-MM-dd");
            string fin = FechaFin.ToString("yyyy-MM-dd");
            string url = $"api/Ventas/exportar?inicio={inicio}&fin={fin}&maquinaId={MaquinaSeleccionada}";

            Logger.LogDebug("Exportando: {Url}", url);

            // Descargar el archivo
            var response = await Http.GetAsync(url);

            if (response.IsSuccessStatusCode)
            {
                var content = await response.Content.ReadAsByteArrayAsync();
                var fileName = $"Reporte_{FechaInicio:ddMMyy}_{FechaFin:ddMMyy}.xlsx";

                // Usar JS para descargar
                await JS.InvokeVoidAsync("descargarArchivo", content, fileName);
            }
            else
            {
                MensajeError = "Error al exportar: " + response.StatusCode;
                Logger.LogError("Error exportando: {StatusCode}", response.StatusCode);
            }
        }
        catch (Exception ex)
        {
            MensajeError = "Error: " + ex.Message;
            Logger.LogError(ex, "Error en ExportarExcel");
        }
    }

    // --- CLASES DTO ---
    public class MaquinaSimpleDto
    {
        public int Id { get; set; }
        public string Nombre { get; set; } = string.Empty;
        public string Ubicacion { get; set; } = string.Empty;
    }

    public class ReporteDto
    {
        public int TotalVentas { get; set; }
        public decimal MontoTotal { get; set; }
        public decimal MontoPagado { get; set; }
        public decimal MontoPendiente { get; set; }
        public List<DetalleVentaDto> Detalle { get; set; } = new();
    }

    public class DetalleVentaDto
    {
        public string Fecha { get; set; } = string.Empty;
        public DateTime FechaRaw { get; set; }
        public string Maquina { get; set; } = string.Empty;
        public decimal Monto { get; set; }
        public string Estado { get; set; } = string.Empty;
        public int Slot { get; set; }
        public string Producto { get; set; } = string.Empty;
        public decimal Ganancia { get; set; }
    }
}
