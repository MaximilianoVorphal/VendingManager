@page "/"
@inject HttpClient Http

<PageTitle>CENTRO DE COMANDO</PageTitle>

<div class="container-fluid px-4 mt-4">

    <div class="row align-items-center mb-5 border-bottom border-dark pb-3">
        <div class="col-md-8">
            <h2 class="m-0" style="letter-spacing: -2px;">STATUS_OPERACIONAL__</h2>
            <small class="text-muted">DATOS EN TIEMPO REAL: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</small>
        </div>
        <div class="col-md-4">
            <label class="fw-bold mb-1">VISUALIZAR UNIDAD:</label>
            <select class="form-select border-dark rounded-0 fw-bold"
                    @onchange="CambiarMaquina"
                    style="background-color: #f4f4f4;">
                <option value="0">:: TODAS LAS MÁQUINAS ::</option>
                @if (ListaMaquinas != null)
                {
                    @foreach (var m in ListaMaquinas)
                    {
                        <option value="@m.Id">@m.Nombre.ToUpper()</option>
                    }
                }
            </select>
        </div>
    </div>

    @if (Stats == null)
    {
        <div class="text-center py-5">
            <div class="spinner-grow text-dark" role="status"></div>
            <p class="mt-2 fw-bold">CALCULANDO MÉTRICAS...</p>
        </div>
    }
    else
    {
        <div class="row g-4">

            <div class="col-md-4">
                <div class="border border-dark bg-white p-0 h-100">
                    <div class="bg-dark text-white p-2 fw-bold text-center">
                        HOY (@DateTime.Now.ToString("dd/MM"))
                    </div>
                    <div class="p-4 text-center">
                        <small class="text-muted text-uppercase">Venta Diaria</small>
                        <h1 class="display-4 fw-bold my-2">$@Stats.Hoy.VentaTotal.ToString("N0")</h1>

                        <div class="d-flex justify-content-between mt-4 border-top border-dark pt-3">
                            <div class="text-start">
                                <span class="d-block small fw-bold text-success">PAGADO (TB)</span>
                                <span>$@Stats.Hoy.PagadoTB.ToString("N0")</span>
                            </div>
                            <div class="text-end">
                                <span class="d-block small fw-bold text-muted">MOVIMIENTOS</span>
                                <span>@Stats.Hoy.CantidadVentas</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="border border-dark bg-white p-0 h-100">
                    <div class="bg-secondary text-white p-2 fw-bold text-center border-bottom border-dark">
                        SEMANA EN CURSO
                    </div>
                    <div class="p-4 text-center">
                        <small class="text-muted text-uppercase">Acumulado Semanal</small>
                        <h1 class="display-4 fw-bold my-2">$@Stats.Semana.VentaTotal.ToString("N0")</h1>

                        <div class="d-flex justify-content-between mt-4 border-top border-dark pt-3">
                            <div class="text-start">
                                <span class="d-block small fw-bold text-success">PAGADO (TB)</span>
                                <span>$@Stats.Semana.PagadoTB.ToString("N0")</span>
                            </div>
                            <div class="text-end">
                                <span class="d-block small fw-bold text-danger">PENDIENTE</span>
                                <span>$@Stats.Semana.Pendiente.ToString("N0")</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="border border-dark bg-light p-0 h-100">
                    <div class="p-2 fw-bold text-center border-bottom border-dark" style="background-color: #e0e0e0;">
                        MES DE @DateTime.Now.ToString("MMMM").ToUpper()
                    </div>
                    <div class="p-4 text-center">
                        <small class="text-muted text-uppercase">Proyección Mensual</small>
                        <h1 class="display-4 fw-bold my-2">$@Stats.Mes.VentaTotal.ToString("N0")</h1>

                        <div class="d-flex justify-content-between mt-4 border-top border-dark pt-3">
                            <div class="text-start">
                                <span class="d-block small fw-bold text-success">TOTAL PAGADO</span>
                                <span>$@Stats.Mes.PagadoTB.ToString("N0")</span>
                            </div>
                            <div class="text-end">
                                <span class="d-block small fw-bold">TOTAL QTY</span>
                                <span>@Stats.Mes.CantidadVentas</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <div class="row mt-5">
            <h4 class="mb-3 border-bottom border-dark pb-2">INGESTA DE DATOS_</h4>

            <div class="col-md-6">
                <label class="mb-2 fw-bold">1. SUBIR REPORTE MÁQUINA:</label>
                <div class="input-group">
                    <InputFile OnChange="@(e => SubirArchivo(e, "api/Ventas/subir-ventas-maquina"))" class="form-control border-dark rounded-0" />
                </div>
            </div>

            <div class="col-md-6">
                <label class="mb-2 fw-bold">2. SUBIR REPORTE TRANSBANK:</label>
                <div class="input-group">
                    <InputFile OnChange="@(e => SubirArchivo(e, "api/Ventas/subir-transbank"))" class="form-control border-dark rounded-0" />
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Mensaje))
            {
                <div class="col-12 mt-3">
                    <div class="alert alert-dark rounded-0 border-dark">
                        <strong>LOG:</strong> @Mensaje
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private DashboardStats? Stats;
    private List<MaquinaSimpleDto>? ListaMaquinas;
    private int MaquinaActualId = 0;
    private string Mensaje = "";

    protected override async Task OnInitializedAsync()
    {
        await CargarMaquinas();
        await CargarDatos();
    }

    private async Task CargarMaquinas()
    {
        try
        {
            ListaMaquinas = await Http.GetFromJsonAsync<List<MaquinaSimpleDto>>("api/Ventas/lista-maquinas");
        }
        catch { }
    }

    private async Task CambiarMaquina(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id))
        {
            MaquinaActualId = id;
            Stats = null; // Reset visual para que se note la carga
            await CargarDatos();
        }
    }

    private async Task CargarDatos()
    {
        try
        {
            Stats = await Http.GetFromJsonAsync<DashboardStats>($"api/Ventas/dashboard-stats?maquinaId={MaquinaActualId}");
        }
        catch (Exception ex)
        {
            Mensaje = "ERROR DE CONEXIÓN: " + ex.Message;
        }
    }

    // Lógica de carga de archivos (Reutilizada y compactada)
    private async Task SubirArchivo(InputFileChangeEventArgs e, string endpoint)
    {
        Mensaje = "CARGANDO DATOS...";
        using var content = new MultipartFormDataContent();
        try
        {
            var fileContent = new StreamContent(e.File.OpenReadStream(1024 * 1024 * 10)); // 10MB max
            fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(e.File.ContentType);
            content.Add(fileContent, "archivo", e.File.Name);

            var resp = await Http.PostAsync(endpoint, content);
            if (resp.IsSuccessStatusCode)
            {
                Mensaje = "CARGA EXITOSA. ACTUALIZANDO TABLERO...";
                await CargarDatos(); // ¡Refresca los números automáticamente!
            }
            else Mensaje = "ERROR EN CARGA: " + await resp.Content.ReadAsStringAsync();
        }
        catch (Exception ex) { Mensaje = "ERROR CRÍTICO: " + ex.Message; }
    }

    // CLASES DTO
    public class DashboardStats
    {
        public PeriodoStats Hoy { get; set; } = new();
        public PeriodoStats Semana { get; set; } = new();
        public PeriodoStats Mes { get; set; } = new();
    }

    public class PeriodoStats
    {
        public decimal VentaTotal { get; set; }
        public decimal PagadoTB { get; set; }
        public decimal Pendiente { get; set; }
        public int CantidadVentas { get; set; }
    }

    public class MaquinaSimpleDto { public int Id { get; set; } public string Nombre { get; set; } = ""; }
}