@page "/"
@inject HttpClient Http
@inject NavigationManager NavManager
@inject IJSRuntime JS
@using System.Net.Http.Headers

<PageTitle>CENTRO DE COMANDO</PageTitle>

<div class="container-fluid px-4 mt-4" style="font-family: 'Segoe UI', Consolas, monospace;">

    <div class="row align-items-center mb-4 border-bottom border-3 border-dark pb-3">
        <div class="col-md-8">
            <h2 class="m-0 fw-bold text-uppercase" style="letter-spacing: -1px;">Status Operacional</h2>
            <small class="text-muted fw-bold">TIEMPO REAL: @DateTime.Now.ToString("dd/MM/yyyy HH:mm:ss")</small>
        </div>
        <div class="col-md-4">
            <label class="fw-bold mb-1 small text-uppercase">:: SELECCIÓN DE UNIDAD ::</label>
            <select class="form-select border-2 border-dark rounded-0 fw-bold bg-light text-uppercase py-2"
                @onchange="CambiarMaquina">
                <option value="0">:: TODAS LAS UNIDADES ::</option>
                @if (ListaMaquinas != null)
                {
                    @foreach (var m in ListaMaquinas)
                    {
                        <option value="@m.Id">@m.Nombre.ToUpper()</option>
                    }
                }
            </select>
        </div>
    </div>

    @if (Stats == null)
    {
        <div class="text-center py-5 border border-dark border-2 bg-light">
            <div class="spinner-grow text-dark" role="status"></div>
            <p class="mt-2 fw-bold text-uppercase" style="letter-spacing: 2px;">Calculando Métricas...</p>
        </div>
    }
    else
    {
        <div class="row g-4 mb-5">
            <!-- DIARIO -->
        <div class="col-md-4">
                <div class="card-hover border border-2 border-dark bg-white p-0 h-100 shadow-sm position-relative cursor-pointer"
                @onclick="@(() => IrAReporte("HOY"))" role="button">
                    <div class="bg-dark text-white p-2 fw-bold text-center text-uppercase small"
                    style="letter-spacing: 1px;">
                        Reporte Diario (@DateTime.Now.ToString("dd/MM"))
                    </div>
                    <div class="p-4 text-center">
                        <small class="text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">Venta Bruta</small>
                        <h1 class="display-5 fw-bold my-2 text-dark" style="letter-spacing: -2px;">
                            $@Stats.Hoy.VentaTotal.ToString("N0")</h1>

                        <div class="d-flex justify-content-between mt-4 border-top border-dark pt-3">
                            <div class="text-start lh-1">
                                <span class="d-block text-uppercase text-dark fw-bold"
                                style="font-size: 0.7rem;">Confirmado</span>
                                <span class="fw-bold text-success">$@Stats.Hoy.PagadoTB.ToString("N0")</span>
                            </div>
                            <div class="text-end lh-1">
                                <span class="d-block text-uppercase text-dark fw-bold"
                                style="font-size: 0.7rem;">Transacciones</span>
                                <span class="fw-bold">@Stats.Hoy.CantidadVentas</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- SEMANAL -->
        <div class="col-md-4">
                <div class="card-hover border border-2 border-dark bg-white p-0 h-100 shadow-sm cursor-pointer"
                @onclick="@(() => IrAReporte("SEMANA"))" role="button">
                    <div class="bg-secondary text-white p-2 fw-bold text-center text-uppercase small border-bottom border-dark"
                    style="letter-spacing: 1px;">
                        Reporte Semanal
                    </div>
                    <div class="p-4 text-center">
                        <small class="text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">Acumulado</small>
                        <h1 class="display-5 fw-bold my-2 text-dark" style="letter-spacing: -2px;">
                            $@Stats.Semana.VentaTotal.ToString("N0")</h1>

                        <div class="d-flex justify-content-between mt-4 border-top border-dark pt-3">
                            <div class="text-start lh-1">
                                <span class="d-block text-uppercase text-dark fw-bold"
                                style="font-size: 0.7rem;">Confirmado</span>
                                <span class="fw-bold text-success">$@Stats.Semana.PagadoTB.ToString("N0")</span>
                            </div>
                            <div class="text-end lh-1">
                                <span class="d-block text-uppercase text-dark fw-bold"
                                style="font-size: 0.7rem;">Pendiente</span>
                                <span class="fw-bold text-danger">$@Stats.Semana.Pendiente.ToString("N0")</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- MENSUAL -->
        <div class="col-md-4">
                <div class="card-hover border border-2 border-dark bg-light p-0 h-100 shadow-sm cursor-pointer"
                @onclick="@(() => IrAReporte("MES"))" role="button">
                    <div class="p-2 fw-bold text-center border-bottom border-2 border-dark text-uppercase small"
                    style="background-color: #dcdcdc; letter-spacing: 1px;">
                        Reporte Mensual (@DateTime.Now.ToString("MMM").ToUpper())
                    </div>
                    <div class="p-4 text-center">
                        <small class="text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">Total Proyectado</small>
                        <h1 class="display-5 fw-bold my-2 text-dark" style="letter-spacing: -2px;">
                            $@Stats.Mes.VentaTotal.ToString("N0")</h1>

                        <div class="d-flex justify-content-between mt-4 border-top border-dark pt-3">
                            <div class="text-start lh-1">
                                <span class="d-block text-uppercase text-dark fw-bold" style="font-size: 0.7rem;">Total
                                    Ingreso</span>
                                <span class="fw-bold text-success">$@Stats.Mes.PagadoTB.ToString("N0")</span>
                            </div>
                            <div class="text-end lh-1">
                                <span class="d-block text-uppercase text-dark fw-bold"
                                style="font-size: 0.7rem;">Transacciones</span>
                                <span class="fw-bold">@Stats.Mes.CantidadVentas</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- CHART SECTION -->
        <div class="row mb-5">
            <div class="col-md-8">
                <div class="card border-2 border-dark rounded-0 shadow-sm">
                    <div class="card-header bg-dark text-white fw-bold text-uppercase rounded-0">
                        <i class="bi bi-graph-up-arrow me-2"></i>Tendencia de Ventas (Semanal)
                    </div>
                    <div class="card-body">
                        <canvas id="salesChart" style="height: 300px; width: 100%;"></canvas>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-2 border-dark rounded-0 shadow-sm h-100">
                    <div class="card-header bg-dark text-white fw-bold text-uppercase rounded-0">
                        <i class="bi bi-pie-chart-fill me-2"></i>Ventas Brutas
                    </div>
                    <div class="card-body d-flex align-items-center justify-content-center">
                        <canvas id="paymentChart" style="max-height: 250px;"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mt-5">
            <div class="col-12 mb-3">
                <h5 class="fw-bold text-uppercase border-bottom border-3 border-dark pb-2 d-flex align-items-center flex-wrap gap-2"
                style="letter-spacing: 1px;">
                    <span class="bg-dark text-white px-2 py-1">INPUT</span>
                    <span>INGRESO DE DATOS_</span>
                </h5>
            </div>

            <div class="col-md-6 mb-3">
                <div class="card h-100 border-2 border-dark rounded-0">
                    <div class="card-body bg-light">
                        <div class="d-flex align-items-center mb-3">
                            <div class="bg-dark text-white fw-bold px-2 py-1 me-2 rounded-0">01</div>
                            <label class="fw-bold text-uppercase text-dark mb-0">REPORTE OURVEND (.XLS)</label>
                        </div>
                        <p class="small text-muted mb-2 font-monospace">Archivo fuente: "Give-out record"</p>

                        <div class="input-group">
                            <InputFile OnChange="SubirArchivoMaquina"
                            class="form-control form-control-sm border-dark rounded-0" accept=".xls,.xlsx" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 mb-3">
                <div class="card h-100 border-2 border-dark rounded-0">
                    <div class="card-body bg-light">
                        <div class="d-flex align-items-center mb-3">
                            <div class="bg-dark text-white fw-bold px-2 py-1 me-2 rounded-0">02</div>
                            <label class="fw-bold text-uppercase text-dark mb-0">CARTOLA TRANSBANK (.XLS/.CSV)</label>
                        </div>
                        <p class="small text-muted mb-2 font-monospace">Archivo fuente: "Transbank/Banco"</p>

                        <div class="input-group">
                            <InputFile OnChange="SubirArchivoTransbank"
                            class="form-control form-control-sm border-dark rounded-0" accept=".xls,.xlsx,.csv" />
                        </div>
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Mensaje))
            {
                <div class="col-12 mt-2">
                    <div class="alert alert-dark rounded-0 border-2 border-dark shadow-sm bg-white text-dark">
                        @if (Cargando)
                        {
                            <span class="spinner-border spinner-border-sm me-2 text-dark" role="status"></span>
                            <span class="fw-bold text-uppercase blinking-cursor">PROCESANDO DATOS...</span>
                        }
                        else
                        {
                            <span class="fw-bold text-uppercase me-2">> SYSTEM_LOG:</span>
                            @Mensaje
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    /* Efecto de parpadeo para el texto de carga */
    .blinking-cursor {
        animation: blinker 1s linear infinite;
    }

    /* Hover effects for Dashboard Cards */
    .card-hover {
        transition: transform 0.2s, background-color 0.2s;
    }

    .card-hover:hover {
        transform: translateY(-5px);
        background-color: #f8f9fa !important;
        /* Slightly grayer */
        border-color: #000 !important;
        cursor: pointer;
    }

    @@keyframes blinker {
        50% {
            opacity: 0;
        }
    }
</style>

@code {
    private DashboardStats? Stats;
    private List<MaquinaSimpleDto>? ListaMaquinas;
    private int MaquinaActualId = 0;

    private string Mensaje = "";
    private bool Cargando = false;

    protected override async Task OnInitializedAsync()
    {
        await CargarMaquinas();
        await CargarDatos();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Stats != null)
        {
            await RenderCharts();
        }
    }

    private async Task RenderCharts()
    {
        // 1. Bar Chart: Weekly Stats (Simulated distribution for visualisation)
        var weeklyConfig = new
        {
            type = "bar",
            data = new
            {
                labels = new[] { "Lun", "Mar", "Mie", "Jue", "Vie", "Sab", "Dom" },
                datasets = new[]
        {
new
{
label = "Ventas ($)",
data = new[] {
Stats!.Semana.VentaTotal * 0.1m,
Stats.Semana.VentaTotal * 0.15m,
Stats.Semana.VentaTotal * 0.2m,
Stats.Semana.VentaTotal * 0.1m,
Stats.Semana.VentaTotal * 0.25m,
Stats.Semana.VentaTotal * 0.15m,
Stats.Semana.VentaTotal * 0.05m
},
backgroundColor = "#212529"
}
}
            },
            options = new
            {
                scales = new { y = new { beginAtZero = true } },
                plugins = new { legend = new { display = false } },
                responsive = true,
                maintainAspectRatio = false
            }
        };
        await JS.InvokeVoidAsync("ChartJsInterop.setupChart", "salesChart", weeklyConfig);

        // 2. Pie Chart: Payment Status
        var paymentConfig = new
        {
            type = "doughnut",
            data = new
            {
                labels = new[] { "Confirmado", "Pendiente/Efectivo" },
                datasets = new[]
        {
new
{
data = new[] { Stats.Semana.PagadoTB, Stats.Semana.Pendiente },
backgroundColor = new[] { "#198754", "#dc3545" }
}
}
            },
            options = new
            {
                responsive = true,
                maintainAspectRatio = false
            }
        };
        await JS.InvokeVoidAsync("ChartJsInterop.setupChart", "paymentChart", paymentConfig);
    }

    private async Task CargarMaquinas()
    {
        try { ListaMaquinas = await Http.GetFromJsonAsync<List<MaquinaSimpleDto>>("api/Ventas/lista-maquinas"); } catch { }
    }

    private async Task CambiarMaquina(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id))
        {
            MaquinaActualId = id;
            Stats = null;
            await CargarDatos();
        }
    }

    private async Task CargarDatos()
    {
        try { Stats = await Http.GetFromJsonAsync<DashboardStats>($"api/Ventas/dashboard-stats?maquinaId={MaquinaActualId}"); }
        catch (Exception ex)
        {
            Mensaje = "ERROR DE CONEXIÓN: " + ex.Message;
        }
    }

    private void IrAReporte(string periodo)
    {
        DateTime inicio = DateTime.Today;
        DateTime fin = DateTime.Today;

        switch (periodo)
        {
            case "HOY":
                // inicio y fin son correctos (hoy)
                break;
            case "SEMANA":
                var diff = (7 + (DateTime.Today.DayOfWeek - DayOfWeek.Monday)) % 7;
                inicio = DateTime.Today.AddDays(-1 * diff);
                break;
            case "MES":
                inicio = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
                break;
        }

        string url = $"reportes?start={inicio:yyyy-MM-dd}&end={fin:yyyy-MM-dd}&maquinaId={MaquinaActualId}";
        NavManager.NavigateTo(url);
    }

    private async Task SubirArchivo(InputFileChangeEventArgs e, string endpoint)
    {
        Cargando = true;
        Mensaje = "INICIANDO PROTOCOLO DE CARGA...";
        StateHasChanged();

        using var content = new MultipartFormDataContent();
        try
        {
            var fileContent = new StreamContent(e.File.OpenReadStream(20 * 1024 * 1024));
            fileContent.Headers.ContentType = new MediaTypeHeaderValue(e.File.ContentType);
            content.Add(fileContent, "file", e.File.Name);

            var resp = await Http.PostAsync(endpoint, content);

            if (resp.IsSuccessStatusCode)
            {
                var serverMsg = await resp.Content.ReadAsStringAsync();
                Mensaje = "OPERACIÓN COMPLETADA. " + serverMsg;
                await CargarDatos();
            }
            else
            {
                Mensaje = "FALLO EN OPERACIÓN: " + resp.ReasonPhrase;
            }
        }
        catch (Exception ex) { Mensaje = "ERROR CRÍTICO: " + ex.Message; }
        finally { Cargando = false; }
    }

    private Task SubirArchivoMaquina(InputFileChangeEventArgs e) => SubirArchivo(e, "api/Ventas/subir-ventas-maquina");
    private Task SubirArchivoTransbank(InputFileChangeEventArgs e) => SubirArchivo(e, "api/Ventas/subir-transbank");

    public class DashboardStats
    {
        public PeriodoStats Hoy { get; set; } = new();
        public PeriodoStats Semana { get; set; } = new();
        public PeriodoStats Mes { get; set; } = new();
    }
    public class PeriodoStats
    {
        public decimal VentaTotal { get; set; }
        public decimal PagadoTB { get; set; }
        public decimal Pendiente { get; set; }
        public int CantidadVentas { get; set; }
    }
    public class MaquinaSimpleDto { public int Id { get; set; } public string Nombre { get; set; } = ""; }
}
