@page "/caja-demo"

<PageTitle>TESORERÍA</PageTitle>

<div class="container-fluid px-4 mt-4" style="font-family: 'Segoe UI', Consolas, monospace;">

    <div class="row align-items-center mb-4 border-bottom border-3 border-dark pb-3">
        <div class="col-12 d-flex justify-content-between align-items-end">
            <div>
                <h2 class="m-0 fw-bold text-uppercase" style="letter-spacing: -1px;">CONTROL DE TESORERÍA__</h2>
                <small class="text-muted fw-bold">FLUJO DE CAJA Y GASTOS OPERATIVOS</small>
            </div>
            <div class="text-end">
                <span class="badge bg-dark rounded-0 p-2">PERIODO: DICIEMBRE 2025</span>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-5">
        <div class="col-md-3">
            <div class="border border-2 border-dark bg-white p-3 h-100 position-relative">
                <div class="position-absolute top-0 end-0 bg-success text-white px-2 py-1 small fw-bold" style="font-size: 0.6rem;">ENTRADAS</div>
                <small class="text-muted fw-bold text-uppercase">INGRESOS TOTALES</small>
                <h3 class="text-dark fw-bold mt-2">$@CalculoIngresos.ToString("N0")</h3>
                <small class="text-success fw-bold" style="font-size: 0.7rem;">+ VENTAS Y APORTES</small>
            </div>
        </div>

        <div class="col-md-3">
            <div class="border border-2 border-dark bg-white p-3 h-100 position-relative">
                <div class="position-absolute top-0 end-0 bg-danger text-white px-2 py-1 small fw-bold" style="font-size: 0.6rem;">SALIDAS</div>
                <small class="text-muted fw-bold text-uppercase">GASTOS DEL MES</small>
                <h3 class="text-danger fw-bold mt-2">$@CalculoEgresos.ToString("N0")</h3>
                <small class="text-danger fw-bold" style="font-size: 0.7rem;">- COMPRAS Y SERVICIOS</small>
            </div>
        </div>

        <div class="col-md-6">
            <div class="border border-2 border-dark bg-light p-3 h-100">
                <div class="d-flex justify-content-between align-items-center border-bottom border-dark pb-2 mb-2">
                    <small class="text-dark fw-bold text-uppercase">SALDO DISPONIBLE (CAJA REAL)</small>
                    <span class="badge bg-dark rounded-0">ACTUAL</span>
                </div>
                <div class="d-flex align-items-center justify-content-between">
                    <h1 class="display-4 fw-bold m-0 text-dark">$@CalculoSaldo.ToString("N0")</h1>
                    <div class="text-end">
                        <small class="d-block text-muted fw-bold" style="font-size: 0.7rem;">MARGEN OPERATIVO</small>
                        <span class="fw-bold @(Margen > 0 ? "text-success" : "text-danger")">@Margen%</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card border-2 border-dark rounded-0 h-100 shadow-sm">
                <div class="card-header bg-dark text-white rounded-0 fw-bold d-flex justify-content-between align-items-center">
                    <span>NUEVO MOVIMIENTO</span>
                    <span class="small text-white-50">MANUAL</span>
                </div>
                <div class="card-body bg-light">

                    <div class="mb-3">
                        <label class="fw-bold small text-uppercase mb-1">1. TIPO DE OPERACIÓN:</label>
                        <div class="btn-group w-100 border border-dark" role="group">
                            <input type="radio" class="btn-check" name="btnradio" id="btnGasto" autocomplete="off" checked @onclick='() => Nuevo.Tipo = "EGRESO"'>
                            <label class="btn btn-outline-dark rounded-0 fw-bold @(Nuevo.Tipo == "EGRESO" ? "active bg-danger text-white" : "")" for="btnGasto">🔴 GASTO</label>

                            <input type="radio" class="btn-check" name="btnradio" id="btnIngreso" autocomplete="off" @onclick='() => Nuevo.Tipo = "INGRESO"'>
                            <label class="btn btn-outline-dark rounded-0 fw-bold @(Nuevo.Tipo == "INGRESO" ? "active bg-success text-white" : "")" for="btnIngreso">🟢 INGRESO</label>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="fw-bold small text-uppercase mb-1">2. CATEGORÍA:</label>
                        <select @bind="Nuevo.Categoria" class="form-select border-dark rounded-0 bg-white">
                            @if (Nuevo.Tipo == "EGRESO")
                            {
                                <option value="MERCADERIA">📦 MERCADERÍA (Stock)</option>
                                <option value="LOGISTICA">⛽ LOGÍSTICA / COMBUSTIBLE</option>
                                <option value="MANTENCION">🔧 MANTENCIÓN / REPUESTOS</option>
                                <option value="INFRA">💡 INFRAESTRUCTURA / ARRIENDO</option>
                                <option value="RETIRO">💸 RETIRO DE UTILIDAD</option>
                                <option value="OTROS">📝 OTROS GASTOS</option>
                            }
                            else
                            {
                                <option value="VENTA">💰 VENTA DIARIA (Manual)</option>
                                <option value="APORTE">🏦 APORTE DE CAPITAL</option>
                                <option value="DEVOLUCION">🔄 DEVOLUCIÓN PROVEEDOR</option>
                            }
                        </select>
                        @if (Nuevo.Categoria == "MERCADERIA")
                        {
                            <div class="mt-1 p-1 bg-warning bg-opacity-25 border border-warning text-dark small fst-italic">
                                <i class="bi bi-info-circle"></i> Al guardar, esto sumará stock al inventario futuro.
                            </div>
                        }
                    </div>

                    <div class="mb-3">
                        <label class="fw-bold small text-uppercase mb-1">3. DESCRIPCIÓN / PROVEEDOR:</label>
                        <input @bind="Nuevo.Detalle" type="text" class="form-control border-dark rounded-0" placeholder="Ej: COPEC, COCA-COLA ANDINA..." />
                    </div>

                    <div class="mb-3">
                        <label class="fw-bold small text-uppercase mb-1">4. MONTO ($):</label>
                        <div class="input-group">
                            <span class="input-group-text border-dark rounded-0 bg-dark text-white fw-bold">$</span>
                            <input @bind="Nuevo.Monto" type="number" class="form-control border-dark rounded-0 fw-bold fs-5" />
                        </div>
                    </div>

                    <button class="btn btn-dark w-100 rounded-0 fw-bold py-2 mt-2 border-2 border-dark shadow" @onclick="Registrar">
                        REGISTRAR OPERACIÓN_
                    </button>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card border-2 border-dark rounded-0 h-100">
                <div class="card-header bg-white text-dark rounded-0 fw-bold border-bottom border-dark">
                    LIBRO MAYOR (ÚLTIMOS MOVIMIENTOS)
                </div>
                <div class="table-responsive">
                    <table class="table table-hover table-bordered border-dark m-0">
                        <thead class="bg-secondary text-white">
                            <tr>
                                <th style="width: 15%">FECHA</th>
                                <th style="width: 15%">CATEGORÍA</th>
                                <th>DETALLE</th>
                                <th class="text-end" style="width: 15%">MONTO</th>
                                <th class="text-end" style="width: 15%">SALDO</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white">
                            @foreach (var mov in Movimientos.OrderByDescending(x => x.Id))
                            {
                                <tr>
                                    <td class="font-monospace small">@mov.Fecha.ToString("dd/MM HH:mm")</td>
                                    <td>
                                        <span class="badge rounded-0 border border-dark text-dark
                                                @(mov.Tipo == "INGRESO" ? "bg-success-subtle" : "bg-danger-subtle")">
                                            @mov.Categoria
                                        </span>
                                    </td>
                                    <td class="text-uppercase small fw-bold">@mov.Detalle</td>
                                    <td class="text-end fw-bold font-monospace @(mov.Tipo == "INGRESO" ? "text-success" : "text-danger")">
                                        @((mov.Tipo == "INGRESO" ? "+" : "-") + "$" + mov.Monto.ToString("N0"))
                                    </td>
                                    <td class="text-end fw-bold font-monospace bg-light">
                                        $@mov.SaldoAcumulado.ToString("N0")
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    // --- LÓGICA DE SIMULACIÓN (MOCK) ---

    // Modelo temporal para la vista
    public class MovimientoModel
    {
        public int Id { get; set; }
        public DateTime Fecha { get; set; }
        public string Tipo { get; set; } = "EGRESO";
        public string Categoria { get; set; } = "MERCADERIA";
        public string Detalle { get; set; } = "";
        public int Monto { get; set; }
        public int SaldoAcumulado { get; set; }
    }

    private MovimientoModel Nuevo = new();
    private List<MovimientoModel> Movimientos = new();

    // Variables calculadas
    private decimal CalculoIngresos => Movimientos.Where(x => x.Tipo == "INGRESO").Sum(x => x.Monto);
    private decimal CalculoEgresos => Movimientos.Where(x => x.Tipo == "EGRESO").Sum(x => x.Monto);
    private decimal CalculoSaldo => CalculoIngresos - CalculoEgresos;
    private int Margen => CalculoIngresos > 0 ? (int)(((CalculoIngresos - CalculoEgresos) / CalculoIngresos) * 100) : 0;

    protected override void OnInitialized()
    {
        // DATOS DE EJEMPLO (Simulando tu Excel)
        Movimientos.Add(new MovimientoModel { Id = 1, Fecha = DateTime.Today.AddDays(-5), Tipo = "INGRESO", Categoria = "VENTA", Detalle = "Ventas Semanales Maq 1", Monto = 450000, SaldoAcumulado = 450000 });
        Movimientos.Add(new MovimientoModel { Id = 2, Fecha = DateTime.Today.AddDays(-4), Tipo = "EGRESO", Categoria = "MERCADERIA", Detalle = "Compra Coca-Cola Andina", Monto = 120000, SaldoAcumulado = 330000 });
        Movimientos.Add(new MovimientoModel { Id = 3, Fecha = DateTime.Today.AddDays(-3), Tipo = "EGRESO", Categoria = "LOGISTICA", Detalle = "Carga Combustible Camioneta", Monto = 45000, SaldoAcumulado = 285000 });
        Movimientos.Add(new MovimientoModel { Id = 4, Fecha = DateTime.Today.AddDays(-1), Tipo = "EGRESO", Categoria = "MANTENCION", Detalle = "Repuesto Monedero", Monto = 25000, SaldoAcumulado = 260000 });
    }

    private void Registrar()
    {
        if (Nuevo.Monto <= 0 || string.IsNullOrEmpty(Nuevo.Detalle)) return;

        var nuevoMov = new MovimientoModel
        {
            Id = Movimientos.Count + 1,
            Fecha = DateTime.Now,
            Tipo = Nuevo.Tipo,
            Categoria = Nuevo.Categoria,
            Detalle = Nuevo.Detalle,
            Monto = Nuevo.Monto,
            // Calculo simple del saldo
            SaldoAcumulado = (int)(CalculoSaldo + (Nuevo.Tipo == "INGRESO" ? Nuevo.Monto : -Nuevo.Monto))
        };

        Movimientos.Add(nuevoMov);

        // Limpiar form
        Nuevo.Detalle = "";
        Nuevo.Monto = 0;
    }
}