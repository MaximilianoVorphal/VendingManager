<!DOCTYPE html>
@using Microsoft.AspNetCore.Components.Web
@using VendingManager.Web
@inject VendingManager.Web.Auth.PersistingAuthenticationStateProvider PersistingAuthStateProvider
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>VendingManager</title>
    <base href="/" />
    <link rel="stylesheet" href="lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="css/app.css" />
    <link rel="icon" type="image/png" href="favicon.png" />
    <link href="VendingManager.Web.styles.css" rel="stylesheet" />
    <HeadOutlet @rendermode="RenderMode.InteractiveWebAssembly" />
</head>

<body>
    <div id="app">
        <!-- Load the Client App (which contains the Router) -->
        <VendingManager.Web.App @rendermode="RenderMode.InteractiveWebAssembly" />
    </div>

    <div id="blazor-error-ui">
        An unhandled error has occurred.
        <a href="" class="reload">Reload</a>
        <a class="dismiss">🗙</a>
    </div>


    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="js/ChartJsInterop.js?v=2.0"></script>
    <script src="js/app.js"></script>
    <script src="_framework/blazor.web.js"></script>
</body>

</html>
